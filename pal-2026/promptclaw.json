{
  "project": {
    "name": "PAL 2026",
    "description": "Interactive deployment guide for PAL 2026 Phase 1 on Vast.ai A6000, reachable over Tailscale with Ollama and a FastAPI router."
  },
  "artifacts": {
    "root": ".promptclaw"
  },
  "control_plane": {
    "mode": "heuristic",
    "agent": "claude",
    "allow_fallback": true
  },
  "routing": {
    "verification_enabled": true,
    "max_retries": 1,
    "ask_user_on_ambiguity": true,
    "default_task_type": "deployment"
  },
  "pal": {
    "enabled": true,
    "base_url": "http://pal-cloud-a6000:8000",
    "default_model": "llama3.3:70b-instruct-q4_K_M",
    "timeout_s": 300.0,
    "health_timeout_s": 10.0,
    "knowledge_sources": [
      "docs/**/*.md",
      "ops/**/*.md",
      "ops/deployment-manifest.json",
      "ops/templates/*.conf",
      "ops/templates/*.md",
      "ops/templates/*.py",
      "ops/templates/*.sh",
      "ops/templates/*.yml",
      "ops/templates/router-Dockerfile",
      ".promptclaw/pal-smoke/*.json",
      ".promptclaw/runs/**/summary/*.md",
      ".promptclaw/runs/**/outputs/*.json",
      "../docs/architecture.md",
      "../docs/command-reference.md",
      "../docs/handoff-protocol.md",
      "../sdp/prd-pal-2026-agentic-ops-platform.md"
    ]
  },
  "agents": {
    "pal-setup": {
      "enabled": true,
      "kind": "mock",
      "shell_command": "",
      "command": [],
      "env": {},
      "capabilities": [
        "deployment",
        "ops",
        "cloud",
        "tailscale",
        "docker",
        "ollama",
        "runbook",
        "checkpointing"
      ],
      "instruction_file": "prompts/agents/pal-setup.md"
    },
    "codex": {
      "enabled": true,
      "kind": "mock",
      "shell_command": "",
      "command": [],
      "env": {},
      "capabilities": [
        "coding",
        "implementation",
        "testing",
        "refactoring"
      ],
      "instruction_file": "prompts/agents/codex.md"
    },
    "claude": {
      "enabled": true,
      "kind": "mock",
      "shell_command": "",
      "command": [],
      "env": {},
      "capabilities": [
        "architecture",
        "specification",
        "verification",
        "analysis"
      ],
      "instruction_file": "prompts/agents/claude.md"
    },
    "gemini": {
      "enabled": true,
      "kind": "mock",
      "shell_command": "",
      "command": [],
      "env": {},
      "capabilities": [
        "research",
        "writing",
        "docs",
        "synthesis"
      ],
      "instruction_file": "prompts/agents/gemini.md"
    }
  }
}
