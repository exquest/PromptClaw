+def _split_message(text: str) -> list[str]:
+    if len(text) <= MAX_MESSAGE_LEN:
+        return [text]
+    chunks = []
+    while text:
+        if len(text) <= MAX_MESSAGE_LEN:
+            chunks.append(text)
+            break
+        split_at = text.rfind("\n", 0, MAX_MESSAGE_LEN)
+        if split_at == -1:
+            split_at = MAX_MESSAGE_LEN
+        chunks.append(text[:split_at])
+        text = text[split_at:].lstrip("\n")
+    return chunks
+
