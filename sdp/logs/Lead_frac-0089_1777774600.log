            )
        )

    if not min_peak <= policy.limiter_ceiling_dbtp <= max_peak or policy.limiter_ceiling_dbtp > -1.0:
        issues.append(
            MixProfileIssue(
                "mastering.limiter_ceiling_dbtp",
                f"unsafe limiter ceiling ({policy.limiter_ceiling_dbtp} dBTP)",
            )
        )

