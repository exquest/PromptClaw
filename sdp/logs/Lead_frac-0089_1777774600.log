senseweave/live_buffer.py`\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+- tests verify buffer refresh and archive path selection\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+  - VERIFY: `pytest tests/test_live_buffer.py -x`\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndiff --git a/tests/test_live_buffer.py b/tests/test_live_buffer.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nnew file mode 100644\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nindex 0000000..3bdd45f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n--- /dev/null\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+++ b/tests/test_live_buffer.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n@@ -0,0 +1,85 @@\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+import json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+import os\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+import sys\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+import time\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+from pathlib import Path\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+import pytest\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+sys.path.insert(0, os.path.join(os.path.dirname(__file__), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"..\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"my-claw\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tools\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+sys.path.insert(0, os.path.join(os.path.dirname(__file__), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"..\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"my-claw\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tools\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"senseweave\\\\\\\\\\\\\\\\\