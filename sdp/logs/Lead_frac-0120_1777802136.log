+                    "sw_breath": target_to_sources["sw_breath"],
+                },
+                "source_to_target": {
+                    source: source_to_target[source]
+                    for source in ("gong", "sw_grain", "tabla_ge")
+                },
+            },
+        }
+
+        round_trip = json.loads(json.dumps(diagnostic, sort_keys=True))
+        assert round_trip == diagnostic

