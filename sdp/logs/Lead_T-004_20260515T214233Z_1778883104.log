            run=_tailscale_status_tool,
        ),
        "ssh_process_check": PALOpsTool(
            name="ssh_process_check",
            description="If PAL_SSH_* env vars are configured, run a fixed read-only remote process/log check.",
            run=_ssh_process_check_tool,
        ),
    }


