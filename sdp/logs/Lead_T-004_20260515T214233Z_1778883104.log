                "compliant_actions": ts.compliant_actions,
                "last_updated": ts.last_updated,
            }
            for agent, ts in trust_scores.items()
        },
    }
    print(json.dumps(result, indent=2))
    return 0


def cmd_coherence_decisions(args: argparse.Namespace) -> int:
