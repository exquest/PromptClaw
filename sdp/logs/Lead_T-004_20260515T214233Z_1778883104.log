new file mode 100644
index 0000000000000000000000000000000000000000..70866dbd2761089e345d0300378b1632539084cb
--- /dev/null
+++ b/promptclaw/pal_knowledge.py
@@ -0,0 +1,51 @@
+from __future__ import annotations
+
+from glob import glob
+from pathlib import Path
+
+from .config import load_config
+from .models import PromptClawConfig
+
+DEFAULT_PAL_KNOWLEDGE_SOURCES: tuple[str, ...] = (
+    "docs/**/*.md",
+    "ops/**/*.md",
+    "ops/templates/*.conf",
+    "ops/templates/*.md",
+    "ops/templates/*.py",
+    "ops/templates/*.sh",
+    "ops/templates/*.yml",
+    "ops/templates/router-Dockerfile",
+    ".promptclaw/pal-smoke/*.json",
+    ".promptclaw/runs/**/summary/*.md",
+    ".promptclaw/runs/**/outputs/*.json",
+)
+
+
+def discover_pal_source_files(
+    project_root: Path,
+    config: PromptClawConfig | None = None,
+) -> tuple[Path, ...]:
+    """Return configured PAL knowledge source files in deterministic order."""
+    root = project_root.resolve()
+    active_config = config or load_config(root)
+    configured_sources = tuple(active_config.pal.knowledge_sources)
+    patterns = configured_sources or DEFAULT_PAL_KNOWLEDGE_SOURCES
+    discovered: dict[str, Path] = {}
+
+    for pattern in patterns:
+        for path in _expand_source_pattern(root, pattern):
+            if not path.is_file():
+                continue
+            resolved = path.resolve()
+            discovered[resolved.as_posix()] = resolved
+
+    return tuple(discovered[key] for key in sorted(discovered))
+
+
+def _expand_source_pattern(project_root: Path, pattern: str) -> tuple[Path, ...]:
+    stripped = pattern.strip()
+    if not stripped:
+        return ()
+    pattern_path = Path(stripped).expanduser()
+    search_pattern = str(pattern_path if pattern_path.is_absolute() else project_root / stripped)
+    return tuple(Path(match) for match in glob(search_pattern, recursive=True))
diff --git a/specs/t-004@20260515t214233z-spec.md b/specs/t-004@20260515t214233z-spec.md
new file mode 100644
index 0000000000000000000000000000000000000000..0c76dc45d4cc1c2fb0fb8b3a6fddcc9a40e9665f
--- /dev/null
+++ b/specs/t-004@20260515t214233z-spec.md
@@ -0,0 +1,58 @@
+# T-004@20260515T214233Z Specification
+
+## Problem Statement
+
+PAL-013 starts the PAL knowledge-base slice by adding a deterministic source
+discovery function. Later PAL chunking and index-writing tasks need one local
+function that reads PromptClaw project configuration and returns the configured
+PAL knowledge input files without contacting the live PAL router or mutating
+runtime artifacts.
+
+The acceptance criterion is: "Test returns configured sample files."
+
+## Technical Approach
+
+- Extend `PALConfig` with a `knowledge_sources` list of glob or file patterns.
+- Add a small PAL knowledge/source module under `promptclaw/`.
+- Implement `discover_pal_source_files(project_root, config=None)`:
+  - load `promptclaw.json` when no config is provided;
+  - expand configured `pal.knowledge_sources` entries relative to
+    `project_root`;
+  - allow absolute patterns for future operator-supplied source lists;
+  - return only existing files;
+  - de-duplicate repeated matches by resolved path;
+  - sort output deterministically by resolved POSIX path.
+- Keep the function stdlib-only and side-effect free.
+- Update the committed `pal-2026/promptclaw.json` to declare the current PAL
+  source set used by future KB tasks.
+
+## Edge Cases
+
+- Missing configured files or empty glob matches are ignored.
+- Directories matched by a broad glob are ignored.
+- Duplicate matches from overlapping patterns appear once.
+- An empty configuration falls back to the default PAL knowledge source
+  patterns so existing PAL configs continue to work.
+- The function does not parse or read file contents; unreadable file content is
+  handled by later chunk/index tasks.
+- Startup identity hardening is outside this source-discovery change, but the
+  existing regression anchors must be re-run because the task prompt carries the
+  recurring bootstrap checks.
+
+## Acceptance Criteria
+
+1. Configured sample PAL source files are discovered deterministically.
+   VERIFY: `pytest tests/test_pal_knowledge.py -q`
+
+2. PAL configuration round-trips the new knowledge source list.
+   VERIFY: `pytest tests/test_pal_client.py::PALConfigTests::test_pal_config_round_trips_through_project_config -q`
+
+3. Default PAL source discovery remains local and side-effect free for existing
+   configs.
+   VERIFY: `pytest tests/test_pal_knowledge.py::test_discover_pal_source_files_uses_default_pal_sources_when_config_is_empty -q`
+
+4. Startup identity hardening anchors still pass.
+   VERIFY: `pytest tests/test_first_boot.py::TestStartupIdentityPersistence tests/test_first_boot.py::TestStartupIdentityModePersistence tests/test_governor_integration.py::TestStartupIdentityWiring tests/test_narrative_api_main.py::test_asgi_module_startup_bootstraps_identity_persistence_between_imports -q`
+
+5. Full validation passes before final commit.
+   VERIFY: `pip install -e '.[dev]' && pytest tests/ -x && ruff check src/ tests/ && mypy src/`
