 j in range(1, 3):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                 note = p.notes[i * 3 + j]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n-                # The bass weak-beat degrees should be root+2 (third) or root+4 (fifth)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n-                expected = {root_deg, root_deg + 2, root_deg + 4}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+                expected = {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+                    ((root_deg - 1) % 7) + 1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+                    ((root_deg + 1) % 7) + 1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+                    ((root_deg + 3) % 7) + 1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+                }\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                 assert note.scale_degree in expected, (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                     f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"beat {j} of chord {root_deg}: got degree {note.scale_degree}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                 )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n@@ -210,6 +368,45 @@ class TestGenerateBassLine:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n         p = generate_bass_line(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", [1, 5], beats_per_chord=4)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n         assert len(p.notes) == 8\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    def test_pattern_styles_change_comping_shape(self):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+        pedal = generate_bass_line(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+            [1, 4, 5, 1],\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+            beats_per_chord=4,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+            pattern_style=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\