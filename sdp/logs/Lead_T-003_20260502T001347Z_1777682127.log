+    created_at: str | None,
+) -> EventRecord:
+    return EventRecord(
+        id=record.id,
+        type=record.type or event_type,
+        domain=record.domain or domain,
+        payload=record.payload or dict(payload),
+        created_at=record.created_at or created_at,
