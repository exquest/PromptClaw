+
+    assert calls[0][0] == [
+        "ssh",
+        "-o",
+        "BatchMode=yes",
+        "cypherclaw",
+        "python3",
+        "-m",
+        "promptclaw.asset_bus.remote_exec",
+        "--output-dir",
+        "/tmp/deniable-asset-bus/run-abc123",
+    ]
+    assert calls[1][0] == [
+        "rsync",
+        "-a",
+        "--",
