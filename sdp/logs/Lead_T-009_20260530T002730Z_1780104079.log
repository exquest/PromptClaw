+        "cypherclaw",
+        "python3",
+        "-m",
+        "promptclaw.asset_bus.remote_exec",
+        "--output-dir",
+        "/tmp/deniable-asset-bus/run-abc123",
+    ]
+    assert calls[1][0] == [
+        "rsync",
+        "-a",
+        "--",
+        "cypherclaw:/tmp/deniable-asset-bus/run-abc123/",
+        f"{output_dir}/",
+    ]
+    assert result.exit_status == 0
+    assert result.artifacts == (output_dir / "image-0.png",)
