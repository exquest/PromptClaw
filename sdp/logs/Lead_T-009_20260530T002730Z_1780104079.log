+
+def test_ssh_box_runner_rejects_invalid_argv_before_subprocess(tmp_path: Path) -> None:
+    calls: list[tuple[Sequence[str] | str, dict[str, Any]]] = []
+
+    def fake_run(
+        args: Sequence[str] | str,
