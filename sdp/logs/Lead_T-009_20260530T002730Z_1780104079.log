+        subprocess_run=fake_run,
+    )
+
+    runner.run(argv, output_dir=tmp_path / "deliverables")
+
+    ssh_args, ssh_kwargs = calls[0]
+    rsync_args, _ = calls[1]
+    assert isinstance(ssh_args, list)
+    assert isinstance(rsync_args, list)
