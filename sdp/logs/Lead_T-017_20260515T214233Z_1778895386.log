er.md\\\\n        sdp/run-log.md\\\\n        sdp/self-improvement/\\\\n        sdp/state.db.legacy-20260416T045403Z\\\\n        sdp/task-graph.md\\\\n        sdp/telemetry/\\\\n        sdp/templates/candidates/\\\\n        sdp/templates/claude/\\\\n        sdp/verification/t-001@20260416t043834z-manual-verify.md\\\\n        sdp/verification/t-010@20260408t223256zb-verify.md\\\\n        tests/test_archive_paths.py\\\\n        tests/test_arrangement_engine.py\\\\n        tests/test_artistic_identity.py\\\\n        tests/test_cadence_engine.py\\\\n        tests/test_capstone_engine.py\\\\n        tests/test_capture_alias.py\\\\n        tests/test_cast_planner.py\\\\n        tests/test_commission_context.py\\\\n        tests/test_contact_mic_calibration_runtime.py\\\\n        tests/test_cypherclaw_audio_runtime.py\\\\n        tests/test_cypherclaw_av_stack_service.py\\\\n        tests/test_cypherclaw_boot_runtime.py\\\\n        tests/test_dsp_scene_lab.py\\\\n        tests/test_ear_engine.py\\\\n        tests/test_emsd_curriculum.py\\\\n        tests/test_emsd_performance.py\\\\n        tests/test_emsd_runtime.py\\\\n        tests/test_form_grammar.py\\\\n        tests/test_gallery_x11_runtime.py\\\\n        tests/test_glyphweave_cli.py\\\\n        tests/test_harmonic_planner.py\\\\n        tests/test_hook_engine.py\\\\n        tests/test_instrument_patches.py\\\\n        tests/test_master_bus.py\\\\n        tests/test_midi_keyboard_listener_runtime.py\\\\n        tests/test_mix_engine.py\\\\n        tests/test_music_tracker.py\\\\n        tests/test_music_tracker_runtime.py\\\\n        tests/test_musical_integration_runtime.py\\\\n        tests/test_observer_vision_runtime.py\\\\n        tests/test_piece_brief.py\\\\n        tests/test_piece_commission.py\\\\n        tests/test_piece_queue.py\\\\n        tests/test_practice_curriculum.py\\\\n        tests/test_presence_engine.py\\\\n        tests/test_procedural_arc.py\\\\n        tests/test_prosody_engine.py\\\\n        tests/test_reharmonizer.py\\\\n        tests/test_repertoire_memory.py\\\\n        tests/test_repertoire_memory_score_tree.py\\\\n        tests/test_room_presence_daemon.py\\\\n        tests/test_runtime_paths.py\\\\n        tests/test_sample_dsp_activity.py\\\\n        tests/test_sample_event_renderer.py\\\\n        tests/test_sample_lab.py\\\\n        tests/test_sample_status.py\\\\n        tests/test_score_tree.py\\\\n        tests/test_score_tree_composer.py\\\\n        tests/test_score_tree_pipeline.py\\\\n        tests/test_self_listener_tracker_runtime.py\\\\n        tests/test_sound_palette_lab.py\\\\n        tests/test_tracker_cadence.py\\\\n        tests/test_tracker_compiler.py\\\\n        tests/test_tracker_variation.py\\\\n        tests/test_voice_aliases.py\\\\n        tests/test_voice_shaping.py\\\\n        verification_reports/\\\\n\\\\nno changes added to commit (use \\\\\\\"git add\\\\\\\" and/or \\\\\\\"git commit -a\\\\\\\")\\\\ndiff --git a/CHANGELOG.md b/CHANGELOG.md\\\\nindex c0e1324..aa40528 100644\\\\n--- a/CHANGELOG.md\\\\n+++ b/CHANGELOG.md\\\\n@@ -2,6 +2,109 @@\\\\n \\\\n ## Unreleased\\\\n \\\\n+- Tuned local SDP agent templates for dirty-baseline operation: leads must commit task-scoped changes, while verifiers now treat unrelated pre-existing dirty workspace state as notes instead of failing otherwise-correct tasks or asking agents to clean another operator's work.\\\\n+- Implemented ST1-ST6 of the score-tree songwriting stack end to end: added `piece_commission.py`, `piece_brief.py`, `form_grammar.py`, `score_tree.py`, `recursive_composer.py`, `composition_gate.py`, `tracker_compiler.py`, and `piece_queue.py`; extended `repertoire_memory.py` to store structural score-tree summaries; and rewired `duet_composer.py` so tracker solo mode can commission a piece, build a complete score tree, gate it, compile it into tracker scenes, and precompose the next piece into a small persistent queue instead of treating the tracker as the composer.\\\\n+- Rebalanced the first live score-tree pass for audibility: fresh post-restart commissions now avoid jumping straight to a maximal sparse suite unless the cadence is already wind-down/sleep-oriented, and `music_tracker_runtime.py` now emits stronger safe amplitudes for primary melody/bass/rhythm lanes so a healthy running piece is easier to hear and meter.\\\\n+- Fixed the long-section tracker compile bug that was turning songs into isolated sustained tones: `tracker_compiler.py` now converts large section budgets into repeat counts plus modest note-length scaling, and `music_tracker.py` quantizes those repeats into real repeated phrase cycles instead of stretching a handful of notes across the whole scene.\\\\n+- Finished the next score-tree composition pass: `tracker_compiler.py` now derives and enriches a fresh score per section, applies section-function and motif-aware phrase transforms before tracker quantization, and `music_tracker.py` now varies repeated cycles inside long sections, so longer pieces can develop through distinct section writing instead of only looping one shared phrase body.\\\\n+- Added internal phrase-family development inside longer sections: `Phrase` now carries metadata, `tracker_compiler.py` expands section bodies into recursive families like `A`, `A_prime`, and `B`, and `music_tracker.py` annotates emitted steps with `internal_phrase_family` so development sections can be tested and diagnosed as more than literal loops.\\\\n+- Coordinated those internal phrase families across tracker roles: shared root/function profiles now shape melody, bass, counter, and color variants together, and tracker steps expose `internal_family_root_degree` plus `internal_family_function` for diagnostics and future orchestration consumers.\\\\n+- Added authored section transitions: `tracker_compiler.py` now tags each non-final scene with the next scene/function/root target, and `music_tracker.py` marks and retunes final-cycle tail steps as transition preparation so long sections aim into the following section instead of simply looping until a hard boundary.\\\\n+- Added staged lane windows inside repeated tracker scenes: `music_tracker.py` now assigns per-role `entry_cycle` / `exit_cycle` metadata and delays counter/color support in long development-style sections, so sections can thicken internally instead of launching every lane at row 0.\\\\n+- Fixed transition metadata through motif recall: recalled `Recap` / `Release` lanes now strip stale source-scene transition fields and attach the current scene's own transition target to their final preparation tail.\\\\n+- Added section-level motif development and local harmonic progressions: `tracker_compiler.py` now labels each section as statement, sequence/fragment, contrast inversion, recall answer, liquidation, or residue, reshapes phrase material accordingly, and applies section-local progressions that are exposed on tracker scenes and steps for bass/progression verification.\\\\n+- Added section-level rhythmic development: `tracker_compiler.py` now maps section functions to named rhythm cells such as steady statement, syncopated fragment, half-time displacement, recall groove, and residue breath, reshaping phrase durations/accents and exposing `rhythm_development` / `rhythm_cell` through tracker metadata.\\\\n+- Fixed recalled motif rhythm metadata so later sections that borrow earlier material inherit the current scene's rhythm/progression profile instead of leaking the source scene's old `rhythm_development`.\\\\n+- Added arrangement automation curves to tracker playback: `music_tracker.py` now derives `arrangement_curve` from section rhythm, writes row-point automation for `density`, `master_amp`, and `reverb_send`, shapes note velocity across each lane's active window, and `music_tracker_runtime.py` / `duet_composer.py` now expose and apply interpolated automation to the live master bus during the section. Low density also thins optional color/counter runtime events while preserving melody and bass continuity.\\\\n+- Fixed a live capture fallback issue that made the sampler lean on a quiet self bus: `room_listener.py` now skips absent named JACK ports and tries direct `jack_rec` fallback ports such as `system:capture_1`, while `sample_dsp_activity.py` now resolves missing `theramini_in` to `contact_mic` / `room_mic` before `self_bus`.\\\\n+- Rebalanced the live song mix after the repeat-cycle fix: `music_tracker_runtime.py` now gives texture lanes a stronger floor while slightly easing bass dominance, and `emsd_performance.py` now uses a gentler amp-scaling curve so normal `away_practice` songs no longer pin bass and melody at the top of the EMSD gain range.\\\\n+- Fixed the live score-tree runtime on CypherClaw: `duet_composer.py` now derives commission context defensively from the world when `TrackerPlan` lacks `day_phase` / `weekly_phase`, `master_bus.py` now exposes an explicit `sw_master_smooth` seed helper, and `restart_composer.sh` now reseeds that master node again after the new composer PID is confirmed alive so the first piece does not run with scene-level `/n_set` traffic targeting a dead node.\\\\n+- Added a concrete score-tree composition spec for the next songwriting pass: `cypherclaw-score-tree-composition-spec.md` now defines the piece commission layer, narrative brief contract, section-function grammar, score-tree data model, recursive composer, composition gate, tracker compiler, repertoire score-tree memory, and rollout phases needed to move CypherClaw from short tracker-first sketches toward longer, more varied composed pieces.\\\\n+- Isolated observer vision from the shared local model queue: added `cypherclaw-observer-ollama.service` on `127.0.0.1:11435`, routed `observer_vision.py` to try `11435` before `11434`, and taught the multimodal call path to fail over across ordered observer Ollama URLs before dropping to local fallback mode.\\\\n+- Moved heavy runtime storage toward the large archive volume: added `archive_paths.py`, taught `sample_playback_engine.py` and `archive_daemon.py` to resolve a shared archive root (preferring `/mnt/archive/cypherclaw` on the live box), updated `cypherclaw_boot.sh` to put porch/side capture rings on that archive root, and reconfigured the live host so Litestream observatory/state file replicas live off the root disk with a much tighter observatory snapshot retention window.\\\\n+- Hardened the slow observer-vision path: `observer_vision.py` now treats Ollama `503 server busy / maximum pending requests exceeded` as queue saturation instead of a user-facing description, preserves the HTTP body detail in `vision_error`, emits a compact local fallback description with `vision_backend: \\\\\\\\\\\\\\\"local_fallback\\\\\\\\\\\\\\\"`, and backs off before retrying the multimodal model call again.\\\\n+- Repaired the live display/camera contract on CypherClaw: `cypherclaw_av_boot.sh` now reapplies the observed dual-head layout (`DP-2` face at `1280x1024`, `DP-0` gallery at `3840x2160`) and launches face/gallery on `:0.0` / `:0.1`, while `gallery_x11.py` now uses origin positioning on the secondary X screen instead of the old combined-desktop offset that left the 4K monitor partially black.\\\\n+- Hardened the local webcam path: `observer_vision.py` now defaults to `/dev/video0`, records `video_device`, and rejects stale old JPEGs when `ffmpeg` capture fails; `room_presence_daemon.py` can now run in `--observer-frame-only` mode and report `capture_source: \\\\\\\"observer_frame\\\\\\\"` so presence can share the single observer webcam instead of contending for it.\\\\n+- Mirrored the shared observer frame back into `/tmp/room_frame.jpg` when `room_presence_daemon.py` is running in `--observer-frame-only` mode, so archive and room-frame consumers stay fresh instead of freezing on the last independent room-camera capture.\\\\n+- Tightened the user-boot camera ownership path too: `cypherclaw_boot.sh` now deduplicates the local observer/presence daemons and starts `room_presence_daemon.py` in shared-observer mode, which prevents repeated boot invocations from piling up dozens of competing camera loops on the live box.\\\\n+- Locked the EMSD room sampler to tracker transport: `sample_dsp_activity.py` now emits `transport_trigger_now` / `transport_trigger_key`, `sample_playback_engine.py` uses those keys to launch once per musical bucket instead of only by cooldown, and the face/status layer can now reflect that transport-synchronized sampler execution.\\\\n+- Made the self-monitor more truthful: `self_listener.py` now derives glyph-facing brightness and motion from captured audio features instead of target-only metadata, while `cypherclaw_av_boot.sh` pins the live meter to the verified JACK path on CypherClaw and still leaves PipeWire / `pw-jack` capture as fallback code paths.\\\\n+- Fixed the remaining live self-monitor blackout path: when direct `jack_rec` capture times out, `self_listener.py` now falls back to analyzing a fresh `/tmp/room_capture.wav` clip instead of writing a dark `capture_timeout` state, so glyph and sampler decisions stay audio-derived on boxes where the JACK recorder hangs.\\\\n+- Added real EMSD master-bus control: `master_bus.py` now translates live `mix_*` fields plus tracker-scene `master_amp` / `reverb_send` automation into `sw_master_smooth` `/n_set` updates at scene start, so EMSD mix intent now shapes the summed output path instead of only per-note rendering.\\\\n+- Extended hook phrasing into actual later-section pitch behavior: `score_from_mood()` now publishes hook answer-degree metadata, and `music_tracker.py` uses that data in `Recap` / `Release` / `Resolution` / `Afterglow` so later sections can answer harmonically as well as textually.\\\\n+- Collapsed split boot ownership for the core AV stack: `cypherclaw_boot.sh` now delegates audio/composer/face/gallery/room-listener/sample startup to `cypherclaw_av_boot.sh`, which keeps one authority for those daemons instead of racing duplicate boot paths.\\\\n+- Added a replayable musical integration regression that exercises the composer-state -> sampler-plan -> sample-playback -> self-listener glyph state -> face-status chain, so this integration can be verified without a live host.\\\\n+- Hardened the live audio runtime after the Scarlett/JACK outage: `start_audio.sh` now links the repo SynthDef bundle into `~/.local/share/SuperCollider/synthdefs`, starts `scsynth` with synthdef auto-load enabled, and prefers a real JACK/Scarlett graph before falling back to `pw-jack`; `restart_composer.sh` now restarts the composer gracefully and verifies the new PID instead of rebuilding synthdefs with `/d_recv`; and `cypherclaw_boot.sh` no longer blindly sends `/n_set` to master node `99999` after boot.\\\\n+- Tightened that audio-runtime recovery again so `start_audio.sh` only stays on the real-JACK path when `system:playback_1` is actually present, and it now retries `scsynth` on `pw-jack` automatically if the real JACK graph disappears or never registers `SuperCollider:out_1`.\\\\n+- Made the Scarlett recovery path deterministic: when real JACK needs to be rebuilt, `start_audio.sh` now clears stale JACK state, relaunches `jackdbus`, and configures the ALSA backend for `hw:USB` before starting `scsynth`, so the box can recover onto the Scarlett monitor path instead of drifting into a PipeWire-only fallback.\\\\n+- Relaxed composer restart verification to the real steady-state condition: `restart_composer.sh` now waits for any healthy `duet_composer.py` process instead of only trusting the very first child PID, which avoids false failures during the current live startup race.\\\\n+- Made the composer restart truly session-detached: `restart_composer.sh` now launches `duet_composer.py` with `nohup setsid ... </dev/null` so the live composer survives operator SSH/session teardown instead of disappearing with the parent shell.\\\\n+- Added a persistent cold-boot path for the live AV runtime: `cypherclaw_av_boot.sh` now restarts `start_audio.sh`, `restart_composer.sh`, `self_listener.py`, `room_listener.py`, `sample_playback_engine.py`, and `face_display.py` under detached sessions, and `cypherclaw-av-stack.service` can bind that stack to `graphical.target` so music and the face monitor return after reboot without a manual SSH recovery.\\\\n+- Tightened the cold-boot wrapper to avoid daemon duplication: it now waits for `SuperCollider:out_1` before launching the meter, and it only backfills `room_listener.py`, `sample_playback_engine.py`, and `face_display.py` if another startup source has not already brought them up during the same boot.\\\\n+- Made the cold-boot wrapper opportunistic instead of combative: if `scsynth` and `duet_composer.py` are already present from another startup path, `cypherclaw_av_boot.sh` now skips `start_audio.sh` / `restart_composer.sh` entirely and only backfills the missing meter/listener surface.\\\\n+- Made `self_listener.py` backend-aware: it now auto-selects between `jack_rec` and `pw-jack jack_rec`, sets `JACK_NO_START_SERVER=1` on its capture probes to avoid waking an unwanted JACK server, and publishes `capture_backend` in `/tmp/self_listen.json` so operators can tell which live graph the meter is following.\\\\n+- Hardened that backend selection for the real CypherClaw boot race: direct `jack_lsp` probes can now take longer without forcing a false `pw-jack` fallback, `self_listener.py` caches the last working backend and resets that cache after failed capture loops, its `jack_rec` capture path now discards child stdout/stderr instead of risking a blocked pipe and stale meter state, and `cypherclaw_av_boot.sh` now deduplicates stale `room_listener.py`, `sample_playback_engine.py`, and `face_display.py` copies instead of letting old bad boot loops accumulate dozens of live daemons.\\\\n+- Made the cold-boot meter less ambiguous: `cypherclaw_av_boot.sh` now chooses `SELF_LISTENER_CAPTURE_BACKEND` from the boot-time graph decision, preferring a live PipeWire sink monitor before JACK fallbacks, and it performs a second delayed dedupe pass so late-start room/sampler/face daemons from other boot hooks are collapsed back to one process each.\\\\n+- Swapped the self-listener toward a host-stable monitor path: `self_listener.py` now prefers a PipeWire sink monitor target when one is available, still falls back to direct JACK or `pw-jack` port capture when needed, and keeps the old backend cache/reprobe logic only as fallback behavior instead of the primary live path.\\\\n+- Brought the gallery back under the same AV boot contract as the face: the repo now ships a top-level `gallery_x11.py` entrypoint again, and `cypherclaw_av_boot.sh` now starts and deduplicates `gallery_x11.py` alongside `face_display.py` so reboot recovery cannot leave the gallery unmanaged or multiplied into dozens of stale X processes.\\\\n+- Tightened the display recovery behavior again: `cypherclaw_av_boot.sh` now force-restarts `face_display.py` and `gallery_x11.py` on recovery instead of only deduplicating them, because a single stale headless display process was enough to leave the monitors blank while still looking “healthy” in `ps`.\\\\n+- Fixed the display-runtime environment for those restarts too: `cypherclaw_av_boot.sh` now exports `XDG_RUNTIME_DIR=/run/user/1000` before launching face and gallery, which avoids the live SDL/X error where both display clients would restart with `DISPLAY=:0` but still fail to attach to the user session.\\\\n+- Turned EMSD sample planning into real playback: added `sample_event_renderer.py`, `sample_playback_engine.py`, and `sample_status.py`; `cypherclaw_boot.sh` now starts the playback daemon; `/tmp/sample_dsp_activity.json` now feeds rendered room-derived WAV events through `pw-play`; and `/tmp/sample_playback_state.json` exposes the live sampler state for operators and face surfaces.\\\\n+- Hardened the sample-playback daemon so stable ambient scenes can refresh repeatedly after cooldown instead of firing once per unchanged signature, and render failures now write a structured error state instead of crashing the loop.\\\\n+- Taught `face_display.py` to surface the live EMSD sample layer from `/tmp/sample_dsp_activity.json`, so the head monitor can show which source and activity mode the room-sampling layer is currently holding or triggering.\\\\n+- Rebalanced EMSD source authority toward the room in lived-in late phases: capstone `Convergence` and `Crystallization` now prefer `room_mic` outside `away_practice`, DSP scene focus follows that same room bias, and `sample_dsp_activity.py` can retarget a sparse late-phase `self_bus` request onto a fresh room capture while still preserving the original requested source in state for operator visibility.\\\\n+- Fixed room-capture triggering so external sample sources no longer depend on `self_listener` RMS. `room_mic`, `contact_mic`, and `theramini_in` now trigger from their own live cues, while only `self_bus` remains gated by self-audio level.\\\\n+- Tightened head-monitor truth again: the sample status line can now read `/tmp/sample_playback_state.json` and show actual live sampler playback instead of only the planned source/mode.\\\\n+- Made the sampler musically scene-aware instead of only transform-aware: `sample_dsp_activity.py` now emits scene profiles like `development_grains`, `theme_accents`, `recap_echo`, `divination_bed`, and `afterglow_residue`, and `sample_event_renderer.py` now changes duration, density, peak target, filtering, stretch, and echo geometry from those profiles so the room layer follows the tracker form instead of using one generic behavior under different labels.\\\\n+- Promoted the Perform-VE room mic to the actual live capture path: `cypherclaw_boot.sh` now starts `room_listener.py` without `--no-jack`, and `room_listener.py` now reports `capture_backend` / `capture_source` so the live state shows whether JACK on the condenser path or an ALSA fallback is in use.\\\\n+- Adjusted room-listener fallback priority so ALSA auto-selection now prefers the Perform-VE interface over webcam or generic analog capture when JACK is unavailable.\\\\n+- Made room-listener ALSA capture more resilient by retrying alternate sample formats on each candidate device before falling through to the next one.\\\\n+- Made Perform-VE usable through the Linux audio stack by teaching `room_listener.py` to prefer a PipeWire `pw-record` target for Perform-VE before trying JACK or ALSA fallbacks.\\\\n+- Rebased the EMSD ambient default onto the real room condenser path: Divination/capstone planning and DSP source focus now prefer `room_mic` instead of `garden_mic`, so the default ambient sampler matches the Perform-VE microphone actually present on CypherClaw.\\\\n+- Made EMSD sample activity resilient to missing sources: `sample_dsp_activity.py` can now resolve a requested source like `garden_mic` onto a fresh room/contact/self capture when the requested alias is unavailable, and `self_listener.py` now publishes a full capture registry so that fallback can happen from live file freshness instead of hardcoded guesswork.\\\\n+- Wired stable EMSD sample capture into the live runtime: added `capture_alias.py` plus `sample_dsp_activity.py`, taught `room_listener.py`, `contact_listener.py`, `theramini_listener.py`, and `self_listener.py` to mirror fresh clips into `/tmp/room_capture.wav`, `/tmp/contact_capture.wav`, `/tmp/theramini_capture.wav`, and `/tmp/self_capture.wav`, and made `self_listener.py` publish `/tmp/sample_dsp_activity.json` with concrete activity modes, trigger flags, and DSP/sample-control values derived from composer, cadence, and sensor state.\\\\n+- Expanded CypherClaw boot coverage for the EMSD sampler path: `cypherclaw_boot.sh` now starts `theramini_listener.py` and `contact_listener.py` alongside the room listener so the stable sample aliases can refresh during unattended startup instead of remaining planned-but-missing files.\\\\n+- Fed EMSD production plans into actual tracker playback: added `emsd_performance.py`, wired `duet_composer.py` to apply live mix/sample/DSP adjustments at the note boundary, extended `composer_emsd_extras()` with concrete sample capture metadata, and made the strongest top register fold down harder so notes above roughly `C6` are lowered an octave and the sharpest band is lowered two octaves.\\\\n+- Wired the next EMSD runtime pass into live state: added `emsd_runtime.py`, taught `duet_composer.py` to build a typed EMSD context per tracker song and publish arc/mix/sample/DSP/identity fields into `/tmp/composer_state.json`, extended `repertoire_memory.py` to retain `patch_name`, and taught `self_listener.py` to publish `/tmp/glyph_audio_features.json` by combining live audio analysis with composer/cadence state for GlyphWeave-facing consumers.\\\\n+- Built the first end-to-end EMSD package: added a 40-course curriculum catalog plus generated `my-claw/curriculum/EMSD-*` scaffolds, and implemented `sound_palette_lab.py`, `sample_lab.py`, `mix_engine.py`, `procedural_arc.py`, `dsp_scene_lab.py`, `artistic_identity.py`, and `capstone_engine.py` so the electronic music production roadmap now exists as runnable code and tests instead of only a brief.\\\\n+- Folded the highest live octave down by one octave at playback time: `voice_shaping.py` now marks the extreme top band with a `pitch_multiplier`, and `play_voice()` applies that fold before sending OSC so CypherClaw's brightest instruments stop landing in the most painful register.\\\\n+- Tightened title-hook coherence again: `hook_engine.py` now chooses title phrases from image-field-aware pools that also react to cadence, progression profile, hook type, and repertoire source titles, so CypherClaw can move between labels like `Low Light`, `Electric Circuits`, `Moving Lines`, and `Open Thresholds` without collapsing back to generic or repeated adjective-noun pairs.\\\\n+- Very high-note playback shaping is now stronger and more explicit: `voice_shaping.py` emits best-effort `highpass_hz` and `saturation_mix` controls in addition to the existing top-octave gain/brightness/release shaping, and `play_voice()` forwards those controls so ear-splitting notes can be filtered and driven slightly when the live SynthDefs support it.\\\\n+- Tightened hook-language quality at the source: `hook_engine.py` now normalizes rough historical phrases like `carry the line wide` and `open the room open`, and `repertoire_memory.py` repairs those forms on load/store so they stop resurfacing through recall.\\\\n+- Made face captions orchestration-aware: `prosody_engine.py` now uses `patch_name` and lane count so sparse scenes compress hook language while denser scenes widen it into fuller face text.\\\\n+- Made face captions harmonic-function-aware: `prosody_engine.py` now uses `cadence_type` for `Resolution` and `Afterglow`, so the same hook can resolve differently under dominant, plagal, authentic, and deceptive harmonic landings.\\\\n+- Added legacy repertoire hook repair: `repertoire_memory.py` now normalizes broken historical hook text like `answer the again` on load and store, so old artifacts stop leaking into new songs and captions.\\\\n+- Made scene captions section-aware: `prosody_engine.py` now reshapes the same hook differently for `Theme`, `Recap`/`Release`, and `Resolution`/`Afterglow`, so face text follows the song arc instead of repeating one caption verbatim.\\\\n+- Made repertoire answer hooks less literal and less repetitive: `hook_engine.py` now chooses among contextual phrase-level answer variants based on family/cadence/song state, so recalled hook lines stay grammatical without collapsing into one stock response.\\\\n+- Tightened repertoire hook language and payoff shaping: answer-mode hooks now use phrase-level transforms instead of awkward generic suffixes, repertoire memory can target a preferred payoff scene, and tracker runtime state now exposes scene metadata like `payoff_focus` for live correlation.\\\\n+- Extended repertoire influence into tracker form memory: the live composer can now inherit a prior strong song's preferred progression profile, title/hook recall mode, form variant, and section-density bias before building the next tracker song.\\\\n+- Made repertoire memory active instead of archival-only: `repertoire_memory.py` now returns forward-looking influence by family/cadence, `hook_engine.py` can answer or recall prior title/hook material, and the live composer can bias the next song's progression profile before score generation begins.\\\\n+- Built the first complete M1-M6 musicianship package end to end: added `reharmonizer.py`, `hook_engine.py`, `arrangement_engine.py`, `ear_engine.py`, `practice_curriculum.py`, `prosody_engine.py`, and `repertoire_memory.py`; extended `harmonic_planner.py`, `generative_scores.py`, `music_tracker.py`, `continuous_learner.py`, `duet_composer.py`, and `keyboard_chat.py` so tracker songs now carry section functions, cadence types, hook metadata, scene arrangement intent, practice-block focus, ear-metric evaluation, repertoire storage, and face-visible song titles/captions through the live runtime.\\\\n+- Added `docs/cypherclaw-musicianship-roadmap.md`, which maps the Berklee songwriting curriculum onto CypherClaw's live harmony, melody, arrangement, ear-training, practice, and repertoire systems, and linked it from the upgrade checklist as the next musicianship program after stability work.\\\\n+- Lowered the live bass register further, widened per-patch octave spacing across bass/melody/counter/color, and made that register policy survive the whole tracker pipeline by preserving patch metadata through family shaping, cadence clamping, tracker scene building, and runtime scheduling.\\\\n+- Broke the fixed tracker-song mold: `tracker_form_for_family(..., song_num=...)` now yields variant forms with different scene counts and scene-length multipliers, so CypherClaw no longer plays every song with the same five-scene duration profile.\\\\n+- Added a small high-note saturation-style shaping layer for live playback. Because the current synths do not expose a true drive parameter, very high notes are softened by trimming gain/release, reducing pluck brightness, and adding a little detune/space instead of sending unsupported OSC args.\\\\n+- Diversified family and harmonic planning across the day and week: `resolve_tracker_plan()` now rotates through day-phase and weekly-phase family palettes instead of pinning occupied daytime songs to one family, and it emits progression profiles like `open_day`, `lift`, `settling`, and `experiment` so the score generator changes chord motion as well as form.\\\\n+- Added family-level motif memory to the live tracker path: `ContinuousLearner` now tags songs with tracker family, progression profile, cadence state, and patch context, `MelodicMemory` can retrieve matching fragments by keyword, and `score_from_mood()` now prefers and answers same-family/profile motifs instead of drawing only from a generic recent fragment pool.\\\\n+- Added scene-level tracker recall inside each song: `build_korsakov_tracker_song()` now lets `Recap` and short-form `Release` borrow motif shapes from the already-built `Theme` scene with answering transforms and provenance metadata, so those sections feel like intentional returns instead of parallel re-renderings of the same score.\\\\n+- Gave the named house patches real musical identities instead of just voice pools: `score_from_mood()` is now patch-aware, so melody contour, bass/comping pattern, progression bank, dynamics, and register spread all change with the active house patch.\\\\n+- Replaced the provisional tracker patch set with named house patches (`house_monastery`, `house_chamber`, `house_garden`, `house_procession`, `house_workshop`) and retired `bell` / `metal` from live runtime playback, so CypherClaw now stays inside a more coherent western-compatible ensemble even when the cast contains those older inharmonic voices.\\\\n+- Added a motif-driven score generator to `generative_scores.py` and threaded `song_num`, tracker family, cadence state, and recent melodic-memory fragments into live score generation, so CypherClaw can now both invent fresh melody cells and recall transformed motifs instead of rebuilding the same contour-only phrase and comping pattern across similar songs.\\\\n+- Replaced the inharmonic runtime `gong` playback voice with a tuned bowed substitute, so the live foundation voice sits inside western/modal harmonic material instead of fighting it.\\\\n+- Added an explicit OpenCV-backed visual person cue in `observer_vision.py` with local fallback when `cv2` is unavailable, so CypherClaw can confirm faces on the live box without blocking the fast observer loop.\\\\n+- Refactored `observer_vision.py` so it writes fresh fast-state immediately, only promotes `someone_here` from motion or explicit person descriptions, and tuned presence fusion to keep quiet recent-home occupancy through wind-down instead of flipping to `likely_away` too aggressively.\\\\n+- Added a mode-aware harmonic planner and live keyboard-grimoire path: tracker solo now preserves major/minor/modal key specs, ignores stale garden and MIDI files, supports scene-level modulation, and `midi_keyboard_listener.py` discovers the real keyboard devices while publishing pedal-derived harmonic suggestions.\\\\n+- Widened tracker orchestration so CypherClaw can actually use the broader character-instrument registry: cast planning now keeps a support-role character in low-energy songs, tracker role hints recognize metal/grain/pad/tabla synths, and runtime voice routing preserves those explicit lane instruments instead of collapsing them to legacy fallbacks.\\\\n+- Tuned tracker voice routing to be lane-aware again after the orchestration widening pass: ringing `metal`/`bell`/`pad` hints are normalized away from long quiet texture/counter lanes, and tracker runtime restores a pad safety fallback so subdued scenes do not sit on a constant unregulated tone.\\\\n+- Added cadence-aware tracker voice softening for `wind_down` and sleep-adjacent scenes, so chirpy `pluck`/`kotekan`/`grain` cast hints are remapped toward bowed, breath, choir, or gong voices before late-night playback.\\\\n+- Quarantined tracker `grain` playback to `breath` on the live runtime after discovering hundreds of leaked `sw_grain` nodes building up in scsynth and collapsing the speaker output into broadband static.\\\\n+- Added explicit runtime voice aliases so unavailable or unsafe voices can degrade cleanly: `grain` now resolves to `breath`, and `tabla_ge` currently resolves to `tabla_tin` until a real `sw_tabla_ge` SynthDef is deployed.\\\\n+- Replaced the inline room-camera loop with a dedicated `room_presence_daemon.py` and taught `room_listener.py` to auto-select a working ALSA room mic, so live presence inputs survive reboot and no longer depend on the dead `hw:4,0` fallback.\\\\n+- Fixed canonical presence fail-safe behavior so stale or error-only sensor inputs no longer collapse CypherClaw into `likely_away`, and added `room_listener.py` to the live boot path so presence has a speech signal to consume.\\\\n+- Added a concrete CypherClaw upgrade checklist covering phase status, owned files, test gates, and live deployment order for the presence/cadence/personality/audio-efficiency program.\\\\n+- Added canonical `presence_engine.py` and `cadence_engine.py`, wired them into the CypherClaw boot path, taught `world_model.py` to trust `/tmp/presence_state.json` and `/tmp/cadence_state.json`, and made tracker solo clamp tempo inside the published cadence band.\\\\n+- Expanded the CypherClaw presence/cadence spec into an implementation blueprint with research-backed daily and weekly cadence rules, silence architecture, social-synchrony guardrails, CPU-safe rollout phases, and a concrete cadence-state runtime contract.\\\\n+- Made CypherClaw tracker solo cast-aware: the live composer now derives tracker lane voice hints from the active character cast and enforces a quiet foundation lane through subdued `Theme`/`Development`/`Recap` scenes.\\\\n - Added `LOCAL_ONLY` daemon enforcement so live routing collapses to `ollama`, bypasses cloud router CLIs, and coerces explicit cloud-agent steps back to the local agent.\\\\n - Added a Telegram `/local` built-in backed by a shared daemon status snapshot so operators can request per-socket Ollama health, loaded models, and latency on demand.\\\\n - Wired `ollama_health()` into the `/status` Telegram command and half-hour heartbeat so operators can see per-socket Ollama health, loaded models, and latency without SSH.\\\\ndiff --git a/docs/architecture.md b/docs/architecture.md\\\\nindex 437647d..5caffec 100644\\\\n--- a/docs/architecture.md\\\\n+++ b/docs/architecture.md\\\\n@@ -53,6 +53,11 @@ The control plane decides:\\\\n - whether the run can complete or needs another loop\\\\n - when a live provider should be deprioritized or excluded because quota headroom is degraded\\\\n \\\\n+In SDP-backed queues, verification is task-scoped even when the project worktree\\\\n+already contains unrelated local changes. Agents must commit their own task\\\\n+changes, but pre-existing unrelated dirty or untracked files are treated as a\\\\n+baseline condition and must not be cleaned, reverted, or folded into the task.\\\\n+\\\\n There are two modes:\\\\n \\\\n - `agent`: ask a configured agent to return routing JSON\\\\n@@ -86,6 +91,8 @@ Agent runtimes support three modes:\\\\n \\\\n In CypherClaw-style live command deployments, command routing can consult `sdp-cli` quota telemetry. Healthy and warn providers remain eligible, degraded and paused providers are excluded from new work, and if every provider is degraded the runtime falls back to the provider with the most remaining headroom instead of refusing to operate.\\\\n \\\\n+The live daemon also supports a hard local-only guard through `LOCAL_ONLY=true`. In that mode, the available-agent set collapses to `ollama`, the daemon skips cloud router CLIs entirely, and any explicit `claude`/`codex`/`gemini` step is coerced to `ollama` at execution time so fitness scores or routed step payloads cannot reintroduce cloud agent calls.\\\\n+\\\\n ### 7. CypherClaw resilience layer\\\\n \\\\n CypherClaw live deployments add a runtime safety layer around the orchestrator:\\\\n@@ -104,7 +111,59 @@ When the project root also looks like a live CypherClaw runtime, `promptclaw doc\\\\n \\\\n The live daemon path is now also portable across the MacBook dev home and the Linux server home. Status checks branch on platform, optional watchdog integrations are treated as optional imports, and runtime semaphore acquire/release/reject transitions are recorded so concurrency throttling is observable instead of implicit.\\\\n \\\\n-Operator-facing Telegram status now also splits cleanly between built-ins and routed work. Queue-backed commands like `/monitor`, `/quota`, and `/prd` read live runtime state directly instead of relying on conversational summaries, so queue progress, roadmap status, and provider health stay aligned with the SQLite authority DB.\\\\n+Maintenance mode is now disk-authoritative too. The canonical flag lives at `.sdp/MAINTENANCE`, resolved through the authority `state.db` path so tmpfs workdir copies cannot invent a second maintenance state. Entering maintenance while the managed runner or a running task exists now requires an explicit operator override; `safe_reboot.sh prepare` is the intended path for that transition.\\\\n+\\\\n+Daemon child processes also run with a sanitized environment: `NOTIFY_SOCKET`, `WATCHDOG_PID`, and `WATCHDOG_USEC` are stripped before spawning agent CLIs or helper commands, so only the daemon main process talks to systemd's watchdog socket.\\\\n+\\\\n+The managed runner path also repairs a stale `.sdp/run.lock` before preflight runs. That keeps normal systemd restarts from failing their own startup checks after the previous runner PID has been terminated.\\\\n+The systemd runner unit itself now uses `Restart=always` so a clean `sdp-cli run` exit cannot silently strand the queue. Maintenance-gated launcher exits stay non-looping through `SuccessExitStatus=75` and `RestartPreventExitStatus=75`.\\\\n+When a sibling `sdp-cli/src` checkout exists next to the home, the launcher also exports that path into `PYTHONPATH` automatically unless the operator has already pinned a different value. That keeps the live runner on the checked-out source tree instead of an older installed package.\\\\n+\\\\n+Operator-facing Telegram status now also splits cleanly between built-ins and routed work. Queue-backed commands like `/monitor`, `/quota`, `/prd`, and `/tasks` read live runtime state directly instead of relying on conversational summaries, so queue progress, roadmap status, provider health, and actionable worklists stay aligned with the SQLite authority DB. Queue totals use one canonical denominator everywhere: all live executable tasks, excluding only split parents. `/prd` now also distinguishes empty roadmap stages from frozen or decomposed ones: stages with only frozen work are shown as `frozen`, stages with only split parents are shown as `decomposed`, and only truly absent work is shown as `not loaded`. `/monitor` now carries a compact `sdp-cli`-style status slice too: completion-gate status, latest completed run verdict/pair, and per-agent quota/provider health, while still surfacing queue-state drift when the active-task and open-task-run records disagree. `/tasks` now defaults to an operator-first queue view with running work, next root tasks, split-needed work, and attention items, while filtered slices like `/tasks frozen` or `/tasks all 20` expose deeper backlog details on demand. Roadmap-aware task slices such as `/tasks prd 6` and `/tasks stage clone and home creation` resolve through the same roadmap/batch files as `/prd`, so stage-level work inspection stays aligned with the live execution spine.\\\\n+\\\\n+The live daemon scheduler also owns a compact half-hour heartbeat. At `:00` and `:30` each hour it sends uptime, I/O wait, memory, load, available-agent count, queue progress, and pet XP summary to Telegram, and records the send in Observatory. This is the text-only precursor to the richer GlyphWeave art heartbeat.\\\\n+CypherClaw's tracker orchestration now also has an explicit instrument-patch layer. Cast voices are no longer used as a flat pool during normal listening: songs resolve into named house patches such as `house_monastery`, `house_chamber`, `house_garden`, `house_procession`, and `house_workshop`, with normal occupied listening biased toward `bowed`, `pluck`, `choir`, and `breath`. Those house patches are now musical as well as timbral: each patch carries its own contour bias, bass/comping vocabulary, dynamic envelope, and wider register spread. The older `bell` and `metal` voices are retired from live playback and degraded to tuned substitutes at runtime.\\\\n+That patch layer now reaches all the way through tracker runtime and playback too: patch metadata survives family shaping and cadence clamping, live tracker scenes apply per-patch octave floors and ceilings by role, tracker forms vary by song number instead of always using one fixed five-scene length, and very high notes are softened with a small saturation-style shaping pass because the live synth surface does not expose a dedicated drive control.\\\\n+Family planning is now more authored as well. `resolve_tracker_plan()` no longer pins large parts of the day to one family like `bloom`; it rotates through day-phase and weekly-phase family palettes, while also emitting a harmonic progression profile such as `awakening`, `open_day`, `lift`, `settling`, or `experiment` so the score generator changes not just scene shape but harmonic material across the day.\\\\n+\\\\n+`my-claw/tools/telegram.py` now treats test execution and tmpfs task-run workdirs as non-production contexts by default. If `PYTEST_CURRENT_TEST` or `PROMPTCLAW_TEST_MODE` is present, or if the helper is running from `/run/cypherclaw-tmp/workdir/`, Telegram sends are suppressed unless `PROMPTCLAW_ALLOW_LIent.lane_name == \\\\\\\\\\\\\\\"foundation\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\n++        melody = next(event for event in events if event.lane_name == \\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\n++        texture = next(event for event in events if event.lane_name == \\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\n++\\\\\\\\n++        assert bass.frequency_hz < (melody.frequency_hz / 2.5)\\\\\\\\n++        assert texture.frequency_hz > (melody.frequency_hz * 2.5)\\\\\\\\n++\\\\\\\\n++    def test_patch_metadata_changes_live_register_profile(self):\\\\\\\\n++        monastery = _sample_scene()\\\\\\\\n++        monastery.metadata[\\\\\\\\\\\\\\\"patch_name\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\"house_monastery\\\\\\\\\\\\\\\"\\\\\\\\n++        procession = _sample_scene()\\\\\\\\n++        procession.metadata[\\\\\\\\\\\\\\\"patch_name\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\"house_procession\\\\\\\\\\\\\\\"\\\\\\\\n++\\\\\\\\n++        monastery_events = build_scene_events(monastery)\\\\\\\\n++        procession_events = build_scene_events(procession)\\\\\\\\n++\\\\\\\\n++        monastery_melody = next(event for event in monastery_events if event.lane_name == \\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\n++        procession_melody = next(event for event in procession_events if event.lane_name == \\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\n++        monastery_texture = next(event for event in monastery_events if event.lane_name == \\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\n++        procession_texture = next(event for event in procession_events if event.lane_name == \\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\n++\\\\\\\\n++        assert monastery_melody.frequency_hz < procession_melody.frequency_hz\\\\\\\\n++        assert monastery_texture.frequency_hz <= procession_texture.frequency_hz\\\\\\\\n++\\\\\\\\n++    def test_keeps_primary_roles_above_live_audibility_floor(self):\\\\\\\\n++        scene = _sample_scene()\\\\\\\\n++\\\\\\\\n++        events = build_scene_events(scene)\\\\\\\\n++\\\\\\\\n++        melody_peak = max(event.amplitude for event in events if event.role == \\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\")\\\\\\\\n++        bass_peak = max(event.amplitude for event in events if event.role == \\\\\\\\\\\\\\\"bass\\\\\\\\\\\\\\\")\\\\\\\\n++        color_peak = max(event.amplitude for event in events if event.role == \\\\\\\\\\\\\\\"color\\\\\\\\\\\\\\\")\\\\\\\\n++\\\\\\\\n++        assert melody_peak >= 0.14\\\\\\\\n++        assert bass_peak >= 0.12\\\\\\\\n++        assert color_peak >= 0.02\\\\\\\\n++\\\\\\\\n++\\\\\\\\n++class TestRuntimeStatePaths:\\\\\\\\n++    def test_tmp_state_path_is_unique_per_call(self, tmp_path):\\\\\\\\n++        target = tmp_path / \\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\"\\\\\\\\n++\\\\\\\\n++        first = _tmp_state_path(target)\\\\\\\\n++        second = _tmp_state_path(target)\\\\\\\\n++\\\\\\\\n++        assert first != second\\\\\\\\n++        assert first.parent == target.parent\\\\\\\\n++        assert second.parent == target.parent\\\\\\\\n++\\\\\\\\n++\\\\\\\\n++class TestScheduleScene:\\\\\\\\n++    def test_emits_events_and_sleep_intervals(self, tmp_path):\\\\\\\\n++        scene = _sample_scene()\\\\\\\\n++        scene.metadata[\\\\\\\\\\\\\\\"payoff_focus\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\"primary\\\\\\\\\\\\\\\"\\\\\\\\n++        scene.metadata[\\\\\\\\\\\\\\\"section_function\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\"arrival\\\\\\\\\\\\\\\"\\\\\\\\n++        scene.metadata[\\\\\\\\\\\\\\\"text_hook\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\"answer the room\\\\\\\\\\\\\\\"\\\\\\\\n++        played = []\\\\\\\\n++        slept = []\\\\\\\\n++        state_path = tmp_path / \\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\"\\\\\\\\n++\\\\\\\\n++        result = schedule_scene(\\\\\\\\n++            scene,\\\\\\\\n++            play_event=played.append,\\\\\\\\n++            sleep_fn=slept.append,\\\\\\\\n++            stop_check=lambda row: False,\\\\\\\\n++            state_path=state_path,\\\\\\\\n++            time_fn=lambda: 1000.0,\\\\\\\\n++            song_title=\\\\\\\\\\\\\\\"Test Song\\\\\\\\\\\\\\\",\\\\\\\\n++        )\\\\\\\\n++\\\\\\\\n++        assert result.completed is True\\\\\\\\n++        assert result.rows_processed == scene.pattern.rows\\\\\\\\n++        assert result.events_emitted == len(played) == len(build_scene_events(scene))\\\\\\\\n++        assert len(slept) == scene.pattern.rows - 1\\\\\\\\n++        assert all(round(seconds, 3) == 0.125 for seconds in slept)\\\\\\\\n++\\\\\\\\n++        runtime_state = json.loads(state_path.read_text())\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\"song_title\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\"Test Song\\\\\\\\\\\\\\\"\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\"scene_name\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\"Theme\\\\\\\\\\\\\\\"\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\"row\\\\\\\\\\\\\\\"] == scene.pattern.rows - 1\\\\\\\\n++        assert \\\\\\\\\\\\\\\"active_lanes\\\\\\\\\\\\\\\" in runtime_state\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\"scene_metadata\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\"payoff_focus\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\"primary\\\\\\\\\\\\\\\"\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\"scene_metadata\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\"section_function\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\"arrival\\\\\\\\\\\\\\\"\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\"scene_metadata\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\"text_hook\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\"answer the room\\\\\\\\\\\\\\\"\\\\\\\\n++\\\\\\\\n++    def test_can_abort_mid_scene(self, tmp_path):\\\\\\\\n++        scene = _sample_scene()\\\\\\\\n++        played = []\\\\\\\\n++\\\\\\\\n++        result = schedule_scene(\\\\\\\\n++            scene,\\\\\\\\n++            play_event=played.append,\\\\\\\\n++            sleep_fn=lambda _seconds: None,\\\\\\\\n++            stop_check=lambda row: row >= 4,\\\\\\\\n++            state_path=tmp_path / \\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\",\\\\\\\\n++            time_fn=lambda: 2000.0,\\\\\\\\n++        )\\\\\\\\n++\\\\\\\\n++        assert result.completed is False\\\\\\\\n++        assert result.rows_processed == 4\\\\\\\\n++        assert all(event.row < 4 for event in played)\\\\\\\\n++\\\\\\\\n++    def test_runtime_state_exposes_interpolated_automation(self, tmp_path):\\\\\\\\n++        scene = _sample_scene()\\\\\\\\n++        scene.pattern.automation = [\\\\\\\\n++            AutomationLane(\\\\\\\\n++                name=\\\\\\\\\\\\\\\"density\\\\\\\\\\\\\\\",\\\\\\\\n++                default=0.4,\\\\\\\\n++                points=[(0, 0.2), (scene.pattern.rows - 1, 0.8)],\\\\\\\\n++            )\\\\\\\\n++        ]\\\\\\\\n++\\\\\\\\n++        schedule_scene(\\\\\\\\n++            scene,\\\\\\\\n++            play_event=lambda _event: None,\\\\\\\\n++            sleep_fn=lambda _seconds: None,\\\\\\\\n++            stop_check=lambda row: row >= scene.pattern.rows // 2,\\\\\\\\n++            state_path=tmp_path / \\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\",\\\\\\\\n++            time_fn=lambda: 2100.0,\\\\\\\\n++        )\\\\\\\\n++\\\\\\\\n++        runtime_state = json.loads((tmp_path / \\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\").read_text())\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\"automation\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\"density\\\\\\\\\\\\\\\"] > 0.2\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\"automation\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\"density\\\\\\\\\\\\\\\"] < 0.8\\\\\\\\n++\\\\\\\\n++    def test_row_callback_receives_current_automation(self, tmp_path):\\\\\\\\n++        scene = _sample_scene()\\\\\\\\n++        scene.pattern.automation = [\\\\\\\\n++            AutomationLane(\\\\\\\\n++                name=\\\\\\\\\\\\\\\"master_amp\\\\\\\\\\\\\\\",\\\\\\\\n++                default=0.5,\\\\\\\\n++                points=[(0, 0.25), (scene.pattern.rows - 1, 0.75)],\\\\\\\\n++            )\\\\\\\\n++        ]\\\\\\\\n++        seen = []\\\\\\\\n++\\\\\\\\n++        schedule_scene(\\\\\\\\n++            scene,\\\\\\\\n++            play_event=lambda _event: None,\\\\\\\\n++            sleep_fn=lambda _seconds: None,\\\\\\\\n++            stop_check=lambda row: row >= 3,\\\\\\\\n++            state_path=tmp_path / \\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\",\\\\\\\\n++            time_fn=lambda: 2200.0,\\\\\\\\n++            on_row=lambda _scene, row, state: seen.append((row, state[\\\\\\\\\\\\\\\"automation\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\"master_amp\\\\\\\\\\\\\\\"])),\\\\\\\\n++        )\\\\\\\\n++\\\\\\\\n++        assert [row for row, _value in seen] == [0, 1, 2]\\\\\\\\n++        assert seen[0][1] < seen[-1][1]\\\\\\\\n++\\\\\\\\n++    def test_low_density_automation_thins_optional_support_events(self, tmp_path):\\\\\\\\n++        scene = _sample_scene()\\\\\\\\n++        scene.pattern.automation = [\\\\\\\\n++            AutomationLane(\\\\\\\\n++                name=\\\\\\\\\\\\\\\"density\\\\\\\\\\\\\\\",\\\\\\\\n++                default=0.1,\\\\\\\\n++                points=[(0, 0.1), (scene.pattern.rows - 1, 0.1)],\\\\\\\\n++            )\\\\\\\\n++        ]\\\\\\\\n++        played = []\\\\\\\\n++\\\\\\\\n++        result = schedule_scene(\\\\\\\\n++            scene,\\\\\\\\n++            play_event=played.append,\\\\\\\\n++            sleep_fn=lambda _seconds: None,\\\\\\\\n++            state_path=tmp_path / \\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\",\\\\\\\\n++            time_fn=lambda: 2300.0,\\\\\\\\n++        )\\\\\\\\n++\\\\\\\\n++        expected = build_scene_events(scene)\\\\\\\\n++        expected_primary = {\\\\\\\\n++            (event.lane_name, event.row, event.frequency_hz)\\\\\\\\n++            for event in expected\\\\\\\\n++            if event.role in {\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\"bass\\\\\\\\\\\\\\\"}\\\\\\\\n++        }\\\\\\\\n++        played_primary = {\\\\\\\\n++            (event.lane_name, event.row, event.frequency_hz)\\\\\\\\n++            for event in played\\\\\\\\n++            if event.role in {\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\"bass\\\\\\\\\\\\\\\"}\\\\\\\\n++        }\\\\\\\\n++\\\\\\\\n++        assert result.completed is True\\\\\\\\n++        assert len(played) < len(expected)\\\\\\\\n++        assert expected_primary <= played_primary\\\\\\\\n++        assert sum(1 for event in played if event.role == \\\\\\\\\\\\\\\"color\\\\\\\\\\\\\\\") < sum(\\\\\\\\n++            1 for event in expected if event.role == \\\\\\\\\\\\\\\"color\\\\\\\\\\\\\\\"\\\\\\\\n++        )\\\\\\\\n++\\\\\\\\n++\\\\\\\\n++class TestScheduleSong:\\\\\\\\n++    def test_runs_all_scenes_and_calls_scene_hook(self, tmp_path):\\\\\\\\n++        scene = _sample_scene()\\\\\\\\n++        song = TrackerSong(title=\\\\\\\\\\\\\\\"Suite\\\\\\\\\\\\\\\", scenes=[scene, scene])\\\\\\\\n++        started = []\\\\\\\\n++        played = []\\\\\\\\n++\\\\\\\\n++        result = schedule_song(\\\\\\\\n++            song,\\\\\\\\n++            play_event=played.append,\\\\\\\\n++            sleep_fn=lambda _seconds: None,\\\\\\\\n++            stop_check=lambda _scene, _row: False,\\\\\\\\n++            state_path=tmp_path / \\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\",\\\\\\\\n++            time_fn=lambda: 3000.0,\\\\\\\\n++            on_scene_start=lambda current_scene, _index: started.append(current_scene.name),\\\\\\\\n++        )\\\\\\\\n++\\\\\\\\n++        assert result.completed is True\\\\\\\\n++        assert started == [\\\\\\\\\\\\\\\"Theme\\\