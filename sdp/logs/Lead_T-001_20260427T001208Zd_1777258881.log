   250	class _FakePredictions:
   251	    def __init__(self, response: object | None = None, error: Exception | None = None):
   252	        self.calls: list[dict[str, object]] = []
   253	        self._response = response
   254	        self._error = error
   255	
   256	    def create(self, **kwargs: object) -> object:
   257	        self.calls.append(kwargs)
   258	        if self._error is not None:
   259	            raise self._error
   260	        return self._response
