   419	# ── _poll_prediction (T-001) ─────────────────────────────────────────
   420	
   421	
   422	class _PollingPrediction:
   423	    def __init__(self, statuses: list[str], error: str | None = None) -> None:
   424	        self._statuses = statuses
   425	        self._index = 0
   426	        self.status = statuses[0]
   427	        self.error = error
   428	        self.reloads = 0
   429	
   430	    def reload(self) -> "_PollingPrediction":
   431	        self.reloads += 1
   432	        self._index = min(self._index + 1, len(self._statuses) - 1)
   433	        self.status = self._statuses[self._index]
   434	        return self
   435	
   436	
   437	def test_poll_prediction_returns_when_succeeded() -> None:
   438	    rec = _Recorder()
