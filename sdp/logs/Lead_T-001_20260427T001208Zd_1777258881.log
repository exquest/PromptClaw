   390	def test_submit_prediction_retry_layer_engages_on_http_error(
   391	    monkeypatch: pytest.MonkeyPatch,
   392	) -> None:
   393	    """End-to-end: HTTP 503 from the SDK retries via the existing loop."""
   394	    response = SimpleNamespace(status_code=503, headers={})
   395	    http_error = type("HTTPStatusError", (Exception,), {})()
   396	    http_error.response = response  # type: ignore[attr-defined]
   397	
   398	    call_count = {"n": 0}
   399	    success = SimpleNamespace(id="ok", status="succeeded", output=b"")
   400	
   401	    class _FlakyPredictions:
   402	        def create(self, **_kwargs: object) -> object:
   403	            call_count["n"] += 1
   404	            if call_count["n"] < 2:
   405	                raise http_error
   406	            return success
   407	
   408	    _patch_replicate(monkeypatch, _FlakyPredictions())  # type: ignore[arg-type]
   409	    rec = _Recorder()
   410	    client = _make_client(rec)
   411	
   412	    result = client.generate({"model": "m", "prompt": "p"})
   413	
   414	    assert result["prediction_id"] == "ok"
   415	    assert call_count["n"] == 2
   416	    assert rec.sleeps == [BACKOFF_SCHEDULE[0]]
