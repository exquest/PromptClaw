+
+
+EXPECTED_MODE_FRAGMENTS = {
+    "solitary": (
+        "intimate",
+        "sparse",
+        "single voice",
+        "long held tones",
+        "lots of silence",
+    ),
+    "companion": (
+        "warm",
+        "harmonic",
+        "supportive",
+        "two-three voices",
+    ),
+    "working_ambience": (
