+        "no melody",
+        "minimal",
+    ),
+    "evening_reflection": (
+        "longer phrases",
+        "harmonic tension",
+        "tender",
+        "lyrical",
+    ),
+    "storm": (
+        "turbulent",
+        "dense grains",
+        "modal shifts",
+        "fast articulation",
+    ),
+}
+
+
+def _centroid() -> np.ndarray:
+    values = np.arange(1, CLAP_CENTROID_DIM + 1, dtype=np.float32)
