(phrase_tracker.play_duration(now), 3)\n+        if phrase_event is not None:\n+            state[\"phrase_event\"] = phrase_event\n+            print(\n+                f\"phrase_event: {phrase_event} \"\n+                f\"duration={state['phrase_duration_seconds']}s\",\n+                flush=True,\n+            )\n     return state\n \n \n@@ -195,6 +209,7 @@ def run(devices: list[str] | None = None) -> None:\n     recent_pedal_events: list[tuple[float, bool]] = []\n     last_activity = 0.0\n     fds: dict[str, int] = {}\n+    phrase_tracker = PhraseTracker()\n \n     while True:\n         if not fds:\n@@ -208,6 +223,7 @@ def run(devices: list[str] | None = None) -> None:\n                     last_activity=last_activity,\n                     now=time.time(),\n                     active_devices=sorted(fds),\n+                    phrase_tracker=phrase_tracker,\n                 )\n             )\n             if not fds:\n@@ -276,6 +292,7 @@ def run(devices: list[str] | None = None) -> None:\n                 last_activity=last_activity,\n                 now=now,\n                 active_devices=sorted(fds),\n+                phrase_tracker=phrase_tracker,\n             )\n         )\n         time.sleep(0.05)\ndiff --git a/my-claw/tools/senseweave/phrase_tracker.py b/my-claw/tools/senseweave/phrase_tracker.py\nnew file mode 100644\nindex 0000000..119dc99\n--- /dev/null\n+++ b/my-claw/tools/senseweave/phrase_tracker.py\n@@ -0,0 +1,72 @@\n+\"\"\"Phrase tracker — detects continuous play sessions across MIDI/audio listeners.\n+\n+Watches a stream of (is_playing, now) ticks and emits 'phrase_started' once a\n+continuous play session has lasted past the threshold, then 'phrase_ended' when\n+the player stops. Stdlib only.\n+\"\"\"\n+from __future__ import annotations\n+\n+from dataclasses import dataclass\n+from typing import Literal, Optional\n+\n+PhraseEvent = Literal[\"phrase_started\", \"phrase_ended\"]\n+\n+DEFAULT_PHRASE_THRESHOLD_SECONDS = 5.0\n+\n+\n+@dataclass\n+class PhraseTracker:\n+    \"\"\"Detects continuous play sessions and emits phrase boundary events.\n+\n+    Parameters\n+    ----------\n+    threshold_seconds:\n+        How long a continuous play session must last before it is treated as a\n+        phrase. Defaults to 5 seconds.\n+\n+    Notes\n+    -----\n+    Call :meth:`update` once per tick with the listener's current\n+    ``is_playing`` flag. The return value is the boundary event triggered by\n+    that tick, or ``None`` if no transition occurred.\n+    \"\"\"\n+\n+    threshold_seconds: float = DEFAULT_PHRASE_THRESHOLD_SECONDS\n+    _play_start: Optional[float] = None\n+    _phrase_active: bool = False\n+\n+    @property\n+    def phrase_active(self) -> bool:\n+        return self._phrase_active\n+\n+    @property\n+    def play_start(self) -> Optional[float]:\n+        return self._play_start\n+\n+    def play_duration(self, now: float) -> float:\n+        \"\"\"Seconds of continuous play up to ``now``. Zero when not playing.\"\"\"\n+        if self._play_start is None:\n+            return 0.0\n+        return max(0.0, now - self._play_start)\n+\n+    def update(self, is_playing: bool, now: float) -> Optional[PhraseEvent]:\n+        \"\"\"Advance the tracker. Returns the boundary event for this tick.\"\"\"\n+        if is_playing:\n+            if self._play_start is None:\n+                self._play_start = now\n+                return None\n+            if not self._phrase_active and (now - self._play_start) >= self.threshold_seconds:\n+                self._phrase_active = True\n+                return \"phrase_started\"\n+            return None\n+\n+        self._play_start = None\n+        if self._phrase_active:\n+            self._phrase_active = False\n+            return \"phrase_ended\"\n+        return None\n+\n+    def reset(self) -> None:\n+        \"\"\"Drop all state without emitting an event.\"\"\"\n+        self._play_start = None\n+        self._phrase_active = False\ndiff --git a/my-claw/tools/theramini_listener.py b/my-claw/tools/theramini_listener.py\nindex 7772724..d47d664 100644\n--- a/my-claw/tools/theramini_listener.py\n+++ b/my-claw/tools/theramini_listener.py\n@@ -25,6 +25,7 @@ from audio_analysis import (\n     pitch_to_nearest_key,\n     pitch_to_note_name,\n )\n+from senseweave.phrase_tracker import PhraseTracker\n \n STATE_FILE = Path(\"/tmp/theramini_state.json\")\n CLIP_FILE = Path(\"/tmp/theramini_clip.wav\")\n@@ -78,6 +79,7 @@ def analyze_once(\n     previous_rms: float,\n     onset_time: float | None,\n     silence_start: float | None,\n+    phrase_tracker: PhraseTracker | None = None,\n ) -> tuple[dict, float, float | None, float | None]:\n     \"\"\"Capture and analyze one clip. Returns (state_dict, current_rms, onset_time, silence_start).\"\"\"\n     now = time.time()\n@@ -98,6 +100,7 @@ def analyze_once(\n             \"onset_time\": onset_time,\n             \"error\": \"capture_failed\",\n         }\n+        apply_phrase_tracker(state, phrase_tracker, now=now)\n         return state, 0.0, onset_time, silence_start or now\n     persist_capture_alias(CLIP_FILE, SAMPLE_CAPTURE_FILE)\n \n@@ -140,9 +143,38 @@ def analyze_once(\n         \"consecutive_silence_ms\": consecutive_silence_ms,\n         \"onset_time\": onset_time,\n     }\n+    apply_phrase_tracker(state, phrase_tracker, now=now)\n     return state, rms, onset_time, silence_start\n \n \n+def apply_phrase_tracker(\n+    state: dict,\n+    phrase_tracker: PhraseTracker | None,\n+    *,\n+    now: float,\n+) -> None:\n+    \"\"\"Update ``phrase_tracker`` from ``state['is_playing']`` and annotate state.\n+\n+    Idempotent only across distinct ticks: callers must invoke this once per\n+    state snapshot. The tracker reads ``state['is_playing']`` after any\n+    listener-side overrides (e.g., idle-tone suppression) so events reflect\n+    the final playing decision.\n+    \"\"\"\n+    if phrase_tracker is None:\n+        return\n+    is_playing = bool(state.get(\"is_playing\", state.get(\"playing\", False)))\n+    phrase_event = phrase_tracker.update(is_playing, now)\n+    state[\"phrase_active\"] = phrase_tracker.phrase_active\n+    state[\"phrase_duration_seconds\"] = round(phrase_tracker.play_duration(now), 3)\n+    if phrase_event is not None:\n+        state[\"phrase_event\"] = phrase_event\n+        print(\n+            f\"phrase_event: {phrase_event} \"\n+            f\"duration={state['phrase_duration_seconds']}s\",\n+            flush=True,\n+        )\n+\n+\n def run_daemon(ports: list[str]) -> None:\n     \"\"\"Main daemon loop.\"\"\"\n     running = True\n@@ -152,6 +184,7 @@ def run_daemon(ports: list[str]) -> None:\n     previous_rms = 0.0\n     onset_time: float | None = None\n     silence_start: float | None = time.time()\n+    phrase_tracker = PhraseTracker()\n \n     # Track pitch history to detect idle tone vs human playing\n     pitch_history: list[float] = []\n@@ -183,6 +216,7 @@ def run_daemon(ports: list[str]) -> None:\n         else:\n             pitch_history.clear()\n \n+        apply_phrase_tracker(state, phrase_tracker, now=state[\"timestamp\"])\n         write_state(state)\n \n         if state.get(\"is_playing\"):\ndiff --git a/progress.md b/progress.md\nindex b842825..4eacfd4 100644\n--- a/progress.md\n+++ b/progress.md\n@@ -2,10 +2,10 @@\n \n Generated from SQLite state (`tasks`, `task_runs`, `escalations`). Do not edit manually.\n \n-ETC: ~2h 52m remaining (16 tasks, low confidence, calibrating)\n-Expected completion: 9:19 PM today.\n-Progress: [██████████████████████████████████░░░░] 91%  156 / 172 tasks complete\n-  completed: 156, pending: 8, needs_split: 8, blocked: 0, skipped: 14\n+ETC: ~3h 0m remaining (17 tasks, low confidence, calibrating)\n+Expected completion: 9:50 PM today.\n+Progress: [██████████████████████████████████░░░░] 90%  158 / 175 tasks complete\n+  completed: 158, pending: 10, needs_split: 7, blocked: 0, skipped: 15\n \n - **T-001@20260408T223256Z**: complete — Comple