+    elapsed_by_scene = {
+        "OpeningA": 1.0,
+        "PatternA": 7.0,
+        "DialogueA": 15.0,
+        "ReturnA": 22.0,
+        "ResidueA": 28.0,
+        "OpeningB": 31.0,
+        "PatternB": 37.0,
+    }
+    directives = {
+        section.scene_name: directive_for_elapsed(
