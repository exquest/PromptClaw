+        PlannedSection("ResidueA", "afterglow", 12.0, harmonic_role="plagal"),
+        PlannedSection("OpeningB", "invocation", 12.0, harmonic_role="tonic"),
+        PlannedSection("PatternB", "statement", 12.0, harmonic_role="tonic"),
