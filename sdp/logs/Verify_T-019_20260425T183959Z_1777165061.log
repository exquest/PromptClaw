            amp=amp,
            fx_send=fx_send,
            mode=mode,
            fx_node_id=fx_node_id,
        )

    def stop_sampler(self, handle: SamplerHandle) -> None:
        """Release a sustained sampler voice started via `start_sampler`."""
        handle.release()

