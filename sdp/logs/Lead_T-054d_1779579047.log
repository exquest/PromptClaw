    assert parse_verdict(str(report)) is VerdictResult.PASS


def test_default_spec_path_derived_from_task_id(
    tmp_path: Path, monkeypatch
) -> None:
    monkeypatch.chdir(tmp_path)
    specs_dir = tmp_path / "specs"
    specs_dir.mkdir()
