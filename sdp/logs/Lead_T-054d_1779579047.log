\\\\\\\\\\\\\\\\\\\\\\\\"timestamp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"updated\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+_KEYBOARD_MAX_AGE_S = 15.0\\\\\\\\\\\\\\\\n+_GARDEN_MAX_AGE_S = 180.0\\\\\\\\\\\\\\\\n+_INNER_MAX_AGE_S = 180.0\\\\\\\\\\\\\\\\n+_SCENE_ORDER = (\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Emergence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Theme\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Development\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Bridge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Recap\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Release\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Resolution\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Afterglow\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+)\\\\\\\\\\\\\\\\n+_CADENCE_TARGET_ROOT = {\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"authentic\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 1,\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"plagal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 1,\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"suspended\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 1,\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"half\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 5,\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"deceptive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 6,\\\\\\\\\\\\\\\\n+}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+@dataclass(frozen=True)\\\\\\\\\\\\\\\\n+class HarmonicPlan:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"The resolved harmonic center and its scene-level modulation path.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    key: str\\\\\\\\\\\\\\\\n+    root: str\\\\\\\\\\\\\\\\n+    mode: str\\\\\\\\\\\\\\\\n+    source: str\\\\\\\\\\\\\\\\n+    chord_palette: str\\\\\\\\\\\\\\\\n+    voicing_profile: str\\\\\\\\\\\\\\\\n+    modulation_intent: str\\\\\\\\\\\\\\\\n+    scene_keys: dict[str, str]\\\\\\\\\\\\\\\\n+    section_functions: dict[str, str]\\\\\\\\\\\\\\\\n+    section_cadences: dict[str, str]\\\\\\\\\\\\\\\\n+    section_progressions: dict[str, tuple[int, ...]]\\\\\\\\\\\\\\\\n+    section_chord_degrees: dict[str, tuple[tuple[int, ...], ...]]\\\\\\\\\\\\\\\\n+    modulation_path: tuple[str, ...]\\\\\\\\\\\\\\\\n+    reharm_strategy: str\\\\\\\\\\\\\\\\n+    next_key: str\\\\\\\\\\\\\\\\n+    section_harmonic_functions: dict[str, str]\\\\\\\\\\\\\\\\n+    section_transition_intents: dict[str, str]\\\\\\\\\\\\\\\\n+    strategy: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"diatonic\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _normalize_root(root: str | None) -> str | None:\\\\\\\\\\\\\\\\n+    if not root:\\\\\\\\\\\\\\\\n+        return None\\\\\\\\\\\\\\\\n+    normalized = root.strip()\\\\\\\\\\\\\\\\n+    if not normalized:\\\\\\\\\\\\\\\\n+        return None\\\\\\\\\\\\\\\\n+    normalized = normalized[0].upper() + normalized[1:]\\\\\\\\\\\\\\\\n+    if normalized not in _ROOT_TO_INDEX:\\\\\\\\\\\\\\\\n+        return None\\\\\\\\\\\\\\\\n+    return _NOTE_ORDER[_ROOT_TO_INDEX[normalized]]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _root_from_index(index: int) -> str:\\\\\\\\\\\\\\\\n+    return _NOTE_ORDER[index % 12]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def normalize_key_spec(value: str | None) -> str | None:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Canonicalize major/minor/modal key spellings.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\