"""Tests for migration-snapshot verdict wiring (T-005@20260503T180144Zc / SI-003).

Exercises ``_maybe_force_fail_for_missing_migration_snapshot`` and the
companion ``render_missing_migration_snapshot_notes`` renderer:

- non-migration specs are no-ops
- migration specs with snapshot evidence are no-ops
- migration specs without snapshot force FAIL from PASS or PASS WITH NOTES
- FAIL/MISSING/UNPARSEABLE verdicts are no-ops
- missing spec file is treated as no-mention
- default spec_path is derived from task_id
"""

from __future__ import annotations

import textwrap
from pathlib import Path

from sdp._orchestrator_impl import _maybe_force_fail_for_missing_migration_snapshot
from sdp.gates.verdict import VerdictResult, parse_verdict
from sdp.pipeline.migration_detection import render_missing_migration_snapshot_notes


def _write_report(path: Path, *, verdict_marker: str, body: str = "") -> None:
    text = textwrap.dedent(
        f"""
        # Verification Report — T-MIG

        ## Summary
        Verifier ran end-to-end.

        {body}

        ## Verdict: {verdict_marker}
        """
    ).strip() + "\n"
    path.write_text(text, encoding="utf-8")


def _write_migration_spec(path: Path) -> None:
    path.write_text(
        "# Spec\n\n"
        "## Problem Statement\n"
        "Apply ALTER TABLE users ADD COLUMN email TEXT;\n",
        encoding="utf-8",
    )


def _write_non_migration_spec(path: Path) -> None:
    path.write_text(
        "# Spec\n\n"
        "## Problem Statement\n"
        "Refactor the CLI argument parser to share defaults across commands.\n",
        encoding="utf-8",
    )


def _write_negative_migration_assertion_spec(path: Path) -> None:
    path.write_text(
        "# Spec\n\n"
        "## Problem Statement\n"
        "The report must not expose an approval action, cloud lifecycle action, "
        "model-loading action, volume migration, or any Phase 2 execution path.\n\n"
        "## Acceptance Criteria\n"
        "7. No new dependencies, migrations, remote-write commands, provider "
        "secrets, or database columns are introduced.\n"
        "- VERIFY: git diff -- pyproject.toml promptclaw/coherence/migrations\n",
        encoding="utf-8",
    )


def test_render_missing_migration_snapshot_notes_contents() -> None:
    notes = render_missing_migration_snapshot_notes()
    assert notes
    assert "## Notes for Lead Agent" in notes
    assert "## Verdict: FAIL" in notes
    # Both supported snapshot forms must be referenced so the lead agent
    # knows what evidence to add.
    assert "PRAGMA table_info" in notes
    assert "\\d" in notes
    # Rule reference helps grep-ability.
    assert "SI-003" in notes


def test_non_migration_spec_leaves_pass_unchanged(tmp_path: Path) -> None:
    report = tmp_path / "t-mig-verify.md"
    _write_report(report, verdict_marker="PASS")
    original_bytes = report.read_bytes()

    spec = tmp_path / "spec.md"
    _write_non_migration_spec(spec)

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS,
        report,
        "T-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.PASS
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.PASS


def test_negative_migration_assertion_spec_leaves_pass_unchanged(
    tmp_path: Path,
) -> None:
    report = tmp_path / "t-readiness-verify.md"
    _write_report(report, verdict_marker="PASS WITH NOTES")
    original_bytes = report.read_bytes()

    spec = tmp_path / "spec.md"
    _write_negative_migration_assertion_spec(spec)

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS_WITH_NOTES,
        report,
        "T-READINESS",
        spec_path=spec,
    )

    assert result is VerdictResult.PASS_WITH_NOTES
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.PASS_WITH_NOTES


def test_migration_spec_with_sqlite_snapshot_leaves_pass_unchanged(
    tmp_path: Path,
) -> None:
    report = tmp_path / "t-mig-verify.md"
    _write_report(
        report,
