+def _normalize_arc_shape(value: object | None) -> str | None:
+    if value is None:
+        return None
+    shape = str(value).strip()
+    if not shape:
+        return None
+    shape_key = shape.lower().replace("_", "-")
+    for authored_shape in ARC_SHAPES:
+        if shape_key == authored_shape.lower():
+            return authored_shape
+    return None
+
