+        event = Event(
+            normalized_phrase_position=0.5,
+            role="melody",
+            metadata={"phrase_id": f"{intent_tag}-{index}", "intent_tag": intent_tag},
+        )
+        rule.apply(event)
+        counts[event.metadata["phrase_arch_shape"]] += 1
+    return counts

