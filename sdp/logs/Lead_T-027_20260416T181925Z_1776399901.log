+def _performance_intent(event: Event) -> object | None:
+    intent = getattr(event, "performance_intent", None)
+    if intent is not None:
+        return intent
+
+    phrase = getattr(event, "phrase", None)
+    intent = getattr(phrase, "performance_intent", None)
+    if intent is not None:
