                path=str(path),
                module_name=path.stem,
                depth=-1,
                reason="unreadable file",
            )
    except OSError:
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="unreadable file",
        )
