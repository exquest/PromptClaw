def _is_public_function(node: ast.FunctionDef | ast.AsyncFunctionDef) -> bool:
    """Return whether a function contributes to the module's public surface."""
    return node.name == '__init__' or not node.name.startswith('_')


def _qualifies_for_depth_four(
    *,
    source: str,
    line_count: int,
    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef],
    matching_tests: list[Path],
    test_boosted: bool = False,
) -> bool:
    """Return whether a depth-3 module qualifies as polished depth 4."""
    if line_count <= 100:
        return False
    if _DEPTH_FOUR_MARKER_RE.search(source):
        return False
    if _docstring_coverage(public_function_nodes) <= _DEPTH_FOUR_DOCSTRING_THRESHOLD:
        return False
    if test_boosted:
        return True
    return _test_line_ratio(line_count, matching_tests) >= _DEPTH_FOUR_TEST_RATIO_THRESHOLD


def _docstring_coverage(
    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef],
) -> float:
    """Return the fraction of public functions with docstrings."""
    if not public_function_nodes:
        return 0.0

    documented = sum(1 for node in public_function_nodes if ast.get_docstring(node) is not None)
    return documented / len(public_function_nodes)


def _test_line_ratio(source_line_count: int, matching_tests: list[Path]) -> float:
    """Return the total test-to-source line ratio for matching tests."""
    if source_line_count <= 0:
        return 0.0

    test_line_count = 0
    for test_path in matching_tests:
        try:
            test_line_count += len(test_path.read_text().splitlines())
        except OSError:
            continue
    return test_line_count / source_line_count


def _compute_test_coverage(
    module_name: str,
    public_functions: list[str],
    matching_tests: list[Path],
) -> tuple[float, float]:
    """Return (total_coverage, max_single_file_coverage) of public functions."""
    if not public_functions:
        return 0.0, 0.0

    total_imported_funcs: set[str] = set()
    max_single_file_coverage = 0.0

    for test_path in matching_tests:
        try:
            tree = ast.parse(test_path.read_text())
        except (SyntaxError, OSError):
            continue

        file_imported_funcs: set[str] = set()
        for node in ast.walk(tree):
            if isinstance(node, ast.ImportFrom) and node.module and node.module.endswith(
                module_name
            ):
                for alias in node.names:
                    if alias.name in public_functions:
                        file_imported_funcs.add(alias.name)
                        total_imported_funcs.add(alias.name)
        
        file_coverage = len(file_imported_funcs) / len(public_functions)
        if file_coverage > max_single_file_coverage:
            max_single_file_coverage = file_coverage

    total_coverage = len(total_imported_funcs) / len(public_functions)
    return total_coverage, max_single_file_coverage


def _find_matching_test_files(source_path: Path) -> list[Path]:
    """Locate matching test files under the nearest tests directory.

    Python convention: ``test_<module>.py``
    JS/TS convention: ``<module>.test.{js,ts,tsx}``, ``<module>.spec.{js,ts,tsx}``,
    and ``__tests__/<module>.{js,ts,tsx}``
    """
    stem = source_path.stem
    results: list[Path] = []

    if source_path.suffix == ".py":
        pattern = f"test_{stem}.py"
        for parent in source_path.parents:
            tests_dir = parent / "tests"
            if tests_dir.is_dir():
                results.extend(tests_dir.rglob(pattern))
                break
    elif source_path.suffix in _JS_TS_EXTENSIONS:
        js_patterns = [
            f"{stem}.test.js", f"{stem}.test.ts", f"{stem}.test.tsx",
            f"{stem}.spec.js", f"{stem}.spec.ts", f"{stem}.spec.tsx",
        ]
        for parent in source_path.parents:
            # Search tests/ directory
            tests_dir = parent / "tests"
            if tests_dir.is_dir():
                for pat in js_patterns:
                    results.extend(tests_dir.rglob(pat))
            # Search __tests__/ directory
            dunder_tests = parent / "__tests__"
            if dunder_tests.is_dir():
                for ext in (".js", ".ts", ".tsx"):
                    match_path = dunder_tests / f"{stem}{ext}"
                    if match_path.exists():
                        results.append(match_path)
            if results:
                break

    return sorted(set(results))


def _is_trivial_return(body: list[ast.stmt]) -> bool:
    """Check if a function body is just a trivial return."""
    if len(body) == 1 and isinstance(body[0], ast.Return):
        ret = body[0].value
        if ret is None:
            return True
        if isinstance(ret, ast.Constant):
            return True
        if isinstance(ret, ast.List | ast.Dict | ast.Tuple):
            return True
    return False


# ── JS/TS Depth Classification ──────────────────────────────────


def classify_depth_js(source_path: str | Path) -> ModuleDepth:
    """Classify a JS/TS module's implementation depth using regex heuristics."""
    path = Path(source_path)
    if not path.exists():
        return ModuleDepth(
            path=str(path), module_name=path.stem,
            depth=-1, reason="file does not exist",
        )

    try:
        source = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        try:
            source = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return ModuleDepth(
                path=str(path), module_name=path.stem,
                depth=-1, reason="unreadable file",
            )
    except OSError:
        return ModuleDepth(
            path=str(path), module_name=path.stem,
            depth=-1, reason="unreadable file",
        )
    lines = source.splitlines()
    line_count = len(lines)

    # Extract classes and functions
    classes = _JS_CLASS_RE.findall(source)
    functions: list[str] = []
    functions.extend(_JS_FUNCTION_RE.findall(source))
    functions.extend(_JS_ARROW_FUNC_RE.findall(source))

    # Analyze function bodies via regex heuristics
    not_implemented = len(_JS_NOT_IMPLEMENTED_RE.findall(source))
    trivial_arrows = len(_JS_TRIVIAL_ARROW_RE.findall(source))
    trivial_returns = len(_JS_TRIVIAL_RETURN_RE.findall(source))
    total_trivial = trivial_arrows + trivial_returns
    logic_blocks = len(_JS_LOGIC_BLOCK_RE.findall(source))

    total_funcs = len(functions)
    matching_tests = _find_matching_test_files(path)

    # Depth classification
    if total_funcs == 0:
        depth = 0
        reason = "no functions found"
    elif not_implemented > 0:
        depth = 0
        reason = f"{not_implemented}/{total_funcs} not implemented"
    elif total_trivial >= total_funcs and logic_blocks == 0:
        depth = 1
        reason = f"all functions return trivial values ({total_trivial} trivial)"
    elif total_trivial > logic_blocks and logic_blocks == 0:
        depth = 1
        reason = f"{total_trivial}/{total_funcs} trivial, {logic_blocks} real"
    elif logic_blocks > 0 and line_count < 100:
        depth = 2
        reason = f"simple implementations ({line_count} lines)"
    elif logic_blocks > 0 and line_count < 300:
        depth = 3
        reason = f"full implementations ({line_count} lines, {logic_blocks} logic blocks)"
    elif logic_blocks > 0:
        depth = 3
        reason = f"substantial ({line_count} lines, {logic_blocks} logic blocks)"
    else:
        depth = 1
        reason = f"trivial ({total_trivial} trivial returns)"

    # Depth 3 with no tests → cap at 2 (same as Python)
    if depth == 3 and not matching_tests:
        depth = 2
        reason = f"{reason.split('(')[0].strip()} (no tests)"

    return ModuleDepth(
        path=str(path),
        module_name=path.stem,
        depth=depth,
        reason=reason,
        classes=classes,
        functions=functions,
        not_implemented_count=not_implemented,
        trivial_return_count=total_trivial,
        real_logic_count=logic_blocks,
        test_count=len(matching_tests),
        test_files=[str(t) for t in matching_tests],
        test_coverage=0.0,  # JS/TS test coverage analysis not yet supported
        test_boosted=False,
        line_count=line_count,
    )


# ── Scanning ──────────────────────────────────────────────────

_DEFAULT_SCAN_PATTERNS = ("*.py", "*.js", "*.ts", "*.tsx")

# Path components that mean "this is vendored / generated / cache, not project source."
# Matched as exact directory-name components in the path, so ".venv" matches
# "/x/.venv/lib/..." but does NOT match "/x/myvenv/foo".
_EXCLUDED_DIR_COMPONENTS: frozenset[str] = frozenset({
    ".venv",
    "venv",
    "env",
    ".env",          # env directories — distinct from .env files (handled below)
    "node_modules",
    "__pycache__",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    ".tox",
    ".nox",
    "dist",
    "build",
    ".next",
    ".nuxt",
    ".cache",
    ".git",
    ".hg",
    ".svn",
    "htmlcov",
    "coverage",
    "site-packages",  # belt-and-suspenders against vendored Python deps
    ".eggs",
    "egg-info",
    ".idea",
    ".vscode",
    ".DS_Store",
    "vendor",        # Go / PHP / Ruby vendored deps
    "target",        # Rust / Java build dirs
    ".gradle",
    ".sdp",          # SDP runtime state — not source code
})


def _is_excluded_path(path: Path, root: Path) -> bool:
    """Return True if *path* contains any excluded directory component
    between *root* and the file itself."""
    try:
        rel = path.relative_to(root)
    except ValueError:
        rel = path
    for part in rel.parts:
        # `.env` directory matches; `.env` file (no parts after it) does not
        if part in _EXCLUDED_DIR_COMPONENTS:
            return True
        # egg-info as suffix (e.g., "promptclaw.egg-info")
        if part.endswith(".egg-info"):
            return True
    return False


def scan_directory(
    directory: str | Path,
    pattern: str | None = None,
    *,
    patterns: tuple[str, ...] | None = None,
) -> list[ModuleDepth]:
    """Scan a directory and classify all supported modules.

    Excludes vendored / generated / cache directories per
    ``_EXCLUDED_DIR_COMPONENTS`` so we don't deepen third-party code.

    If *pattern* is given, only that glob is used (backward compat).
    Otherwise *patterns* defaults to Python + JS/TS globs.
    """
    if pattern is not None:
        globs: tuple[str, ...] = (pattern,)
    elif patterns is not None:
        globs = patterns
    else:
        globs = _DEFAULT_SCAN_PATTERNS

    seen: set[Path] = set()
    results: list[ModuleDepth] = []
    root = Path(directory).resolve()

    for glob in globs:
        for path in sorted(root.rglob(glob)):
            if path in seen:
                continue
            seen.add(path)
            if _is_excluded_path(path, root):
                continue

