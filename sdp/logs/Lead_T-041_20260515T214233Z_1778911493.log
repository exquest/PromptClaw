+def default_pal_deploy_apply_backup_id() -> str:
+    """Return a deterministic-format backup id for an apply run."""
+    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
+    return f"apply-{timestamp}"
