diff --git a/specs/t-041@20260515t214233z-spec.md b/specs/t-041@20260515t214233z-spec.md
new file mode 100644
index 0000000000000000000000000000000000000000..3fed519a9ecce614b59b42eb55a0e7d588b92ef6
