+        deployment_root=manifest.deployment_root,
+        remote_inventory_path=remote_inventory_path,
+        backup=backup,
+        applied_entries=tuple(applied_entries),
+        skipped_entries=skipped_entries,
+        unmanaged_remote=diff.unmanaged_remote,
+    )
