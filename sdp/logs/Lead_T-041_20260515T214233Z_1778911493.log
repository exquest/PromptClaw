+    parsed_without_approval = parser.parse_args([
+        "pal",
+        "deploy",
+        "apply",
+        str(tmp_path),
+        "--remote-inventory",
+        str(remote_inventory_path),
+    ])
+    parsed_with_approval = parser.parse_args([
+        "pal",
+        "deploy",
+        "apply",
