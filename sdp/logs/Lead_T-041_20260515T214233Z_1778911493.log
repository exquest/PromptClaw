            source=entry.source,
            target=entry.target,
            mode=entry.mode,
            owner=entry.owner,
            group=entry.group,
            kind=entry.kind,
            service_impact=entry.service_impact,
            required=entry.required,
            exists=False,
            sha256=None,
            size_bytes=None,
        )
    content = source_path.read_bytes()
