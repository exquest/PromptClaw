+def apply_pal_deployment_changes(
+    manifest: PALDeploymentManifest,
+    project_root: Path,
+    *,
+    remote_inventory: Iterable[PALDeploymentRemoteFile],
+    remote_inventory_path: Path,
+    backup_root: Path,
