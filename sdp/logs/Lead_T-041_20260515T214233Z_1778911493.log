+        json=True,
+    )
+    with redirect_stdout(output):
+        rc = promptclaw_cli.cmd_pal_deploy_apply(args)
+
+    assert rc == 0
+    payload = json.loads(output.getvalue())
+    assert payload["workflow_id"] == "pal_deploy_apply"
+    assert payload["status"] == "complete"
