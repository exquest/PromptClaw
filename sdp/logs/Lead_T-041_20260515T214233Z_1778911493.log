+def write_pal_remote_inventory_snapshot(
+    path: Path,
+    remote_inventory: Iterable[PALDeploymentRemoteFile],
+) -> None:
+    """Write a JSON-safe fake PAL remote inventory snapshot."""
+    payload = {
