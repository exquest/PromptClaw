+    overlap = _tag_overlap(acoustic_tags, descriptor_acoustic_tags)
+    if not overlap:
+        return None
+    if row["arc_phase"] != descriptor_arc_phase:
+        return None
+    payload = json.loads(str(row["tags_json"]))
+    extras = payload.get("extra_tags", {})
