+
+def quote_verification_exit_code(report: QuoteVerificationReport) -> int:
+    """Map report status to the legacy CLI exit code."""
+    if report.status == STATUS_NO_SELF_QUOTES:
+        return 1
+    if report.status == STATUS_NO_MOTIF_TAG_MATCH:
+        return 2
+    return 0
