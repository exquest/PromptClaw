+    return QuoteMatch(
+        sample_id=str(row["sample_id"]),
+        arc_phase=str(row["arc_phase"]),
+        acoustic_tags=_normalize_acoustic_tags(acoustic_tags),
+        overlap=overlap,
+        song_id=song_id,
+    )
+
