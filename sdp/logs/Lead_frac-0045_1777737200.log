+    descriptor_set = set(_normalize_acoustic_tags(descriptor_tags))
+    overlap: list[str] = []
+    for tag in _normalize_acoustic_tags(candidate_tags):
+        if tag in descriptor_set:
+            overlap.append(tag)
+    return tuple(overlap)
+
