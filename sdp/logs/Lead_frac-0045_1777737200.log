+def _report_status(captured: int, match: QuoteMatch | None) -> str:
+    if captured == 0:
+        return STATUS_NO_SELF_QUOTES
+    if match is None:
+        return STATUS_NO_MOTIF_TAG_MATCH
+    return STATUS_SELF_QUOTE_MATCH_OK
