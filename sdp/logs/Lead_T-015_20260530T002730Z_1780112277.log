sdp/verification/t-001@20260530t002730z-verify.md:30:{"type":"tool_use","timestamp":"2026-05-30T00:37:58.081Z","tool_name":"write_file","tool_id":"write_file_1780101478080_0","parameters":{"content":"from pathlib import Path\nimport os\nimport pytest\nfrom promptclaw.asset_bus.paths import safe_deliverable_path, UnsafePathError\n\ndef test_symlink_escape():\n    # Setup a fake bus root\n    bus_root = Path(\"test_bus_root\").absolute()\n    bus_root.mkdir(parents=True, exist_ok=True)\n    \n    request_id = \"req123\"\n    deliverables_dir = bus_root / \"deliverables\" / request_id\n    deliverables_dir.mkdir(parents=True, exist_ok=True)\n    \n    # Create a file outside the bus root\n    secret_file = Path(\"secret.txt\").absolute()\n    secret_file.write_text(\"sensitive data\")\n    \n    # Create a symlink inside the deliverables dir pointing outside\n    link_path = deliverables_dir / \"bad_link\"\n    if link_path.exists():\n        link_path.unlink()\n    os.symlink(secret_file, link_path)\n    \n    print(f\"Bus root: {bus_root}\")\n    print(f\"Deliverables dir: {deliverables_dir}\")\n    print(f\"Link path: {link_path} -> {link_path.resolve()}\")\n    \n    # Now try to access it via safe_deliverable_path\n    # Note: safe_deliverable_path calls sanitize_target_path which rejects \"bad_link/..\" or similar\n    # But what if we just ask for \"bad_link\"?\n    \n    try:\n        resolved = safe_deliverable_path(bus_root, request_id, \"bad_link\")\n        print(f\"Resolved (unexpectedly): {resolved}\")\n    except UnsafePathError as e:\n        print(f\"Caught expected error for direct symlink: {e}\")\n\n    # cleanup\n    link_path.unlink()\n    secret_file.unlink()\n    import shutil\n    shutil.rmtree(bus_root)\n\nif __name__ == \"__main__\":\n    test_symlink_escape()\n","file_path":"verify_symlink.py"}}
