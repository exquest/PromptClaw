+    assert theramini_meta["instrument"] == "theramini"
+    assert set(keyboard_meta) == {"instrument", "song_id", "key", "tempo", "source"}
+    assert set(theramini_meta) == {"instrument", "song_id", "key", "tempo", "source"}
