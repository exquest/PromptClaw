+    stream = [
+        (bytes([0x90, 60, 100]), {"playing": True, "timestamp": 100.0}),
+        (None, {"playing": True, "timestamp": 103.0}),
+        (None, {"playing": True, "timestamp": 105.0}),
+        (bytes([0x80, 60, 0]), {"playing": False, "timestamp": 106.0}),
