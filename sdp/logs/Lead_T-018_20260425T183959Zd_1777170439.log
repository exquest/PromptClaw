+def test_capture_phrase_writes_keyboard_phrase_during_active_song(tmp_path: Path) -> None:
+    composer_state = tmp_path / "composer_state.json"
+    composer_state.write_text(
+        json.dumps(
+            {
+                "song": 7,
+                "key": "Dm",
+                "tempo": 96,
+                "updated": 100.0,
