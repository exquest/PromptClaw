+    keyboard_meta = json.loads(payload["keyboard_metadata"])
+    theramini_meta = json.loads(payload["theramini_metadata"])
+    assert keyboard_meta["instrument"] == "midi_keyboard"
+    assert theramini_meta["instrument"] == "theramini"
