+def test_main_prints_human_phrase_capture_ok_and_returns_zero(tmp_path, capsys) -> None:
+    rc = main(["--capture-root", str(tmp_path)])
+    assert rc == 0
+
+    out = capsys.readouterr().out
+    assert "HUMAN_PHRASE_CAPTURE_OK" in out
