+        meta = json.loads(written.with_suffix(".json").read_text())
+        validate_sample_metadata(meta)
+        assert meta["instrument"] == "theramini"
+        assert meta["song_id"] == "tracker-12"
+        assert meta["key"] == "A"
+        assert meta["tempo"] == 88.0

