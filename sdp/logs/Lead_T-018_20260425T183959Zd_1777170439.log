+    def test_capture_phrase_writes_theramini_phrase_during_active_song(self, tmp_path) -> None:
+        composer_state = tmp_path / "composer_state.json"
+        composer_state.write_text(
+            json.dumps(
+                {
+                    "song": "tracker-12",
+                    "key": "A",
+                    "tempo_bpm": 88.0,
+                    "updated": 0.0,
+                }
+            )
+        )
+        capture = ActiveSongPhraseCapture(
+            "theramini",
