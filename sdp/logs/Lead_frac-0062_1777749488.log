+        assert decoded["phases"][2]["sampling"]["source"] == "theramini_in"
+        assert decoded["phases"][2]["mix"]["duck_db"] > 0.0
+
+    def test_cycle_modes_preserve_phase_count_and_valid_ranges(self) -> None:
