    tempo_band: tuple[float, float] = (60.0, 84.0)
    """Inclusive (min, max) tempo in BPM. The composer should pick from
    inside this band."""

    density_bias: float = 0.0
    """Adjustment to global density target. -0.3 = much sparser;
