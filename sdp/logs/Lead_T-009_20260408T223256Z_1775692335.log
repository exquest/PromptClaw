+def _parse_tasks_args(args: list[str]) -> tuple[str | None, int]:
+    limit = 10
+    words: list[str] = []
+    for arg in args:
+        stripped = arg.strip()
+        if not stripped:
+            continue
+        if stripped.isdigit():
+            limit = max(1, min(25, int(stripped)))
+            continue
+        words.append(stripped)
+
+    filter_key = _normalize_task_filter(words)
+    return filter_key, limit
