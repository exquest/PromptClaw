[32m+[m[32mdef _task_icon(task: dict[str, object]) -> str:[m
[32m+[m[32m    if int(task.get("frozen", 0) or 0):[m
[32m+[m[32m        return "🧊"[m
[32m+[m[32m    return {[m
[32m+[m[32m        "running": "🔄",[m
[32m+[m[32m        "pending": "🟡",[m
[32m+[m[32m        "needs_split": "✂️",[m
[32m+[m[32m        "blocked": "⛔",[m
[32m+[m[32m        "needs_review": "⚠️",[m
[32m+[m[32m        "rolled_back": "↩️",[m
[32m+[m[32m        "quarantined": "🚧",[m
[32m+[m[32m        "split": "🪓",[m
[32m+[m[32m        "complete": "✅",[m
[32m+[m[32m    }.get(str(task.get("status", "")), "❓")[m
