[32m+[m[32mdef _task_line(task: dict[str, object], *, show_status: bool = False) -> str:[m
[32m+[m[32m    task_id = str(task.get("task_id", ""))[m
[32m+[m[32m    description = _truncate_summary(str(task.get("description", "") or "Untitled task"), limit=78)[m
[32m+[m[32m    tier = str(task.get("tier", "")).strip()[m
[32m+[m[32m    parent_task_id = str(task.get("parent_task_id", "")).strip()[m
[32m+[m[32m    status = str(task.get("status", "")).strip()[m
[32m+[m[32m    frozen = int(task.get("frozen", 0) or 0) == 1[m
[32m+[m[32m    reason = str(task.get("frozen_reason" if frozen else "status_reason", "")).strip()[m
[32m+[m
[32m+[m[32m    extras: list[str] = [][m
[32m+[m[32m    if tier:[m
[32m+[m[32m        extras.append(tier)[m
[32m+[m[32m    if show_status:[m
[32m+[m[32m        extras.append("frozen" if frozen else status.replace("_", " "))[m
[32m+[m[32m    if parent_task_id:[m
[32m+[m[32m        extras.append(f"child of {parent_task_id}")[m
[32m+[m[32m    if reason:[m
[32m+[m[32m        extras.append(_truncate_summary(reason, limit=54))[m
[32m+[m
[32m+[m[32m    suffix = f" — {' · '.join(extras)}" if extras else ""[m
[32m+[m[32m    return f"{_task_icon(task)} `{task_id}` {description}{suffix}"[m
