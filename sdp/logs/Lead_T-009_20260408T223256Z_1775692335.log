[32m+[m[32mdef format_tasks_status(args: list[str] | None = None) -> str:[m
[32m+[m[32m    """Return an actionable queue-task summary for Telegram."""[m
[32m+[m[32m    args = args or [][m
[32m+[m[32m    if not _queue_db_exists():[m
[32m+[m[32m        return _format_background_tasks_fallback()[m
[32m+[m
[32m+[m[32m    stage_mode, stage_ref, stage_limit = _parse_task_stage_args(args)[m
[32m+[m[32m    if stage_mode is not None:[m
[32m+[m[32m        if stage_ref is None:[m
[32m+[m[32m            if stage_mode == "prd":[m
[32m+[m[32m                return "🧾 Queue Tasks\nUsage: `/tasks prd <stage-number> [limit]`"[m
[32m+[m[32m            return "🧾 Queue Tasks\nUsage: `/tasks stage <stage name> [limit]`"[m
[32m+[m
[32m+[m[32m        resolved = _resolve_stage_reference(stage_ref)[m
[32m+[m[32m        if resolved is None:[m
[32m+[m[32m            if stage_mode == "prd":[m
[32m+[m[32m                return f"🧾 Queue Tasks\nUnknown roadmap stage `{stage_ref}`."[m
[32m+[m[32m            suggestions = _stage_suggestions(str(stage_ref))[m
[32m+[m[32m            if suggestions:[m
[32m+[m[32m                return "🧾 Queue Tasks\nStage not found. Try: " + " · ".join(suggestions)[m
[32m+[m[32m            return f"🧾 Queue Tasks\nStage not found: `{stage_ref}`."[m
[32m+[m
[32m+[m[32m        stage_number, label, batches = resolved[m
[32m+[m[32m        return _format_stage_tasks_status(stage_number, label, batches, stage_limit)[m
[32m+[m
[32m+[m[32m    filter_key, limit = _parse_tasks_args(args)[m
[32m+[m[32m    if args and filter_key is None:[m
[32m+[m[32m        return ([m
[32m+[m[32m            "🧾 Queue Tasks\n"[m
[32m+[m[32m            "Unknown filter. Use `/tasks`, `/tasks pending 10`, `/tasks needs_split`, "[m
[32m+[m[32m            "`/tasks blocked`, `/tasks attention`, `/tasks running`, `/tasks frozen`, or `/tasks all 20`."[m
[32m+[m[32m        )[m
[32m+[m
[32m+[m[32m    if filter_key is None:[m
[32m+[m[32m        counts = _root_queue_counts()[m
[32m+[m[32m        lines = ["🧾 Queue Tasks", _task_summary_line(counts)][m
[32m+[m
[32m+[m[32m        _append_task_section(lines, "Running", _task_rows("running", limit=3, root_only=False))[m
[32m+[m[32m        _append_task_section(lines, "Next Root Tasks", _task_rows("pending", limit=5, root_only=True))[m
[32m+[m[32m        _append_task_section(lines, "Needs Split", _task_rows("needs_split", limit=5, root_only=True))[m
[32m+[m[32m        _append_task_section(lines, "Blocked", _task_rows("blocked", limit=5, root_only=True))[m
[32m+[m[32m        _append_task_section(lines, "Needs Attention", _task_rows("attention", limit=5, root_only=True))[m
[32m+[m
[32m+[m[32m        if counts["frozen"] or counts["skipped"]:[m
[32m+[m[32m            lines.append("")[m
[32m+[m[32m            detail_parts = [][m
[32m+[m[32m            if counts["frozen"]:[m
[32m+[m[32m                detail_parts.append(f"{counts['frozen']} frozen")[m
[32m+[m[32m            if counts["skipped"]:[m
[32m+[m[32m                detail_parts.append(f"{counts['skipped']} decomposed parents")[m
[32m+[m[32m            lines.append("Background: " + " · ".join(detail_parts))[m
[32m+[m
[32m+[m[32m        lines.append("")[m
[32m+[m[32m        lines.append([m
[32m+[m[32m            "Use: `/tasks pending 10` · `/tasks needs_split` · `/tasks blocked` · "[m
[32m+[m[32m            "`/tasks attention` · `/tasks frozen` · `/tasks prd 6` · `/tasks stage clone and home creation`"[m
[32m+[m[32m        )[m
[32m+[m[32m        return "\n".join(lines)[:3500][m
[32m+[m
[32m+[m[32m    label, _, _ = _task_filter_config(filter_key)[m
[32m+[m[32m    total_matches = _task_match_count(filter_key)[m
[32m+[m[32m    tasks = _task_rows(filter_key, limit=limit, root_only=False)[m
[32m+[m[32m    lines = [f"🧾 Tasks · {label}", f"Showing {len(tasks)} of {total_matches}"][m
[32m+[m[32m    if not tasks:[m
[32m+[m[32m        lines.append(f"No {label.lower()} tasks.")[m
[32m+[m[32m    else:[m
[32m+[m[32m        show_status = filter_key == "all"[m
[32m+[m[32m        for task in tasks:[m
[32m+[m[32m            lines.append(_task_line(task, show_status=show_status))[m
[32m+[m[32m    return "\n".join(lines)[:3500][m
