[32m+[m[32mdef _format_stage_tasks_status(stage_number: int, label: str, batches: tuple[str, ...], limit: int) -> str:[m
[32m+[m[32m    batch_rollups = _batch_rollups()[m
[32m+[m[32m    summary = _merge_rollups(batches, batch_rollups)[m
[32m+[m
[32m+[m[32m    lines = [f"🧾 Tasks · PRD {stage_number} · {label}", _task_summary_line(summary)][m
[32m+[m[32m    if batches:[m
