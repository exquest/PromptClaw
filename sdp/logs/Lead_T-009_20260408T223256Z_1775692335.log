[32m+[m[32m    return label, statuses, frozen_only if isinstance(frozen_only, bool) or frozen_only is None else None[m
[32m+[m
[32m+[m
[32m+[m[32mdef _task_batch_clause(batches: tuple[str, ...]) -> tuple[str, list[object]]:[m
[32m+[m[32m    placeholders = ", ".join("?" for _ in batches)[m
[32m+[m[32m    expr = """[m
[32m+[m[32m        substr([m
[32m+[m[32m            CASE[m
[32m+[m[32m                WHEN COALESCE(parent_task_id, '') = '' THEN task_id[m
[32m+[m[32m                ELSE parent_task_id[m
[32m+[m[32m            END,[m
[32m+[m[32m            instr([m
[32m+[m[32m                CASE[m
[32m+[m[32m                    WHEN COALESCE(parent_task_id, '') = '' THEN task_id[m
[32m+[m[32m                    ELSE parent_task_id[m
[32m+[m[32m                END,[m
[32m+[m[32m                '@'[m
[32m+[m[32m            ) + 1[m
[32m+[m[32m        )[m
[32m+[m[32m    """[m
[32m+[m[32m    return f"{expr} IN ({placeholders})", [*batches][m
[32m+[m
[32m+[m
[32m+[m[32mdef _task_match_count([m
[32m+[m[32m    filter_key: str,[m
[32m+[m[32m    *,[m
[32m+[m[32m    root_only: bool = False,[m
[32m+[m[32m    batches: tuple[str, ...] | None = None,[m
[32m+[m[32m) -> int:[m
[32m+[m[32m    db_path = _queue_db_path()[m
[32m+[m[32m    if not db_path.exists():[m
[32m+[m[32m        return 0[m
[32m+[m
[32m+[m[32m    label, statuses, frozen_only = _task_filter_config(filter_key)[m
[32m+[m[32m    del label[m
[32m+[m
[32m+[m[32m    clauses: list[str] = [][m
[32m+[m[32m    params: list[object] = [][m
[32m+[m[32m    if frozen_only is True:[m
[32m+[m[32m        clauses.append("COALESCE(frozen, 0) = 1")[m
[32m+[m[32m    elif frozen_only is False:[m
[32m+[m[32m        clauses.append("COALESCE(frozen, 0) = 0")[m
[32m+[m[32m    if statuses:[m
[32m+[m[32m        placeholders = ", ".join("?" for _ in statuses)[m
[32m+[m[32m        clauses.append(f"status IN ({placeholders})")[m
[32m+[m[32m        params.extend(statuses)[m
[32m+[m[32m    if root_only:[m
[32m+[m[32m        clauses.append("COALESCE(parent_task_id, '') = ''")[m
[32m+[m[32m    if batches:[m
[32m+[m[32m        clause, batch_params = _task_batch_clause(batches)[m
[32m+[m[32m        clauses.append(clause)[m
[32m+[m[32m        params.extend(batch_params)[m
[32m+[m
[32m+[m[32m    where_sql = f"WHERE {' AND '.join(clauses)}" if clauses else ""[m
[32m+[m
[32m+[m[32m    con = sqlite3.connect(db_path)[m
[32m+[m[32m    try:[m
[32m+[m[32m        if not _table_exists(con, "tasks"):[m
[32m+[m[32m            return 0[m
[32m+[m[32m        row = con.execute(f"SELECT COUNT(*) FROM tasks {where_sql}", params).fetchone()[m
[32m+[m[32m    finally:[m
[32m+[m[32m        con.close()[m
[32m+[m
[32m+[m[32m    return int(row[0] or 0) if row is not None else 0[m
[32m+[m
[32m+[m
[32m+[m[32mdef _task_rows([m
[32m+[m[32m    filter_key: str,[m
[32m+[m[32m    *,[m
[32m+[m[32m    limit: int,[m
[32m+[m[32m    root_only: bool = False,[m
[32m+[m[32m    batches: tuple[str, ...] | None = None,[m
[32m+[m[32m) -> list[dict[str, object]]:[m
[32m+[m[32m    db_path = _queue_db_path()[m
[32m+[m[32m    if not db_path.exists():[m
[32m+[m[32m        return [][m
[32m+[m
[32m+[m[32m    _, statuses, frozen_only = _task_filter_config(filter_key)[m
[32m+[m[32m    clauses: list[str] = [][m
[32m+[m[32m    params: list[object] = [][m
[32m+[m[32m    if frozen_only is True:[m
[32m+[m[32m        clauses.append("COALESCE(frozen, 0) = 1")[m
[32m+[m[32m    elif frozen_only is False:[m
[32m+[m[32m        clauses.append("COALESCE(frozen, 0) = 0")[m
[32m+[m[32m    if statuses:[m
[32m+[m[32m        placeholders = ", ".join("?" for _ in statuses)[m
[32m+[m[32m        clauses.append(f"status IN ({placeholders})")[m
[32m+[m[32m        params.extend(statuses)[m
[32m+[m[32m    if root_only:[m
[32m+[m[32m        clauses.append("COALESCE(parent_task_id, '') = ''")[m
[32m+[m[32m    if batches:[m
[32m+[m[32m        clause, batch_params = _task_batch_clause(batches)[m
[32m+[m[32m        clauses.append(clause)[m
[32m+[m[32m        params.extend(batch_params)[m
[32m+[m[32m    where_sql = f"WHERE {' AND '.join(clauses)}" if clauses else ""[m
[32m+[m
[32m+[m[32m    order_sql = "ORDER BY updated_at DESC, created_at DESC, task_id ASC"[m
[32m+[m[32m    if frozen_only is True:[m
[32m+[m[32m        order_sql = "ORDER BY COALESCE(frozen_at, '') DESC, updated_at DESC, task_id ASC"[m
[32m+[m[32m    elif statuses == ("pending",):[m
[32m+[m[32m        order_sql = "ORDER BY priority DESC, created_at ASC, task_id ASC"[m
[32m+[m[32m    elif statuses == ("needs_split",):[m
[32m+[m[32m        order_sql = "ORDER BY priority DESC, updated_at DESC, task_id ASC"[m
[32m+[m
[32m+[m[32m    con = sqlite3.connect(db_path)[m
[32m+[m[32m    con.row_factory = sqlite3.Row[m
[32m+[m[32m    try:[m
[32m+[m[32m        if not _table_exists(con, "tasks"):[m
[32m+[m[32m            return [][m
[32m+[m[32m        rows = con.execute([m
[32m+[m[32m            f"""[m
[32m+[m[32m            SELECT[m
[32m+[m[32m                task_id,[m
[32m+[m[32m                COALESCE(description, '') AS description,[m
[32m+[m[32m                COALESCE(tier, '') AS tier,[m
[32m+[m[32m                COALESCE(status, '') AS status,[m
[32m+[m[32m                COALESCE(priority, 0) AS priority,[m
[32m+[m[32m                COALESCE(parent_task_id, '') AS parent_task_id,[m
[32m+[m[32m                COALESCE(status_reason, '') AS status_reason,[m
[32m+[m[32m                COALESCE(frozen, 0) AS frozen,[m
[32m+[m[32m                COALESCE(frozen_reason, '') AS frozen_reason,[m
[32m+[m[32m                COALESCE(created_at, '') AS created_at,[m
[32m+[m[32m                COALESCE(updated_at, '') AS updated_at[m
[32m+[m[32m            FROM tasks[m
[32m+[m[32m            {where_sql}[m
[32m+[m[32m            {order_sql}[m
[32m+[m[32m            LIMIT ?[m
[32m+[m[32m            """,[m
[32m+[m[32m            [*params, limit],[m
[32m+[m[32m        ).fetchall()[m
[32m+[m[32m    finally:[m
[32m+[m[32m        con.close()[m
[32m+[m
[32m+[m[32m    return [dict(row) for row in rows][m
[32m+[m
