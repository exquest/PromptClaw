[32m+[m
[32m+[m[32m    _append_task_section(lines, "Running", _task_rows("running", limit=min(limit, 3), batches=batches))[m
[32m+[m[32m    _append_task_section(lines, "Next Root Tasks", _task_rows("pending", limit=limit, root_only=True, batches=batches))[m
[32m+[m[32m    _append_task_section(lines, "Needs Split", _task_rows("needs_split", limit=limit, root_only=True, batches=batches))[m
[32m+[m[32m    _append_task_section(lines, "Blocked", _task_rows("blocked", limit=limit, root_only=True, batches=batches))[m
[32m+[m[32m    _append_task_section(lines, "Needs Attention", _task_rows("attention", limit=limit, root_only=True, batches=batches))[m
[32m+[m
[32m+[m[32m    background_parts = [][m
[32m+[m[32m    if summary.get("frozen", 0):[m
[32m+[m[32m        background_parts.append(f"{summary['frozen']} frozen")[m
[32m+[m[32m    if summary.get("skipped", 0):[m
[32m+[m[32m        background_parts.append(f"{summary['skipped']} decomposed parents")[m
[32m+[m[32m    if background_parts:[m
[32m+[m[32m        lines.append("")[m
[32m+[m[32m        lines.append("Background: " + " · ".join(background_parts))[m
[32m+[m
[32m+[m[32m    if len(lines) <= 3:[m
[32m+[m[32m        lines.append("No tasks loaded for this roadmap stage.")[m
[32m+[m
[32m+[m[32m    lines.append("")[m
[32m+[m[32m    lines.append([m
[32m+[m[32m        f"Use: `/tasks prd {stage_number} {limit}` · "[m
[32m+[m[32m        f"`/tasks stage {label.lower()} {limit}`"[m
[32m+[m[32m    )[m
[32m+[m[32m    return "\n".join(lines)[:3500][m
