 """Tests for audio_analysis.py — pure functions, synthetic signals."""
 from __future__ import annotations
 
+import json
 import math
 import sys
 import os
@@ -13,6 +14,7 @@
     detect_onset,
     detect_pitch_autocorrelation,
     classify_audio_content,
