+                "rms": rms,
+                "peak": peak,
+                "pitch_hz": freq,
+                "pitch_confidence": confidence,
+                "note": pitch_to_note_name(freq or 0.0),
+                "root": root,
+                "scale": scale,
+                "content": classify_audio_content(samples, 44100),
