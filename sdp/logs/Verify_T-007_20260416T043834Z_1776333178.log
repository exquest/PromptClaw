                "sample_rate": sample_rate,
                "mono": [],
                "rms": 0.0,
                "peak": 0.0,
                "pitch_hz": 0.0,
                "pitch_confidence": 0.0,
            }

        norm = [sample / 32768.0 for sample in mono]
        rms = math.sqrt(sum(sample * sample for sample in norm) / len(norm))
        peak = max(abs(sample) for sample in norm)
