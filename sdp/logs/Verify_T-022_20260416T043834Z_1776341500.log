+_SUSTAINED = set()  # nothing sustained — everything is fire-and-forget
+_PERCUSSIVE = {"pluck", "kotekan", "gong", "bell", "bowed", "choir", "breath", "pad", "metal", "grain", "tabla_ge", "tabla_tin"}  # ALL fire-and-forget
