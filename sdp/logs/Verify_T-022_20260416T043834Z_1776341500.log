++class TestScheduleScene:
++    def test_emits_events_and_sleep_intervals(self, tmp_path):
++        scene = _sample_scene()
++        scene.metadata["payoff_focus"] = "primary"
++        scene.metadata["section_function"] = "arrival"
++        scene.metadata["text_hook"] = "answer the room"
