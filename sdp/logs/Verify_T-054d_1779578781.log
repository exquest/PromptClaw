+import { SELF } from "cloudflare:test";
+import { expect, test } from "vitest";
+
+const LIVE_MIDI_URL = "https://cypherclaw.holdenu.com/api/cypherclaw/live-midi";
+const FAN_OUT_TIMEOUT_MS = 1000;
+
+type WebSocketUpgradeResponse = Response & {
+    webSocket?: WebSocket | null;
+};
+
+type ReceivedMessage = {
+    data: unknown;
+    receivedAtMs: number;
+};
+
+async function connectLiveMidiClient(): Promise<WebSocket> {
+    const response = await SELF.fetch(LIVE_MIDI_URL, {
+        method: "GET",
+        headers: { Upgrade: "websocket" },
+    }) as WebSocketUpgradeResponse;
+
+    expect(response.status).toBe(101);
+    expect(response.webSocket).toBeDefined();
+
+    const socket = response.webSocket;
+    if (socket === undefined || socket === null) {
+        throw new Error("live MIDI route did not return a WebSocket");
+    }
+
+    socket.accept();
+    return socket;
+}
+
+function waitForMessage(socket: WebSocket, timeoutMs: number): Promise<ReceivedMessage> {
+    return new Promise((resolve, reject) => {
+        let timeoutId: number | undefined;
+
+        const cleanup = (): void => {
+            if (timeoutId !== undefined) {
+                clearTimeout(timeoutId);
+            }
+            socket.removeEventListener("message", onMessage);
+            socket.removeEventListener("close", onClose);
+            socket.removeEventListener("error", onError);
+        };
+
+        const onMessage = (event: MessageEvent): void => {
+            cleanup();
+            resolve({
+                data: event.data,
+                receivedAtMs: performance.now(),
+            });
+        };
+
+        const onClose = (): void => {
+            cleanup();
+            reject(new Error("live MIDI client closed before receiving fan-out"));
+        };
+
+        const onError = (): void => {
+            cleanup();
+            reject(new Error("live MIDI client errored before receiving fan-out"));
+        };
+
+        timeoutId = setTimeout(() => {
+            cleanup();
+            reject(new Error(`live MIDI fan-out exceeded ${timeoutMs}ms`));
+        }, timeoutMs);
+
+        socket.addEventListener("message", onMessage);
+        socket.addEventListener("close", onClose);
+        socket.addEventListener("error", onError);
+    });
+}
+
+function closeClient(socket: WebSocket | undefined): void {
+    try {
+        socket?.close(1000, "test complete");
+    } catch (_error) {
+        // The test assertion is the fan-out latency; cleanup should not mask it.
+    }
+}
+
+test("fans out a live MIDI event from client A to client B within 1000ms", async () => {
+    let clientA: WebSocket | undefined;
+    let clientB: WebSocket | undefined;
+
+    try {
+        clientA = await connectLiveMidiClient();
+        clientB = await connectLiveMidiClient();
+
+        const noteOn = JSON.stringify({
+            status: 144,
+            data1: 60,
+            data2: 100,
+            ts: 1779571159.25,
+        });
+        const receivedByB = waitForMessage(clientB, FAN_OUT_TIMEOUT_MS);
+        const sentAtMs = performance.now();
+
+        clientA.send(noteOn);
+
+        const received = await receivedByB;
+        const fanOutLatencyMs = received.receivedAtMs - sentAtMs;
+
+        expect(received.data).toBe(noteOn);
+        expect(fanOutLatencyMs).toBeLessThan(FAN_OUT_TIMEOUT_MS);
+    } finally {
+        closeClient(clientA);
+        closeClient(clientB);
+    }
+});
+
