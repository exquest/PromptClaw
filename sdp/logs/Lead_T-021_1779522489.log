+    """Return elapsed seconds for a span that may cross modulation rows."""
+
+    if length_rows <= 0:
+        return 0.0
+    row_durations = metric_modulated_row_durations_seconds(scene)
+    start = max(0, int(start_row))
+    end = min(len(row_durations), start + int(length_rows))
