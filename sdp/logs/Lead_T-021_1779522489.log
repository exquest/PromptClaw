+@dataclass(frozen=True)
+class MetricModulation:
+    """Duration-ratio change that applies from one tracker row onward."""
+
+    at_row: int
+    ratio_num: int
+    ratio_den: int
+
+
 @dataclass
 class TrackerPattern:
