+    """Return elapsed start time for each tracker row in *scene*."""
+
+    starts: list[float] = []
+    elapsed = 0.0
+    for row_duration in metric_modulated_row_durations_seconds(scene):
+        starts.append(elapsed)
+        elapsed += row_duration
+    return starts
+
+
+def metric_modulated_duration_seconds(
+    scene: TrackerScene,
+    *,
+    start_row: int,
+    length_rows: int,
