 DEFAULT_PHRASE_THRESHOLD_SECONDS = 5.0
+_MILLISECOND = Decimal("0.001")
 
 
+@dataclass(frozen=True)
+class PhraseBoundary:
+    """One phrase boundary emitted while scanning a listener tick stream."""
