+    )
+    if completed_durations:
+        total_phrase_seconds = sum(completed_durations)
+        longest_phrase_seconds = max(completed_durations)
+    else:
+        total_phrase_seconds = 0.0
+        longest_phrase_seconds = 0.0
+    return PhraseStreamSummary(
