\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"section_intent\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_repertoire_hint_biases_songwriter_metadata(self):\\\\\\\\\\\\\\\\n++        score = score_from_mood(\\\\\\\\\\\\\\\\n++            {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.58, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"valence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.64, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arousal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.52},\\\\\\\\\\\\\\\\n++            song_num=10,\\\\\\\\\\\\\\\\n++            family=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ember\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            cadence_state=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"occupied_day\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            patch_name=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_chamber\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            progression_profile=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lift\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            repertoire_hint={\\\\\\\\\\\\\\\\n++                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"source_title\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Quiet Machines\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hook_text\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hold the light\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"hook_class\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"contour\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"progression_profile\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"open_day\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mode\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"answer\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            },\\\\\\\\\\\\\\\\n++        )\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert score.metadata[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"song_title\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] != \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Quiet Machines\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        assert score.metadata[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"text_hook\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] != \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        assert score.metadata[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"repertoire_source_title\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Quiet Machines\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n+ \\\\\\\\\\\\\\\\n+ # === generate_bass_line ===\\\\\\\\\\\\\\\\n+ \\\\\\\\\\\\\\\\n+@@ -190,14 +345,17 @@ class TestGenerateBassLine:\\\\\\\\\\\\\\\\n+             assert note.scale_degree == root_deg\\\\\\\\\\\\\\\\n+ \\\\\\\\\\\\\\\\n+     def test_weak_beats_are_chord_tones(self):\\\\\\\\\\\\\\\\n+-        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Weak-beat notes should be 3rd or 5th above root (or root).\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Weak-beat notes should stay on low chord tones for the current harmony.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+         prog = [1, 4, 5, 1]\\\\\\\\\\\\\\\\n+         p = generate_bass_line(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", prog, beats_per_chord=3)\\\\\\\\\\\\\\\\n+         for i, root_deg in enumerate(prog):\\\\\\\\\\\\\\\\n+             for j in range(1, 3):\\\\\\\\\\\\\\\\n+                 note = p.notes[i * 3 + j]\\\\\\\\\\\\\\\\n+-                # The bass weak-beat degrees