def test_parse_args_and_main_wire_faithful_transmission_flag(
    tmp_path: Path,
    monkeypatch,
) -> None:
    args = mod.parse_args(["--faithful-transmission"])
    assert args.faithful_transmission is True

    call_order: list[str] = []
