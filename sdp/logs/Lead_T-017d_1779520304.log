\\\\\\\\\\\\\\"house_garden\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", theramini_present=False)\\\\\\\\\\\\\\\\n++    with_theramini = build_mix_profile(cadence_state=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"occupied_day\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", patch_name=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_garden\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", theramini_present=True)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    assert with_theramini.theramini_duck_db > without.theramini_duck_db\\\\\\\\\\\\\\\\n+diff --git a/tests/test_music_tracker_runtime.py b/tests/test_music_tracker_runtime.py\\\\\\\\\\\\\\\\n+new file mode 100644\\\\\\\\\\\\\\\\n+index 0000000..27a7dc2\\\\\\\\\\\\\\\\n+--- /dev/null\\\\\\\\\\\\\\\\n++++ b/tests/test_music_tracker_runtime.py\\\\\\\\\\\\\\\\n+@@ -0,0 +1,311 @@\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Tests for tracker runtime scheduling and row-state emission.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++from __future__ import annotations\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++import json\\\\\\\\\\\\\\\\n++import os\\\\\\\\\\\\\\\\n++import sys\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++sys.path.insert(0, os.path.join(os.path.dirname(__file__), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"..\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"my-claw\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tools\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n++sys.path.insert(0, os.path.join(os.path.dirname(__file__), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"..\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"my-claw\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tools\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"senseweave\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++from senseweave.generative_scores import Note, Phrase, Score\\\\\\\\\\\\\\\\n++from senseweave.music_tracker import AutomationLane, TrackerSong, build_scene_from_score\\\\\\\\\\\\\\\\n++from senseweave.music_tracker_runtime import (\\\\\\\\\\\\\\\\n++    _tmp_state_path,\\\\\\\\\\\\\\\\n++    build_scene_events,\\\\\\\\\\\\\\\\n++    schedule_scene,\\\\\\\\\\\\\\\\n++    schedule_song,\\\\\\\\\\\\\\\\n++)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def _sample_scene():\\\\\\\\\\\\\\\\n++    score = Score(\\\\\\\\\\\\\\\\n++        phrases=[\\\\\\\\\\\\\\\\n++            Phrase(\\\\\\\\\\\\\\\\n++                notes=[Note(1, 1.0, False), Note(3, 0.5, True), Note(5, 1.5, False)],\\\\\\\\\\\\\\\\n++                voice=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pluck\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                dynamic=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mf\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                role=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            ),\\\\\\\\\\\\\\\\n++            Phrase(\\\\\\\\\\\\\\\\n++                notes=[Note(1, 1.0, True), Note(5, 1.0, False), Note(1, 1.0, False)],\\\\\\\\\\\\\\\\n++                voice=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"gong\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                dynamic=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                role=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bass\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            ),\\\\\\\\\\\\\\\\n++            Phrase(\\\\\\\\\\\\\\\\n++                notes=[Note(1, 2.0, False), Note(3, 2.0, False)],\\\\\\\\\\\\\\\\n++                voice=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pad\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                dynamic=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                role=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            ),\\\\\\\\\\\\\\\\n++        ],\\\\\\\\\\\\\\\\n++        key=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        tempo_bpm=120.0,\\\\\\\\\\\\\\\\n++        mood=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"calm\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        created_at=0.0,\\\\\\\\\\\\\\\\n++    )\\\\\\\\\\\\\\\\n++    return build_scene_from_score(\\\\\\\\\\\\\\\\n++        score,\\\\\\\\\\\\\\\\n++        name=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Theme\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        allowed_roles=(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bass\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"),\\\\\\\\\\\\\\\\n++        rows_per_beat=4,\\\\\\\\\\\\\\\\n++        max_polyphony=3,\\\\\\\\\\\\\\\\n++    )\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++class TestBuildSceneEvents:\\\\\\\\\\\\\\\\n++    def test_builds_sorted_events_with_routed_voices(self):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        events = build_scene_events(scene)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert [event.row for event in events] == sorted(event.row for event in events)\\\\\\\\\\\\\\\\n++        assert events[0].scene_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Theme\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        assert events[0].lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        assert any(event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"foundation\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.voice == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"gong\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" for event in events)\\\\\\\\\\\\\\\\n++        assert any(event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.voice == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"breath\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" for event in events)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_duration_seconds_follow_row_length(self):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        events = build_scene_events(scene)\\\\\\\\\\\\\\\\n++        melody = next(event for event in events if event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\\\\\\\\\n++        assert round(melody.duration_seconds, 3) == 0.5\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_preserves_extended_lane_voices_except_pad_safety_fallback(self):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        scene.pattern.lanes[1].voice = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tabla_ge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        scene.pattern.lanes[2].voice = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pad\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        events = build_scene_events(scene)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert any(event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"foundation\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.voice == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tabla_ge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" for event in events)\\\\\\\\\\\\\\\\n++        assert any(event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.voice == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"breath\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" for event in events)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_quarantines_grain_texture_voice_to_breath(self):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        scene.pattern.lanes[2].voice = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"grain\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        events = build_scene_events(scene)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert any(event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.voice == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"breath\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" for event in events)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_preserves_non_quarantined_extended_texture_voices(self):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        scene.pattern.lanes[2].voice = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"choir\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        events = build_scene_events(scene)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert any(event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.voice == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"choir\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" for event in events)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_spreads_roles_across_a_wider_register_band(self):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        events = build_scene_events(scene)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        bass = next(event for event in events if event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"foundation\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\\\\\\\\\n++        melody = next(event for event in events if event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\\\\\\\\\n++        texture = next(event for event in events if event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert bass.frequency_hz < (melody.frequency_hz / 2.5)\\\\\\\\\\\\\\\\n++        assert texture.frequency_hz > (melody.frequency_hz * 2.5)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_patch_metadata_changes_live_register_profile(self):\\\\\\\\\\\\\\\\n++        monastery = _sample_scene()\\\\\\\\\\\\\\\\n++        monastery.metadata[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_monastery\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        procession = _sample_scene()\\\\\\\\\\\\\\\\n++        procession.metadata[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_procession\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        monastery_events = build_scene_events(monastery)\\\\\\\\\\\\\\\\n++        procession_events = build_scene_events(procession)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        monastery_melody = next(event for event in monastery_events if event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\\\\\\\\\n++        procession_melody = next(event for event in procession_events if event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\\\\\\\\\n++        monastery_texture = next(event for event in monastery_events if event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\\\\\\\\\n++        procession_texture = next(event for event in procession_events if event.lane_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"texture\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and event.row == 0)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert monastery_melody.frequency_hz < procession_melody.frequency_hz\\\\\\\\\\\\\\\\n++        assert monastery_texture.frequency_hz <= procession_texture.frequency_hz\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_keeps_primary_roles_above_live_audibility_floor(self):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        events = build_scene_events(scene)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        melody_peak = max(event.amplitude for event in events if event.role == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++        bass_peak = max(event.amplitude for event in events if event.role == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bass\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++        color_peak = max(event.amplitude for event in events if event.role == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert melody_peak >= 0.14\\\\\\\\\\\\\\\\n++        assert bass_peak >= 0.12\\\\\\\\\\\\\\\\n++        assert color_peak >= 0.02\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++class TestRuntimeStatePaths:\\\\\\\\\\\\\\\\n++    def test_tmp_state_path_is_unique_per_call(self, tmp_path):\\\\\\\\\\\\\\\\n++        target = tmp_path / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        first = _tmp_state_path(target)\\\\\\\\\\\\\\\\n++        second = _tmp_state_path(target)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert first != second\\\\\\\\\\\\\\\\n++        assert first.parent == target.parent\\\\\\\\\\\\\\\\n++        assert second.parent == target.parent\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++class TestScheduleScene:\\\\\\\\\\\\\\\\n++    def test_emits_events_and_sleep_intervals(self, tmp_path):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        scene.metadata[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"payoff_focus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"primary\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        scene.metadata[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"section_function\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arrival\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        scene.metadata[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"text_hook\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"answer the room\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        played = []\\\\\\\\\\\\\\\\n++        slept = []\\\\\\\\\\\\\\\\n++        state_path = tmp_path / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        result = schedule_scene(\\\\\\\\\\\\\\\\n++            scene,\\\\\\\\\\\\\\\\n++            play_event=played.append,\\\\\\\\\\\\\\\\n++            sleep_fn=slept.append,\\\\\\\\\\\\\\\\n++            stop_check=lambda row: False,\\\\\\\\\\\\\\\\n++            state_path=state_path,\\\\\\\\\\\\\\\\n++            time_fn=lambda: 1000.0,\\\\\\\\\\\\\\\\n++            song_title=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Test Song\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        )\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert result.completed is True\\\\\\\\\\\\\\\\n++        assert result.rows_processed == scene.pattern.rows\\\\\\\\\\\\\\\\n++        assert result.events_emitted == len(played) == len(build_scene_events(scene))\\\\\\\\\\\\\\\\n++        assert len(slept) == scene.pattern.rows - 1\\\\\\\\\\\\\\\\n++        assert all(round(seconds, 3) == 0.125 for seconds in slept)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        runtime_state = json.loads(state_path.read_text())\\\\\\\\\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"song_title\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Test Song\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"scene_name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Theme\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"row\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == scene.pattern.rows - 1\\\\\\\\\\\\\\\\n++        assert \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"active_lanes\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in runtime_state\\\\\\\\\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"scene_metadata\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"payoff_focus\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"primary\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"scene_metadata\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"section_function\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arrival\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        assert runtime_state[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"scene_metadata\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"text_hook\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"answer the room\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_can_abort_mid_scene(self, tmp_path):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        played = []\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        result = schedule_scene(\\\\\\\\\\\\\\\\n++            scene,\\\\\\\\\\\\\\\\n++            play_event=played.append,\\\\\\\\\\\\\\\\n++            sleep_fn=lambda _seconds: None,\\\\\\\\\\\\\\\\n++            stop_check=lambda row: row >= 4,\\\\\\\\\\\\\\\\n++            state_path=tmp_path / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tracker_state.json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++            time_fn=lambda: 2000.0,\\\\\\\\\\\\\\\\n++        )\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++        assert result.completed is False\\\\\\\\\\\\\\\\n++        assert result.rows_processed == 4\\\\\\\\\\\\\\\\n++        assert all(event.row < 4 for event in played)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def test_runtime_state_exposes_interpolated_automation(self, tmp_path):\\\\\\\\\\\\\\\\n++        scene = _sample_scene()\\\\\\\\\\\\\\\\n++        scene.pattern.automation = [\\\\\\\\\\\\\\\\n++            AutomationLane(\\\\\\\\\\\\\\\\n++                name=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"density\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                default=0.4,\\\\\\\\\\\\\\\\n++                points=[(0, 0.2), (scene.pattern.rows - 1, 0.8)],\\\\\\\\\\\\\\\\n++            )