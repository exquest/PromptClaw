+    con = sqlite3.connect(db_path)
+    try:
+        if not _table_exists(con, "tasks") or not _table_exists(con, "task_runs"):
+            return {"running_without_open": 0, "stale_open_runs": 0, "duplicate_open_runs": 0}
+        row = con.execute(
