+                "healthy": False,
+                "status": "unreachable",
+                "models": [],
+                "latency_ms": None,
+            },
+        ],
+    }
+
+
+def _status_snapshot() -> dict[str, object]:
+    return {
+        "memory": 3,
+        "tasks": 1,
+        "schedules": 2,
+        "artifacts": 4,
