    lanes: list[TrackerLane],
    *,
    meter: str = "4/4",
    name: str = "fixture",
    rows: int = 16,
) -> TrackerScene:
    return TrackerScene(
        name=name,
        key="C",
        tempo_bpm=120.0,
        rows_per_beat=4,
        pattern=TrackerPattern(rows=rows, lanes=lanes),
        constraints=SceneConstraint(max_polyphony=1, allowed_roles=("melody",)),
        metadata={"groove_meter": meter},
    )


