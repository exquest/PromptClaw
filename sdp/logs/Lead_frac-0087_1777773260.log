        for row in range(count)
    ]


def _lane(
    role: str,
    *,
    name: str | None = None,
    steps: list[TrackerStep] | None = None,
    metadata: dict[str, str] | None = None,
) -> TrackerLane:
    return TrackerLane(
        name=name or role,
        role=role,
        voice="pluck",
        steps=steps or _steps(),
        metadata=metadata or {},
    )


