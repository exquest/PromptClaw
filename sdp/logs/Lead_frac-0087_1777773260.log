+                )
+            ],
+            name="scene_b",
+        )
+        song = TrackerSong(title="lung_capacity_song", scenes=[scene_a, scene_b])
+
+        rendered, report = analyze_lung_capacity(song, rule=LungCapacityRule())
+
+        assert isinstance(rendered, TrackerSong)
