+        insert_lane = _lane(
+            "wind_insert",
+            [
+                _step(0, 4, phrase_id="p1"),
+                _step(4, 3, phrase_id="p2"),
+            ],
+            voice="breath",
+        )
+        tag_lane = _lane(
