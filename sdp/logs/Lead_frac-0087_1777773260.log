+
+def _multi_lane_scene(lanes: list[TrackerLane], *, name: str = "fixture") -> TrackerScene:
+    return TrackerScene(
+        name=name,
+        key="C",
+        tempo_bpm=60.0,
+        rows_per_beat=1,
+        pattern=TrackerPattern(rows=32, lanes=lanes),
+        constraints=SceneConstraint(max_polyphony=1, allowed_roles=("color",)),
