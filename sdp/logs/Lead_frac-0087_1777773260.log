+        assert len(report.lane_stats) == 3
+
+        inserted_breath = rendered.pattern.lanes[0].steps[2]
+        assert inserted_breath.row == 7
+        assert inserted_breath.velocity == 0.0
+        assert inserted_breath.metadata == {
