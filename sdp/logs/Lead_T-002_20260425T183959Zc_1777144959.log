+        self, scd_source: str
+    ) -> None:
+        assert re.search(
+            r"SelectX\.ar\(\s*fzAmt\s*,\s*\[\s*postVerb\s*,\s*freezeChain\s*\]\s*\)",
+            scd_source,
+        ), (
+            "freeze_amount should remain the wet/dry mix control after the "
+            "binary PV_Freeze gate is derived from it"
+        )
+
