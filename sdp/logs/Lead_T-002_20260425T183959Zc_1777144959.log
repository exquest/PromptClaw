   208	class TestReverbBranchSelection:
   209	    """Reverb stage must support both convolution and FreeVerb paths."""
   210	
   211	    def test_ir_bufnum_arg_defaults_to_no_ir_sentinel(
   212	        self, scd_source: str
   213	    ) -> None:
   214	        block = _arg_block(scd_source)
   215	        # A negative default signals "no IR loaded" — BufFrames.kr returns 0
   216	        # for an unallocated/invalid bufnum, so this gates the conv branch off.
   217	        assert _arg_default(block, "ir_bufnum") < 0, (
   218	            "ir_bufnum must default to a sentinel (<0) so the FreeVerb fallback "
   219	            "is the active branch when no IR buffer has been loaded"
   220	        )
   221	
   222	    def test_ir_presence_check_uses_bufframes(self, scd_source: str) -> None:
   223	        # The presence check must read live buffer state so a runtime-loaded
   224	        # IR can flip the branch without recompiling the SynthDef.
   225	        assert re.search(
   226	            r"BufFrames\.(?:kr|ir)\(\s*ir_bufnum\s*\)", scd_source
   227	        ), (
   228	            "IR presence must be detected via BufFrames(ir_bufnum) so the "
   229	            "branch selector reflects whether a buffer has actually been loaded"
   230	        )
   231	
   232	    def test_partconv_uses_guarded_bufnum(self, scd_source: str) -> None:
   233	        # PartConv must not be fed the raw `ir_bufnum` arg — when ir_bufnum=-1
   234	        # it would read from an invalid buffer. A guard (Select.kr or similar)
   235	        # routes a safe sentinel buffer when no IR is loaded.
   236	        assert re.search(
   237	            r"PartConv\.ar\(\s*[A-Za-z_]\w*\s*,\s*[A-Za-z_]\w*\s*,\s*"
   238	            r"(?!ir_bufnum\b)[A-Za-z_]\w*",
   239	            scd_source,
   240	        ), (
   241	            "PartConv must read from a guarded bufnum (not the raw ir_bufnum) "
   242	            "so an unallocated default doesn't drive the convolution UGen"
   243	        )
   244	
   245	    def test_branch_selector_keyed_on_ir_presence(self, scd_source: str) -> None:
   246	        # The branch selector must take the IR-presence flag, with FreeVerb at
   247	        # index 0 (no IR) and PartConv at index 1 (IR loaded). We check that
   248	        # both UGens appear inside a single SelectX/Select array AND that the
   249	        # presence flag is the selector input.
   250	        match = re.search(
   251	            r"(?:SelectX|Select)\.ar\(\s*([A-Za-z_]\w*)\s*,\s*\[([^\]]+)\]",
   252	            scd_source,
   253	        )
   254	        assert match, (
   255	            "reverb branches must be combined via SelectX.ar/Select.ar so the "
   256	            "IR-presence flag picks between FreeVerb and PartConv at runtime"
   257	        )
   258	        selector_var, branch_array = match.group(1), match.group(2)
   259	        # The selector variable must trace back to the BufFrames(ir_bufnum)
   260	        # comparison — i.e. the variable is assigned from a BufFrames > 0 expr.
   261	        selector_assignment = re.search(
   262	            rf"\b{re.escape(selector_var)}\s*=\s*BufFrames\.(?:kr|ir)"
   263	            rf"\(\s*ir_bufnum\s*\)\s*>\s*0",
   264	            scd_source,
   265	        )
   266	        assert selector_assignment, (
   267	            f"branch selector {selector_var!r} must be assigned from "
   268	            "BufFrames(ir_bufnum) > 0 so the IR-presence check drives selection"
   269	        )
   270	        # Both branches must be referenced in the SelectX array. The names
   271	        # are vars that point to FreeVerb / PartConv signals respectively.
   272	        branch_names = [tok.strip() for tok in branch_array.split(",")]
   273	        assert len(branch_names) == 2, (
   274	            "reverb selector array must contain exactly two branches "
   275	            "(fallback, convolution)"
   276	        )
   277	        fallback_var, conv_var = branch_names
   278	        # Confirm fallback_var holds FreeVerb output and conv_var holds PartConv.
   279	        fallback_assigned = re.search(
   280	            rf"\b{re.escape(fallback_var)}\s*=\s*FreeVerb\.ar", scd_source
   281	        )
   282	        conv_assigned = re.search(
   283	            rf"\b{re.escape(conv_var)}\s*=\s*PartConv\.ar", scd_source
   284	        )
   285	        assert fallback_assigned, (
   286	            f"first branch {fallback_var!r} must be assigned from FreeVerb.ar "
   287	            "so the no-IR path is the fallback at selector index 0"
   288	        )
   289	        assert conv_assigned, (
   290	            f"second branch {conv_var!r} must be assigned from PartConv.ar "
   291	            "so the IR-loaded path is the convolution branch at selector index 1"
   292	        )
