   295	class TestStageOrdering:
   296	    """The chain must run delay → reverb → freeze → comb (per the spec)."""
   297	
   298	    def test_chain_ordering(self, scd_source: str) -> None:
   299	        # Strip line comments before checking ordering, so doc-block markers
   300	        # don't confuse the search.
   301	        code = "\n".join(
   302	            line.split("//", 1)[0] for line in scd_source.splitlines()
   303	        )
   304	        order_patterns = [
   305	            ("DelayC.ar",   r"\bDelayC\.ar"),
   306	            ("FreeVerb.ar", r"\bFreeVerb\.ar"),
   307	            ("PV_Freeze",   r"\bPV_Freeze\b"),
   308	            ("CombC.ar",    r"\bCombC\.ar"),
   309	            ("Out.ar",      r"(?<!Local)\bOut\.ar"),
   310	        ]
   311	        positions = {}
   312	        for label, pattern in order_patterns:
   313	            match = re.search(pattern, code)
   314	            assert match, f"missing stage marker: {label}"
   315	            positions[label] = match.start()
   316	        ordered = list(positions.values())
   317	        assert ordered == sorted(ordered), (
   318	            f"stages out of order: {positions}"
   319	        )
