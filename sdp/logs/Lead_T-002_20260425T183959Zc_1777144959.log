// test_sampler_effects.scd — SC-side smoke test for sw_sampler_fx.
//
// Runs on cypherclaw (where sclang/scsynth are installed). Verifies:
//   (a) The SynthDef loads.
//   (b) An impulse applied to in_bus produces non-silent output on out_bus.
//   (c) When comb_b_amount > 0, the output spectrum has a peak at 61.74 Hz.
//
// Usage (from the my-claw repo root):
//   sclang my-claw/supercollider/test_sampler_effects.scd
//
// Exit codes / output:
//   - All assertions print "PASS …" lines on success.
//   - Any failure prints "FAIL …" with diagnostics; non-zero exit via 1.exit.

(
~sampleRate  = 48000;
~combPeakHz  = 61.74;
~peakTolHz   = 1.0;     // allow ±1 Hz drift from comb tuning
~impulseAmp  = 0.5;
~renderDur   = 2.0;     // seconds
~loadDir     = "../tools/senseweave/synthesis/synthdefs/";

~assert = { |cond, label|
    if (cond) {
        ("PASS " ++ label).postln;
    } {
        ("FAIL " ++ label).postln;
        1.exit;
    };
};

// --- (a) Load the compiled SynthDef -------------------------------------
~defPath = ~loadDir ++ "sw_sampler_fx.scsyndef";
~assert.(File.exists(~defPath), "compiled scsyndef present: " ++ ~defPath);

s.waitForBoot {
    var inBus, outBus, recBuf, impulseSyn, fxSyn, recSyn;
    var samples, peak, rms;
    var fftSize = 16384;
    var fftBuf, freqBin, expectedBin;

    SynthDef(\test_impulse_in, { |out = 16, amp = 0.5|
        // One-sample impulse on both channels.
        var trig = Impulse.ar(0);
        Out.ar(out, [trig * amp, trig * amp]);
    }).add;

    SynthDef(\test_record, { |in = 0, buf = 0|
        RecordBuf.ar(In.ar(in, 2).sum * 0.5, buf, loop: 0, doneAction: 2);
    }).add;

    s.sync;

    inBus  = 16;
    outBus = 0;
    recBuf = Buffer.alloc(s, ~sampleRate * ~renderDur, 1);

    // (b) impulse -> sampler_fx -> record path ---------------------------
    fxSyn      = Synth(\sw_sampler_fx, [\in_bus, inBus, \out_bus, outBus,
                                        \comb_b_amount, 0.6, \verb_mix, 0.35]);
    recSyn     = Synth.after(fxSyn, \test_record, [\in, outBus, \buf, recBuf]);
    impulseSyn = Synth.before(fxSyn, \test_impulse_in, [\out, inBus,
                                                        \amp, ~impulseAmp]);

    (~renderDur + 0.2).wait;
    fxSyn.free; impulseSyn.free;

    recBuf.loadToFloatArray(action: { |arr|
        samples = arr;
        peak = arr.abs.maxItem;
        rms  = (arr * arr).sum / arr.size;
        rms  = rms.sqrt;

        ~assert.(peak > 0.001, "non-silent output for impulse (peak > 1e-3)");
        ~assert.(rms  > 1.0e-5, "non-trivial RMS energy");

        // (c) Frequency-domain check: comb peak near 61.74 Hz ------------
        fftBuf = FFT.fftSize(fftSize); // logical bin count
        // Compute magnitude spectrum on the host side via Signal.fft.
        block { |break|
            var sig = Signal.newClear(fftSize);
            var i = 0;
            while ({ (i < fftSize) and: { i < arr.size } }) {
                sig[i] = arr[i]; i = i + 1;
            };
            var cosTbl = Signal.fftCosTable(fftSize);
            var imag = Signal.newClear(fftSize);
            var spec = sig.fft(imag, cosTbl).magnitude;
            var binHz = ~sampleRate / fftSize;
            var targetBin = (~combPeakHz / binHz).round.asInteger;
            var window = (~peakTolHz / binHz).ceil.asInteger.max(1);
            var lo = (targetBin - window).max(1);
            var hi = (targetBin + window).min(spec.size - 1);
            var combRegion = spec.copyRange(lo, hi).maxItem;
            var nearbyBaseline =
                spec.copyRange((targetBin * 4).min(spec.size - 1) - 4,
                               (targetBin * 4).min(spec.size - 1) + 4)
                    .maxItem.max(1.0e-9);

            ~assert.(combRegion > nearbyBaseline,
                "61.74 Hz comb peak exceeds far-band baseline "
                ++ "(peak=" ++ combRegion ++ ", baseline=" ++ nearbyBaseline ++ ")");
        };

        recBuf.free;
        "ALL TESTS PASSED".postln;
        0.exit;
    });
};
)

