+// =================================================================
+// Public: CypherClaw live MIDI WebSocket room
+// =================================================================
+
+function isWebSocketUpgrade(req: Request): boolean {
+    return (req.headers.get('Upgrade') || '').toLowerCase() === 'websocket';
+}
+
+function webSocketUpgradeRequiredResponse(env: Env, req: Request): Response {
+    const headers = new Headers(corsHeaders(env, req));
+    headers.set('Upgrade', 'websocket');
+    return new Response('Expected Upgrade: websocket', { status: 426, headers });
+}
+
+async function serveCypherClawLiveMidi(req: Request, env: Env): Promise<Response> {
+    if (!isWebSocketUpgrade(req)) {
+        return webSocketUpgradeRequiredResponse(env, req);
+    }
+    const id = env.LIVE_MIDI_ROOM.idFromName('global');
+    const room = env.LIVE_MIDI_ROOM.get(id);
+    return await room.fetch(req);
+}
+
+export class LiveMidiRoom implements DurableObject {
+    private readonly env: Env;
+    private readonly clients: Set<WebSocket>;
+
+    constructor(_state: DurableObjectState, env: Env) {
+        this.env = env;
+        this.clients = new Set<WebSocket>();
+    }
+
+    async fetch(req: Request): Promise<Response> {
+        if (!isWebSocketUpgrade(req)) {
+            return webSocketUpgradeRequiredResponse(this.env, req);
+        }
+
+        const pair = new WebSocketPair();
+        const client = pair[0];
+        const server = pair[1];
+        server.accept();
+        this.clients.add(server);
+
+        const removeClient = (_event: Event): void => {
+            this.clients.delete(server);
+        };
+        server.addEventListener('close', removeClient);
+        server.addEventListener('error', removeClient);
+
+        return new Response(null, {
+            status: 101,
+            webSocket: client,
+        });
+    }
+
+    clientCount(): number {
+        return this.clients.size;
+    }
+}
+
 // =================================================================
 // Public: CypherClaw archive feed (T-030)
 // =================================================================
