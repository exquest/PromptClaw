index 0000000000000000000000000000000000000000..452a739fa849459028df374d9638fe42f7ded805
--- /dev/null
+++ b//Users/anthony/Programming/catalog-explorer/worker/tests/cypherclaw-live-midi.test.js
@@ -0,0 +1,201 @@
+const test = require("node:test");
+const assert = require("node:assert/strict");
+
+const mod = require("../.tmp/test-build/index.js");
+const worker = mod.default;
+const { LiveMidiRoom } = mod;
+
+function makeBaseEnv(overrides = {}) {
+    return {
+        DB: {},
+        MEDIA: {},
+        ADMIN_TOKEN: "segment-token",
+        STRIPE_SECRET_KEY: "sk_test_unused",
+        STRIPE_WEBHOOK_SECRET: "whsec_unused",
+        RESEND_API_KEY: "re_unused",
+        PUBLIC_SITE_ORIGIN: "https://holdenu.com",
+        ENVIRONMENT: "test",
+        ...overrides,
+    };
+}
+
+function makeForwardingNamespace(response) {
+    const calls = [];
+    const namespace = {
+        calls,
+        idFromName(name) {
+            calls.push({ op: "idFromName", name });
+            return { name };
+        },
+        get(id) {
+            calls.push({ op: "get", id });
+            return {
+                fetch: async (request) => {
+                    calls.push({
+                        op: "fetch",
+                        url: request.url,
+                        upgrade: request.headers.get("Upgrade"),
+                    });
+                    return response;
+                },
+            };
+        },
+    };
+    return namespace;
+}
+
+function makeExplodingNamespace() {
+    return {
+        calls: [],
+        idFromName() {
+            throw new Error("route must reject before touching Durable Object");
+        },
+        get() {
+            throw new Error("route must reject before touching Durable Object");
+        },
+    };
+}
+
+function makeFakeWebSocketPairFactory() {
+    const pairs = [];
+
+    class FakeWebSocket {
+        constructor(kind) {
+            this.kind = kind;
+            this.accepted = false;
+            this.listeners = new Map();
+            this.sent = [];
+        }
+
+        accept() {
+            this.accepted = true;
+        }
+
+        addEventListener(type, listener) {
+            if (!this.listeners.has(type)) this.listeners.set(type, []);
+            this.listeners.get(type).push(listener);
+        }
+
+        dispatch(type) {
+            for (const listener of this.listeners.get(type) || []) {
+                listener({ type, target: this });
+            }
+        }
+
+        send(message) {
+            this.sent.push(message);
+        }
+    }
+
+    function FakeWebSocketPair() {
+        const pair = {
+            0: new FakeWebSocket("client"),
+            1: new FakeWebSocket("server"),
+        };
+        pairs.push(pair);
+        return pair;
+    }
+
+    return { FakeWebSocketPair, pairs };
+}
+
+function installUpgradeResponseShim() {
+    const OriginalResponse = globalThis.Response;
+
+    class UpgradeResponse {
+        constructor(body = null, init = {}) {
+            this.body = body;
+            this.status = init.status || 200;
+            this.headers = new Headers(init.headers || {});
+            this.webSocket = init.webSocket;
+        }
+
+        async text() {
+            return typeof this.body === "string" ? this.body : "";
+        }
+    }
+
+    globalThis.Response = UpgradeResponse;
+    return () => {
+        globalThis.Response = OriginalResponse;
+    };
+}
+
+test("GET /api/cypherclaw/live-midi rejects non-WebSocket requests before Durable Object lookup", async () => {
+    const env = makeBaseEnv({ LIVE_MIDI_ROOM: makeExplodingNamespace() });
+    const request = new Request("https://cypherclaw.holdenu.com/api/cypherclaw/live-midi", {
+        method: "GET",
+    });
+
+    const response = await worker.fetch(request, env, { waitUntil() {} });
+    const body = await response.text();
+
+    assert.equal(response.status, 426);
+    assert.equal(response.headers.get("Upgrade"), "websocket");
+    assert.match(body, /websocket/i);
+});
+
+test("GET /api/cypherclaw/live-midi forwards WebSocket upgrades to the global LiveMidiRoom Durable Object", async () => {
+    const forwardedResponse = { status: 101, webSocket: { kind: "client-socket" } };
+    const liveMidiRoom = makeForwardingNamespace(forwardedResponse);
+    const env = makeBaseEnv({ LIVE_MIDI_ROOM: liveMidiRoom });
+    const request = new Request("https://cypherclaw.holdenu.com/api/cypherclaw/live-midi", {
+        method: "GET",
+        headers: { Upgrade: "websocket" },
+    });
+
+    const response = await worker.fetch(request, env, { waitUntil() {} });
+
+    assert.equal(response, forwardedResponse);
+    assert.deepEqual(liveMidiRoom.calls, [
+        { op: "idFromName", name: "global" },
+        { op: "get", id: { name: "global" } },
+        {
+            op: "fetch",
+            url: "https://cypherclaw.holdenu.com/api/cypherclaw/live-midi",
+            upgrade: "websocket",
+        },
+    ]);
+});
+
+test("LiveMidiRoom accepts WebSockets, tracks clients, and cleans up on close and error", async () => {
+    assert.equal(typeof LiveMidiRoom, "function");
+
+    const { FakeWebSocketPair, pairs } = makeFakeWebSocketPairFactory();
+    const originalWebSocketPair = globalThis.WebSocketPair;
+    globalThis.WebSocketPair = FakeWebSocketPair;
+    const restoreResponse = installUpgradeResponseShim();
+
+    try {
+        const room = new LiveMidiRoom({}, makeBaseEnv());
+        const request = new Request("https://cypherclaw.holdenu.com/api/cypherclaw/live-midi", {
+            method: "GET",
+            headers: { Upgrade: "websocket" },
+        });
+
+        assert.equal(room.clientCount(), 0);
+
+        const closeResponse = await room.fetch(request);
+        assert.equal(closeResponse.status, 101);
+        assert.equal(closeResponse.webSocket.kind, "client");
+        assert.equal(pairs[0][1].accepted, true);
+        assert.equal(room.clientCount(), 1);
+        assert.deepEqual(pairs[0][1].sent, []);
+
+        pairs[0][1].dispatch("close");
+        assert.equal(room.clientCount(), 0);
+
+        const errorResponse = await room.fetch(request);
+        assert.equal(errorResponse.status, 101);
+        assert.equal(errorResponse.webSocket.kind, "client");
+        assert.equal(pairs[1][1].accepted, true);
+        assert.equal(room.clientCount(), 1);
+
+        pairs[1][1].dispatch("error");
+        assert.equal(room.clientCount(), 0);
+        assert.deepEqual(pairs[1][1].sent, []);
+    } finally {
+        restoreResponse();
+        globalThis.WebSocketPair = originalWebSocketPair;
+    }
+});
