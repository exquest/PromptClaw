function makeArchiveMedia(sessions) {
    const objects = sessions.map((s) => ({ key: s.metadata_key }));
    return {
        list: async ({ prefix }) => {
            const filtered = objects.filter((o) => o.key.startsWith(prefix));
            return { objects: filtered, truncated: false, delimitedPrefixes: [] };
        },
        get: async (key) => {
            const session = sessions.find((s) => s.metadata_key === key);
            if (!session) return null;
            return {
                text: async () => JSON.stringify(session),
            };
        },
    };
}

test("renderCypherClawArchiveFeed produces a stable snapshot for a fixture session list", () => {
    const rendered = renderCypherClawArchiveFeed(FIXTURE_SESSIONS);
    assert.equal(rendered, EXPECTED_RENDERED_FEED);
});

test("renderCypherClawArchiveFeed orders sessions reverse chronologically by started_at", () => {
    const rendered = renderCypherClawArchiveFeed(FIXTURE_SESSIONS);
    const indices = FIXTURE_SESSIONS
        .map((s) => ({ id: s.session_id, idx: rendered.indexOf(s.session_id) }))
        .sort((a, b) => a.idx - b.idx);
    assert.deepEqual(
        indices.map((i) => i.id),
        [
            "session-20260523T042000Z",
            "session-20260523T041000Z",
            "session-20260523T040000Z",
        ],
    );
});

test("renderCypherClawArchiveFeed emits a playable audio element per session pointing at session.opus", () => {
    const rendered = renderCypherClawArchiveFeed(FIXTURE_SESSIONS);
    const matches = rendered.match(/<audio[^>]*>/g) || [];
    assert.equal(matches.length, FIXTURE_SESSIONS.length);
    for (const match of matches) {
        assert.match(match, /controls/);
        assert.match(match, /preload="none"/);
        assert.match(match, /aria-label="Play archived session/);
        assert.match(match, /src="\/api\/cypherclaw\/segment\/cypherclaw\/archive\/[^"]+\/session\.opus"/);
    }
});

test("renderCypherClawArchiveFeed renders an empty-state placeholder when there are no sessions", () => {
    const rendered = renderCypherClawArchiveFeed([]);
    assert.match(rendered, /data-archive-feed-state="empty"/);
    assert.match(rendered, /data-archive-session-count="0"/);
    assert.match(rendered, /No archived sessions yet\./);
    assert.doesNotMatch(rendered, /<audio/);
});

test("renderCypherClawArchiveFeed escapes HTML-sensitive characters in session titles", () => {
    const rendered = renderCypherClawArchiveFeed([
        {
            ...FIXTURE_SESSIONS[0],
            title: "<script>alert(1)</script> & friends",
        },
    ]);
    assert.doesNotMatch(rendered, /<script>alert/);
    assert.match(rendered, /&lt;script&gt;alert\(1\)&lt;\/script&gt; &amp; friends/);
});

test("listCypherClawArchiveSessions reads metadata.json objects from R2 and sorts reverse chronologically", async () => {
