test("GET / connects the visualizer to live-features with an SSE client", async () => {
    const env = makeEnv();
    const request = new Request("https://cypherclaw.holdenu.com/", { method: "GET" });
    const response = await worker.fetch(request, env, { waitUntil() {} });
    const body = await response.text();

    assert.equal(response.status, 200);
    assert.match(body, /data-live-features-url="\/api\/cypherclaw\/live-features"/);
    assert.match(body, /const featuresUrl = canvas\.getAttribute\("data-live-features-url"\) \|\| "\/api\/cypherclaw\/live-features";/);
    assert.match(body, /new EventSource\(featuresUrl\)/);
    assert.match(body, /source\.addEventListener\("message", handleFeatureMessage\)/);
    assert.match(body, /source\.addEventListener\("features", handleFeatureMessage\)/);
    assert.match(body, /JSON\.parse\(event\.data\)/);
    assert.match(body, /window\.cypherclawLiveFeatureSource = source/);
    assert.match(body, /window\.cypherclawLiveFeatures = state\.latestFeatures/);
    assert.match(body, /source\.close\(\)/);
    assert.match(body, /data-feed-state/);
    assert.doesNotMatch(body.toLowerCase(), /listener count|viewer count|analytics/);
});

test("GET /api/cypherclaw/live-features returns an SSE bootstrap feed", async () => {
    const env = makeEnv();
    const request = new Request("https://cypherclaw.holdenu.com/api/cypherclaw/live-features", { method: "GET" });
    const response = await worker.fetch(request, env, { waitUntil() {} });
    const body = await response.text();

    assert.equal(response.status, 200);
    assert.match(response.headers.get("Content-Type") || "", /text\/event-stream/);
    assert.equal(response.headers.get("Cache-Control"), "no-cache");
    assert.match(body, /^retry: 5000$/m);
    assert.match(body, /^event: features$/m);

    const dataLine = body.split("\n").find((line) => line.startsWith("data: "));
    assert.ok(dataLine, "SSE response includes a data line");
    const payload = JSON.parse(dataLine.slice("data: ".length));
    assert.equal(payload.source, "worker-bootstrap");
    assert.equal(typeof payload.rms, "number");
    assert.equal(typeof payload.pitch_hz, "number");
    assert.equal(typeof payload.centroid_hz, "number");
    assert.equal(typeof payload.scene, "string");
    assert.equal(typeof payload.tuning, "string");
    assert.doesNotMatch(body.toLowerCase(), /listener count|viewer count|analytics/);
});

