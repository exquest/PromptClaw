        ear_metrics={
            "interval_variety": 0.05,
            "pitch_range_semitones": 2.0,
            "onset_density": 0.2,
            "repetition_score": 0.9,
            "spectral_centroid_hz": 420.0,
            "spectral_flatness": 0.12,
            "roughness": 0.1,
            "hook_clarity": 0.2,
            "cadence_strength": 0.25,
