        underdeveloped_score = float(feedback_scores.get("underdeveloped_score", 0.0) or 0.0)
        if cadence_strength >= 0.85:
            form_variant = "afterglow"
        elif hook_clarity >= 0.85:
            form_variant = "bridge"
        elif underdeveloped_score >= 0.55:
