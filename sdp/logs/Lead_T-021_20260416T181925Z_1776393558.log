{"type":"tool_use","timestamp":"2026-04-17T02:47:12.994Z","tool_name":"write_file","tool_id":"write_file_1776394032994_0","parameters":{"file_path":"src/cypherclaw/render/rules/motif_memory.py","content":"from __future__ import annotations\n\nimport collections\nimport hashlib\nimport random\nfrom typing import Any\n\nfrom cypherclaw.render.events import Event\nfrom cypherclaw.render.role_gate import role_is_eligible\n\nVARIATION_MENU = (\n    \"transposition\",\n    \"inversion\",\n    \"retrograde\",\n    \"rhythmic augmentation\",\n    \"re-voicing\",\n    \"partial fragmentation\",\n)\n\nclass MotifMemoryRule:\n    \"\"\"R9 Motif Memory: LRU cache of motif hashes with variation menu and return-home decay.\"\"\"\n\n    rule_id = \"R9\"\n\n    def __init__(\n        self,\n        max_cache_size: int = 16,\n        return_home_iterations: int = 8,\n        seed: int | None = None\n    ) -> None:\n        self.max_cache_size = max_cache_size\n        self.return_home_iterations = return_home_iterations\n        self._rng = random.Random(seed)\n        \n        self._motif_counts: dict[str, int] = collections.defaultdict(int)\n        self._lru_cache: collections.OrderedDict[str, bool] = collections.OrderedDict()\n        \n        self._variation_last_used: dict[str, int] = {v: 0 for v in VARIATION_MENU}\n        self._variation_counter = 0\n\n    def applies_to(self, role: str, metadata: dict[str, str] | None = None) -> bool:\n        return role_is_eligible(role, metadata)\n\n    def _hash_motif(self, events: list[Event]) -> str:\n        \"\"\"Hash motifs by pitch-class + rhythm signature.\"\"\"\n        parts = []\n        for e in events:\n            pc = getattr(e, 'pitch', 0) % 12\n            dur = getattr(e, 'nominal_dur_sec', 0.0)\n            parts.append(f\"{pc}:{dur:.3f}\")\n        return hashlib.md5(\",\".join(parts).encode(\"utf-8\")).hexdigest()\n\n    def _select_variation(self) -> str:\n        \"\"\"Select a variation weighted inversely by recency.\"\"\"\n        weights = []\n        for v in VARIATION_MENU:\n            age = self._variation_counter - self._variation_last_used[v]\n            weights.append(max(1, age))\n            \n        chosen = self._rng.choices(VARIATION_MENU, weights=weights, k=1)[0]\n        self._variation_counter += 1\n        self._variation_last_used[chosen] = self._variation_counter\n        return chosen\n\n    def apply(self, events: list[Event]) -> str:\n        \"\"\"\n        Apply motif memory to a list of events representing a phrase/motif.\n        Returns the variation to apply, or 'original' if unchanged.\n        \"\"\"\n        if not events:\n            return \"original\"\n\n        role = getattr(events[0], 'role', \"\")\n        metadata = getattr(events[0], 'metadata', {})\n        if not self.applies_to(role, metadata):\n            return \"original\"\n\n        motif_hash = self._hash_motif(events)\n        \n        self._motif_counts[motif_hash] += 1\n        count = self._motif_counts[motif_hash]\n        \n        if motif_hash in self._lru_cache:\n            self._lru_cache.move_to_end(motif_hash)\n        else:\n            self._lru_cache[motif_hash] = True\n            if len(self._lru_cache) > self.max_cache_size:\n                oldest_hash, _ = self._lru_cache.popitem(last=False)\n                if oldest_hash in self._motif_counts:\n                    del self._motif_counts[oldest_hash]\n        \n        if count % self.return_home_iterations == 1:\n            return \"original\"\n            \n        return self._select_variation()\n"}}
{"type":"tool_use","timestamp":"2026-04-17T02:47:13.058Z","tool_name":"write_file","tool_id":"write_file_1776394033057_1","parameters":{"file_path":"tests/test_motif_memory.py","content":"from __future__ import annotations\n\nimport collections\n\nfrom cypherclaw.render.events import Event\nfrom cypherclaw.render.rules.motif_memory import MotifMemoryRule, VARIATION_MENU\n\n\ndef _make_motif(pitch_start: int = 60, role: str = \"melody\") -> list[Event]:\n    e1 = Event(role=role, pitch=pitch_start, nominal_dur_sec=0.5) # type: ignore\n    e2 = Event(role=role, pitch=pitch_start + 2, nominal_dur_sec=0.25) # type: ignore\n    e3 = Event(role=role, pitch=pitch_start + 4, nominal_dur_sec=0.25) # type: ignore\n    return [e1, e2, e3]\n\n\ndef test_motif_memory_hashes_by_pitch_class_and_rhythm() -> None:\n    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=8)\n    m1 = _make_motif(60) # C4\n    m2 = _make_motif(72) # C5 - same pitch class\n    \n    # Both should hash to the same value\n    h1 = rule._hash_motif(m1)\n    h2 = rule._hash_motif(m2)\n    assert h1 == h2\n    \n    # Different rhythm -> different hash\n    m3 = _make_motif(60)\n    m3[0].nominal_dur_sec = 0.75 # type: ignore\n    h3 = rule._hash_motif(m3)\n    assert h1 != h3\n\n\ndef test_motif_memory_return_home() -> None:\n    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=8, seed=42)\n    motif = _make_motif()\n    \n    # Iteration 1\n    assert rule.apply(motif) == \"original\"\n    \n    # Iterations 2-8\n    for i in range(2, 9):\n        var = rule.apply(motif)\n        assert var in VARIATION_MENU\n        assert var != \"original\"\n        \n    # Iteration 9 (return home)\n    assert rule.apply(motif) == \"original\"\n\n\ndef test_motif_memory_recency_weighting() -> None:\n    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=100, seed=123)\n    motif = _make_motif()\n    \n    # Advance to build up history\n    rule.apply(motif) # iteration 1 -> original\n    \n    # Let's apply many times and track distribution\n    counts = collections.Counter()\n    for _ in range(100):\n        # Different motifs so we don't hit return-home\n        m = _make_motif(pitch_start=60 + _)\n        var = rule.apply(m) # m is new, so it returns \"original\"\n        # wait, we want to test variations, so we should apply the SAME motif\n    \n    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=1000, seed=123)\n    motif = _make_motif()\n    rule.apply(motif) # 1 -> original\n    \n    vars_seen = []\n    for _ in range(50):\n        vars_seen.append(rule.apply(motif))\n        \n    # Because of inverse recency weighting, we should see a relatively even distribution\n    # over time, avoiding long runs of the same variation.\n    counts = collections.Counter(vars_seen)\n    assert len(counts) == len(VARIATION_MENU)\n    for v in VARIATION_MENU:\n        assert counts[v] > 0\n        \n    # Check that consecutive repeats are rare or nonexistent\n    consecutive_repeats = 0\n    for i in range(1, len(vars_seen)):\n        if vars_seen[i] == vars_seen[i-1]:\n            consecutive_repeats += 1\n            \n    assert consecutive_repeats < 5 # Inverse recency should heavily penalize repeats\n\n\ndef test_motif_memory_lru_decay() -> None:\n    rule = MotifMemoryRule(max_cache_size=2, return_home_iterations=8)\n    \n    m1 = _make_motif(60)\n    m2 = _make_motif(62)\n    m3 = _make_motif(64)\n    \n    assert rule.apply(m1) == \"original\" # m1 in cache\n    assert rule.apply(m2) == \"original\" # m1, m2 in cache\n    \n    # m1 is now oldest. if we apply m3, m1 should be evicted\n    assert rule.apply(m3) == \"original\" # m2, m3 in cache\n    \n    # Since m1 was evicted, applying it again should treat it as new (iteration 1 -> original)\n    assert rule.apply(m1) == \"original\"\n    \n    # Applying m2 should result in variation (it was in cache)\n    # wait, when m1 was inserted, m2 became oldest.\n    assert rule.apply(m2) == \"original\" # wait, applying m1 evicted m2!\n    # Let's trace:\n    # m1 inserted -> [m1]\n    # m2 inserted -> [m1, m2]\n    # m3 inserted -> evicts m1 -> [m2, m3]\n    # m1 inserted -> evicts m2 -> [m3, m1]\n    # m2 inserted -> evicts m3 -> [m1, m2]\n    # So m2 is treated as new, returns \"original\".\n    \n    # Let's just make sure m1 returns original when evicted and re-entered\n    rule = MotifMemoryRule(max_cache_size=2, return_home_iterations=8)\n    assert rule.apply(_make_motif(60)) == \"original\" # m1: count=1\n    assert rule.apply(_make_motif(60)) != \"original\" # m1: count=2\n    \n    # evict m1\n    rule.apply(_make_motif(62))\n    rule.apply(_make_motif(64))\n    \n    # m1 should be forgotten\n    assert rule.apply(_make_motif(60)) == \"original\" # count=1\n\n\ndef test_motif_memory_role_gating() -> None:\n    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=8)\n    \n    # Ostinato is grid-locked, shouldn't be varied\n    motif = _make_motif(role=\"ostinato\")\n    \n    for _ in range(10):\n        assert rule.apply(motif) == \"original\"\n"}}
