const test = require("node:test");
const assert = require("node:assert/strict");
const fs = require("node:fs");
const path = require("node:path");

const WORKER_ROOT = path.join(__dirname, "..");
const wranglerToml = fs.readFileSync(path.join(WORKER_ROOT, "wrangler.toml"), "utf8");
const workerSource = fs.readFileSync(path.join(WORKER_ROOT, "src", "index.ts"), "utf8");

function tableBodies(toml, tableName) {
    const target = `[[${tableName}]]`;
    const bodies = [];
    let current = null;

    for (const line of toml.split(/\r?\n/)) {
        const trimmed = line.trim();
        if (trimmed.startsWith("[") && trimmed.endsWith("]")) {
            if (current !== null) {
                bodies.push(current.join("\n"));
            }
            current = trimmed === target ? [] : null;
            continue;
        }

        if (current !== null) {
            current.push(line);
        }
    }

    if (current !== null) {
        bodies.push(current.join("\n"));
    }

    return bodies;
}

function hasTableMatching(toml, tableName, patterns) {
    return tableBodies(toml, tableName).some((body) => (
        patterns.every((pattern) => pattern.test(body))
    ));
}

test("wrangler config binds and migrates LiveMidiRoom at top-level and in env.dev", () => {
    const bindingPatterns = [
        /^name\s*=\s*"LIVE_MIDI_ROOM"/m,
        /^class_name\s*=\s*"LiveMidiRoom"/m,
    ];
    const migrationPatterns = [
        /^tag\s*=\s*"v1"/m,
        /^new_sqlite_classes\s*=\s*\[\s*"LiveMidiRoom"\s*\]/m,
    ];

    assert.equal(
        hasTableMatching(wranglerToml, "durable_objects.bindings", bindingPatterns),
        true,
        "top-level wrangler config must bind LIVE_MIDI_ROOM to LiveMidiRoom",
    );
    assert.equal(
        hasTableMatching(wranglerToml, "migrations", migrationPatterns),
        true,
        "top-level wrangler config must migrate LiveMidiRoom",
    );
    assert.equal(
        hasTableMatching(wranglerToml, "env.dev.durable_objects.bindings", bindingPatterns),
        true,
        "env.dev wrangler config must bind LIVE_MIDI_ROOM to LiveMidiRoom",
    );
    assert.equal(
        hasTableMatching(wranglerToml, "env.dev.migrations", migrationPatterns),
        true,
        "env.dev wrangler config must migrate LiveMidiRoom",
    );
});

