-- ============================================================
-- audio_files — streamable MP3s independent of release events.
-- ============================================================
-- A song can be "mastered" (or later) in the catalog-explorer's
-- pipeline and uploaded for public streaming BEFORE it has a
-- release row on holdenu.com. The explorer auto-fires an upload
-- whenever a pipeline_override hits a stage >= mastered, so
-- /api/stream/<slug> needs a separate index of "this slug has
-- an MP3 in R2" that doesn't depend on the release_tracks table.
--
-- /api/stream/<slug> resolves a key by:
--   1. audio_files (if present) — preview/stream of the V0 MP3
--   2. release_tracks (fallback) — the older flac/aac path used
--      for paid downloads on holdenu.com releases
-- ============================================================

CREATE TABLE IF NOT EXISTS audio_files (
    track_id     TEXT PRIMARY KEY,           -- song slug from the catalog
    r2_key       TEXT NOT NULL,              -- "audio/<slug>.mp3"
    mime         TEXT NOT NULL DEFAULT 'audio/mpeg',
    bytes        INTEGER,                    -- final encoded size
    duration_ms  INTEGER,                    -- from ffprobe
    bitrate_kbps INTEGER,                    -- VBR average from ffprobe
    sha256       TEXT,                       -- of the MP3 body, for re-upload skip
    source_path  TEXT,                       -- original render path on disk (diagnostic)
    uploaded_at  TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP)
);

CREATE INDEX IF NOT EXISTS idx_audio_files_uploaded
    ON audio_files (uploaded_at DESC);
