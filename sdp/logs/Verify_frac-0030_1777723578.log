    if voice.active_count > 0:
        return False
    return True


def build_voice_adsr_snapshot(adsr: ADSR) -> VoiceADSRSnapshot:
    """Resolve an ADSR envelope into a frozen diagnostic snapshot."""
    preset_name = preset_name_for_adsr(adsr)
