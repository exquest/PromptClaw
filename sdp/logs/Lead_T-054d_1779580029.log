"""Migration-detection helper for verifier rule SI-003 (T-005).

Scans a task specification for trigger phrases that indicate the task
performs a database migration or schema change. When any trigger fires,
the verifier requires post-migration evidence (e.g., ``PRAGMA table_info``
or ``\\d <table>`` snapshot) before the task may reach PASS.
"""

from __future__ import annotations

import re

_MIGRATION_TRIGGER_RE = re.compile(
    r"\bALTER\s+TABLE\b|\bCREATE\s+TABLE\b|\bmigration\b|\bschema\s+change\b",
    re.IGNORECASE,
)

_SCHEMA_SQL_RE = re.compile(
    r"\bALTER\s+TABLE\b|\bCREATE\s+TABLE\b",
    re.IGNORECASE,
)

_NEGATIVE_MIGRATION_CONTEXT_RE = re.compile(
    r"\b("
    r"no|not|never|without|forbid|forbids|forbidden|"
    r"must\s+not|do\s+not|does\s+not|cannot|can't|"
    r"may\s+not|should\s+not|out\s+of\s+scope"
    r")\b",
    re.IGNORECASE,
)

_MIGRATIONS_DIFF_PATH_RE = re.compile(
    r"\bgit\s+diff\b.*\bmigrations?\b|/[^\s`]*migrations?\b",
    re.IGNORECASE,
)

_NON_DATABASE_MIGRATION_CONTEXT_RE = re.compile(
    r"\bdurable\s+object\b|\bwrangler(?:\.toml)?\b|\bschema\s+change\s+config(?:uration)?\b",
    re.IGNORECASE,
)

_DATABASE_MIGRATION_CONTEXT_RE = re.compile(
    r"\b("
    r"database|db|d1|sqlite|postgres|postgresql|mysql|mariadb|"
    r"table|column|index|foreign\s+key|fk|alembic|sqlalchemy|django"
    r")\b",
    re.IGNORECASE,
)

_SQLITE_TABLE_INFO_RE = re.compile(
    r"\bPRAGMA\s+table_info\s*\(\s*[\"'`]?([A-Za-z_][A-Za-z0-9_]*)[\"'`]?\s*\)",
    re.IGNORECASE,
)

_POSTGRES_DESCRIBE_RE = re.compile(
    r"\\d\+?\s+[\"'`]?([A-Za-z_][A-Za-z0-9_.]*)[\"'`]?",
)


def _is_non_database_migration_context(context: str) -> bool:
    """Return True when migration wording references non-DB runtime config."""
    return (
        _NON_DATABASE_MIGRATION_CONTEXT_RE.search(context) is not None
        and _DATABASE_MIGRATION_CONTEXT_RE.search(context) is None
    )


def spec_mentions_migration(spec_text: str) -> bool:
    """Return True if *spec_text* contains an affirmative migration trigger.

    Trigger phrases (case-insensitive): ``ALTER TABLE``, ``CREATE TABLE``,
    ``migration``, ``schema change``.

    Negative assertions such as ``No new migrations`` or ``must not expose a
    volume migration`` do not trigger SI-003 by themselves. Those clauses are
    common in safety-oriented specs and require the absence of schema work, not
    post-migration database evidence.
    """
    if not spec_text:
        return False
    previous_line = ""
    for raw_line in spec_text.splitlines():
        line = raw_line.strip()
        if not line or _MIGRATION_TRIGGER_RE.search(line) is None:
            if line:
                previous_line = line
            continue
        context = f"{previous_line} {line}".strip()
        # Explicit SQL DDL references are strong migration signals. Keep these
        # strict so SI-003 still catches real schema-changing tasks.
        if _SCHEMA_SQL_RE.search(line):
            return True
        if _is_non_database_migration_context(context):
            previous_line = line
            continue
        if _MIGRATIONS_DIFF_PATH_RE.search(context):
            previous_line = line
            continue
        if _NEGATIVE_MIGRATION_CONTEXT_RE.search(context):
            previous_line = line
            continue
        return True
    return False


def report_has_table_snapshot(report_text: str) -> bool:
    """Return True if *report_text* contains a post-migration table snapshot.

    Recognised forms (either dialect satisfies the rule):

    * SQLite — ``PRAGMA table_info(<table>)`` (case-insensitive).
    * Postgres — ``\\d <table>`` or ``\\d+ <table>`` meta-command.

    The function only verifies that the snapshot *invocation* is present
    with a table name. It is intentionally permissive about surrounding
    formatting (fenced code blocks, prompts, quoting) so that evidence
    pasted from either ``sqlite3`` or ``psql`` sessions is recognised.
    """
    if not report_text:
        return False
    if _SQLITE_TABLE_INFO_RE.search(report_text):
        return True
    return _POSTGRES_DESCRIBE_RE.search(report_text) is not None


def render_missing_migration_snapshot_notes() -> str:
    """Render the FAIL-marked Notes block for verifier rule SI-003.

    Appended to a verification report when the spec mentions a migration
    trigger phrase but the report lacks a post-migration table snapshot.
    The block ends with a ``## Verdict: FAIL`` marker so that re-parsing
    the report with ``parse_verdict`` (which scans from end of file)
    returns the forced FAIL verdict.
    """
    lines = [
        "",
        "## Notes for Lead Agent",
        "",
        (
            "Verifier rule SI-003: this task spec mentions a database "
            "migration but the verification report does not contain a "
            "post-migration table snapshot. Add one of the following "
            "evidence forms and re-run verify:"
        ),
        "",
        "- SQLite — `PRAGMA table_info(<table>)` output",
        "- Postgres — `\\d <table>` or `\\d+ <table>` output",
        "",
        "## Verdict: FAIL",
        "",
    ]
    return "\n".join(lines)
    if test_files is None:
        test_files = [Path(p) for p in _detect_changed_test_files(task_id)]
    unexercised = _engine_surface_downgrade_symbols(spec_path, test_files)
    if not unexercised:
        return verdict
    notes = render_engine_surface_unexercised_notes(unexercised)
    if notes:
        try:
            with report_path.open("a", encoding="utf-8") as fh:
                fh.write(notes)
        except OSError:
            pass
    return VerdictResult.PASS_WITH_NOTES


def _maybe_force_fail_for_missing_migration_snapshot(
    verdict: VerdictResult,
    report_path: Path,
    task_id: str,
    *,
    spec_path: Path | None = None,
) -> VerdictResult:
    """Force verdict to FAIL when a migration spec lacks DB snapshot evidence.

    Verifier rule SI-003: when the task spec contains a migration trigger
    phrase (``ALTER TABLE``, ``CREATE TABLE``, ``migration``,
    ``schema change``) and the verification report does not contain a
    post-migration table snapshot (``PRAGMA table_info(<table>)`` for SQLite
    or ``\\d <table>`` / ``\\d+ <table>`` for Postgres), the verdict is
    forced to FAIL with a clear reason string referencing the missing DB
    evidence.

    A short-circuit returns ``verdict`` unchanged for any non-PASS, non
    PASS-WITH-NOTES input (FAIL/MISSING/UNPARSEABLE already block PASS).
    When ``spec_path`` is omitted, it is derived from ``task_id`` using the
    project convention ``specs/{task_id_lower}-spec.md``.

    On forced FAIL, appends a Notes for Lead Agent block plus a new
    ``## Verdict: FAIL`` marker to ``report_path`` so that re-parsing the
    file with ``parse_verdict`` returns the forced verdict. Append failures
    (e.g. missing report) are swallowed; the in-memory verdict still flips
    to FAIL.
    """
    if verdict not in (VerdictResult.PASS, VerdictResult.PASS_WITH_NOTES):
        return verdict
    if spec_path is None:
        spec_path = Path("specs") / f"{task_id.lower()}-spec.md"
    try:
        spec_text = spec_path.read_text(encoding="utf-8")
    except OSError:
        return verdict
    if not spec_mentions_migration(spec_text):
        return verdict
    try:
        report_text = report_path.read_text(encoding="utf-8")
    except OSError:
        report_text = ""
    if report_has_table_snapshot(report_text):
        return verdict
    notes = render_missing_migration_snapshot_notes()
    if notes:
        try:
            with report_path.open("a", encoding="utf-8") as fh:
                fh.write(notes)
        except OSError:
            pass
    return VerdictResult.FAIL


