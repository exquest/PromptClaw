"""Tests for migration-detection helper (T-005 / SI-003)."""

from __future__ import annotations

import pytest

from sdp.pipeline.migration_detection import (
    report_has_table_snapshot,
    spec_mentions_migration,
)


@pytest.mark.parametrize(
    "spec_text",
    [
        "Apply ALTER TABLE users ADD COLUMN email TEXT;",
        "We need to CREATE TABLE sessions for the new feature.",
        "Run the migration before deploying the service.",
        "This is a schema change to support multi-tenant data.",
    ],
)
def test_spec_mentions_migration_detects_trigger_phrases(spec_text: str) -> None:
    """Each of the four trigger phrases should be detected."""
    assert spec_mentions_migration(spec_text) is True


@pytest.mark.parametrize(
    "spec_text",
    [
        "alter table accounts drop column legacy_id;",
        "create   table   audits ( id integer );",
        "Track migration progress for the rollout.",
        "  Schema   Change   tracker for downstream consumers.",
    ],
)
def test_spec_mentions_migration_is_case_and_whitespace_insensitive(
    spec_text: str,
) -> None:
    """Trigger phrase matching ignores case and tolerates extra whitespace."""
    assert spec_mentions_migration(spec_text) is True


def test_spec_mentions_migration_negative_case() -> None:
    """A spec without any trigger phrase should not be flagged."""
    spec_text = (
        "Refactor the CLI argument parser to share defaults across commands. "
        "No database work involved; this is a pure code reorganisation."
    )
    assert spec_mentions_migration(spec_text) is False


@pytest.mark.parametrize(
    "spec_text",
    [
        "No new dependencies, migrations, provider secrets, or database columns.",
        "The workflow must not expose a volume migration or model-loading action.",
        "Phase 2 migration work is out of scope for this read-only report.",
        "VERIFY: git diff -- pyproject.toml promptclaw/coherence/migrations",
        "No database schema changes are introduced by this task.",
    ],
)
def test_spec_mentions_migration_ignores_negative_assertions(
    spec_text: str,
) -> None:
    """Negative migration assertions should not trigger SI-003 evidence."""
    assert spec_mentions_migration(spec_text) is False


def test_spec_mentions_migration_ignores_existing_durable_object_config_reference() -> None:
    """Existing Workers Durable Object config is not SQLite/Postgres schema work."""
    spec_text = (
        "Add a Worker Vitest config that points at worker/wrangler.toml so the "
        "test uses the real LIVE_MIDI_ROOM Durable Object binding and schema "
        "change config.\n"
        "No D1 database schema change and no Durable Object schema change is "
        "introduced by this task."
    )
    assert spec_mentions_migration(spec_text) is False


def test_spec_mentions_migration_keeps_real_schema_work_after_negative_clause() -> None:
    """A negative dependency line must not mask a later real migration."""
    spec_text = (
        "No new provider secrets are allowed.\n"
        "Apply ALTER TABLE users ADD COLUMN email TEXT."
    )
    assert spec_mentions_migration(spec_text) is True


def test_spec_mentions_migration_empty_string() -> None:
    """An empty spec returns False without raising."""
    assert spec_mentions_migration("") is False


def test_report_has_table_snapshot_detects_sqlite_pragma() -> None:
    """A SQLite ``PRAGMA table_info(<table>)`` snapshot satisfies the rule."""
    report_text = (
        "## Post-migration evidence\n"
        "```\n"
        "sqlite> PRAGMA table_info(users);\n"
        "0|id|INTEGER|0||1\n"
        "1|email|TEXT|1||0\n"
        "```\n"
    )
    assert report_has_table_snapshot(report_text) is True


def test_report_has_table_snapshot_detects_sqlite_pragma_case_insensitive() -> None:
    """The PRAGMA keyword should match regardless of case."""
    assert report_has_table_snapshot("pragma table_info(accounts)") is True


def test_report_has_table_snapshot_detects_postgres_describe() -> None:
    """A Postgres ``\\d <table>`` snapshot satisfies the rule."""
    report_text = (
        "## Post-migration evidence\n"
        "```\n"
        "app=# \\d users\n"
        "                Table \"public.users\"\n"
        " Column |  Type   | Nullable\n"
        "--------+---------+----------\n"
        " id     | integer | not null\n"
        " email  | text    | not null\n"
        "```\n"
    )
    assert report_has_table_snapshot(report_text) is True


def test_report_has_table_snapshot_detects_postgres_describe_plus() -> None:
    """The ``\\d+`` extended-describe form is also recognised."""
    assert report_has_table_snapshot("\\d+ public.sessions") is True


def test_report_has_table_snapshot_missing_evidence() -> None:
    """A report without either snapshot returns False."""
    report_text = (
        "## Verification\n"
        "Ran the migration and the application started cleanly. "
        "Tests pass. No schema dump was captured."
    )
    assert report_has_table_snapshot(report_text) is False


def test_report_has_table_snapshot_empty_string() -> None:
    """An empty report returns False without raising."""
    assert report_has_table_snapshot("") is False


def test_report_has_table_snapshot_ignores_unrelated_psql_metacommands() -> None:
    """Other ``\\d``-prefixed psql meta-commands (e.g. ``\\dt``) do not count."""
    report_text = "Listed all tables with \\dt and then exited."
    assert report_has_table_snapshot(report_text) is False
"""Tests for migration-snapshot verdict wiring (T-005@20260503T180144Zc / SI-003).

Exercises ``_maybe_force_fail_for_missing_migration_snapshot`` and the
companion ``render_missing_migration_snapshot_notes`` renderer:

- non-migration specs are no-ops
- migration specs with snapshot evidence are no-ops
- migration specs without snapshot force FAIL from PASS or PASS WITH NOTES
- FAIL/MISSING/UNPARSEABLE verdicts are no-ops
- missing spec file is treated as no-mention
- default spec_path is derived from task_id
"""

from __future__ import annotations

import textwrap
from pathlib import Path

from sdp._orchestrator_impl import _maybe_force_fail_for_missing_migration_snapshot
from sdp.gates.verdict import VerdictResult, parse_verdict
from sdp.pipeline.migration_detection import render_missing_migration_snapshot_notes


def _write_report(path: Path, *, verdict_marker: str, body: str = "") -> None:
    text = textwrap.dedent(
        f"""
        # Verification Report — T-MIG

        ## Summary
        Verifier ran end-to-end.

        {body}

        ## Verdict: {verdict_marker}
        """
    ).strip() + "\n"
    path.write_text(text, encoding="utf-8")


def _write_migration_spec(path: Path) -> None:
    path.write_text(
        "# Spec\n\n"
        "## Problem Statement\n"
        "Apply ALTER TABLE users ADD COLUMN email TEXT;\n",
        encoding="utf-8",
    )


def _write_non_migration_spec(path: Path) -> None:
    path.write_text(
        "# Spec\n\n"
        "## Problem Statement\n"
        "Refactor the CLI argument parser to share defaults across commands.\n",
        encoding="utf-8",
    )


def _write_negative_migration_assertion_spec(path: Path) -> None:
    path.write_text(
        "# Spec\n\n"
        "## Problem Statement\n"
        "The report must not expose an approval action, cloud lifecycle action, "
        "model-loading action, volume migration, or any Phase 2 execution path.\n\n"
        "## Acceptance Criteria\n"
        "7. No new dependencies, migrations, remote-write commands, provider "
        "secrets, or database columns are introduced.\n"
        "- VERIFY: git diff -- pyproject.toml promptclaw/coherence/migrations\n",
        encoding="utf-8",
    )


def test_render_missing_migration_snapshot_notes_contents() -> None:
    notes = render_missing_migration_snapshot_notes()
    assert notes
    assert "## Notes for Lead Agent" in notes
    assert "## Verdict: FAIL" in notes
    # Both supported snapshot forms must be referenced so the lead agent
    # knows what evidence to add.
    assert "PRAGMA table_info" in notes
    assert "\\d" in notes
    # Rule reference helps grep-ability.
    assert "SI-003" in notes


def test_non_migration_spec_leaves_pass_unchanged(tmp_path: Path) -> None:
    report = tmp_path / "t-mig-verify.md"
    _write_report(report, verdict_marker="PASS")
    original_bytes = report.read_bytes()

    spec = tmp_path / "spec.md"
    _write_non_migration_spec(spec)

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS,
        report,
        "T-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.PASS
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.PASS


def test_negative_migration_assertion_spec_leaves_pass_unchanged(
    tmp_path: Path,
) -> None:
    report = tmp_path / "t-readiness-verify.md"
    _write_report(report, verdict_marker="PASS WITH NOTES")
    original_bytes = report.read_bytes()

    spec = tmp_path / "spec.md"
    _write_negative_migration_assertion_spec(spec)

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS_WITH_NOTES,
        report,
        "T-READINESS",
        spec_path=spec,
    )

    assert result is VerdictResult.PASS_WITH_NOTES
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.PASS_WITH_NOTES


def test_migration_spec_with_sqlite_snapshot_leaves_pass_unchanged(
    tmp_path: Path,
) -> None:
    report = tmp_path / "t-mig-verify.md"
    _write_report(
        report,
        verdict_marker="PASS",
        body=(
            "## Post-migration evidence\n"
            "```\n"
            "sqlite> PRAGMA table_info(users);\n"
            "0|id|INTEGER|0||1\n"
            "1|email|TEXT|1||0\n"
            "```\n"
        ),
    )
    original_bytes = report.read_bytes()

    spec = tmp_path / "spec.md"
    _write_migration_spec(spec)

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS,
        report,
        "T-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.PASS
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.PASS


def test_migration_spec_with_postgres_snapshot_leaves_pass_unchanged(
    tmp_path: Path,
) -> None:
    report = tmp_path / "t-mig-verify.md"
    _write_report(
        report,
        verdict_marker="PASS",
        body=(
            "## Post-migration evidence\n"
            "```\n"
            "app=# \\d users\n"
            "                Table \"public.users\"\n"
            " Column |  Type   | Nullable\n"
            "--------+---------+----------\n"
            " id     | integer | not null\n"
            "```\n"
        ),
    )
    original_bytes = report.read_bytes()

    spec = tmp_path / "spec.md"
    _write_migration_spec(spec)

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS,
        report,
        "T-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.PASS
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.PASS


def test_missing_snapshot_forces_fail_from_pass(tmp_path: Path) -> None:
    report = tmp_path / "t-mig-verify.md"
    _write_report(report, verdict_marker="PASS")

    spec = tmp_path / "spec.md"
    _write_migration_spec(spec)

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS,
        report,
        "T-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.FAIL
    contents = report.read_text(encoding="utf-8")
    assert "## Notes for Lead Agent" in contents
    assert "PRAGMA table_info" in contents
    assert "SI-003" in contents
    assert contents.rstrip().endswith("## Verdict: FAIL")
    assert parse_verdict(str(report)) is VerdictResult.FAIL


