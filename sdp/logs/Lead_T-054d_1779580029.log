"""Integration tests for the migration-snapshot downgrade rule (T-005(d)).

Exercises the full SI-003 rule end-to-end:

- write a realistic-shaped task spec and verification report,
- run ``_maybe_force_fail_for_missing_migration_snapshot``,
- re-parse the report with ``parse_verdict``,

across the four scenarios specified in T-005@20260503T180144Zd:

1. PASS stays PASS when a migration task ships a real
   ``PRAGMA table_info`` snapshot in the report.
2. PASS is forced to FAIL when a migration task ships a report that
   contains no DB snapshot evidence anywhere.
3. PASS stays PASS when the spec mentions no migration trigger phrase
   (the rule is spec-gated; absence of evidence alone is not enough).
4. FAIL verdicts are not affected by the rule (no duplicate Notes
   block appended to an already-failing report).
"""

from __future__ import annotations

import textwrap
from pathlib import Path

from sdp._orchestrator_impl import _maybe_force_fail_for_missing_migration_snapshot
from sdp.gates.verdict import VerdictResult, parse_verdict


def _write_migration_spec(path: Path) -> None:
    path.write_text(
        textwrap.dedent(
            """
            # Spec — T-INTEG-MIG

            ## Problem Statement
            Add an `email` column to the `users` table:

            ```sql
            ALTER TABLE users ADD COLUMN email TEXT;
            ```

            ## Acceptance Criteria
            - The new column is present after migration.
            """
        ).strip()
        + "\n",
        encoding="utf-8",
    )


def _write_non_migration_spec(path: Path) -> None:
    path.write_text(
        textwrap.dedent(
            """
            # Spec — T-INTEG-MIG

            ## Problem Statement
            Refactor the CLI argument parser to share defaults across commands.

            ## Acceptance Criteria
            - All CLI subcommands inherit the shared default flags.
            """
        ).strip()
        + "\n",
        encoding="utf-8",
    )


def _write_verification_report(
    path: Path,
    *,
    verdict_marker: str,
    snapshot_body: str | None = None,
) -> None:
    evidence_section = ""
    if snapshot_body is not None:
        evidence_section = (
            "\n## Post-migration evidence\n\n"
            "```\n"
            f"{snapshot_body}"
            "```\n"
        )
    path.write_text(
        textwrap.dedent(
            f"""
            # Verification Report — T-INTEG-MIG

            ## Summary
            Verifier ran end-to-end.

            ## Issues Found
            None.
            {evidence_section}
            ## Verdict: {verdict_marker}
            """
        ).strip()
        + "\n",
        encoding="utf-8",
    )


def test_migration_task_with_snapshot_passes_unchanged(tmp_path: Path) -> None:
    spec = tmp_path / "spec.md"
    _write_migration_spec(spec)

    report = tmp_path / "t-integ-mig-verify.md"
    _write_verification_report(
        report,
        verdict_marker="PASS",
        snapshot_body=(
            "sqlite> PRAGMA table_info(users);\n"
            "0|id|INTEGER|0||1\n"
            "1|email|TEXT|1||0\n"
        ),
    )
    original_bytes = report.read_bytes()

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS,
        report,
        "T-INTEG-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.PASS
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.PASS


def test_migration_task_without_snapshot_is_forced_to_fail(tmp_path: Path) -> None:
    spec = tmp_path / "spec.md"
    _write_migration_spec(spec)

    report = tmp_path / "t-integ-mig-verify.md"
    _write_verification_report(report, verdict_marker="PASS")

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS,
        report,
        "T-INTEG-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.FAIL

    contents = report.read_text(encoding="utf-8")
    assert "## Notes for Lead Agent" in contents
    assert "SI-003" in contents
    assert "PRAGMA table_info" in contents
    assert "\\d" in contents
    assert contents.rstrip().endswith("## Verdict: FAIL")
    assert parse_verdict(str(report)) is VerdictResult.FAIL


def test_non_migration_task_without_snapshot_passes_unchanged(tmp_path: Path) -> None:
    spec = tmp_path / "spec.md"
    _write_non_migration_spec(spec)

    report = tmp_path / "t-integ-mig-verify.md"
    _write_verification_report(report, verdict_marker="PASS")
    original_bytes = report.read_bytes()

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.PASS,
        report,
        "T-INTEG-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.PASS
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.PASS


def test_fail_verdict_is_not_re_failed_even_when_snapshot_missing(
    tmp_path: Path,
) -> None:
    spec = tmp_path / "spec.md"
    _write_migration_spec(spec)

    report = tmp_path / "t-integ-mig-verify.md"
    _write_verification_report(report, verdict_marker="FAIL")
    original_bytes = report.read_bytes()

    result = _maybe_force_fail_for_missing_migration_snapshot(
        VerdictResult.FAIL,
        report,
        "T-INTEG-MIG",
        spec_path=spec,
    )

    assert result is VerdictResult.FAIL
    assert report.read_bytes() == original_bytes
    assert parse_verdict(str(report)) is VerdictResult.FAIL

