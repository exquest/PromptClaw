+            "tampered": tampered,
+        }
+        decoded = json.loads(json.dumps(diagnostic, sort_keys=True))
+
+        assert decoded["defaults"]["coding"] == {
+            "model": "qwen3-coder:30b",
+            "port": 11434,
+        }
+        assert decoded["active"]["coding"] == {
+            "model": "deepseek-coder:33b",
+            "port": 11435,
+        }
+        assert decoded["active"]["review"] == {
