ry = songs[0].get(\\\"score_tree_summary\\\", {})\\n++    assert summary.get(\\\"piece_id\\\") == \\\"piece-12\\\"\\n++    assert summary.get(\\\"form_class\\\") == commission.form_class\\n++    assert summary.get(\\\"composition_mode\\\") == commission.composition_mode\\n++\\n+diff --git a/tests/test_resilience_runtime_scripts.py b/tests/test_resilience_runtime_scripts.py\\n+index c29e70a..6444bd5 100644\\n+--- a/tests/test_resilience_runtime_scripts.py\\n++++ b/tests/test_resilience_runtime_scripts.py\\n+@@ -7,6 +7,7 @@ import os\\n+ import sqlite3\\n+ import subprocess\\n+ import sys\\n++from shutil import copy2\\n+ from importlib import import_module\\n+ from pathlib import Path\\n+ \\n+@@ -107,6 +108,7 @@ def _script_env(project_root: Path, tmp_root: Path) -> dict[str, str]:\\n+     env.update(\\n+         {\\n+             \\\"PROJECT_ROOT\\\": str(project_root),\\n++            \\\"PROMPTCLAW_TEST_MODE\\\": \\\"1\\\",\\n+             \\\"TMP_ROOT\\\": str(tmp_root),\\n+             \\\"WORKDIR_NAME\\\": \\\"cypherclaw-work\\\",\\n+             \\\"PYTHON_BIN\\\": sys.executable,\\n+@@ -122,6 +124,15 @@ def _write_fake_command(fake_bin: Path, name: str, body: str) -> None:\\n+     path.chmod(0o755)\\n+ \\n+ \\n++def _install_tool_stack(project_root: Path, *names: str) -> Path:\\n++    tools_dir = project_root / \\\"tools\\\"\\n++    tools_dir.mkdir(exist_ok=True)\\n++    for name in names:\\n++        copy2(TOOLS_DIR / name, tools_dir / name)\\n++        (tools_dir / name).chmod(0o755)\\n++    return tools_dir\\n++\\n++\\n+ def test_init_workdir_creates_tmpfs_clone_and_symlinks_authority_dbs(tmp_path: Path) -> None:\\n+     project_root, tmp_root = _healthy_project(tmp_path)\\n+ \\n+@@ -141,6 +152,23 @@ def test_init_workdir_creates_tmpfs_clone_and_symlinks_authority_dbs(tmp_path: P\\n+     assert (workdir / \\\"sdp.toml\\\").resolve() == project_root / \\\"sdp.toml\\\"\\n+ \\n+ \\n++def test_init_workdir_discovers_project_root_from_script_location(tmp_path: P