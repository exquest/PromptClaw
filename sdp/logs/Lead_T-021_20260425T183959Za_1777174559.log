+        },
+        {
+            "playing": True,
+            "sample_source": "self_bus",
+            "requested_sample_source": "self_bus",
+            "mode": "freeze_bed",
+        },
+    )
+
+    lower = text.lower()
+    assert "currently sampling theramini in via room mic" in lower
+    assert "playing sample freeze bed from source self bus" in lower
