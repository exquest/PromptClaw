e a `SampleBankStorage` (or `SampleArchive`) class representing the \\\"sample bank\\\" abstraction. It will handle copying/moving selected clips to an archive directory and storing associated metadata (e.g., as JSON files side-by-side with the audio).\\n+4. Create comprehensive tests in `tests/test_live_buffer.py` to ensure `LiveBuffer` state updates correctly upon refresh, and that `SampleBankStorage` accurately selects archive paths and persists metadata.\\n+\\n+## Edge Cases\\n+- Missing source files during retention (should gracefully fail or return `None`).\\n+- Empty spectral profiles or missing RMS values on refresh (should default to zeros or retain previous valid values based on the semantics).\\n+- Metadata persistence formatting and safety.\\n+\\n+## Acceptance Criteria\\n+- stable buffers expose source name, capture path, freshness, RMS, spectral profile, and transform history\\n+  - VERIFY: `grep -q \\\"class LiveBuffer\\\" my-claw/tools/senseweave/live_buffer.py`\\n+- sample banks can retain selected clips on archive storage with metadata\\n+  - VERIFY: `grep -q \\\"def retain_clip\\\" my-claw/tools/senseweave/live_buffer.py`\\n+- tests verify buffer refresh and archive path selection\\n+  - VERIFY: `pytest tests/test_live_buffer.py -x`\\ndiff --git a/tests/test_live_buffer.py b/tests/test_live_buffer.py\\nnew file mode 100644\\nindex 0000000..3bdd45f\\n--- /dev/null\\n+++ b/tests/test_live_buffer.py\\n@@ -0,0 +1,85 @@\\n+import json\\n+import os\\n+import sys\\n+import time\\n+from pathlib import Path\\n+\\n+import pytest\\n+\\n+sys.path.insert(0, os.path.join(os.path.dirname(__file__), \\\"..\\\", \\\"my-claw\\\", \\\"tools\\\"))\\n+sys.path.insert(0, os.path.join(os.path.dirname(__file__), \\\"..\\\", \\\"my-claw\\\", \\\"tools\\\", \\\"senseweave\\\"))\\n+\\n+from senseweave.live_buffer import LiveBuffer, SampleBankArchive\\n+\\n+def test_live_buffer_refresh():\\n+    \\\"\\\"\\\"Verify buffer refresh exposes source name, capture path, freshness, RMS, spectral profile, and transform history.\\\"\\\"\\\"\\n+    buffer = LiveBuffer(source_name=\\\"room_mic\\\", capture_path=\\\"/tmp/room_mic.wav\\\")\\n+    \\n+    assert buffer.source_name == \\\"room_mic\\\"\\n+    assert buffer.capture_path == \\\"/tmp/room_mic.wav\\\"\\n+    assert buffer.freshness == 0.0\\n+    assert buffer.rms == 0.0\\n+    assert buffer.spectral_profile == {}\\n+    assert buffer.transform_history == ()\\n+    \\n+    # Refresh\\n+    buffer.refresh(\\n+        freshness=12.5,\\n+        rms=0.45,\\n+        spectral_profile={\\\"centroid\\\": 1200.0, \\\"rolloff\\\": 3400.0},\\n+        transform_history=(\\\"stretch\\\", \\\"pitch_window\\\")\\n+    )\\n+    \\n+    assert buffer.freshness == 12.5\\n+    assert buffer.rms == 0.45\\n+    assert buffer.spectral_profile == {\\\"centroid\\\": 1200.0, \\\"rolloff\\\": 3400.0}\\n+    assert buffer.transform_history == (\\\"stretch\\\", \\\"pitch_window\\\")\\n+\\n+def test_sample_bank_archive_path_selection(tmp_path):\\n+    \\\"\\\"\\\"Verify sample banks can retain selected clips on archive storage with metadata.\\\"\\\"\\\"\\n+    archive_dir = tmp_path / \\\"sample_archive\\\"\\n+    archive = SampleBankArchive(archive_dir=archive_dir)\\n+    \\n+    # Create a dummy source file\\n+    source_file = tmp_path / \\\"source.wav\\\"\\n+    source_file.write_bytes(b\\\"dummy wav content\\\")\\n+    \\n+    metadata = {\\n+        \\\"source_name\\\": \\\"contact_mic\\\",\\n+        \\\"rms\\\": 0.8,\\n+        \\\"spectral_profile\\\": {\\\"centroid\\\": 500.0},\\n+        \\\"tags\\\": [\\\"impulse\\\", \\\"body\\\"]\\n+    }\\n+    \\n+    archived_path = archive.retain_clip(\\n+        source_path=source_file,\\n+        source_name=\\\"contact_mic\\\",\\n+        metadata=metadata\\n+    )\\n+    \\n+    assert archived_path is not None\\n+    assert archived_path.exists()\\n+    assert archived_path.parent == archive_dir / \\\"contact_mic\\\"\\n+    assert archived_path.suffix == \\\".wav\\\"\\n+    \\n+    # Verify metadata is stored\\n+    meta_path = archived_path.with_suffix(\\\".json\\\")\\n+    assert meta_path.exists()\\n+    \\n+    saved_meta = json.loads(meta_path.read_text())\\n+    assert saved_meta[\\\"source_name\\\"] == \\\"contact_mic\\\"\\n+    assert saved_meta[\\\"rms\\\"] == 0.8\\n+    assert saved_meta[\\\"tags\\\"] == [\\\"impulse\\\", \\\"body\\\"]\\n+    assert \\\"timestamp\\\" in saved_meta\\n+\\n+def test_sample_bank_archive_missing_file(tmp_path):\\n+    \\\"\\\"\\\"Verify archive fails gracefully when source file is missing.\\\"\\\"\\\"\\n+    archive = SampleBankArchive(archive_dir=tmp_path / \\\"archive\\\")\\n+    \\n+    archived_path = archive.retain_clip(\\n+        source_path=tmp_path / \\\"nonexistent.wav\\\",\\n+        source_name=\\\"room_mic\\\",\\n+        metadata={}\\n+    )\\n+    \\n+    assert archived_path is None\"}\n+./sdp/logs/Lead_T-022_20260416T043834Z_1776340284.log:18:{\"type\":\"tool_use\",\"timestamp\":\"2026-04-16T11:52:30.813Z\",\"tool_name\":\"run_shell_command\",\"tool_id\":\"run_shell_command_1776340350813_0\",\"parameters\":{\"command\":\"git add my-claw/tools/senseweave/live_buffer.py tests/test_live_buffer.py specs/t-022@20260416t043834z-spec.md progress.md sdp/logs/ sdp/notifications.log sdp/run-log.md && git commit -m \\\"feat: add live-buffer and sample-bank abstractions for SenseWeave inputs\\\"\"}}\n+my-claw/tools/reviewer.py:197:        lines.append(f\"- {completed} tasks completed ({diff_str})\")\n+./my-claw/tools/reviewer.py:197:        lines.append(f\"- {completed} tasks completed ({diff_str})\")\n+\n+ succeeded in 676ms:\n+                                                                                \n+ Usage: sdp-cli [OPTIONS] COMMAND [ARGS]...                                     \n+                                                                                \n+ Software Development Process — dual-agent orchestration CLI.                   \n+                       