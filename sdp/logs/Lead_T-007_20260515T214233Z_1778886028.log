+) -> None:
+    (tmp_path / "docs").mkdir()
+    (tmp_path / "docs" / "router.md").write_text(
+        "# Router\nPAL router restart validates health and smoke evidence.\n"
+    )
+    (tmp_path / "docs" / "deploy.md").write_text(
+        "# Deploy\nRouter deployment uses a host-managed start script.\n"
