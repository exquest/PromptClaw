+def query_pal_knowledge_index(
+    project_root: Path,
+    query: str,
+    *,
+    index_path: Path | None = None,
+    limit: int = 5,
+) -> tuple[PALKnowledgeQueryResult, ...]:
+    """Return ranked local PAL knowledge snippets from a JSONL index."""
