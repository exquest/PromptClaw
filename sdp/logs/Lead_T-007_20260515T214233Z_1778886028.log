+    assert [asdict(result) for result in first] == [asdict(result) for result in second]
+    assert [result.source_path for result in first] == [
+        "docs/tailscale.md",
+        "docs/router.md",
+    ]
+    assert all("docs/unrelated.md" != result.source_path for result in first)
