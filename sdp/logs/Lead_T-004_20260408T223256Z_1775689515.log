_researcher: Researcher | None = None

def get_researcher() -> Researcher:
    global _researcher
    if _researcher is None:
        _researcher = Researcher(
            send_fn=tg_send,
            send_file_fn=tg_send_file,
            observatory=observatory,
        )
    return _researcher


