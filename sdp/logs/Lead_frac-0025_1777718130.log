    assert grain_density_band(8.01) == "moderate"
    assert grain_density_band(16.0) == "moderate"
    assert grain_density_band(16.01) == "dense"
    assert grain_density_band(28.0) == "dense"
    assert grain_density_band(28.01) == "saturated"


