"\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\"\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11566:++tests/test_self_critique.py:295:        from senseweave.tracker_compiler import compile_score_tree_to_tracker\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11569:++tests/test_self_critique.py:391:            compiled = compile_score_tree_to_tracker(\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11570:++tests/test_self_critique.py:399:        assert len(calls) >= 1, \\\\\\\\\\\\\\\"revise_score was not called by compile_score_tree_to_tracker\\\\\\\\\\\\\\\"\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11591:++my-claw/tools/senseweave/tracker_compiler.py:1070:def compile_score_tree_to_tracker(\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11601:++def _sample_gesture_metadata_for_section(score_tree: ScoreTree, section: SectionNode) -> dict[str, str]:\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11602:++    gestures = score_tree.arrangement_plan.get(\\\\\\\\\\\\\\\"sample_gestures\\\\\\\\\\\\\\\", {})\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11637:++    score_tree: ScoreTree,\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11649:++    section = next(section for section in score_tree.sections if section.scene_name == scene_name)\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11650:++    motif = _motif_for_section(score_tree, scene_name)\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11654:++    sample_gesture_metadata = _sample_gesture_metadata_for_section(score_tree, section)\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11665:++    ops = _phrase_ops_for_section(score_tree, scene_name)\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11695:++            \\\\\\\\\\\\\\\"song_title\\\\\\\\\\\\\\\": score_tree.title,\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11696:++            \\\\\\\\\\\\\\\"text_hook\\\\\\\\\\\\\\\": score_tree.primary_hook_text,\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11697:++            \\\\\\\\\\\\\\\"hook_class\\\\\\\\\\\\\\\": score_tree.motifs[0].hook_class if score_tree.motifs else \\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11698:++            \\\\\\\\\\\\\\\"hook_anchor_degrees\\\\\\\\\\\\\\\": json.dumps(list(score_tree.motifs[0].anchor_degrees)) if score_tree.motifs else \\\\\\\\\\\\\\\"[]\\\\\\\\\\\\\\\",\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11699:++            \\\\\\\\\\\\\\\"hook_answer_degrees\\\\\\\\\\\\\\\": json.dumps(list(score_tree.motifs[0].answer_degrees)) if score_tree.motifs else \\\\\\\\\\\\\\\"[]\\\\\\\\\\\\\\\",\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11725:++    score_tree: ScoreTree,\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11733:++    base_song_num = int(score_tree.metadata.get(\\\\\\\\\\\\\\\"song_num\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\"1\\\\\\\\\\\\\\\") or 1)\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11736:++            score_tree,\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11745:++            transition_profile=_transition_profile_for_section(score_tree, index),\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11747:++        for index, section in enumerate(score_tree.sections)\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11761:++def _scene_templates_for_tree(score_tree: ScoreTree, base_score: Score, scale: float = 1.0) -> tuple[SceneTemplate, ...]:\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11764:++    for section in score_tree.sections:\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11768:++        if _sample_gesture_metadata_for_section(score_tree, section):\\\\\\\\n+sdp/logs/Verify_T-023_20260416T043834Z_1776342791.log:11