    assert.equal(features.density, 0.72);
    assert.equal(features.salience, 0.58);
    assert.equal(features.scene, "Second Return");
    assert.equal(features.arc_phase, "Conversation");
    assert.equal(features.tuning, "slendro");
    assert.deepEqual(features.dsp_blocks, ["parallel_delay"]);
    assert.equal(features.event_count, 1);

    assert.equal(runtime.canvas.getAttribute("data-feed-state"), "live");
    assert.equal(runtime.canvas.getAttribute("data-last-scene"), "Second Return");
    assert.equal(runtime.canvas.getAttribute("data-last-tuning"), "slendro");
    assert.equal(runtime.canvas.getAttribute("data-feed-events"), "1");
