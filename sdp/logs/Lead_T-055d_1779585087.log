@@ -0,0 +1,404 @@
+const test = require("node:test");
+const assert = require("node:assert/strict");
+const vm = require("node:vm");
+
+const LIVE_ORIGIN = process.env.CYPHERCLAW_LIVE_ORIGIN || "https://cypherclaw.holdenu.com";
+const RUN_LIVE_E2E = process.env.CYPHERCLAW_RUN_LIVE_E2E === "1";
+const LIVE_E2E_OPTIONS = RUN_LIVE_E2E
+    ? {}
+    : { skip: "set CYPHERCLAW_RUN_LIVE_E2E=1 to verify the deployed live site" };
+
+function liveUrl(path) {
+    const url = new URL(path, LIVE_ORIGIN);
+    url.searchParams.set("t055d", String(Date.now()));
+    return url.toString();
+}
+
+function liveWebSocketUrl() {
+    const url = new URL("/api/cypherclaw/live-midi", LIVE_ORIGIN);
+    url.searchParams.set("t055d", String(Date.now()));
+    url.protocol = url.protocol === "http:" ? "ws:" : "wss:";
+    return url.toString();
+}
+
+async function fetchLiveText(path) {
+    const response = await fetch(liveUrl(path), {
+        headers: { "Cache-Control": "no-cache" },
+    });
+    const body = await response.text();
+    return { response, body };
+}
+
+function extractInlinePageScript(html) {
+    const match = html.match(/<script>\s*\(function \(\) \{[\s\S]*?\}\)\(\);\s*<\/script>/);
+    assert.ok(match, "live CypherClaw page includes the inline runtime script");
+    return match[0].replace(/^<script>\s*/, "").replace(/\s*<\/script>$/, "");
+}
+
+function makeElement(initialAttributes = {}) {
+    const attributes = new Map(Object.entries(initialAttributes));
+    return {
+        src: "",
+        setAttribute(name, value) {
+            attributes.set(name, String(value));
+        },
+        getAttribute(name) {
+            return attributes.has(name) ? attributes.get(name) : null;
+        },
+    };
+}
+
+function makeDeployedRuntime(script) {
+    const drawCalls = [];
+    const animationFrames = [];
+    const eventSources = [];
+    const webSockets = [];
+    const fakeClock = { now: 1000 };
+    let currentGlobalCompositeOperation = "source-over";
+    const canvas = makeElement({
+        "data-live-features-url": "/api/cypherclaw/live-features",
+        "data-live-midi-url": "/api/cypherclaw/live-midi",
+        "data-visualizer-state": "pending",
+        "data-feed-state": "pending",
+        "data-midi-state": "pending",
+        "data-midi-events": "0",
+        "data-midi-shapes": "0",
+    });
+    canvas.width = 1280;
+    canvas.height = 720;
+    canvas.getBoundingClientRect = () => ({ width: 640, height: 360 });
+
+    const context2d = {
+        set fillStyle(value) {
+            drawCalls.push({ op: "fillStyle", value });
+        },
+        set strokeStyle(value) {
+            drawCalls.push({ op: "strokeStyle", value });
+        },
+        set lineWidth(value) {
+            drawCalls.push({ op: "lineWidth", value });
+        },
+        set globalCompositeOperation(value) {
+            currentGlobalCompositeOperation = value;
+            drawCalls.push({ op: "globalCompositeOperation", value });
+        },
+        get globalCompositeOperation() {
+            return currentGlobalCompositeOperation;
+        },
+        setTransform(...args) {
+            drawCalls.push({ op: "setTransform", args });
+        },
+        fillRect(...args) {
+            drawCalls.push({ op: "fillRect", args });
+        },
+        createRadialGradient(...args) {
+            drawCalls.push({ op: "createRadialGradient", args });
+            return {
+                addColorStop(offset, color) {
+                    drawCalls.push({ op: "addColorStop", offset, color });
+                },
+            };
+        },
+        beginPath() {
+            drawCalls.push({ op: "beginPath" });
+        },
+        arc(...args) {
+            drawCalls.push({ op: "arc", args });
+        },
+        fill() {
+            drawCalls.push({ op: "fill" });
+        },
+        moveTo(...args) {
+            drawCalls.push({ op: "moveTo", args });
+        },
+        lineTo(...args) {
+            drawCalls.push({ op: "lineTo", args });
+        },
+        stroke() {
+            drawCalls.push({ op: "stroke" });
+        },
+    };
+    canvas.getContext = (kind) => {
+        assert.equal(kind, "2d");
+        return context2d;
+    };
+
+    const audio = makeElement({
+        "data-stream-url": "/api/cypherclaw/live.m3u8",
+        "data-playback-mode": "pending",
+    });
+    audio.canPlayType = () => "";
+
+    class FakeEventSource {
+        constructor(url) {
+            this.url = url;
+            this.listeners = {};
+            eventSources.push(this);
+        }
+
+        addEventListener(type, listener) {
+            if (!this.listeners[type]) this.listeners[type] = [];
+            this.listeners[type].push(listener);
+        }
+
+        dispatch(type, event) {
+            for (const listener of this.listeners[type] || []) {
+                listener(event);
+            }
+        }
+    }
+
+    class FakeWebSocket {
+        constructor(url) {
+            this.url = url;
+            this.listeners = {};
+            webSockets.push(this);
+        }
+
+        addEventListener(type, listener) {
+            if (!this.listeners[type]) this.listeners[type] = [];
+            this.listeners[type].push(listener);
+        }
+
+        dispatch(type, event = {}) {
+            for (const listener of this.listeners[type] || []) {
+                listener(event);
+            }
+        }
+
+        close() {}
+    }
+
+    const sandbox = {
+        console,
+        window: {},
+        location: {
+            href: LIVE_ORIGIN + "/",
+            protocol: new URL(LIVE_ORIGIN).protocol,
+            host: new URL(LIVE_ORIGIN).host,
+        },
+        document: {
+            readyState: "complete",
+            addEventListener() {},
+            getElementById(id) {
+                if (id === "cypherclaw-visualizer") return canvas;
+                if (id === "cypherclaw-live-audio") return audio;
+                return null;
+            },
+        },
+        EventSource: FakeEventSource,
+        WebSocket: FakeWebSocket,
+        performance: {
+            now() {
+                return fakeClock.now;
+            },
+        },
+        requestAnimationFrame(callback) {
+            animationFrames.push(callback);
+            return animationFrames.length;
+        },
+        Math,
+        Date,
+        JSON,
+        Number,
+        Object,
+        String,
+    };
+    sandbox.window = sandbox;
+    sandbox.window.devicePixelRatio = 1.5;
+
+    vm.runInNewContext(script, sandbox);
+
+    return {
+        animationFrames,
+        canvas,
+        context2d,
+        drawCalls,
+        eventSources,
+        webSockets,
+        runNextFrame(timestamp) {
+            const callback = animationFrames.shift();
+            assert.ok(callback, "a visualizer frame was queued");
+            callback(timestamp);
+        },
+        setNow(timestamp) {
+            fakeClock.now = timestamp;
+        },
+        window: sandbox.window,
+    };
+}
+
+function waitForSocketOpen(socket, label) {
+    return new Promise((resolve, reject) => {
+        const timeout = setTimeout(() => {
+            reject(new Error(`${label} did not open before timeout`));
+        }, 5000);
+        socket.addEventListener("open", () => {
+            clearTimeout(timeout);
+            resolve();
+        }, { once: true });
+        socket.addEventListener("error", () => {
+            clearTimeout(timeout);
+            reject(new Error(`${label} failed to open`));
+        }, { once: true });
+        socket.addEventListener("close", () => {
+            clearTimeout(timeout);
+            reject(new Error(`${label} closed before opening`));
+        }, { once: true });
+    });
+}
+
+function waitForExactMessages(socket, expectedMessages) {
+    const pending = new Set(expectedMessages);
+    return new Promise((resolve, reject) => {
+        const timeout = setTimeout(() => {
+            reject(new Error(`timed out waiting for live MIDI messages: ${Array.from(pending).join(", ")}`));
+        }, 5000);
+        socket.addEventListener("message", (event) => {
+            const data = typeof event.data === "string" ? event.data : String(event.data);
+            if (!pending.has(data)) return;
+            pending.delete(data);
+            if (pending.size === 0) {
+                clearTimeout(timeout);
+                resolve();
+            }
+        });
+        socket.addEventListener("error", () => {
+            clearTimeout(timeout);
+            reject(new Error("receiver errored while waiting for live MIDI fan-out"));
+        }, { once: true });
+        socket.addEventListener("close", () => {
+            clearTimeout(timeout);
+            reject(new Error("receiver closed while waiting for live MIDI fan-out"));
+        }, { once: true });
+    });
+}
+
+test("live deployment exposes the current CypherClaw visualizer surface", LIVE_E2E_OPTIONS, async () => {
+    const { response, body } = await fetchLiveText("/");
+
+    assert.equal(response.status, 200);
+    assert.match(response.headers.get("Content-Type") || "", /text\/html/);
+    assert.match(body, /<title>CypherClaw — live<\/title>/);
+    assert.match(body, /id="cypherclaw-live-page"/);
+    assert.match(body, /id="cypherclaw-live-audio"/);
+    assert.match(body, /data-stream-url="\/api\/cypherclaw\/live\.m3u8"/);
+    assert.match(body, /id="cypherclaw-visualizer"/);
+    assert.match(body, /data-live-features-url="\/api\/cypherclaw\/live-features"/);
+    assert.match(body, /data-live-midi-url="\/api\/cypherclaw\/live-midi"/);
+    assert.match(body, /data-visualizer-layers="audio-features,midi-shapes"/);
+    assert.match(body, /data-midi-layer="foreground"/);
+    assert.match(body, /data-midi-blend-mode="lighter"/);
+    assert.doesNotMatch(body, /being prepared at this address/);
+
+    const features = await fetchLiveText("/api/cypherclaw/live-features");
+    assert.equal(features.response.status, 200);
+    assert.match(features.response.headers.get("Content-Type") || "", /text\/event-stream/);
+    assert.match(features.body, /^event: features$/m);
+    const dataLine = features.body.split("\n").find((line) => line.startsWith("data: "));
+    assert.ok(dataLine, "live feature SSE response includes a data payload");
+    const payload = JSON.parse(dataLine.slice("data: ".length));
+    assert.equal(typeof payload.rms, "number");
+    assert.equal(typeof payload.pitch_hz, "number");
+    assert.equal(typeof payload.brightness, "number");
+    assert.equal(typeof payload.motion, "number");
+});
+
+test("live MIDI feed drives deployed pitch and velocity shapes beside audio features", LIVE_E2E_OPTIONS, async () => {
+    const receiver = new WebSocket(liveWebSocketUrl());
+    const sender = new WebSocket(liveWebSocketUrl());
+    const scriptedMessages = [
+        JSON.stringify({ status: 144, data1: 36, data2: 24, ts: Date.now() / 1000 }),
+        JSON.stringify({ status: 144, data1: 96, data2: 120, ts: Date.now() / 1000 + 0.125 }),
+    ];
+
+    try {
+        await Promise.all([
+            waitForSocketOpen(receiver, "receiver"),
+            waitForSocketOpen(sender, "sender"),
+        ]);
+
+        const fanout = waitForExactMessages(receiver, scriptedMessages);
+        for (const message of scriptedMessages) {
+            sender.send(message);
+        }
+        await fanout;
+    } finally {
+        receiver.close();
+        sender.close();
+    }
+
+    const { body } = await fetchLiveText("/");
+    const runtime = makeDeployedRuntime(extractInlinePageScript(body));
+    assert.equal(runtime.eventSources.length, 1);
+    assert.equal(runtime.eventSources[0].url, "/api/cypherclaw/live-features");
+    assert.equal(runtime.webSockets.length, 1);
+    assert.match(runtime.webSockets[0].url, /^wss:\/\/cypherclaw\.holdenu\.com\/api\/cypherclaw\/live-midi$/);
+
+    runtime.eventSources[0].dispatch("features", {
+        data: JSON.stringify({
+            audio: {
+                rms: 0.46,
+                pitch_hz: 392,
+                spectral_centroid_hz: 2600,
+                onset_rate_hz: 5.5,
+            },
+            visual: {
+                brightness: 0.75,
+                motion: 0.62,
+                texture: 0.42,
+                density: 0.66,
+                salience: 0.58,
+            },
+            scene: { name: "T-055d live e2e" },
+            tuning: { name: "twelve_tet" },
+        }),
+    });
+    runtime.setNow(140);
+    runtime.webSockets[0].dispatch("message", { data: scriptedMessages[0] });
+    runtime.setNow(180);
+    runtime.webSockets[0].dispatch("message", { data: scriptedMessages[1] });
+
+    const shapes = runtime.window.cypherclawLiveMidiShapes;
+    assert.equal(shapes.length, 2);
+    assert.deepEqual(shapes.map((shape) => shape.note), [36, 96]);
+    assert.ok(shapes[0].y_norm > shapes[1].y_norm, "higher MIDI pitch maps higher on the canvas");
+    assert.ok(shapes[1].radius_px > shapes[0].radius_px, "larger velocity maps to a larger shape radius");
+    assert.equal(shapes[0].pitch_axis, "y");
+    assert.equal(shapes[0].size_source, "velocity");
+    assert.equal(runtime.canvas.getAttribute("data-midi-shapes"), "2");
+
+    const shape = shapes[1];
+    const drawStart = runtime.drawCalls.length;
+    runtime.runNextFrame(340);
+    const frameCalls = runtime.drawCalls.slice(drawStart);
+    const backgroundIndex = frameCalls.findIndex((call) => call.op === "fillRect");
+    const audioPulseIndex = frameCalls.findIndex((call) => call.op === "arc" && call.args[2] > 80);
+    const blendIndex = frameCalls.findIndex(
+        (call) => call.op === "globalCompositeOperation" && call.value === "lighter",
+    );
+    const sourceOverIndex = frameCalls.findIndex(
+        (call, index) => index > blendIndex && call.op === "globalCompositeOperation" && call.value === "source-over",
+    );
+    assert.ok(backgroundIndex >= 0, "the frame clears the shared canvas");
+    assert.ok(audioPulseIndex > backgroundIndex, "audio-feature reactions draw before MIDI");
+    assert.ok(blendIndex > audioPulseIndex, "MIDI foreground blend starts after audio drawing");
+
+    const age = 340 - shape.born_at_ms;
+    const life = 1 - Math.min(1, Math.max(0, age / shape.lifetime_ms));
+    const expectedRadius = Math.max(3, shape.radius_px * (0.72 + life * 0.28));
+    const expectedX = Math.max(expectedRadius, Math.min(640 - expectedRadius, shape.x_norm * 640));
+    const expectedY = Math.max(expectedRadius, Math.min(360 - expectedRadius, shape.y_norm * 360));
+    const midiArcIndex = frameCalls.findIndex(
+        (call, index) =>
+            index > blendIndex &&
+            call.op === "arc" &&
+            Math.abs(call.args[0] - expectedX) < 0.001 &&
+            Math.abs(call.args[1] - expectedY) < 0.001 &&
+            Math.abs(call.args[2] - expectedRadius) < 0.001,
+    );
+    assert.ok(midiArcIndex > blendIndex, "MIDI shape draws during the foreground pass");
+    assert.ok(midiArcIndex < sourceOverIndex, "source-over is restored after the MIDI pass");
+    assert.equal(runtime.context2d.globalCompositeOperation, "source-over");
+    assert.equal(runtime.canvas.getAttribute("data-feed-state"), "live");
+});
