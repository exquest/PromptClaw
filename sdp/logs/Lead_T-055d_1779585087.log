   965	function parseLiveMidiEventMessage(data: unknown): string | null {
   966	    if (typeof data !== 'string') {
   967	        return null;
   968	    }
   969
   970	    let parsed: unknown;
   971	    try {
   972	        parsed = JSON.parse(data);
