   980	function isLiveMidiEvent(value: unknown): value is LiveMidiEvent {
   981	    if (value === null || typeof value !== 'object' || Array.isArray(value)) {
   982	        return false;
   983	    }
   984
   985	    const record = value as Record<string, unknown>;
   986	    const keys = Object.keys(record);
   987	    if (keys.length !== LIVE_MIDI_EVENT_KEYS.size) {
   988	        return false;
   989	    }
   990	    if (!keys.every((key) => LIVE_MIDI_EVENT_KEYS.has(key))) {
   991	        return false;
   992	    }
   993
   994	    return (
   995	        isMidiByte(record.status) &&
   996	        isMidiByte(record.data1) &&
   997	        isMidiByte(record.data2) &&
   998	        typeof record.ts === 'number' &&
   999	        Number.isFinite(record.ts)
  1000	    );
  1001	}
