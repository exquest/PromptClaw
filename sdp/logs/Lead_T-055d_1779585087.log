function makeForwardingNamespace(response) {
    const calls = [];
    const namespace = {
        calls,
        idFromName(name) {
            calls.push({ op: "idFromName", name });
            return { name };
        },
        get(id) {
            calls.push({ op: "get", id });
            return {
                fetch: async (request) => {
                    calls.push({
                        op: "fetch",
                        url: request.url,
                        upgrade: request.headers.get("Upgrade"),
                    });
                    return response;
                },
            };
        },
    };
    return namespace;
}

