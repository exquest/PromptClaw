{"type":"tool_use","timestamp":"2026-04-16T23:18:23.950Z","tool_name":"write_file","tool_id":"write_file_1776381503950_0","parameters":{"content":"import math\nfrom dataclasses import dataclass\nfrom src.cypherclaw.render.events import Event\n\n@dataclass\nclass PhraseArchRule:\n    tempo_deviation_pct: float = 4.0\n    amp_deviation_pct: float = 4.0\n    peak: float = 0.6\n    k: float = 1.0\n    arc_shape: str = \"parabolic\"\n\n    def _get_base_arch(self, x: float) -> float:\n        if self.arc_shape == \"parabolic\":\n            return -4 * (x - self.peak)**2 + 1\n        elif self.arc_shape == \"cosine\":\n            return math.cos((x - self.peak) * math.pi)\n        elif self.arc_shape == \"flat\":\n            return 0.0\n        elif self.arc_shape == \"inverted\":\n            return 4 * (x - self.peak)**2 - 1\n        elif self.arc_shape == \"asymmetric-Bezier\":\n            # Simple asymmetric curve peaking at self.peak\n            if x <= self.peak and self.peak > 0:\n                t = x / self.peak\n                return 1.0 - (1.0 - t)**2\n            elif self.peak < 1:\n                t = (x - self.peak) / (1.0 - self.peak)\n                return 1.0 - t**2\n            return 0.0\n        return -4 * (x - self.peak)**2 + 1\n\n    def apply(self, event: Event) -> None:\n        x = event.normalized_phrase_position\n        arch_val = self._get_base_arch(x)\n        \n        tempo_arch_mult = 1.0 + self.k * arch_val * (self.tempo_deviation_pct / 100.0)\n        amp_arch_mult = 1.0 + self.k * arch_val * (self.amp_deviation_pct / 100.0)\n        \n        # Compose multiplicatively with SectionEnvelope.tempo_base\n        section_tempo_base = 1.0\n        if event.section_envelope is not None:\n            section_tempo_base = event.section_envelope.tempo_base\n            \n        event.tempo_mult *= (tempo_arch_mult * section_tempo_base)\n        event.amp_mult *= amp_arch_mult\n","file_path":"src/cypherclaw/render/rules/phrase_arch.py"}}
{"type":"tool_result","timestamp":"2026-04-16T23:18:23.970Z","tool_id":"write_file_1776381503950_0","status":"success"}
{"type":"tool_use","timestamp":"2026-04-16T23:18:31.611Z","tool_name":"write_file","tool_id":"write_file_1776381511610_0","parameters":{"content":"import math\nimport pytest\nfrom src.cypherclaw.render.events import Event, SectionEnvelope\nfrom src.cypherclaw.render.rules.phrase_arch import PhraseArchRule\n\ndef test_phrase_arch_parabolic():\n    rule = PhraseArchRule(arc_shape=\"parabolic\", peak=0.6, k=1.0, tempo_deviation_pct=4.0)\n    \n    # At peak, base_arch should be 1.0\n    event = Event(normalized_phrase_position=0.6)\n    rule.apply(event)\n    assert event.tempo_mult == 1.04\n    assert event.amp_mult == 1.04\n\n    # At x=0, base_arch = -4*(0-0.6)**2 + 1 = 1 - 4*(0.36) = 1 - 1.44 = -0.44\n    # tempo_mult = 1.0 + 1.0 * (-0.44) * 0.04 = 1.0 - 0.0176 = 0.9824\n    event2 = Event(normalized_phrase_position=0.0)\n    rule.apply(event2)\n    assert math.isclose(event2.tempo_mult, 0.9824)\n\ndef test_phrase_arch_cosine():\n    rule = PhraseArchRule(arc_shape=\"cosine\", peak=0.5, k=1.0, tempo_deviation_pct=4.0)\n    event = Event(normalized_phrase_position=0.5)\n    rule.apply(event)\n    assert event.tempo_mult == 1.04\n\n    event2 = Event(normalized_phrase_position=0.0)\n    rule.apply(event2)\n    # cos((0-0.5)*pi) = cos(-pi/2) = 0\n    assert math.isclose(event2.tempo_mult, 1.0)\n\ndef test_phrase_arch_multiplicative_composition():\n    rule = PhraseArchRule(arc_shape=\"parabolic\", peak=0.6, k=1.0, tempo_deviation_pct=4.0)\n    env = SectionEnvelope(tempo_base=1.1)\n    \n    event = Event(normalized_phrase_position=0.6, section_envelope=env, tempo_mult=2.0)\n    rule.apply(event)\n    \n    # previous_tempo_mult = 2.0\n    # tempo_arch_mult = 1.04\n    # section_tempo_base = 1.1\n    # expected: 2.0 * 1.04 * 1.1 = 2.288\n    assert math.isclose(event.tempo_mult, 2.288)\n\ndef test_phrase_arch_variants():\n    # Just verify they don't crash and return reasonable values at peak\n    shapes = [\"parabolic\", \"cosine\", \"flat\", \"inverted\", \"asymmetric-Bezier\"]\n    for shape in shapes:\n        rule = PhraseArchRule(arc_shape=shape, peak=0.6, k=1.0)\n        event = Event(normalized_phrase_position=0.6)\n        rule.apply(event)\n        if shape == \"flat\":\n            assert event.tempo_mult == 1.0\n        elif shape == \"inverted\":\n            assert event.tempo_mult < 1.0\n        else:\n            assert event.tempo_mult > 1.0\n","file_path":"tests/test_phrase_arch.py"}}
