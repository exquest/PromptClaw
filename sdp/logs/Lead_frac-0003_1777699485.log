# ── Depth Classification ──────────────────────────────────────

@dataclass
class ModuleDepth:
    """Analysis result for a single module."""
    path: str
    module_name: str
    depth: int  # 0-4
    reason: str
    classes: list[str] = field(default_factory=list)
    functions: list[str] = field(default_factory=list)
    not_implemented_count: int = 0
    trivial_return_count: int = 0
    real_logic_count: int = 0
    test_count: int = 0
    test_files: list[str] = field(default_factory=list)
    test_coverage: float = 0.0
    test_boosted: bool = False
    line_count: int = 0


def classify_depth(source_path: str | Path) -> ModuleDepth:
    """Classify a module's implementation depth.

    Dispatches to language-specific classifiers based on file extension.
    """
    path = Path(source_path)
    if not path.exists():
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="file does not exist",
        )

    if path.suffix in _JS_TS_EXTENSIONS:
        return classify_depth_js(path)
    if path.suffix == ".py":
        return _classify_depth_python(path)

    return ModuleDepth(
        path=str(path),
        module_name=path.stem,
        depth=-1,
        reason=f"unsupported file type: {path.suffix}",
    )


def _classify_depth_python(path: Path) -> ModuleDepth:
    """Classify a Python module's implementation depth via AST analysis."""
    try:
        source = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        # Source file is not UTF-8 (e.g., vendored Big5 / GBK / latin-1 test
        # fixtures). Fall back to permissive decode so we still report depth=0.
        try:
            source = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return ModuleDepth(
                path=str(path),
                module_name=path.stem,
                depth=-1,
                reason="unreadable file",
            )
    except OSError:
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="unreadable file",
        )
    lines = source.splitlines()
    line_count = len(lines)

    try:
        tree = ast.parse(source)
    except SyntaxError as e:
        return ModuleDepth(
            path=str(path), module_name=path.stem,
            depth=-1, reason=f"syntax error: {e}",
            line_count=line_count,
        )

    classes = []
    functions = []
    not_implemented = 0
    trivial_returns = 0
    real_logic = 0
    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef] = []

    for node in ast.walk(tree):
        if isinstance(node, ast.ClassDef):
            classes.append(node.name)
        elif isinstance(node, ast.FunctionDef | ast.AsyncFunctionDef):
            if _is_public_function(node):
                functions.append(node.name)
                public_function_nodes.append(node)

            # Analyze function body
            body = node.body
