        with connect_generation_queue_db(self.db_path) as conn:
            queue_depth = conn.execute(
                """SELECT COUNT(*)
                   FROM queue_items
                   WHERE status IN (?, ?, ?)""",
                (QUEUED, RUNNING, BLOCKED),
