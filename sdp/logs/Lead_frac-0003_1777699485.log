    tasks_completed INTEGER DEFAULT 0,
    tasks_failed INTEGER DEFAULT 0,
    tokens_used INTEGER DEFAULT 0,
    total_duration_ms INTEGER DEFAULT 0,
    gate_passes INTEGER DEFAULT 0,
    UNIQUE(agent, date)
