print(\\\\\\\"MIDI keyboard listener online\\\\\\\", flush=True)\\\\n+\\\\n+    midi_state = MidiState()\\\\n+    active_notes: dict[int, dict[str, float | int | str]] = {}\\\\n+    recent_pedal_events: list[tuple[float, bool]] = []\\\\n+    last_activity = 0.0\\\\n+    fds: dict[str, int] = {}\\\\n+\\\\n     while True:\\\\n-        for dev, fd in fds.items():\\\\n+        if not fds:\\\\n+            target_devices = devices or discover_keyboard_devices()\\\\n+            fds = _open_devices(target_devices)\\\\n+            write_state(\\\\n+                build_state(\\\\n+                    midi_state,\\\\n+                    active_notes,\\\\n+                    recent_pedal_events,\\\\n+                    last_activity=last_activity,\\\\n+                    now=time.time(),\\\\n+                    active_devices=sorted(fds),\\\\n+                )\\\\n+            )\\\\n+            if not fds:\\\\n+                time.sleep(1.0)\\\\n+                continue\\\\n+\\\\n+        for dev, fd in list(fds.items()):\\\\n             try:\\\\n                 data = os.read(fd, 256)\\\\n-            except (BlockingIOError, OSError):\\\\n+            except BlockingIOError:\\\\n+                continue\\\\n+            except OSError:\\\\n+                _close_device(fd)\\\\n+                del fds[dev]\\\\n                 continue\\\\n-            \\\\n+            if not data:\\\\n+                continue\\\\n+\\\\n+            now = time.time()\\\\n             i = 0\\\\n             while i < len(data):\\\\n                 status = data[i]\\\\n@@ -52,48 +234,52 @@ def run(devices):\\\\n                     i += 1\\\\n                     continue\\\\n                 msg_type = status & 0xF0\\\\n-                if msg_type == 0x90 and i + 2 < len(data):\\\\n-                    note, vel = data[i+1], data[i+2]\\\\n-                    i += 3\\\\n-                    if vel > 0:\\\\n-                        active_notes[note] = {\\\\n-            