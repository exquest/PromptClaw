+    def test_startup_identity_persists_for_standalone_and_federated_modes(self, tmp_path):
+        """Both startup modes must reuse the first persisted identity on reboot."""
+        cases = (
+            ("standalone", None, "federated"),
+            ("federated", "origin-home", "standalone"),
+        )
+
+        for mode, parent_id, reboot_mode in cases:
+            identity_path = tmp_path / mode / "identity.json"
+            first = bootstrap_identity(
+                mode=mode,
+                parent_id=parent_id,
+                identity_path=identity_path,
+            )
+            second = bootstrap_identity(mode=reboot_mode, identity_path=identity_path)
+
+            assert identity_path.exists()
+            assert second.instance_id == first.instance_id
+            assert second.instance_name == first.instance_name
+            assert second.mode == mode
+            assert second.parent_id == parent_id
