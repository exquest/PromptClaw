        if self.cache is None:
            return None
        get = getattr(self.cache, "get", None)
        if not callable(get):
            return None
        return get(payload)

    def _budget_allows(self, payload: Any) -> bool:
        if self.budget is None:
            return True
        allow = getattr(self.budget, "allow", None)
        if not callable(allow):
