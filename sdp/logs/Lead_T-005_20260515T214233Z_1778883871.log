+def _chunk_ids_by_source(chunks: tuple[PALKnowledgeChunk, ...]) -> dict[str, list[str]]:
+    by_source: dict[str, list[str]] = {}
+    for chunk in chunks:
+        by_source.setdefault(chunk.source_path, []).append(chunk.chunk_id)
+    return by_source

