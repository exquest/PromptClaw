+def test_chunk_pal_source_files_keeps_existing_ids_when_new_source_is_added(
+    tmp_path: Path,
+) -> None:
+    (tmp_path / "docs").mkdir()
+    alpha = tmp_path / "docs" / "alpha.md"
+    alpha.write_text("# Alpha\nfirst line\nsecond line\n")
