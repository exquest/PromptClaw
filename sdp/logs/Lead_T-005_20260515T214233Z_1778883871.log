+
+    before = _chunk_ids_by_source(chunk_pal_source_files(tmp_path, max_chars=24))
+    (tmp_path / "docs" / "later.md").write_text("# Later\nnew file only\n")
+    after = _chunk_ids_by_source(chunk_pal_source_files(tmp_path, max_chars=24))
