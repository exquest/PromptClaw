+    assert [chunk.source_path for chunk in chunks] == [
+        "docs/long.md",
+        "docs/long.md",
+        "docs/long.md",
+    ]
+    assert [chunk.text for chunk in chunks] == ["abcdefghij", "klmnopqrst", "uvwxyz"]
+    assert all(len(chunk.text) <= 10 for chunk in chunks)
