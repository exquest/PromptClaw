+        source_path = _source_reference(root, path.resolve())
+        source_sha256 = hashlib.sha256(text.encode("utf-8")).hexdigest()
+        chunks.extend(
+            _chunk_text(
+                source_path=source_path,
+                source_sha256=source_sha256,
+                text=text,
