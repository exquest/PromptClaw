+    (tmp_path / "docs" / "beta.md").write_text("# Beta\nthird line\n")
+    _save_pal_config(tmp_path, ["docs/*.md"])
+
+    first = chunk_pal_source_files(tmp_path, max_chars=24)
+    second = chunk_pal_source_files(tmp_path, max_chars=24)
+
