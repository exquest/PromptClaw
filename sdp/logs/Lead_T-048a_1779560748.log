"""Static tests for the morph_voice SynthDef source (T-047a, CC-050).

The compiled `.scsyndef` is produced by sclang on the CypherClaw deploy
host; this dev box has no SuperCollider toolchain. These tests validate
the SCD source declaratively — name, argument list, default values,
parallel-source UGens, and the morph_x crossfade contract — so that
regressions surface in CI without sclang.
"""
from __future__ import annotations

import re
from pathlib import Path

import pytest

REPO_ROOT = Path(__file__).resolve().parent.parent
SCD_PATH = (
    REPO_ROOT
    / "my-claw"
    / "tools"
    / "senseweave"
    / "synthesis"
    / "voices"
    / "morph_voice.scd"
)


@pytest.fixture(scope="module")
def scd_source() -> str:
    assert SCD_PATH.is_file(), f"morph_voice.scd missing at {SCD_PATH}"
    return SCD_PATH.read_text(encoding="utf-8")


def _arg_block(source: str) -> str:
    match = re.search(r"\|\s*([^|]+?)\s*\|", source, flags=re.DOTALL)
    assert match, "could not locate SynthDef argument list"
    return match.group(1)


def _arg_default(arg_block: str, name: str) -> float:
    pattern = rf"\b{re.escape(name)}\s*=\s*(-?\d+(?:\.\d+)?)"
    match = re.search(pattern, arg_block)
    assert match, f"argument {name!r} missing or has no default"
    return float(match.group(1))


def test_synthdef_name_is_morph_voice(scd_source: str) -> None:
    assert re.search(r"SynthDef\(\\morph_voice\b", scd_source), (
        "SynthDef must be named \\morph_voice"
    )


def test_writes_def_file_to_synthdefs(scd_source: str) -> None:
    assert re.search(r"\.writeDefFile\(\s*\"\.\./synthdefs/?\"\s*\)", scd_source), (
        "compiled .scsyndef must land in synthesis/synthdefs/ "
        "(via ../synthdefs/ from the voices/synthesis source tree)"
    )


def test_declares_morph_x_control_defaulting_to_source_a(scd_source: str) -> None:
    args = _arg_block(scd_source)
    assert _arg_default(args, "morph_x") == 0.0, (
        "morph_x must default to 0.0 so a freshly spawned synth plays source A only"
    )


def test_declares_common_voice_controls(scd_source: str) -> None:
    args = _arg_block(scd_source)
    for control in ("freq", "amp", "attack", "release", "out_bus"):
        _arg_default(args, control)


def test_has_two_parallel_source_voices(scd_source: str) -> None:
    """Source A = Saw, Source B = Pulse, both running in parallel."""
    assert re.search(r"\bSaw\.ar\b", scd_source), "source A must use Saw.ar"
    assert re.search(r"\bPulse\.ar\b", scd_source), "source B must use Pulse.ar"


def test_morph_x_crossfades_source_a_and_source_b(scd_source: str) -> None:
    """morph_x=0 -> source A only; morph_x=1 -> source B only.

    The linear branch must be present: gain_a = 1 - x, gain_b = x.
    Pin both the inversion and the clip so the contract can't drift.
    """
    assert re.search(r"1\.0\s*-\s*\b(?:x|morph_x\w*)\b", scd_source), (
        "linear source A gain must be (1.0 - x) so morph_x=0 plays A at unity"
    )
    # morph_x must be clipped to [0.0, 1.0] before use.
    assert re.search(r"morph_x\.clip\(\s*0\.0\s*,\s*1\.0\s*\)", scd_source), (
        "morph_x must be clipped to [0.0, 1.0] before use as a gain"
    )


def test_declares_morph_curve_selecting_equal_power_by_default(scd_source: str) -> None:
    """`morph_curve` selects the crossfade law (0=linear, 1=equal-power).

    Default is equal-power because it preserves perceived loudness across
    the morph; the linear branch is retained for tests and special cases.
    """
    args = _arg_block(scd_source)
    assert _arg_default(args, "morph_curve") == 1.0, (
        "morph_curve must default to 1 (equal-power) — the musical default"
    )


def test_equal_power_branch_uses_quarter_cosine_pair(scd_source: str) -> None:
    """Equal-power crossfade uses cos(x*pi/2) and sin(x*pi/2).

    That pair satisfies gain_a^2 + gain_b^2 == 1 and hits unity at the
    endpoints, so morph_x=0/1 still produces source A/B at full level.
    """
    assert re.search(r"cos\(\s*\w+\s*\*\s*0\.5pi\s*\)", scd_source), (
        "equal-power source A gain must be cos(x * 0.5pi)"
    )
    assert re.search(r"sin\(\s*\w+\s*\*\s*0\.5pi\s*\)", scd_source), (
        "equal-power source B gain must be sin(x * 0.5pi)"
    )


def test_morph_curve_selects_between_linear_and_equal_power(scd_source: str) -> None:
    """Both gains are dispatched via Select.kr(morph_curve, ...).

    Using Select.kr keeps the choice a per-synth control rather than a
    compile-time constant, so the same SynthDef can render either law.
    """
    select_calls = re.findall(r"Select\.kr\(\s*morph_curve[^)]*\)", scd_source)
    assert len(select_calls) >= 2, (
        "both gain_a and gain_b must be selected by morph_curve via Select.kr"
    )


def test_summed_to_output_bus(scd_source: str) -> None:
    """The two scaled sources are summed before being written to out_bus."""
    assert re.search(
        r"\(\s*source_a\s*\*\s*gain_a\s*\)\s*\+\s*\(\s*source_b\s*\*\s*gain_b\s*\)",
        scd_source,
    ), "scaled sources must be summed: (source_a * gain_a) + (source_b * gain_b)"
    assert re.search(r"Out\.ar\(\s*out_bus\s*,", scd_source), (
        "summed signal must be written to out_bus via Out.ar"
    )


def test_declares_position_control(scd_source: str) -> None:
    """`position` controls stereo placement; defaults to centred (0.0)."""
    args = _arg_block(scd_source)
    assert _arg_default(args, "position") == 0.0, (
        "position must default to 0.0 (centred)"
    )
    assert re.search(
        r"Pan2\.ar\(\s*sig\s*,\s*position\.clip\(\s*-1\.0\s*,\s*1\.0\s*\)\s*\)",
        scd_source,
    ), "Pan2.ar must place the signal using position.clip(-1.0, 1.0)"


def test_declares_fx_bus_routing_controls(scd_source: str) -> None:
    """Per the voice routing contract: declare fx_bus_id and fx_send.

    fx_bus_id defaults to 22 (the morph voice's per-voice FX return bus);
    fx_send defaults to 0.2 (a quiet baseline send level).
    """
// morph_voice.scd — Source for the `morph_voice` SynthDef.
//
// CypherClaw v2 §11 single-line timbre morph (CC-050 / T-047): two
// parallel source voices crossfaded by a continuous `morph_x` control.
// `morph_x = 0.0` produces source A only (saw); `morph_x = 1.0`
// produces source B only (pulse). The `morph_curve` control selects
// the crossfade law: 0 = linear (constant-sum gain), 1 = equal-power
// (constant-power gain; the standard musical crossfade that avoids the
// ~3 dB perceived dip in the middle of a linear fade). The two scaled
// sources are summed and written to `out_bus`. A parallel send scaled
// by `fx_send` is routed to `fx_bus_id` to feed the per-voice FX return,
// matching the voice routing contract used by the other sw_* voices.
//
// Voice: morph
// FX bus: 22
//
// Compile to synthesis/synthdefs/morph_voice.scsyndef via `.writeDefFile`.

(
SynthDef(\morph_voice, {
    | freq = 220.0,
      amp = 0.06,
      attack = 0.05,
      release = 1.2,
      morph_x = 0.0,
      morph_curve = 1,
      pulse_width = 0.5,
      position = 0.0,
      out_bus = 0,
      fx_bus_id = 22,
      fx_send = 0.2 |

    var env, source_a, source_b, x, lin_a, lin_b, ep_a, ep_b, gain_a, gain_b, sig, dry, send;

    env = EnvGen.kr(
        Env.asr(attack.clip(0.005, 4.0), 1.0, release.clip(0.05, 8.0)),
        doneAction: 2
    );

    // Source A: bandlimited saw.
    source_a = Saw.ar(freq);
    // Source B: bandlimited pulse.
    source_b = Pulse.ar(freq, pulse_width.clip(0.05, 0.95));

    // Clamp morph position into the documented [0.0, 1.0] range once.
    x = morph_x.clip(0.0, 1.0);

    // Linear crossfade: gain_a + gain_b == 1.
    lin_a = 1.0 - x;
    lin_b = x;

    // Equal-power crossfade: gain_a^2 + gain_b^2 == 1. Uses the
    // quarter-cosine pair so the endpoints still hit unity exactly at
    // x=0 and x=1 (cos(0)=1, sin(pi/2)=1).
    ep_a = cos(x * 0.5pi);
    ep_b = sin(x * 0.5pi);

    // Select the law per-synth via `morph_curve` (0=linear, 1=equal-power).
    gain_a = Select.kr(morph_curve.clip(0, 1), [lin_a, ep_a]);
    gain_b = Select.kr(morph_curve.clip(0, 1), [lin_b, ep_b]);

    // Sum the two scaled sources to the output bus.
    sig = (source_a * gain_a) + (source_b * gain_b);
    sig = sig * env * amp;
    sig = Pan2.ar(sig, position.clip(-1.0, 1.0));

    dry  = sig;
    send = sig * fx_send.clip(0.0, 1.0);

    Out.ar(out_bus, dry);
    Out.ar(fx_bus_id, send);
}).writeDefFile("../synthdefs/");
)
// sw_sampler.scd — Source stub for the `sw_sampler` granular SynthDef.
//
// Companion source for `synthdefs/sw_sampler.scsyndef`. This is the memory
// voice of the signature quintet: a granular cloud over a buffer (live
// capture, self-quotation, or curated library sample) with a parallel
// send to the dedicated `sw_sampler_fx` bus (default stereo bus 16).
//
// Voice control surface (driven by `senseweave.sampler_dispatch.SamplerDispatcher`
// over OSC):
//
//     bufnum                      sample buffer to scrub (required)
//     amp                         linear output gain (post-envelope)
//     grain_size_ms               grain duration in milliseconds (20..200)
//     density                     grains per second (Impulse.kr trigger rate)
//     position                    initial buffer position, normalised 0..1
//     position_rate               scrub speed in normalised-pos / second
//                                 (0 = freeze on `position`, 1 = ~natural-time
//                                 scrub through the whole buffer per second)
//     pitch_transpose_semitones   constant transposition applied to grain rate
//     pitch_jitter_semitones      ±semitone jitter rolled per-grain (TRand)
//     attack_sec / release_sec    Env.asr envelope shape
//     gate                        sustained gate; gate=0 triggers release tail
//     out_bus                     dry destination (defaults to master 0)
//     fx_bus_id                   effects-bus destination (defaults to 16)
//     fx_send                     level of the parallel send into fx_bus_id
//
// Routing convention: the dry signal is written at full level to `out_bus`
// (master, channels 0/1 in our graph) and a parallel copy scaled by
// `fx_send` is written to `fx_bus_id` (16/17). `sw_sampler_fx` reads from
// 16 and writes the processed tail back to 0, so master receives dry+wet.
// `fx_bus_id` matches the per-voice routing contract used by the seven
// `voices/*.scd` SynthDefs and `cypherclaw.space_reverb.build_voice_s_new_args`.
//
// `EnvGen.kr(Env.asr, gate, doneAction: 2)` self-frees the synth once the
// release tail completes after the caller flips `gate` to 0.
//
// Compile to synthesis/synthdefs/sw_sampler.scsyndef via .writeDefFile.

(
SynthDef(\sw_sampler, {
    | bufnum = 0,
      amp = 0.5,
      grain_size_ms = 80.0,
      density = 12.0,
      position = 0.0,
      position_rate = 0.0,
      pitch_transpose_semitones = 0.0,
      pitch_jitter_semitones = 0.1,
      attack_sec = 0.05,
      release_sec = 0.2,
      gate = 1.0,
      out_bus = 0,
      fx_bus_id = 16,
      fx_send = 0.4 |

    var grainDur, dens, pos, posRate, transpose, jitter, atk, rel, fxAmt;
    var grainTrig, jitterSemis, rate, positionPhase, pan;
    var env, grain, sig, fxOut;

    // Range-clip incoming controls to keep the granular engine numerically
    // stable. The acceptance ranges live here so OSC senders can push raw
    // values without crashing scsynth.
    grainDur  = grain_size_ms.clip(20.0, 200.0) * 0.001;
    dens      = density.clip(1.0, 200.0);
    pos       = position.clip(0.0, 1.0);
    posRate   = position_rate.clip(-8.0, 8.0);
    transpose = pitch_transpose_semitones.clip(-48.0, 48.0);
    jitter    = pitch_jitter_semitones.clip(0.0, 12.0);
    atk       = attack_sec.clip(0.001, 4.0);
    rel       = release_sec.clip(0.001, 8.0);
    fxAmt     = fx_send.clip(0.0, 1.0);

    // Grain trigger train at the requested density (grains per second).
    grainTrig = Impulse.kr(dens);

    // Per-grain pitch jitter (±jitter semitones) plus the constant
    // transpose, both folded into a single rate multiplier.
    jitterSemis = TRand.kr(jitter.neg, jitter, grainTrig);
    rate        = (transpose + jitterSemis).midiratio;

    // Position scrub: normalised position advances at `posRate` units / sec.
    // Sweep.ar emits a continuous ramp so partial-grain interpolation stays
    // smooth; .wrap keeps the phase inside [0, 1] for GrainBuf.
    positionPhase = (pos + Sweep.ar(1, posRate)).wrap(0.0, 1.0);

    // Mild stereo spread per grain; deterministic-feeling at low jitter.
    pan = TRand.kr(-0.6, 0.6, grainTrig);

    // Stereo grain cloud. interp:2 = linear interp; envbufnum:-1 = built-in
    // Hanning grain envelope. maxGrains caps polyphony to keep CPU bounded.
    grain = GrainBuf.ar(
        numChannels: 2,
        trigger:     grainTrig,
        dur:         grainDur,
        sndbuf:      bufnum,
        rate:        rate,
        pos:         positionPhase,
        interp:      2,
        pan:         pan,
        envbufnum:   -1,
        maxGrains:   64
    );

    // Attack / release envelope with sustain held by `gate`. doneAction:2
    // self-frees the synth once the release tail completes.
    env = EnvGen.kr(Env.asr(atk, 1.0, rel), gate, doneAction: 2);

    sig = grain * env * amp;

    // Parallel send architecture: dry at full level to out_bus, scaled
    // copy to the fx bus. Reducing fx_send does not pull down the dry.
    fxOut = sig * fxAmt;

    Out.ar(out_bus, sig);
    Out.ar(fx_bus_id, fxOut);
}).writeDefFile("synthdefs/");
)

