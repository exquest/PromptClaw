[project]
name = "promptclaw"
version = "3.0.0"
description = "An orchestrated multi-agent prompt scaffold with artifact-based handoffs."
readme = "README.md"
requires-python = ">=3.11"
dependencies = ["partitura>=1.8,<2", "librosa>=0.10,<1"]

[project.optional-dependencies]
coherence-pg = ["psycopg2-binary>=2.9", "pgvector>=0.2", "redis>=5.0"]
