+"""CypherClaw composer HTTP API."""
+
+from __future__ import annotations
+
+from .app import create_app
+from .schemas import (
+    MORPH_CURVE_VALUE_BY_TYPE,
+    SUPPORTED_MORPH_CURVE_TYPES,
+    SUPPORTED_MORPH_VOICES,
+    MorphCurveType,
+    MorphPhraseRequest,
+    MorphPhraseResponse,
+    build_morph_phrase_response,
+)
+
+__all__ = [
+    "MORPH_CURVE_VALUE_BY_TYPE",
+    "SUPPORTED_MORPH_CURVE_TYPES",
+    "SUPPORTED_MORPH_VOICES",
+    "MorphCurveType",
+    "MorphPhraseRequest",
+    "MorphPhraseResponse",
+    "build_morph_phrase_response",
