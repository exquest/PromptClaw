resence_state.json\"\n+        presence_file.write_text(json.dumps({\n+            \"occupancy_state\": \"occupied_quiet\",\n+            \"confidence\": 0.9,\n+            \"attention_state\": \"ambient\",\n+            \"attention_score\": 0.2,\n+            \"identity_hint\": \"guest\",\n+            \"identity_confidence\": 0.3,\n+        }))\n+        cadence_file = tmp_path / \"cadence_state.json\"\n+        cadence_file.write_text(json.dumps({\n+            \"cadence_state\": \"wind_down\",\n+            \"day_phase\": \"pre_sleep\",\n+            \"weekly_phase\": \"sunday_settle\",\n+            \"bpm_target\": 58.0,\n+            \"bpm_range\": [52.0, 66.0],\n+            \"loudness_db_range\": [38.0, 45.0],\n+            \"onset_density_range\": [0.2, 1.0],\n+            \"pulse_clarity\": 0.15,\n+            \"voice_cap\": 2,\n+            \"experimentation_bias\": 0.1,\n+        }))\n+        room_presence_file = tmp_path / \"room_presence.json\"\n+        room_presence_file.write_text(json.dumps({\"someone_here\": False, \"brightness\": 0.1}))\n+\n+        monkeypatch.setitem(mod.STATE_FILES, \"presence\", str(presence_file))\n+        monkeypatch.setitem(mod.STATE_FILES, \"cadence\", str(cadence_file))\n+        monkeypatch.setitem(mod.STATE_FILES, \"room_presence\", str(room_presence_file))\n+\n+        w = read_world()\n+\n+        assert w.someone_here is True\n+        assert w.occupancy_state == \"occupied_quiet\"\n+        assert w.attention_state == \"ambient\"\n+        assert w.identity_hint == \"guest\"\n+        assert w.cadence_state == \"wind_down\"\n+        assert w.day_phase == \"pre_sleep\"\n+        assert w.weekly_phase == \"sunday_settle\"\n+        assert w.bpm_target == 58.0\n+\n \n # ---------------------------------------------------------------------------\n # InnerState\ndiff --git a/tests/test_keyboard_chat.py b/tests/test_keyboard_chat.py\nindex 55de207..6edc6ae 100644\n--- a/tests/test_keyboard_chat.py\n+++ b/tests/test_ke