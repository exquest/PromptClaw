+def _write_pcm_wav(path: Path) -> Path:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    samples = (0, 16_384, -16_384, 8_192, -8_192, 0)
+    frames = b"".join(
+        sample.to_bytes(2, byteorder="little", signed=True)
+        for sample in samples
