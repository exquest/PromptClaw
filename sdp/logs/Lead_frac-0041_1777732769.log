CREATE TABLE tasks (
    task_id TEXT PRIMARY KEY,
    description TEXT NOT NULL,
    tier TEXT NOT NULL CHECK (tier IN ('T1','T2','T3')),
    status TEXT NOT NULL CHECK (
        status IN (
            'pending','running','complete','blocked','split','needs_split',
            'rolled_back','quarantined','needs_review'
        )
    ),
    lead_agent TEXT CHECK (lead_agent IN ('claude','codex','gemini')),
    verify_agent TEXT CHECK (verify_agent IN ('claude','codex','gemini')),
    priority INTEGER NOT NULL DEFAULT 0,
    complexity_score INTEGER NOT NULL DEFAULT 0,
    source TEXT NOT NULL DEFAULT 'manual',
    criteria TEXT NOT NULL DEFAULT '',
    rollback_count INTEGER NOT NULL DEFAULT 0,
    parent_task_id TEXT REFERENCES tasks(task_id),
    status_reason TEXT NOT NULL DEFAULT '',
    status_changed_at TEXT NOT NULL DEFAULT '',
    status_changed_by TEXT NOT NULL DEFAULT '',
    frozen INTEGER NOT NULL DEFAULT 0 CHECK (frozen IN (0, 1)),
    frozen_reason TEXT NOT NULL DEFAULT '',
    frozen_at TEXT NOT NULL DEFAULT '',
    frozen_by TEXT NOT NULL DEFAULT '',
    created_at TEXT NOT NULL,
    updated_at TEXT NOT NULL
, manual_override INTEGER NOT NULL DEFAULT 0);
CREATE UNIQUE INDEX idx_tasks_live_normalized_key ON tasks(  lower(trim(replace(replace(COALESCE(description, ''), char(10), ' '), char(9), ' '))),  lower(trim(replace(replace(COALESCE(criteria, ''), char(10), ' '), char(9), ' '))) ) WHERE status != 'split';

