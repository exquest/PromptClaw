-- ============================================================
-- holdenu D1 schema — Phase 2 initial migration
-- ============================================================
-- Q8 release-as-event model: a `releases` row is a release event
-- (single, EP, or album) with 1..N child tracks. A track can appear
-- on multiple release events (single first, album later).
-- ============================================================

-- ---------------------------------------------------------------
-- releases: one row per release event
-- ---------------------------------------------------------------
CREATE TABLE IF NOT EXISTS releases (
    id              TEXT PRIMARY KEY,            -- slug, e.g. "sunset-looking-west"
    name            TEXT NOT NULL,               -- display title for the release
    type            TEXT NOT NULL DEFAULT 'single',  -- 'single' | 'ep' | 'album'
    release_date    TEXT NOT NULL,               -- ISO-8601 timestamp; tracks become public after this
    price_min_cents INTEGER NOT NULL DEFAULT 100, -- PWYW floor in cents (USD)
    artwork_key     TEXT,                        -- R2 key for primary cover art
    description     TEXT,                        -- optional release notes / blog post
    bandcamp_url    TEXT,
    spotify_url     TEXT,
    apple_url       TEXT,
    distrokid_isrc  TEXT,                        -- album-level ISRC if any
    created_at      TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at      TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX IF NOT EXISTS idx_releases_release_date ON releases(release_date);

-- ---------------------------------------------------------------
-- release_tracks: many-to-many between releases and catalog tracks
-- ---------------------------------------------------------------
-- One track can be on multiple releases (single + later album).
-- track_id matches the catalog node id (e.g. "be-holden-u/sunset-looking-west").
CREATE TABLE IF NOT EXISTS release_tracks (
    release_id        TEXT NOT NULL,
    track_id          TEXT NOT NULL,
    track_order       INTEGER NOT NULL DEFAULT 1, -- 1-indexed track number on this release
    track_price_cents INTEGER,                    -- per-track price in cents; NULL = inherit from release
    audio_flac_key    TEXT,                       -- R2 key for lossless master
    audio_aac_key     TEXT,                       -- R2 key for 256k AAC streaming
    preview_key       TEXT,                       -- R2 key for 30s preview clip
    duration_seconds  INTEGER,                    -- canonical duration
    track_isrc        TEXT,
    title_override    TEXT,                       -- if release-version title differs from catalog title
    created_at        TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (release_id, track_id),
    FOREIGN KEY (release_id) REFERENCES releases(id) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_release_tracks_track ON release_tracks(track_id);

-- ---------------------------------------------------------------
-- public_annotations: workspace annotations mirrored for public-safe display
-- ---------------------------------------------------------------
-- Anthony's workspace localStorage is canonical for live edits; a
-- debounced /api/sync POST mirrors the public-safe subset here so
-- holdenu.com can render fresh annotations for released tracks
-- without a Pages rebuild.
-- Only the public-safe fields land here — private notes, drafts,
-- and pipeline overrides for unreleased tracks are NOT mirrored.
CREATE TABLE IF NOT EXISTS public_annotations (
    track_id      TEXT PRIMARY KEY,
    title_override TEXT,
    band_id       TEXT,
    artist_credits TEXT,                         -- JSON array of {artist_id, role}
    mood          TEXT,
    bpm           INTEGER,
    year          INTEGER,
    cover_art_key TEXT,                          -- R2 key for jdenticon-replacement art
    updated_at    TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- ---------------------------------------------------------------
-- orders: Stripe checkout records
-- ---------------------------------------------------------------
-- One row per completed purchase. We keep these for refund handling,
-- analytics, and re-issuing download links via email.
CREATE TABLE IF NOT EXISTS orders (
    id                  TEXT PRIMARY KEY,         -- our internal id
    stripe_session_id   TEXT UNIQUE,
    stripe_payment_intent TEXT,
    customer_email      TEXT NOT NULL,
    release_id          TEXT,                     -- if buying a full release
    track_id            TEXT,                     -- if buying a single track
    amount_paid_cents   INTEGER NOT NULL,
    currency            TEXT NOT NULL DEFAULT 'usd',
    download_token      TEXT NOT NULL UNIQUE,     -- random, signed URL key for /download/<token>
    download_expires_at TEXT NOT NULL,            -- 7 days post purchase typical
    download_count      INTEGER NOT NULL DEFAULT 0,
    fulfilled_at        TEXT,                     -- when the email was sent
    created_at          TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (release_id) REFERENCES releases(id) ON DELETE SET NULL
);

CREATE INDEX IF NOT EXISTS idx_orders_email ON orders(customer_email);
CREATE INDEX IF NOT EXISTS idx_orders_token ON orders(download_token);

-- ---------------------------------------------------------------
-- email_signups: "notify me when this releases" capture
-- ---------------------------------------------------------------
CREATE TABLE IF NOT EXISTS email_signups (
    email          TEXT PRIMARY KEY,
    notify_track_id TEXT,                         -- specific track if signed up via track CTA
    source         TEXT,                          -- 'cta' | 'checkout' | 'newsletter'
    created_at     TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

