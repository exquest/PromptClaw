+    )
+    genre_second = select_genre(
+        arc_phase="Conversation",
+        cadence_state="occupied_day",
+        groove_identity="pulse",
+        recent_genres=[genre_first] * 5,
+    )
+    assert genre_second != genre_first
+
+
