\\"HTTP Error {exc.code}: {exc.reason}{suffix}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _load_cv2():\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Load cv2 lazily so local development without OpenCV still works.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    try:\\\\\\\\\\\\\\\\n+        return importlib.import_module(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"cv2\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+    except Exception:\\\\\\\\\\\\\\\\n+        return None\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def detect_visual_person_cue(frame_path: str, cv2_module=None) -> dict[str, Any]:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Detect explicit face/person cues with OpenCV when available.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cv2_module = _load_cv2() if cv2_module is None else cv2_module\\\\\\\\\\\\\\\\n+    if cv2_module is None:\\\\\\\\\\\\\\\\n+        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    try:\\\\\\\\\\\\\\\\n+        image = cv2_module.imread(frame_path)\\\\\\\\\\\\\\\\n+        if image is None:\\\\\\\\\\\\\\\\n+            return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0}\\\\\\\\\\\\\\\\n+        gray = cv2_module.cvtColor(image, cv2_module.COLOR_BGR2GRAY)\\\\\\\\\\\\\\\\n+        cascade = cv2_module.CascadeClassifier(\\\\\\\\\\\\\\\\n+            os.path.join(cv2_module.data.haarcascades, \\\\\\\\\\\\\\\\\\\\\\\\\\\