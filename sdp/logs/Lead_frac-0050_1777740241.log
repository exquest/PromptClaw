\\"wave\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    return default\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def role_octave_shift_for_patch(role: str, patch_name: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") -> int:\\\\\\\\\\\\\\\\n+    shifts = _PATCH_ROLE_OCTAVE_SHIFT.get(patch_name, _DEFAULT_ROLE_OCTAVE_SHIFT)\\\\\\\\\\\\\\\\n+    return shifts.get(role, 0)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _wrap_scale_degree(degree: int) -> int:\\\\\\\\\\\\\\\\n+    return ((degree - 1) % 7) + 1\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _merge_progression_banks(*banks: Sequence[Sequence[int]]) -> tuple[list[int], ...]:\\\\\\\\\\\\\\\\n+    merged: list[list[int]] = []\\\\\\\\\\\\\\\\n+    seen: set[tuple[int, ...]] = set()\\\\\\\\\\\\\\\\n+    for bank in banks:\\\\\\\\\\\\\\\\n+        for progression in bank:\\\\\\\\\\\\\\\\n+            frozen = tuple(int(degree) for degree in progression)\\\\\\\\\\\\\\\\n+            if frozen in seen:\\\\\\\\\\\\\\\\n+                continue\\\\\\\\\\\\\\\\n+            seen.add(frozen)\\\\\\\\\\\\\\\\n+            merged.append(list(frozen))\\\\\\\\\\\\\\\\n+    return tuple(merged)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _motif_offsets(\\\\\\\\\\\\\\\\n+    length: int,\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    family: str,\\\\\\\\\\\\\\\\n+    cadence_state: str,\\\\\\\\\\\\\\\\n+    energy: float,\\\\\\\\\\\\\\\\n+    rng,\\\\\\\\\\\\\\\\n+) -> list[int]:\\\\\\\\\\\\\\\\n+    family_key = family if family in _FAMILY_MELODIC_CELLS else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"default\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cell_name = rng.choice(_FAMILY_MELODIC_CELLS[family_key])\\\\\\\\\\\\\\\\n+    cell = list(_MELODIC_OFFSET_CELLS[cell_name])\\\\\\\\\\\\\\\\n+    if len(cell) > 1:\\\\\\\\\\\\\\\\n+        rotation = rng.randrange(len(cell))\\\\\\\\\\\\\\\\n+        cell = cell[rotation:] + cell[:rotation]\\\\\\\\\\\\\\\\n+    if rng.random() < 0.35:\\\\\\\\\\\\\\\\n+        cell = [-value for value in cell]\\\\\\\\\\\\\\\\n+    if cadence_state in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sleep\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"wind_down\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} and rng.random() < 0.6:\\\\\\\\\\\\\\\\n+        cell = list(reversed(cell))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    base_limit = _CADENCE_LEAP_LIMIT.get(cadence_state, 2)\\\\\\\\\\\\\\\\n+    family_scale = 1.2 if family in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"forge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} else 0.75 if family in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"drift\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"nocturne\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} else 1.0\\\\\\\\\\\\\\\\n+    energy_scale = 0.75 + (energy * 0.8)\\\\\\\\\\\\\\\\n+    limit = max(1, int(round(base_limit * family_scale)))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    offsets: list[int] = []\\\\\\\\\\\\\\\\n+    for index in range(length):\\\\\\\\\\\\\\\\n+        raw = cell[index % len(cell)]\\\\\\\\\\\\\\\\n+        shaped = int(round(raw * energy_scale))\\\\\\\\\\\\\\\\n+        offsets.append(max(-limit, min(limit, shaped)))\\\\\\\\\\\\\\\\n+    return offsets\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _rhythm_pattern(\\\\\\\\\\\\\\\\n+    length: int,\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    family: str,\\\\\\\\\\\\\\\\n+    cadence_state: str,\\\\\\\\\\\\\\\\n+    energy: float,\\\\\\\\\\\\\\\\n+    rng,\\\\\\\\\\\\\\\\n+) -> list[float]:\\\\\\\\\\\\\\\\n+    family_key = family if family in _FAMILY_RHYTHM_CELLS else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"default\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cell_name = rng.choice(_FAMILY_RHYTHM_CELLS[family_key])\\\\\\\\\\\\\\\\n+    cell = list(_RHYTHM_CELLS[cell_name])\\\\\\\\\\\\\\\\n+    duration_scale = _CADENCE_DURATION_SCALE.get(cadence_state, 1.0) * (1.15 - energy * 0.35)\\\\\\\\\\\\\\\\n+    return [\\\\\\\\\\\\\\\\n+        round(_clamp(cell[index % len(cell)] * duration_scale, 0.5, 2.5), 2)\\\\\\\\\\\\\\\\n+        for index in range(length)\\\\\\\\\\\\\\\\n+    ]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _degree_distance(key: str, freq_hz: float, degree: int) -> float:\\\\\\\\\\\\\\\\n+    target = _scale_degree_to_freq(key, degree)\\\\\\\\\\\\\\\\n+    return abs(math.log(max(freq_hz, 1.0) / max(target, 1.0)))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _nearest_scale_degree_for_freq(key: str, freq_hz: float) -> int:\\\\\\\\\\\\\\\\n+    candidates = range(1, 9)\\\\\\\\\\\\\\\\n+    return min(candidates, key=lambda degree: _degree_distance(key, freq_hz, degree))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _coerce_memory_fragment(fragment: Mapping[str, object]) -> list[float]:\\\\\\\\\\\\\\\\n+    raw_notes = fragment.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"notes\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+    if not isinstance(raw_notes, Sequence) or isinstance(raw_notes, (str, bytes)):\\\\\\\\\\\\\\\\n+        return []\\\\\\\\\\\\\\\\n+    notes = [float(value) for value in raw_notes if isinstance(value, (int, float)) and float(value) > 0.0]\\\\\\\\\\\\\\\\n+    if len(notes) < 4:\\\\\\\\\\\\\\\\n+        return []\\\\\\\\\\\\\\\\n+    span = max(notes) / max(min(notes), 1.0)\\\\\\\\\\\\\\\\n+    if span > 2.15:\\\\\\\\\\\\\\\\n+        return []\\\\\\\\\\\\\\\\n+    return notes\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _answer_memory_degrees(degrees: Sequence[int]) -> list[int]:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Turn a recalled fragment into a related answering gesture.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    answered = [int(_clamp(degree, 1, 8)) for degree in degrees]\\\\\\\\\\\\\\\\n+    if len(answered) < 2:\\\\\\\\\\\\\\\\n+        return answered\\\\\\\\\\\\\\\\n+    if len(answered) >= 3 and abs(answered[-2] - answered[-3]) > 2:\\\\\\\\\\\\\\\\n+        direction = 1 if answered[-2] > answered[-3] else -1\\\\\\\\\\\\\\\\n+        answered[-2] = int(_clamp(answered[-3] + direction, 1, 8))\\\\\\\\\\\\\\\\n+    answered[-1] = 1 if answered[-2] <= 3 else 3\\\\\\\\\\\\\\\\n+    return answered\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _memory_phrase_targets(\\\\\\\\\\\\\\\\n+    key: str,\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    memory_fragments: Sequence[Mapping[str, object]],\\\\\\\\\\\\\\\\n+    family: str,\\\\\\\\\\\\\\\\n+    cadence_state: str,\\\\\\\\\\\\\\\\n+    progression_profile: str,\\\\\\\\\\\\\\\\n+    rng,\\\\\\\\\\\\\\\\n+) -> list[int]:\\\\\\\\\\\\\\\\n+    usable: list[tuple[float, list[float], str]] = []\\\\\\\\\\\\\\\\n+    for fragment in memory_fragments:\\\\\\\\\\\\\\\\n+        if not isinstance(fragment, Mapping):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        notes = _coerce_memory_fragment(fragment)\\\\\\\\\\\\\\\\n+        if not notes:\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        usable.append(\\\\\\\\\\\\\\\\n+            (\\\\\\\\\\\\\\\\n+                float(fragment.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"score\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 0.0) or 0.0),\\\\\\\\\\\\\\\\n+                notes,\\\\\\\\\\\\\\\\n+                str(fragment.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"context\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"),\\\\\\\\\\\\\\\\n+            )\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\n+    if not usable:\\\\\\\\\\\\\\\\n+        return []\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def _rank(item: tuple[float, list[float], str]) -> tuple[float, float]:\\\\\\\\\\\\\\\\n+        score, _notes, context = item\\\\\\\\\\\\\\\\n+        context_lower = context.lower()\\\\\\\\\\\\\\\\n+        context_bonus = 0.0\\\\\\\\\\\\\\\\n+        if family and family.lower() in context_lower:\\\\\\\\\\\\\\\\n+            context_bonus += 0.15\\\\\\\\\\\\\\\\n+        if cadence_state and cadence_state.lower() in context_lower:\\\\\\\\\\\\\\\\n+            context_bonus += 0.1\\\\\\\\\\\\\\\\n+        if progression_profile and progression_profile.lower() in context_lower:\\\\\\\\\\\\\\\\n+            context_bonus += 0.16\\\\\\\\\\\\\\\\n+        if \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tracker\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in context_lower:\\\\\\\\\\\\\\\\n+            context_bonus += 0.05\\\\\\\\\\\\\\\\n+        return (score + context_bonus, float(len(_notes)))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    ranked = sorted(usable, key=_rank, reverse=True)\\\\\\\\\\\\\\\\n+    _score, notes, context = ranked[0]\\\\\\\\\\\\\\\\n+    source_root = max(notes[0], 1.0)\\\\\\\\\\\\\\\\n+    target_root = _scale_degree_to_freq(key, 1)\\\\\\\\\\\\\\\\n+    transposed = [target_root * (freq_hz / source_root) for freq_hz in notes]\\\\\\\\\\\\\\\\n+    degrees = [_nearest_scale_degree_for_freq(key, freq_hz) for freq_hz in transposed]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    context_lower = context.lower()\\\\\\\\\\\\\\\\n+    family_match = family and family.lower() in context_lower\\\\\\\\\\\\\\\\n+    profile_match = progression_profile and progression_profile.lower() in context_lower\\\\\\\\\\\\\\\\n+    transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"identity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    if cadence_state in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sleep\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"wind_down\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n+        transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"reverse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if rng.random() < 0.55 else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"identity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    elif family_match and profile_match and rng.random() < 0.65:\\\\\\\\\\\\\\\\n+        transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"answer\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    elif family in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"forge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} and rng.random() < 0.45:\\\\\\\\\\\\\\\\n+        transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rotate\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    elif rng.random() < 0.2:\\\\\\\\\\\\\\\\n+        transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"reverse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    if transform == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"reverse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        degrees = list(reversed(degrees))\\\\\\\\\\\\\\\\n+    elif transform == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rotate\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and len(degrees) > 1:\\\\\\\\\\\\\\\\n+        degrees = degrees[1:] + degrees[:1]\\\\\\\\\\\\\\\\n+    elif transform == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"answer\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        degrees = _answer_memory_degrees(degrees)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    return [int(_clamp(degree, 1, 8)) for degree in degrees]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _apply_hook_degrees(phrase: Phrase, degrees: Sequence[int]) -> Phrase:\\\\\\\\\\\\\\\\n+    if not degrees or not phrase.notes:\\\\\\\\\\\\\\\\n+        return phrase\\\\\\\\\\\\\\\\n+    hooked_notes = list(phrase.notes)\\\\\\\\\\\\\\\\n+    hook_span = min(len(hooked_notes), max(1, len(degrees) - 1))\\\\\\\\\\\\\\\\n+    for index, degree in enumerate(degrees[:hook_span]):\\\\\\\\\\\\\\\\n+        hooked_notes[index] = Note(\\\\\\\\\\\\\\\\n+            scale_degree=int(_clamp(degree, 1, 8)),\\\\\\\\\\\\\\\\n+            duration_beats=hooked_notes[index].duration_beats,\\\\\\\\\\\\\\\\n+            accent=True if index == 0 else hooked_notes[index].accent,\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\n+    return Phrase(\\\\\\\\\\\\\\\\n+        notes=hooked_notes,\\\\\\\\\\\\\\\\n+        voice=phrase.voice,\\\\\\\\\\\\\\\\n+        dynamic=phrase.dynamic,\\\\\\\\\\\\\\\\n+        role=phrase.role,\\\\\\\\\\\\\\\\n+        metadata=dict(phrase.metadata),\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _shape_patch_ending(phrase: Phrase, *, patch_name: str) -> Phrase:\\\\\\\\\\\\\\\\n+    if len(phrase.notes) < 2:\\\\\\\\\\\\\\\\n+        return phrase\\\\\\\\\\\\\\\\n+    notes = list(phrase.notes)\\\\\\\\\\\\\\\\n+    first = notes[0].scale_degree\\\\\\\\\\\\\\\\n+    last = notes[-1].scale_degree\\\\\\\\\\\\\\\\n+    if patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_monastery\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and last > first:\\\\\\\\\\\\\\\\n+        notes[-1] = Note(scale_degree=max(1, first - 1), duration_beats=notes[-1].duration_beats, accent=notes[-1].accent)\\\\\\\\\\\\\\\\n+    elif patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_procession\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and last < first:\\\\\\\\\\\\\\\\n+        notes[-1] = Note(scale_degree=min(8, first + 2), duration_beats=notes[-1].duration_beats, accent=True)\\\\\\\\\\\\\\\\n+    return Phrase(notes=notes, voice=phrase.voice, dynamic=phrase.dynamic, role=phrase.role, metadata=dict(phrase.metadata))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n # ---------------------------------------------------------------------------\\\\\\\\\\\\\\\\n # Melody generation\\\\\\\\\\\\\\\\n@@ -156,6 +588,16 @@ def generate_melody(\\\\\\\\\\\\\\\\n     key: str,\\\\\\\\\\\\\\\\n     length: int = 8,\\\\\\\\\\\\\\\\n     contour: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    family: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"default\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    cadence_state: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    patch_name: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    progression_profile: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    energy: float = 0.5,\\\\\\\\\\\\\\\\n+    valence: float = 0.5,\\\\\\\\\\\\\\\\n+    arousal: float = 0.5,\\\\\\\\\\\\\\\\n+    variation_seed: int | None = None,\\\\\\\\\\\\\\\\n+    memory_fragments: Sequence[Mapping[str, object]] | None = None,\\\\\\\\\\\\\\\\n ) -> Phrase:\\\\\\\\\\\\\\\\n     \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Create a melody phrase using scale degrees 1-8.\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n@@ -166,35 +608,87 @@ def generate_melody(\\\\\\\\\\\\\\\\n     \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n     contour_fn = _CONTOUR_FNS.get(contour, _contour_arch)\\\\\\\\\\\\\\\\n     targets = contour_fn(length)\\\\\\\\\\\\\\\\n+    rng = _make_seeded_rng(\\\\\\\\\\\\\\\\n+        key,\\\\\\\\\\\\\\\\n+        length,\\\\\\\\\\\\\\\\n+        contour,\\\\\\\\\\\\\\\\n+        family,\\\\\\\\\\\\\\\\n+        cadence_state,\\\\\\\\\\\\\\\\n+        patch_name,\\\\\\\\\\\\\\\\n+        progression_profile,\\\\\\\\\\\\\\\\n+        round(energy, 3),\\\\\\\\\\\\\\\\n+        round(valence, 3),\\\\\\\\\\\\\\\\n+        round(arousal, 3),\\\\\\\\\\\\\\\\n+        variation_seed=variation_seed,\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+    motif_offsets = _motif_offsets(\\\\\\\\\\\\\\\\n+        length,\\\\\\\\\\\\\\\\n+        family=family,\\\\\\\\\\\\\\\\n+        cadence_state=cadence_state,\\\\\\\\\\\\\\\\n+        energy=energy,\\\\\\\\\\\\\\\\n+        rng=rng,\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+    rhythm = _rhythm_pattern(\\\\\\\\\\\\\\\\n+        length,\\\\\\\\\\\\\\\\n+        family=family,\\\\\\\\\\\\\\\\n+        cadence_state=cadence_state,\\\\\\\\\\\\\\\\n+        energy=energy,\\\\\\\\\\\\\\\\n+        rng=rng,\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+    memory_targets = []\\\\\\\\\\\\\\\\n+    if memory_fragments:\\\\\\\\\\\\\\\\n+        memory_targets = _memory_phrase_targets(\\\\\\\\\\\\\\\\n+            key,\\\\\\\\\\\\\\\\n+            memory_fragments=memory_fragments,\\\\\\\\\\\\\\\\n+            family=family,\\\\\\\\\\\\\\\\n+            cadence_state=cadence_state,\\\\\\\\\\\\\\\\n+            progression_profile=progression_profile,\\\\\\\\\\\\\\\\n+            rng=rng,\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n     chord_tones = {1, 3, 5, 8}\\\\\\\\\\\\\\\\n     notes: list[Note] = []\\\\\\\\\\\\\\\\n-    current_deg = int(round(_clamp(targets[0], 1.0, 8.0)))\\\\\\\\\\\\\\\\n+    initial_target = (\\\\\\\\\\\\\\\\n+        memory_targets[0]\\\\\\\\\\\\\\\\n+        if memory_targets\\\\\\\\\\\\\\\\n+        else _clamp(targets[0] + motif_offsets[0], 1.0, 8.0)\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+    current_deg = int(round(_clamp(initial_target, 1.0, 8.0)))\\\\\\\\\\\\\\\\n+    leap_bias = 0.18 + (0.18 * arousal) + (0.12 if family in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"forge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} else 0.0)\\\\\\\\\\\\\\\\n+    leap_bias *= _PATCH_LEAP_MULTIPLIER.get(patch_name, 1.0)\\\\\\\\\\\\\\\\n+    step_limit = _CADENCE_LEAP_LIMIT.get(cadence_state, 2)\\\\\\\\\\\\\\\\n+    if cadence_state in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sleep\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"wind_down\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n+        leap_bias *= 0.45\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n     for i in range(length):\\\\\\\\\\\\\\\\n-        target = targets[i]\\\\\\\\\\\\\\\\n+        if i < len(memory_targets):\\\\\\\\\\\\\\\\n+            target = float(memory_targets[i])\\\\\\\\\\\\\\\\n+        else:\\\\\\\\\\\\\\\\n+            target = _clamp(targets[i] + motif_offsets[i], 1.0, 8.0)\\\\\\\\\\\\\\\\n         # Move toward target: stepwise (1-2), occasionally leap to chord tone\\\\\\\\\\\\\\\\n         diff = target - current_deg\\\\\\\\\\\\\\\\n         if abs(diff) <= 2:\\\\\\\\\\\\\\\\n             # Step toward target\\\\\\\\\\\\\\\\n             step = int(round(diff))\\\\\\\\\\\\\\\\n-        elif random.random() < 0.3 and abs(diff) > 2:\\\\\\\\\\\\\\\\n+        elif rng.random() < leap_bias and abs(diff) > 2:\\\\\\\\\\\\\\\\n             # Leap to nearest chord tone in the direction of target\\\\\\\\\\\\\\\\n-            direction = 1 if diff > 0 else -1\\\\\\\\\\\\\\\\n             candidates = sorted(chord_tones, key=lambda d: abs(d - target))\\\\\\\\\\\\\\\\n             step = candidates[0] - current_deg\\\\\\\\\\\\\\\\n         else:\\\\\\\\\\\\\\\\n             # Stepwise: move 1-2 in the right direction\\\\\\\\\\\\\\\\n             direction = 1 if diff > 0 else -1\\\\\\\\\\\\\\\\n-            step = direction * random.choice([1, 1, 2])\\\\\\\\\\\\\\\\n+            step = direction * rng.choice([1, 1, 2])\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+        step = max(-step_limit, min(step_limit, step))\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n         current_deg = int(_clamp(current_deg + step, 1, 8))\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-        # Duration: slightly varied around 1 beat\\\\\\\\\\\\\\\\n-        duration = random.choice([0.5, 0.75, 1.0, 1.0, 1.0, 1.5])\\\\\\\\\\\\\\\\n+        duration = rhythm[i]\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n         # Accent on chord tones, first note, and downbeats\\\\\\\\\\\\\\\\n-        accent = current_deg in chord_tones and random.random() < 0.3\\\\\\\\\\\\\\\\n+        accent_chance = _CADENCE_ACCENT_BIAS.get(cadence_state, 0.22)\\\\\\\\\\\\\\\\n+        accent_chance *= _PATCH_ACCENT_MULTIPLIER.get(patch_name, 1.0)\\\\\\\\\\\\\\\\n+        accent = current_deg in chord_tones and rng.random() < accent_chance\\\\\\\\\\\\\\\\n         if i == 0:\\\\\\\\\\\\\\\\n             accent = True\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n@@ -221,6 +715,9 @@ def generate_bass_line(\\\\\\\\\\\\\\\\n     key: str,\\\\\\\\\\\\\\\\n     progression: list[int],\\\\\\\\\\\\\\\\n     beats_per_chord: int = 3,\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    pattern_style: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"root_walk\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    variation_seed: int | None = None,\\\\\\\\\\\\\\\\n ) -> Phrase:\\\\\\\\\\\\\\\\n     \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Create a bass line following a chord progression.\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n@@ -228,27 +725,75 @@ def generate_bass_line(\\\\\\\\\\\\\\\\n     progression is a list of root scale degrees (e.g. [1, 4, 5, 1]).\\\\\\\\\\\\\\\\n     \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n     notes: list[Note] = []\\\\\\\\\\\\\\\\n+    rng = _make_seeded_rng(\\\\\\\\\\\\\\\\n+        key,\\\\\\\\\\\\\\\\n+        tuple(progression),\\\\\\\\\\\\\\\\n+        beats_per_chord,\\\\\\\\\\\\\\\\n+        pattern_style,\\\\\\\\\\\\\\\\n+        variation_seed=variation_seed,\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n     for root_deg in progression:\\\\\\\\\\\\\\\\n-        third_deg = root_deg + 2\\\\\\\\\\\\\\\\n-        fifth_deg = root_deg + 4\\\\\\\\\\\\\\\\n-\\\\\\\\\\\\\\\\n-        for beat in range(beats_per_chord):\\\\\\\\\\\\\\\\n-            if beat == 0:\\\\\\\\\\\\\\\\n-                # Root on beat 1\\\\\\\\\\\\\\\\n-                notes.append(Note(\\\\\\\\\\\\\\\\n-                    scale_degree=root_deg,\\\\\\\\\\\\\\\\n-                    duration_beats=1.0,\\\\\\\\\\\\\\\\n-                    accent=True,\\\\\\\\\\\\\\\\n-                ))\\\\\\\\\\\\\\\\n-            else:\\\\\\\\\\\\\\\\n-                # Weak beats: alternate fifth and third\\\\\\\\\\\\\\\\n+        low_root = _wrap_scale_degree(root_deg)\\\\\\\\\\\\\\\\n+        third_deg = _wrap_scale_degree(root_deg + 2)\\\\\\\\