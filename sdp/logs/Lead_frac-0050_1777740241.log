def _ok_upload(job_id: str, filename: str, body: bytes, ct: str) -> UploadResult:
    return UploadResult(
        bucket="b",
        key=f"jobs/{job_id}/{filename}",
        url=f"https://b.s3.us-west-2.amazonaws.com/jobs/{job_id}/{filename}",
        bytes_uploaded=len(body),
    )


