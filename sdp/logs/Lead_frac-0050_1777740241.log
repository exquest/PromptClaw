\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    msg_type = status & 0xF0\\\\\\\\\\\\\\\\n+    if msg_type == 0x90:\\\\\\\\\\\\\\\\n+        note, velocity = data1, data2\\\\\\\\\\\\\\\\n+        midi_state.note_on(note, velocity)\\\\\\\\\\\\\\\\n+        if velocity > 0:\\\\\\\\\\\\\\\\n+            active_notes[note] = {\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"freq\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": midi_to_freq(note),\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": note_to_name(note),\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"velocity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": velocity,\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"time\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": now,\\\\\\\\\\\\\\\\n+            }\\\\\\\\\\\\\\\\n+            return now\\\\\\\\\\\\\\\\n+        active_notes.pop(note, None)\\\\\\\\\\\\\\\\n+        return last_activity\\\\\\\\\\\\\\\\n+    if msg_type == 0x80:\\\\\\\\\\\\\\\\n+        note = data1\\\\\\\\\\\\\\\\n+        midi_state.note_off(note)\\\\\\\\\\\\\\\\n+        active_notes.pop(note, None)\\\\\\\\\\\\\\\\n+        return last_activity\\\\\\\\\\\\\\\\n+    if msg_type == 0xB0:\\\\\\\\\\\\\\\\n+        cc, value = data1, data2\\\\\\\\\\\\\\\\n+        previous_sustain = midi_state.sustain_pedal\\\\\\\\\\\\\\\\n+        midi_state.control_change(cc, value)\\\\\\\\\\\\\\\\n+        if cc == 64 and midi_state.sustain_pedal != previous_sustain:\\\\\\\\\\\\\\\\n+            recent_pedal_events.append((now, midi_state.sustain_pedal))\\\\\\\\\\\\\\\\n+            del recent_pedal_events[:-8]\\\\\\\\\\\\\\\\n+        return now\\\\\\\\\\\\\\\\n+    if msg_type == 0xE0:\\\\\\\\\\\\\\\\n+        midi_state.pitch_bend_change((data2 << 7) | data1)\\\\\\\\\\\\\\\\n+        return now\\\\\\\\\\\\\\\\n+    if msg_type == 0xD0:\\\\\\\\\\\\\\\\n+        return now\\\\\\\\\\\\