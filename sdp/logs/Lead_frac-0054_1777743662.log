"""Shared test bootstrap."""

from __future__ import annotations

import os
import sys
from pathlib import Path

import pytest

REPO_ROOT = Path(__file__).resolve().parent.parent
SRC_DIR = REPO_ROOT / "src"

if str(SRC_DIR) not in sys.path:
    sys.path.insert(0, str(SRC_DIR))


def pytest_addoption(parser: pytest.Parser) -> None:
    parser.addoption(
        "--run-live-modal", action="store_true", default=False, help="run live Modal tests"
    )
    parser.addoption(
        "--run-live-replicate",
        action="store_true",
        default=False,
        help="run live Replicate tests",
    )


def pytest_configure(config: pytest.Config) -> None:
    config.addinivalue_line("markers", "live_modal: mark test as requiring a live Modal environment")
    config.addinivalue_line(
        "markers", "live_replicate: mark test as requiring a live Replicate environment"
    )
    config.addinivalue_line(
        "markers",
        "cypherclaw_e2e: mark test as requiring the live CypherClaw audio host",
    )


def pytest_collection_modifyitems(config: pytest.Config, items: list[pytest.Item]) -> None:
    if not config.getoption("--run-live-modal"):
        skip_live = pytest.mark.skip(reason="need --run-live-modal option to run")
        for item in items:
            if "live_modal" in item.keywords:
                item.add_marker(skip_live)
    if not config.getoption("--run-live-replicate"):
        skip_live_replicate = pytest.mark.skip(
            reason="need --run-live-replicate option to run"
        )
        for item in items:
            if "live_replicate" in item.keywords:
                item.add_marker(skip_live_replicate)
    if "CI" in os.environ:
        skip_cypherclaw_e2e = pytest.mark.skip(reason="cypherclaw e2e skipped on CI")
        for item in items:
            if "cypherclaw_e2e" in item.keywords:
                item.add_marker(skip_cypherclaw_e2e)

