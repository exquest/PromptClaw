-    )
+@dataclass(frozen=True)
+class CollectionGateDecision:
+    """Resolved pytest collection gate for one marker."""
 
+    marker: str
+    option: str | None
+    enabled: bool
+    skip_reason: str
+    matched_count: int
+    skipped_count: int
 
-def pytest_configure(config: pytest.Config) -> None:
-    config.addinivalue_line("markers", "live_modal: mark test as requiring a live Modal environment")
