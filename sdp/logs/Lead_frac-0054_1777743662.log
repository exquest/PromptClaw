-                item.add_marker(skip_live)
-    if not config.getoption("--run-live-replicate"):
-        skip_live_replicate = pytest.mark.skip(
-            reason="need --run-live-replicate option to run"
+            if marker in item.keywords:
+                matched_count += 1
+        skipped_count = 0 if enabled else matched_count
+        decisions.append(
+            CollectionGateDecision(
+                marker=marker,
