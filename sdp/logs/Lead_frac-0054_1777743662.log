+    enabled_count = 0
+    matched_item_count = 0
+    skipped_item_count = 0
+    for decision in decisions:
+        if decision.enabled:
+            enabled_count += 1
+        matched_item_count += decision.matched_count
+        skipped_item_count += decision.skipped_count
