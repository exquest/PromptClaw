+    failed_id = queue.enqueue(
+        {"request_hash": "hash-failed", "model": "musicgen-medium"},
+        "hash-failed",
+    )
+    assert queue.dequeue() is not None
+    assert queue.mark_failed(failed_id, error="backend unavailable", terminal=True)
