+def _queue_with_diagnostics(tmp_path: Path) -> GenerationQueue:
+    queue = GenerationQueue(
+        tmp_path / "queue.sqlite",
+        client=FakeClient(),
+        cache=FakeCache(),
+        budget=FakeBudget(),
+        clock=TickClock(),
+    )
+    queue.enqueue(
