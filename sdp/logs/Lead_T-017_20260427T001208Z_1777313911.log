+    queue = GenerationQueue(
+        tmp_path / "queue.sqlite",
+        client=FakeClient(),
+        cache=FakeCache(),
+        budget=FakeBudget(),
+        clock=TickClock(),
+    )
+    queue.enqueue(
+        {"request_hash": "hash-ok", "model": "musicgen-medium"},
+        "hash-ok",
+    )
+    assert queue.process_one() is True
+
