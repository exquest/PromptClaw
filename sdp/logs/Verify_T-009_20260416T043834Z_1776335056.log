def _nominal_snapshot(**overrides: object) -> rg.HealthSnapshot:
    """Return a healthy snapshot with optional overrides."""
    defaults = dict(
        cpu_pressure=0.1,
        sc_node_count=50,
        sampler_load=0.1,
        capture_age_seconds=10.0,
        self_listener_rms=0.3,
        master_bus_healthy=True,
