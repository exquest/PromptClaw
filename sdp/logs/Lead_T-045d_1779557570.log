+
+        assert args[0] == f"sw_{voice}"
+        assert _fx_bus_id_from_args(args) == fallback_profile.fx_bus_id
+        assert selected.voice == fallback_space_voice
+        assert scene_selected.voice == fallback_space_voice
+
