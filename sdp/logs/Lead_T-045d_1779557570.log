    monkeypatch.setattr(signal, "signal", lambda *_a: None)

    assert mod.main(["--watch-dir", str(tmp_path)]) == 0
    assert watch_calls == [tmp_path]


def test_main_invokes_bootstrap_identity(monkeypatch) -> None:
