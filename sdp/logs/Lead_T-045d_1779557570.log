    assert step["pitch"] == 69
    assert step["duration_ticks"] == 120
    assert step["render_voice"] == "pluck"
    assert step["metadata"]["requested_render_voice"] == "swamp_harp"
    assert step["render_synth"] == "sw_pluck"
