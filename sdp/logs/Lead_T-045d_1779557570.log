+def test_voice_routing_fx_bus_matrix_covers_all_mood_modes() -> None:
+    """T-045d: every supported voice routes to the expected FX bus by mode."""
+
+    cases: tuple[tuple[str, dict[str, object], dict[str, str]], ...] = (
+        (
+            "matched default",
+            {},
