+        assert tuple(rule.rule_id for rule in filtered) == ("metric_accent",)
+
+        expected_final_artifact = {
+            "schema_version": "render-artifact/v1",
+            "score_id": "score-artifact",
+            "seed_signature": "composition=17|interpretation=41",
