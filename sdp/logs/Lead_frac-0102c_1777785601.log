+            },
+        }
+        direct_artifact = ablate(
+            score,
+            seeds,
+            disabled_rules=("phrase_arch", "microtiming"),
+            active_rules=rules,
+            renderer=artifact_renderer,
+        )
+        assert direct_artifact == expected_final_artifact
+
+        cases = build_ablation_cases(
+            rules,
+            disabled_rule_sets=(
