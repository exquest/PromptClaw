+
+    assert _has_machine_readable_depth_two_marker(tree), (
+        "tests/test_sw_sampler.py must declare depth: 2 in the module "
+        "docstring or a top-level DEPTH constant so the coverage tier is "
+        "machine-readable"
+    )

