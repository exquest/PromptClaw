            {"id": "navigator", "role": "harmony", "synth": "sw_bowed"},
        ]

        hints = build_role_hints_from_cast(
            cast,
            synth_voice_map={
                "sw_pluck": "pluck",
                "sw_gong": "gong",
                "sw_breath": "breath",
                "sw_bowed": "bowed",
            },
        )

        assert hints == {
            "melody": {
                "voice": "pluck",
                "character_id": "poet",
                "character_role": "melody",
            },
            "bass": {
                "voice": "gong",
                "character_id": "basalt",
                "character_role": "foundation",
            },
