def test_tracker_compiler_authors_section_tails_toward_next_section() -> None:
    commission = commission_piece(
        cadence_state="occupied_day",
        day_phase="day",
        weekly_phase="midweek",
        attention_score=0.6,
        narrative_pressure=0.78,
