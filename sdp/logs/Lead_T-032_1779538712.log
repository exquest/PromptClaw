async function seedSegment(env, sequence, body, customMetadata = {}) {
    const key = `cypherclaw/live/${todayKey()}/seg-${sequence}.opus`;
    await env.MEDIA.put(key, body, {
        httpMetadata: { contentType: "audio/ogg; codecs=opus" },
        customMetadata: { sequence: String(sequence), ...customMetadata },
    });
    return key;
}

