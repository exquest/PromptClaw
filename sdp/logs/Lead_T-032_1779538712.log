        "jack_connect",
        "SuperCollider:out_1",
        "cypherclaw-opus-stream:input_1",
    ] in run_commands
    assert [
        "pw-jack",
        "jack_connect",
        "SuperCollider:out_2",
        "cypherclaw-opus-stream:input_2",
    ] in run_commands


