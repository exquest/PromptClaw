+        scene="tone-generator",
+        tuning="twelve_tet",
+        source="jack-tone-generator",
+    )
+    captured: dict[str, Any] = {}
+
+    def fake_urlopen(request: Any, *, timeout: float) -> _FakeHttpResponse:
+        captured["url"] = request.full_url
+        captured["headers"] = {
