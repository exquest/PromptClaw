    ]
    assert config.output_dir.exists()
    assert pid_file.read_text().strip() == "4321"
    assert processes[0].command[:2] == ["pw-jack", "ffmpeg"]
    assert ["pw-jack", "jack_lsp"] in run_commands
    assert [
