interface CypherClawFeatureSnapshot {
    source: string;
    captured_at: string;
    rms: number;
    pitch_hz: number;
    centroid_hz: number;
    spectral_centroid_hz: number;
    onset_rate_hz: number;
    brightness: number;
    motion: number;
    texture: number;
    density: number;
    salience: number;
    scene: string;
    arc_phase: string;
    tuning: string;
    dsp_blocks: string[];
    artistic_identity: string;
}

function serveCypherClawLiveFeatures(req: Request, env: Env): Response {
    const payload: CypherClawFeatureSnapshot = {
        source: 'worker-bootstrap',
        captured_at: new Date().toISOString(),
        rms: 0.07,
        pitch_hz: 196,
        centroid_hz: 900,
        spectral_centroid_hz: 900,
        onset_rate_hz: 0,
        brightness: 0.2,
        motion: 0.08,
        texture: 0.35,
        density: 0.18,
        salience: 0.07,
        scene: 'awaiting-live-features',
        arc_phase: '',
        tuning: 'unknown',
        dsp_blocks: [],
        artistic_identity: '',
    };
    const lines = [
        ': cypherclaw live features bootstrap',
        'retry: 5000',
        'event: features',
        `data: ${JSON.stringify(payload)}`,
        '',
        '',
    ];
    const headers = new Headers(corsHeaders(env, req));
    headers.set('Content-Type', 'text/event-stream; charset=utf-8');
    headers.set('Cache-Control', 'no-cache');
    headers.set('X-Accel-Buffering', 'no');
    return new Response(lines.join('\n'), { status: 200, headers });
}

// =================================================================
// Public: CypherClaw archive feed (T-030)
// =================================================================

export interface CypherClawArchiveSession {
    session_id: string;
    title: string;
    started_at: string;
    ended_at: string;
    duration_seconds: number;
    dominant_house: string;
    primary_tuning: string;
    segment_count: number;
    audio_key: string;
    metadata_key: string;
}

export async function listCypherClawArchiveSessions(env: Env): Promise<CypherClawArchiveSession[]> {
    const media = env.MEDIA;
    if (!media || typeof (media as { list?: unknown }).list !== 'function' || typeof (media as { get?: unknown }).get !== 'function') {
        return [];
    }
    let listing: R2Objects;
    try {
        listing = await media.list({ prefix: CYPHERCLAW_ARCHIVE_PREFIX });
    } catch {
        return [];
    }
    const metaKeys = listing.objects
        .map(o => o.key)
        .filter(k => k.endsWith('/metadata.json'));

    const sessions: CypherClawArchiveSession[] = [];
    for (const key of metaKeys) {
        try {
            const obj = await media.get(key);
            if (!obj) continue;
            const text = await (obj as R2ObjectBody).text();
            const parsed = JSON.parse(text) as Partial<CypherClawArchiveSession> & { [k: string]: unknown };
            if (!parsed || typeof parsed.session_id !== 'string' || typeof parsed.audio_key !== 'string') continue;
            sessions.push({
                session_id: parsed.session_id,
                title: typeof parsed.title === 'string' && parsed.title ? parsed.title : parsed.session_id,
                started_at: typeof parsed.started_at === 'string' ? parsed.started_at : '',
                ended_at: typeof parsed.ended_at === 'string' ? parsed.ended_at : '',
                duration_seconds: Number.isFinite(Number(parsed.duration_seconds)) ? Number(parsed.duration_seconds) : 0,
                dominant_house: typeof parsed.dominant_house === 'string' ? parsed.dominant_house : '',
                primary_tuning: typeof parsed.primary_tuning === 'string' ? parsed.primary_tuning : '',
                segment_count: Number.isFinite(Number(parsed.segment_count)) ? Number(parsed.segment_count) : 0,
                audio_key: parsed.audio_key,
                metadata_key: typeof parsed.metadata_key === 'string' ? parsed.metadata_key : key,
            });
        } catch {
            continue;
        }
    }
    sessions.sort((a, b) => (b.started_at || '').localeCompare(a.started_at || ''));
    return sessions.slice(0, CYPHERCLAW_ARCHIVE_FEED_LIMIT);
}

export function renderCypherClawArchiveFeed(sessions: CypherClawArchiveSession[]): string {
    if (!sessions || sessions.length === 0) {
        return `    <section id="cypherclaw-archive-feed" aria-label="Archived sessions" data-archive-feed-state="empty" data-archive-session-count="0">
      <h2>Archive</h2>
      <p class="archive-empty">No archived sessions yet.</p>
    </section>`;
    }
    const ordered = [...sessions].sort((a, b) => (b.started_at || '').localeCompare(a.started_at || ''));
    const items = ordered.map(s => {
        const titleSafe = escapeHtml(s.title || s.session_id);
        const startedAt = escapeHtml(s.started_at || '');
        const audioUrl = escapeHtml(`${CYPHERCLAW_SEGMENT_PREFIX}${s.audio_key}`);
        const durMin = Math.max(1, Math.round((s.duration_seconds || 0) / 60));
        const houseSafe = escapeHtml(s.dominant_house || 'unknown-house');
        const tuningSafe = escapeHtml(s.primary_tuning || 'unknown-tuning');
        return `        <li class="archive-session" data-session-id="${escapeHtml(s.session_id)}" data-started-at="${startedAt}">
          <article>
            <h3>${titleSafe}</h3>
            <p class="archive-meta"><time datetime="${startedAt}">${startedAt}</time> · ${durMin} min · ${houseSafe} · ${tuningSafe}</p>
            <audio controls preload="none" aria-label="Play archived session ${titleSafe}" src="${audioUrl}" data-archive-audio-url="${audioUrl}"></audio>
          </article>
        </li>`;
    }).join('\n');
    return `    <section id="cypherclaw-archive-feed" aria-label="Archived sessions" data-archive-feed-state="rendered" data-archive-session-count="${ordered.length}">
      <h2>Archive</h2>
      <ol class="archive-list">
${items}
      </ol>
    </section>`;
}

// =================================================================
// Admin: CypherClaw live segment ingest
// =================================================================

async function receiveCypherClawSegment(req: Request, env: Env): Promise<Response> {
    if (!req.body) return errorResponse(400, 'request body required', env, req);

    const sequenceHeader = req.headers.get('X-CypherClaw-Sequence') || '';
    if (!/^\d+$/.test(sequenceHeader)) {
        return errorResponse(400, 'X-CypherClaw-Sequence must be a non-negative integer', env, req);
    }
    const sequence = Number(sequenceHeader);
    if (!Number.isSafeInteger(sequence)) {
        return errorResponse(400, 'X-CypherClaw-Sequence is outside the safe integer range', env, req);
    }

    const capturedAtHeader = req.headers.get('X-CypherClaw-Captured-At');
    const capturedAt = capturedAtHeader ? new Date(capturedAtHeader) : new Date();
    if (Number.isNaN(capturedAt.getTime())) {
        return errorResponse(400, 'X-CypherClaw-Captured-At must be a valid ISO timestamp', env, req);
    }

    const dateKey = capturedAt.toISOString().slice(0, 10);
    const key = `cypherclaw/live/${dateKey}/seg-${sequence}.opus`;
    const contentType = req.headers.get('Content-Type') || CYPHERCLAW_SEGMENT_CONTENT_TYPE;
    const customMetadata: Record<string, string> = {
        sequence: String(sequence),
        captured_at: capturedAt.toISOString(),
    };

    const duration = req.headers.get('X-CypherClaw-Duration');
    const scene = req.headers.get('X-CypherClaw-Scene');
    const tuning = req.headers.get('X-CypherClaw-Tuning');
    if (duration) customMetadata.duration = duration;
    if (scene) customMetadata.scene = scene;
    if (tuning) customMetadata.tuning = tuning;

    const obj = await env.MEDIA.put(key, req.body, {
        httpMetadata: { contentType },
        customMetadata,
    });

    return jsonResponse({
        ok: true,
        key,
        sequence,
        size: obj.size,
        etag: obj.etag,
    }, env, { status: 201 }, req);
}

// =================================================================
// Public: CypherClaw live HLS playlist + segment serving
// =================================================================

interface CypherClawPlaylistEntry {
    key: string;
    sequence: number;
    duration: number;
}

async function serveCypherClawPlaylist(req: Request, env: Env): Promise<Response> {
    // Look at the current UTC date and the prior day to handle midnight
    // rollover — the window of recent segments can straddle the date
    // boundary in the R2 keyspace.
    const now = new Date();
    const todayKey = now.toISOString().slice(0, 10);
    const yesterdayKey = new Date(now.getTime() - 86_400_000).toISOString().slice(0, 10);

    const todayList = await env.MEDIA.list({ prefix: `cypherclaw/live/${todayKey}/` });
    const rawObjects: R2Object[] = [...todayList.objects];
    if (rawObjects.length < CYPHERCLAW_LIVE_PLAYLIST_WINDOW) {
        const yList = await env.MEDIA.list({ prefix: `cypherclaw/live/${yesterdayKey}/` });
        rawObjects.unshift(...yList.objects);
    }

    const parsed: CypherClawPlaylistEntry[] = [];
    for (const obj of rawObjects) {
        const m = /\/seg-(\d+)\.opus$/.exec(obj.key);
        if (!m) continue;
        const sequence = Number(m[1]);
        if (!Number.isSafeInteger(sequence)) continue;
        const durStr = obj.customMetadata?.duration;
        const dur = durStr ? Number(durStr) : NaN;
        parsed.push({
            key: obj.key,
            sequence,
            duration: Number.isFinite(dur) && dur > 0 ? dur : CYPHERCLAW_LIVE_TARGET_DURATION,
        });
    }
    parsed.sort((a, b) => a.sequence - b.sequence);
    const window = parsed.slice(-CYPHERCLAW_LIVE_PLAYLIST_WINDOW);

    const headers = new Headers(corsHeaders(env, req));
    headers.set('Content-Type', 'application/vnd.apple.mpegurl');
    headers.set('Cache-Control', 'no-cache');

    const targetDuration = window.length === 0
        ? CYPHERCLAW_LIVE_TARGET_DURATION
        : Math.max(
            CYPHERCLAW_LIVE_TARGET_DURATION,
            Math.ceil(Math.max(...window.map(e => e.duration))),
        );
    const mediaSequence = window.length === 0 ? 0 : window[0].sequence;

    const lines: string[] = [
        '#EXTM3U',
        '#EXT-X-VERSION:3',
        `#EXT-X-TARGETDURATION:${targetDuration}`,
        `#EXT-X-MEDIA-SEQUENCE:${mediaSequence}`,
    ];
    for (const entry of window) {
        lines.push(`#EXTINF:${entry.duration.toFixed(3)},`);
        lines.push(`${CYPHERCLAW_SEGMENT_PREFIX}${entry.key}`);
    }
    lines.push('');
    return new Response(lines.join('\n'), { status: 200, headers });
}

async function serveCypherClawSegment(req: Request, env: Env, key: string): Promise<Response> {
    if (!key.startsWith('cypherclaw/')) {
        return errorResponse(404, 'unknown segment path', env, req);
    }

    const range = req.headers.get('Range');
    const obj = range
        ? await env.MEDIA.get(key, { range: parseRange(range) })
        : await env.MEDIA.get(key);
    if (!obj) return errorResponse(404, 'segment missing in storage', env, req);

    const headers = new Headers(corsHeaders(env, req));
    headers.set('Content-Type', obj.httpMetadata?.contentType || CYPHERCLAW_SEGMENT_CONTENT_TYPE);
    headers.set('Accept-Ranges', 'bytes');
    headers.set('Cache-Control', 'public, max-age=300');

    if (range && (obj as any).range) {
        const r = (obj as any).range as R2Range;
        const offset = 'offset' in r ? (r.offset || 0) : 0;
        const length = 'length' in r ? (r.length as number) : (obj.size - offset);
        headers.set('Content-Range', `bytes ${offset}-${offset + length - 1}/${obj.size}`);
        return new Response((obj as R2ObjectBody).body, { status: 206, headers });
    }
    headers.set('Content-Length', String(obj.size));
    return new Response((obj as R2ObjectBody).body, { status: 200, headers });
}

