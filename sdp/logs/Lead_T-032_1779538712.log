    const sweepX = (timestamp / Math.max(14, 34 - motion * 16 - onsetRate * 0.35)) % Math.max(1, dims.width);
    const radius = 28 + rms * 170 + salience * 34;
    const hue = 28 + Math.min(180, centroid / 34) + brightness * 26;

