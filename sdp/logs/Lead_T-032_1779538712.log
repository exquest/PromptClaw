ward target: stepwise (1-2), occasionally leap to chord tone\\\\\\\\\\\\\\\\n         diff = target - current_deg\\\\\\\\\\\\\\\\n         if abs(diff) <= 2:\\\\\\\\\\\\\\\\n             # Step toward target\\\\\\\\\\\\\\\\n             step = int(round(diff))\\\\\\\\\\\\\\\\n-        elif random.random() < 0.3 and abs(diff) > 2:\\\\\\\\\\\\\\\\n+        elif rng.random() < leap_bias and abs(diff) > 2:\\\\\\\\\\\\\\\\n             # Leap to nearest chord tone in the direction of target\\\\\\\\\\\\\\\\n-            direction = 1 if diff > 0 else -1\\\\\\\\\\\\\\\\n             candidates = sorted(chord_tones, key=lambda d: abs(d - target))\\\\\\\\\\\\\\\\n             step = candidates[0] - current_deg\\\\\\\\\\\\\\\\n         else:\\\\\\\\\\\\\\\\n             # Stepwise: move 1-2 in the right direction\\\\\\\\\\\\\\\\n             direction = 1 if diff > 0 else -1\\\\\\\\\\\\\\\\n-            step = direction * random.choice([1, 1, 2])\\\\\\\\\\\\\\\\n+            step = direction * rng.choice([1, 1, 2])\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+        step = max(-step_limit, min(step_limit, step))\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n         current_deg = int(_clamp(current_deg + step, 1, 8))\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-        # Duration: slightly varied around 1 beat\\\\\\\\\\\\\\\\n-        duration = random.choice([0.5, 0.75, 1.0, 1.0, 1.0, 1.5])\\\\\\\\\\\\\\\\n+        duration = rhythm[i]\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n         # Accent on chord tones, first note, and downbeats\\\\\\\\\\\\\\\\n-        accent = current_deg in chord_tones and random.random() < 0.3\\\\\\\\\\\\\\\\n+        accent_chance = _CADENCE_ACCENT_BIAS.get(cadence_state, 0.22)\\\\\\\\\\\\\\\\n+        accent_chance *= _PATCH_ACCENT_MULTIPLIER.get(patch_name, 1.0)\\\\\\\\\\\\\\\\n+        accent = current_deg in chord_tones and rng.random() < accent_chance\\\\\\\\\\\\\\\\n         if i == 0:\\\\\\\\\\\\\\\\n             accent = True\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n@@ -221,6 +715,9 