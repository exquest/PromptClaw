-def run(devices):\\\\\\\\\\\\\\\\n-    print(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"MIDI keyboard listener on {devices}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", flush=True)\\\\\\\\\\\\\\\\n-    \\\\\\\\\\\\\\\\n-    fds = {}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def discover_keyboard_devices(amidi_listing: str | None = None) -> list[str]:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Return `/dev/midi*` devices matching the keyboard controllers.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    verify_device_paths = amidi_listing is None\\\\\\\\\\\\\\\\n+    if amidi_listing is None:\\\\\\\\\\\\\\\\n+        try:\\\\\\\\\\\\\\\\n+            result = subprocess.run(\\\\\\\\\\\\\\\\n+                [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"amidi\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"-l\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"],\\\\\\\\\\\\\\\\n+                capture_output=True,\\\\\\\\\\\\\\\\n+                text=True,\\\\\\\\\\\\\\\\n+                timeout=2,\\\\\\\\\\\\\\\\n+                check=False,\\\\\\\\\\\\\\\\n+            )\\\\\\\\\\\\\\\\n+            amidi_listing = result.stdout\\\\\\\\\\\\\\\\n+        except Exception:\\\\\\\\\\\\\\\\n+            amidi_listing = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    devices: list[str] = []\\\\\\\\\\\\\\\\n+    for line in amidi_listing.splitlines():\\\\\\\\\\\\\\\\n+        line = line.strip()\\\\\\\\\\\\\\\\n+        if not line.startswith(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"IO  hw:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        lowered = line.lower()\\\\\\\\\\\\\\\\n+        if any(hint in lowered for hint in _IGNORE_HINTS):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        if not any(hint in lowered for hint in _KEYBOARD_HINTS):\\\\\\\\