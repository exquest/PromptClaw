name = "holdenu-api"
main = "src/index.ts"
compatibility_date = "2026-04-30"
account_id = "1b3ac984f4bf54899baa018edfd94c78"

# Routes — mount the Worker at /api/* on the same origin as the
# catalog-explorer Pages site so the frontend can use relative URLs
# (no CORS hops, no auth-credential cross-origin gotchas). For local
# development run `wrangler dev` and the workspace will hit
# http://localhost:8787 (see HOLDENU_API_BASE in the workspace config).
[[routes]]
pattern = "explorer.holdenu.com/api/*"
zone_name = "holdenu.com"

# CypherClaw v2 public presence (PRD CC-023): the live stream landing
# page is served from a dedicated subdomain. `custom_domain = true`
# binds the entire hostname to this Worker and lets Cloudflare manage
# the DNS record + universal-SSL certificate.
[[routes]]
pattern = "cypherclaw.holdenu.com"
custom_domain = true

# ---------------------------------------------------------------
# D1: relational state (releases, release_tracks, annotations, orders)
# Create with:
#   wrangler d1 create holdenu
# Then paste the returned database_id below.
# ---------------------------------------------------------------
[[d1_databases]]
binding = "DB"
database_name = "holdenu"
database_id = "03f12188-ba6b-4b18-9443-dcc9d1d0b7ee"
migrations_dir = "migrations"

# ---------------------------------------------------------------
# R2: audio + artwork object storage. Zero egress fees.
# Create with:
#   wrangler r2 bucket create holdenu-media
# ---------------------------------------------------------------
[[r2_buckets]]
binding = "MEDIA"
bucket_name = "holdenu-media"

# ---------------------------------------------------------------
# Secrets (set via `wrangler secret put <name>`):
#   ADMIN_TOKEN          — bearer token the workspace sends to gate
#                          /api/release and /api/sync
#   STRIPE_SECRET_KEY    — sk_live_... (or sk_test_... in dev)
#   STRIPE_WEBHOOK_SECRET — whsec_... for /api/webhook/stripe
#   RESEND_API_KEY       — for transactional download emails
# ---------------------------------------------------------------

[vars]
ENVIRONMENT = "production"
PUBLIC_SITE_ORIGIN = "https://holdenu.com"

[env.dev]
[env.dev.vars]
ENVIRONMENT = "development"
PUBLIC_SITE_ORIGIN = "http://localhost:8765"

