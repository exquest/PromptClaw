function makeArchiveMedia(sessions) {
    const objects = sessions.map((s) => ({ key: s.metadata_key }));
    return {
        list: async ({ prefix }) => {
            const filtered = objects.filter((o) => o.key.startsWith(prefix));
            return { objects: filtered, truncated: false, delimitedPrefixes: [] };
        },
        get: async (key) => {
            const session = sessions.find((s) => s.metadata_key === key);
            if (!session) return null;
            return {
                text: async () => JSON.stringify(session),
            };
        },
    };
}

