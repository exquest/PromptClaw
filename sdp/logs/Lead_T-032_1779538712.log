ion.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    text = error.lower()\\\\\\\\\\\\\\\\n+    return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"503\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in text and (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"server busy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in text or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pending requests exceeded\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in text)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def local_scene_description(\\\\\\\\\\\\\\\\n+    fast_state: dict[str, Any],\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    visual_person_cue: bool = False,\\\\\\\\\\\\\\\\n+) -> str:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Create a compact local summary when slow multimodal vision is unavailable.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    lighting = str(fast_state.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lighting\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"unknown\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")).strip() or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"unknown\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    dominant = str(fast_state.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"dominant_color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"neutral\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")).strip() or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"neutral\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    motion = bool(fast_state.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"motion\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    if visual_person_cue:\\\\\\\\\\\\\\\\n+        presence = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"possible person in view\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    elif motion:\\\\\\\\\\\\\\\\n+        presence = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"movement in the room\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\