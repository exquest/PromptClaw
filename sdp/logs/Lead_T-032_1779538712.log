    if (!state || !state.canvas || !state.context) return;

    const canvas = state.canvas;
    const context = state.context;
    const dims = resizeVisualizerCanvas(canvas, context);
    const features = state.latestFeatures || {};
    const rms = clampNumber(pickNumber(features, ["rms", "amplitude"], 0.07), 0, 1, 0.07);
    const pitch = clampNumber(pickNumber(features, ["pitch_hz", "pitchHz"], 196), 55, 1760, 196);
    const centroid = clampNumber(pickNumber(features, ["centroid_hz", "spectral_centroid_hz"], 900), 120, 6000, 900);
    const brightness = clampNumber(pickNumber(features, ["brightness"], centroid / 6000), 0, 1, 0.2);
    const motion = clampNumber(pickNumber(features, ["motion"], 0.08), 0, 1, 0.08);
