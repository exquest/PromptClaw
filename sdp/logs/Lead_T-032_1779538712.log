async function serveReleasePage(req: Request, env: Env, releaseId: string): Promise<Response> {
    const release = await env.DB.prepare(
        `SELECT id, name, type, release_date, price_min_cents,
                artwork_key, description, bandcamp_url, spotify_url, apple_url
           FROM releases
          WHERE id = ? AND release_date <= datetime('now')`
    ).bind(releaseId).first<{
        id: string; name: string; type: string; release_date: string;
        price_min_cents: number; artwork_key: string | null;
        description: string | null;
        bandcamp_url: string | null; spotify_url: string | null; apple_url: string | null;
    }>();

    if (!release) {
        return new Response(notFoundHtml('Release not found', env), {
            status: 404,
            headers: { 'Content-Type': 'text/html; charset=utf-8' },
        });
    }
    const tracks = await env.DB.prepare(
        `SELECT track_id, track_order, title_override, duration_seconds
           FROM release_tracks WHERE release_id = ? ORDER BY track_order`
    ).bind(releaseId).all();

    const trackCount = tracks.results.length;
    const desc = release.description
        || `${trackCount} track${trackCount === 1 ? '' : 's'} from Be Holden U — listen, browse the 3D catalog, fly through the catalog explorer at holdenu.com.`;
    const ogImage = release.artwork_key
        ? `${env.PUBLIC_SITE_ORIGIN}/api/artwork/${encodeURIComponent(release.id)}`
        : `${env.PUBLIC_SITE_ORIGIN}/og-default.jpg`;
    const canonical = `${env.PUBLIC_SITE_ORIGIN}/release/${encodeURIComponent(release.id)}`;

    const html = renderShell({
        title: `${release.name} — holdenu.com`,
        description: desc,
        ogImage,
        canonical,
        ogType: 'music.album',
        spaParam: `release=${encodeURIComponent(release.id)}`,
        siteOrigin: env.PUBLIC_SITE_ORIGIN,
    });

    return new Response(html, {
        headers: {
            'Content-Type': 'text/html; charset=utf-8',
            'Cache-Control': 'public, max-age=300, s-maxage=300',
        },
    });
}

async function serveTrackPage(req: Request, env: Env, trackId: string): Promise<Response> {
    const row = await env.DB.prepare(
        `SELECT rt.track_id, rt.title_override, r.id AS release_id, r.name AS release_name,
