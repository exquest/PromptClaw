alueError:\\\\\\\\\\\\\\\\n+        idx = _DYNAMIC_ORDER.index(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mf\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+    return _DYNAMIC_ORDER[max(0, min(len(_DYNAMIC_ORDER) - 1, idx + delta))]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _contour_for_patch(\\\\\\\\\\\\\\\\n+    default: str,\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    patch_name: str,\\\\\\\\\\\\\\\\n+    energy: float,\\\\\\\\\\\\\\\\n+    valence: float,\\\\\\\\\\\\\\\\n+    arousal: float,\\\\\\\\\\\\\\\\n+) -> str:\\\\\\\\\\\\\\\\n+    if patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_monastery\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"descent\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if energy < 0.65 else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    if patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_chamber\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if valence >= 0.45 else default\\\\\\\\\\\\\\\\n+    if patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_garden\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"wave\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if valence >= 0.45 else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    if patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_procession\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ascent\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if energy >= 0.4 else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    if patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_workshop\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ascent\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if arousal >= 0.65 else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"wave\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    return default\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def role_octave_shift_for_patch(role: str, patch_name: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") -> int:\\\\\\\\\\\\\\\\n+    shifts = _PATCH_ROLE_OCTAVE_SHIFT.get(patch_name, _DEFAULT_ROLE_OCTAVE_SHIFT)\\\\\\\\\\\\\\\\n+    return shifts.get(role, 0)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _wrap_scale_degree(degree: int) -> int:\\\\\\\\\\\\\\\\n+    return ((degree - 1) % 7) + 1\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _merge_progression_banks(*banks: Sequence[Sequence[int]]) -> tuple[list[int], ...]:\\\\\\\\\\\\\\\\n+    merged: list[list[int]] = []\\\\\\\\\\\\\\\\n+    seen: set[tuple[int, ...]] = set()\\\\\\\\\\\\\\\\n+    for bank in banks:\\\\\\\\\\\\\\\\n+        for progression in bank:\\\\\\\\\\\\\\\\n+            frozen = tuple(int(degree) for degree in progression)\\\\\\\\\\\\\\\\n+            if frozen in seen:\\\\\\\\\\\\\\\\n+                continue\\\\\\\\\\\\\\\\n+            seen.add(frozen)\\\\\\\\\\\\\\\\n+            merged.append(list(frozen))\\\\\\\\\\\\\\\\n+    return tuple(merged)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _motif_offsets(\\\\\\\\\\\\\\\\n+    length: int,\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    family: str,\\\\\\\\\\\\\\\\n+    cadence_state: str,\\\\\\\\\\\\\\\\n+    energy: float,\\\\\\\\\\\\\\\\n+    rng,\\\\\\\\\\\\\\\\n+) -> list[int]:\\\\\\\\\\\\\\\\n+    family_key = family if family in _FAMILY_MELODIC_CELLS else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"default\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cell_name = rng.choice(_FAMILY_MELODIC_CELLS[family_key])\\\\\\\\\\\\\\\\n+    cell = list(_MELODIC_OFFSET_CELLS[cell_name])\\\\\\\\\\\\\\\\n+    if len(cell) > 1:\\\\\\\\\\\\\\\\n+        rotation = rng.randrange(len(cell))\\\\\\\\\\\\\\\\n+        cell = cell[rotation:] + cell[:rotation]\\\\\\\\\\\\\\\\n+    if rng.random() < 0.35:\\\\\\\\\\\\\\\\n+        cell = [-value for value in cell]\\\\\\\\\\\\\\\\n+    if cadence_state in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sleep\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"wind_down\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} and rng.random() < 0.6:\\\\\\\\\\\\\\\\n+        cell = list(reversed(cell))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    base_limit = _CADENCE_LEAP_LIMIT.get(cadence_state, 2)\\\\\\\\\\\\\\\\n+    family_scale = 1.2 if family in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"forge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} else 0.75 if family in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"drift\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"nocturne\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} else 1.0\\\\\\\\\\\\\\\\n+    energy_scale = 0.75 + (energy * 0.8)\\\\\\\\\\\\\\\\n+    limit = max(1, int(round(base_limit * family_scale)))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    offsets: list[int] = []\\\\\\\\\\\\\\\\n+    for index in range(length):\\\\\\\\\\\\\\\\n+        raw = cell[index % len(cell)]\\\\\\\\\\\\\\\\n+        shaped = int(round(raw * energy_scale))\\\\\\\\\\\\\\\\n+        offsets.append(max(-limit, min(limit, shaped)))\\\\\\\\\\\\\\\\n+    return offsets\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _rhythm_pattern(\\\\\\\\\\\\\\\\n+    length: int,\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    family: str,\\\\\\\\\\\\\\\\n+    cadence_state: str,\\\\\\\\\\\\\\\\n+    energy: float,\\\\\\\\\\\\\\\\n+    rng,\\\\\\\\\\\\\\\\n+) -> list[float]:\\\\\\\\\\\\\\\\n+    family_key = family if family in _FAMILY_RHYTHM_CELLS else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"default\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cell_name = rng.choice(_FAMILY_RHYTHM_CELLS[family_key])\\\\\\\\\\\\\\\\n+    cell = list(_RHYTHM_CELLS[cell_name])\\\\\\\\\\\\\\\\n+    duration_scale = _CADENCE_DURATION_SCALE.get(cadence_state, 1.0) * (1.15 - energy * 0.35)\\\\\\\\\\\\\\\\n+    return [\\\\\\\\\\\\\\\\n+        round(_clamp(cell[index % len(cell)] * duration_scale, 0.5, 2.5), 2)\\\\\\\\\\\\\\\\n+        for index in range(length)\\\\\\\\\\\\\\\\n+    ]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _degree_distance(key: str, freq_hz: float, degree: int) -> float:\\\\\\\\\\\\\\\\n+    target = _scale_degree_to_freq(key, degree)\\\\\\\\\\\\\\\\n+    return abs(math.log(max(freq_hz, 1.0) / max(target, 1.0)))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _nearest_scale_degree_for_freq(key: str, freq_hz: float) -> int:\\\\\\\\\\\\\\\\n+    candidates = range(1, 9)\\\\\\\\\\\\\\\\n+    return min(candidates, key=lambda degree: _degree_distance(key, freq_hz, degree))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _coerce_memory_fragment(fragment: Mapping[str, object]) -> list[float]:\\\\\\\\\\\\\\\\n+    raw_notes = fragment.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"notes\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+    if not isinstance(raw_notes, Sequence) or isinstance(raw_notes, (str, bytes)):\\\\\\\\\\\\\\\\n+        return []\\\\\\\\\\\\\\\\n+    notes = [float(value) for value in raw_notes if isinstance(value, (int, float)) and float(value) > 0.0]\\\\\\\\\\\\\\\\n+    if len(notes) < 4:\\\\\\\\\\\\\\\\n+        return []\\\\\\\\\\\\\\\\n+    span = max(notes) / max(min(notes), 1.0)\\\\\\\\\\\\\\\\n+    if span > 2.15:\\\\\\\\\\\\\\\\n+        return []\\\\\\\\\\\\\\\\n+    return notes\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _answer_memory_degrees(degrees: Sequence[int]) -> list[int]:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Turn a recalled fragment into a related answering gesture.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    answered = [int(_clamp(degree, 1, 8)) for degree in degrees]\\\\\\\\\\\\\\\\n+    if len(answered) < 2:\\\\\\\\\\\\\\\\n+        return answered\\\\\\\\\\\\\\\\n+    if len(answered) >= 3 and abs(answered[-2] - answered[-3]) > 2:\\\\\\\\\\\\\\\\n+        direction = 1 if answered[-2] > answered[-3] else -1\\\\\\\\\\\\\\\\n+        answered[-2] = int(_clamp(answered[-3] + direction, 1, 8))\\\\\\\\\\\\\\\\n+    answered[-1] = 1 if answered[-2] <= 3 else 3\\\\\\\\\\\\\\\\n+    return answered\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _memory_phrase_targets(\\\\\\\\\\\\\\\\n+    key: str,\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    memory_fragments: Sequence[Mapping[str, object]],\\\\\\\\\\\\\\\\n+    family: str,\\\\\\\\\\\\\\\\n+    cadence_state: str,\\\\\\\\\\\\\\\\n+    progression_profile: str,\\\\\\\\\\\\\\\\n+    rng,\\\\\\\\\\\\\\\\n+) -> list[int]:\\\\\\\\\\\\\\\\n+    usable: list[tuple[float, list[float], str]] = []\\\\\\\\\\\\\\\\n+    for fragment in memory_fragments:\\\\\\\\\\\\\\\\n+        if not isinstance(fragment, Mapping):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        notes = _coerce_memory_fragment(fragment)\\\\\\\\\\\\\\\\n+        if not notes:\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        usable.append(\\\\\\\\\\\\\\\\n+            (\\\\\\\\\\\\\\\\n+                float(fragment.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"score\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 0.0) or 0.0),\\\\\\\\\\\\\\\\n+                notes,\\\\\\\\\\\\\\\\n+                str(fragment.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"context\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"),\\\\\\\\\\\\\\\\n+            )\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\n+    if not usable:\\\\\\\\\\\\\\\\n+        return []\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def _rank(item: tuple[float, list[float], str]) -> tuple[float, float]:\\\\\\\\\\\\\\\\n+        score, _notes, context = item\\\\\\\\\\\\\\\\n+        context_lower = context.lower()\\\\\\\\\\\\\\\\n+        context_bonus = 0.0\\\\\\\\\\\\\\\\n+        if family and family.lower() in context_lower:\\\\\\\\\\\\\\\\n+            context_bonus += 0.15\\\\\\\\\\\\\\\\n+        if cadence_state and cadence_state.lower() in context_lower:\\\\\\\\\\\\\\\\n+            context_bonus += 0.1\\\\\\\\\\\\\\\\n+        if progression_profile and progression_profile.lower() in context_lower:\\\\\\\\\\\\\\\\n+            context_bonus += 0.16\\\\\\\\\\\\\\\\n+        if \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tracker\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in context_lower:\\\\\\\\\\\\\\\\n+            context_bonus += 0.05\\\\\\\\\\\\\\\\n+        return (score + context_bonus, float(len(_notes)))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    ranked = sorted(usable, key=_rank, reverse=True)\\\\\\\\\\\\\\\\n+    _score, notes, context = ranked[0]\\\\\\\\\\\\\\\\n+    source_root = max(notes[0], 1.0)\\\\\\\\\\\\\\\\n+    target_root = _scale_degree_to_freq(key, 1)\\\\\\\\\\\\\\\\n+    transposed = [target_root * (freq_hz / source_root) for freq_hz in notes]\\\\\\\\\\\\\\\\n+    degrees = [_nearest_scale_degree_for_freq(key, freq_hz) for freq_hz in transposed]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    context_lower = context.lower()\\\\\\\\\\\\\\\\n+    family_match = family and family.lower() in context_lower\\\\\\\\\\\\\\\\n+    profile_match = progression_profile and progression_profile.lower() in context_lower\\\\\\\\\\\\\\\\n+    transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"identity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    if cadence_state in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sleep\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"wind_down\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n+        transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"reverse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if rng.random() < 0.55 else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"identity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    elif family_match and profile_match and rng.random() < 0.65:\\\\\\\\\\\\\\\\n+        transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"answer\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    elif family in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"forge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} and rng.random() < 0.45:\\\\\\\\\\\\\\\\n+        transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rotate\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    elif rng.random() < 0.2:\\\\\\\\\\\\\\\\n+        transform = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"reverse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    if transform == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"reverse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        degrees = list(reversed(degrees))\\\\\\\\\\\\\\\\n+    elif transform == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rotate\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and len(degrees) > 1:\\\\\\\\\\\\\\\\n+        degrees = degrees[1:] + degrees[:1]\\\\\\\\\\\\\\\\n+    elif transform == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"answer\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n+        degrees = _answer_memory_degrees(degrees)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    return [int(_clamp(degree, 1, 8)) for degree in degrees]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _apply_hook_degrees(phrase: Phrase, degrees: Sequence[int]) -> Phrase:\\\\\\\\\\\\\\\\n+    if not degrees or not phrase.notes:\\\\\\\\\\\\\\\\n+        return phrase\\\\\\\\\\\\\\\\n+    hooked_notes = list(phrase.notes)\\\\\\\\\\\\\\\\n+    hook_span = min(len(hooked_notes), max(1, len(degrees) - 1))\\\\\\\\\\\\\\\\n+    for index, degree in enumerate(degrees[:hook_span]):\\\\\\\\\\\\\\\\n+        hooked_notes[index] = Note(\\\\\\\\\\\\\\\\n+            scale_degree=int(_clamp(degree, 1, 8)),\\\\\\\\\\\\\\\\n+            duration_beats=hooked_notes[index].duration_beats,\\\\\\\\\\\\\\\\n+            accent=True if index == 0 else hooked_notes[index].accent,\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\n+    return Phrase(\\\\\\\\\\\\\\\\n+        notes=hooked_notes,\\\\\\\\\\\\\\\\n+        voice=phrase.voice,\\\\\\\\\\\\\\\\n+        dynamic=phrase.dynamic,\\\\\\\\\\\\\\\\n+        role=phrase.role,\\\\\\\\\\\\\\\\n+        metadata=dict(phrase.metadata),\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _shape_patch_ending(phrase: Phrase, *, patch_name: str) -> Phrase:\\\\\\\\\\\\\\\\n+    if len(phrase.notes) < 2:\\\\\\\\\\\\\\\\n+        return phrase\\\\\\\\\\\\\\\\n+    notes = list(phrase.notes)\\\\\\\\\\\\\\\\n+    first = notes[0].scale_degree\\\\\\\\\\\\\\\\n+    last = notes[-1].scale_degree\\\\\\\\\\\\\\\\n+    if patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_monastery\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and last > first:\\\\\\\\\\\\\\\\n+        notes[-1] = Note(scale_degree=max(1, first - 1), duration_beats=notes[-1].duration_beats, accent=notes[-1].accent)\\\\\\\\\\\\\\\\n+    elif patch_name == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"house_procession\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and last < first:\\\\\\\\\\\\\\\\n+        notes[-1] = Note(scale_degree=min(8, first + 2), duration_beats=notes[-1].duration_beats, accent=True)\\\\\\\\\\\\\\\\n+    return Phrase(notes=notes, voice=phrase.voice, dynamic=phrase.dynamic, role=phrase.role, metadata=dict(phrase.metadata))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n # ---------------------------------------------------------------------------\\\\\\\\\\\\\\\\n # Melody generation\\\\\\\\\\\\\\\\n@@ -156,6 +588,16 @@ def generate_melody(\\\\\\\\\\\\\\\\n     key: str,\\\\\\\\\\\\\\\\n     length: int = 8,\\\\\\\\\\\\\\\\n     contour: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    family: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"default\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    cadence_state: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    patch_n