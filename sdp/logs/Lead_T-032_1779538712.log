    const visual = objectValue(source.visual);
    const sceneObject = objectValue(source.scene);
    const tuningObject = objectValue(source.tuning);
    const previousFeatures = objectValue(previous);
    const previousEventCount = Number(previousFeatures.event_count || 0);

    const rms = pickFiniteNumber(
