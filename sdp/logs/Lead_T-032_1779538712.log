index 0000000000000000000000000000000000000000..a7bab0c764ef256e1c37f094c345b626d32e713e
--- /dev/null
+++ b//Users/anthony/Programming/catalog-explorer/worker/tests/cypherclaw-e2e.test.js
@@ -0,0 +1,233 @@
+const test = require("node:test");
+const assert = require("node:assert/strict");
+const vm = require("node:vm");
+
+const worker = require("../.tmp/test-build/index.js").default;
+
+class FakeR2Bucket {
+    constructor() {
+        this.objects = new Map();
+    }
+
+    async put(key, value, options = {}) {
+        const bytes = await this.bytesFrom(value);
+        const object = {
+            key,
+            body: bytes,
+            size: bytes.byteLength,
+            etag: `etag-${this.objects.size + 1}`,
+            httpMetadata: options.httpMetadata || {},
+            customMetadata: options.customMetadata || {},
+        };
+        this.objects.set(key, object);
+        return { key, size: object.size, etag: object.etag };
+    }
+
+    async get(key, options = {}) {
+        const object = this.objects.get(key);
+        if (!object) return null;
+        const result = {
+            key: object.key,
+            size: object.size,
+            etag: object.etag,
+            httpMetadata: object.httpMetadata,
+            customMetadata: object.customMetadata,
+            body: new ReadableStream({
+                start(controller) {
+                    controller.enqueue(object.body);
+                    controller.close();
+                },
+            }),
+            arrayBuffer: async () => object.body.buffer.slice(
+                object.body.byteOffset,
+                object.body.byteOffset + object.body.byteLength,
+            ),
+        };
+        if (options.range) result.range = options.range;
+        return result;
+    }
+
+    async list(options = {}) {
+        const prefix = options.prefix || "";
+        const objects = Array.from(this.objects.values())
+            .filter((object) => object.key.startsWith(prefix))
+            .map((object) => ({
+                key: object.key,
+                size: object.size,
+                etag: object.etag,
+                httpMetadata: object.httpMetadata,
+                customMetadata: object.customMetadata,
+            }));
+        return { objects };
+    }
+
+    async bytesFrom(value) {
+        if (value instanceof Uint8Array) return value;
+        if (value instanceof ArrayBuffer) return new Uint8Array(value);
+        if (typeof value === "string") return new TextEncoder().encode(value);
+        if (value && typeof value.arrayBuffer === "function") {
+            return new Uint8Array(await value.arrayBuffer());
+        }
+        if (value && typeof value.getReader === "function") {
+            const reader = value.getReader();
+            const chunks = [];
+            let total = 0;
+            while (true) {
+                const { value: chunk, done } = await reader.read();
+                if (done) break;
+                const bytes = chunk instanceof Uint8Array ? chunk : new Uint8Array(chunk);
+                chunks.push(bytes);
+                total += bytes.byteLength;
+            }
+            const merged = new Uint8Array(total);
+            let offset = 0;
+            for (const chunk of chunks) {
+                merged.set(chunk, offset);
+                offset += chunk.byteLength;
+            }
+            return merged;
+        }
+        throw new TypeError("unsupported R2 put body");
+    }
+}
+
+function makeEnv() {
+    return {
+        DB: {},
+        MEDIA: new FakeR2Bucket(),
+        ADMIN_TOKEN: "segment-token",
+        STRIPE_SECRET_KEY: "sk_test_unused",
+        STRIPE_WEBHOOK_SECRET: "whsec_unused",
+        RESEND_API_KEY: "re_unused",
+        PUBLIC_SITE_ORIGIN: "https://holdenu.com",
+        ENVIRONMENT: "test",
+    };
+}
+
+function extractInlinePageScript(html) {
+    const match = html.match(/<script>\s*\(function \(\) \{[\s\S]*?\}\)\(\);\s*<\/script>/);
+    assert.ok(match, "CypherClaw page includes the inline runtime script");
+    return match[0].replace(/^<script>\s*/, "").replace(/\s*<\/script>$/, "");
+}
+
+function makeElement(initialAttributes = {}) {
+    const attributes = new Map(Object.entries(initialAttributes));
+    return {
+        src: "",
+        setAttribute(name, value) {
+            attributes.set(name, String(value));
+        },
+        getAttribute(name) {
+            return attributes.has(name) ? attributes.get(name) : null;
+        },
+        canPlayType(type) {
+            assert.equal(type, "application/vnd.apple.mpegurl");
+            return "probably";
+        },
+    };
+}
+
+function initializeBrowserAudioFromPage(html) {
+    const audio = makeElement({
+        "data-stream-url": "/api/cypherclaw/live.m3u8",
+        "data-playback-mode": "pending",
+    });
+    const sandbox = {
+        console,
+        window: {},
+        document: {
+            readyState: "complete",
+            addEventListener() {},
+            getElementById(id) {
+                if (id === "cypherclaw-live-audio") return audio;
+                return null;
+            },
+        },
+        EventSource: function EventSource() {},
+        requestAnimationFrame() {
+            return 1;
+        },
+        Math,
+        Date,
+        JSON,
+        Number,
+        Object,
+        String,
+    };
+    sandbox.window = sandbox;
+    vm.runInNewContext(extractInlinePageScript(html), sandbox);
+    return audio;
+}
+
+test("scripted JACK tone reaches R2 playlist and browser audio within 30 seconds", async () => {
+    const env = makeEnv();
+    const startedAt = Date.now();
+    const capturedAt = new Date(startedAt - 1_750).toISOString();
+    const segment = new TextEncoder().encode(
+        "OggS scripted JACK tone-generator 440Hz through cypherclaw-opus-stream",
+    );
+    const ingestRequest = new Request("https://cypherclaw.holdenu.com/api/cypherclaw/segment", {
+        method: "POST",
+        headers: {
+            Authorization: "Bearer segment-token",
+            "Content-Type": "audio/ogg; codecs=opus",
+            "X-CypherClaw-Sequence": "9001",
+            "X-CypherClaw-Captured-At": capturedAt,
+            "X-CypherClaw-Duration": "6.000",
+            "X-CypherClaw-Scene": "tone-generator",
+            "X-CypherClaw-Tuning": "twelve_tet",
+            "X-CypherClaw-Source": "jack-tone-generator",
+        },
+        body: segment,
+    });
+
+    const ingestResponse = await worker.fetch(ingestRequest, env, { waitUntil() {} });
+    const ingestPayload = await ingestResponse.json();
+
+    assert.equal(ingestResponse.status, 201);
+    assert.equal(ingestPayload.ok, true);
+    assert.equal(ingestPayload.sequence, 9001);
+    assert.equal(ingestPayload.size, segment.byteLength);
+    assert.ok(ingestPayload.latency_ms >= 0);
+    assert.ok(ingestPayload.latency_ms < 30_000);
+
+    const stored = await env.MEDIA.get(ingestPayload.key);
+    assert.ok(stored);
+    assert.equal(stored.customMetadata.source, "jack-tone-generator");
+    assert.equal(stored.customMetadata.latency_ms, String(ingestPayload.latency_ms));
+    assert.deepEqual(new Uint8Array(await stored.arrayBuffer()), segment);
+
+    const playlistResponse = await worker.fetch(
+        new Request("https://cypherclaw.holdenu.com/api/cypherclaw/live.m3u8"),
+        env,
+        { waitUntil() {} },
+    );
+    const playlist = await playlistResponse.text();
+    const segmentUri = playlist.split("\n").find((line) => line.startsWith("/api/cypherclaw/segment/"));
+    assert.equal(playlistResponse.status, 200);
+    assert.ok(segmentUri, "playlist references the posted tone segment");
+    assert.match(segmentUri, /\/api\/cypherclaw\/segment\/cypherclaw\/live\/\d{4}-\d{2}-\d{2}\/seg-9001\.opus/);
+
+    const segmentResponse = await worker.fetch(
+        new Request(`https://cypherclaw.holdenu.com${segmentUri}`),
+        env,
+        { waitUntil() {} },
+    );
+    assert.equal(segmentResponse.status, 200);
+    assert.equal(segmentResponse.headers.get("Content-Type"), "audio/ogg; codecs=opus");
+    assert.deepEqual(new Uint8Array(await segmentResponse.arrayBuffer()), segment);
+
+    const pageResponse = await worker.fetch(
+        new Request("https://cypherclaw.holdenu.com/"),
+        env,
+        { waitUntil() {} },
+    );
+    const audio = initializeBrowserAudioFromPage(await pageResponse.text());
+    assert.equal(pageResponse.status, 200);
+    assert.equal(audio.src, "/api/cypherclaw/live.m3u8");
+    assert.equal(audio.getAttribute("data-playback-mode"), "native-hls");
+
+    const latencyMs = Date.now() - Date.parse(capturedAt);
+    console.log(`cypherclaw_t032_latency_ms=${latencyMs} key=${ingestPayload.key}`);
+    assert.ok(latencyMs < 30_000);
+});
