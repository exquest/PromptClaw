// =================================================================
// Commerce: Stripe Checkout
// =================================================================

interface CheckoutPayload {
    release_id?: string;
    track_id?: string;
    amount_cents: number;          // PWYW user-chosen amount
    customer_email?: string;
}

async function createCheckout(req: Request, env: Env): Promise<Response> {
    const body = await req.json<CheckoutPayload>();
    if (!body || (!body.release_id && !body.track_id) || !Number.isFinite(body.amount_cents)) {
        return errorResponse(400, 'release_id (or track_id) and amount_cents required', env, req);
    }

    // Validate against PWYW floor
    let priceFloor = 100;
    let displayName = 'holdenu release';
    let releaseId: string | null = null;
    let trackId: string | null = null;

    if (body.release_id) {
        const row = await env.DB.prepare(
            `SELECT id, name, price_min_cents FROM releases WHERE id = ? AND release_date <= datetime('now')`
        ).bind(body.release_id).first<{ id: string; name: string; price_min_cents: number }>();
        if (!row) return errorResponse(404, 'release not found', env, req);
        priceFloor = row.price_min_cents;
        displayName = row.name;
        releaseId = row.id;
    } else if (body.track_id) {
        const row = await env.DB.prepare(
            `SELECT rt.track_id, rt.track_price_cents, r.id AS release_id, r.name AS release_name, r.price_min_cents AS rel_floor
               FROM release_tracks rt JOIN releases r ON r.id = rt.release_id
              WHERE rt.track_id = ? AND r.release_date <= datetime('now')
              ORDER BY r.release_date DESC LIMIT 1`
        ).bind(body.track_id).first<{ track_id: string; track_price_cents: number | null; release_id: string; release_name: string; rel_floor: number }>();
        if (!row) return errorResponse(404, 'track not found', env, req);
        priceFloor = row.track_price_cents ?? row.rel_floor;
        displayName = `${row.release_name} (track: ${row.track_id})`;
        trackId = row.track_id;
        releaseId = row.release_id;
    }

    if (body.amount_cents < priceFloor) {
        return errorResponse(400, `amount below PWYW floor (${priceFloor} cents)`, env, req);
    }

    // Create Stripe Checkout Session via REST
    const successUrl = `${env.PUBLIC_SITE_ORIGIN}/?purchased=1&session_id={CHECKOUT_SESSION_ID}`;
    const cancelUrl  = `${env.PUBLIC_SITE_ORIGIN}/?cancelled=1`;
    const params = new URLSearchParams();
    params.set('mode', 'payment');
    params.set('success_url', successUrl);
    params.set('cancel_url', cancelUrl);
    params.set('line_items[0][quantity]', '1');
    params.set('line_items[0][price_data][currency]', 'usd');
    params.set('line_items[0][price_data][unit_amount]', String(body.amount_cents));
    params.set('line_items[0][price_data][product_data][name]', displayName);
    if (body.customer_email) params.set('customer_email', body.customer_email);
    if (releaseId) params.set('metadata[release_id]', releaseId);
    if (trackId)   params.set('metadata[track_id]', trackId);

    const stripeRes = await fetch('https://api.stripe.com/v1/checkout/sessions', {
        method: 'POST',
        headers: {
            'Authorization': `Bearer ${env.STRIPE_SECRET_KEY}`,
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: params.toString(),
    });
    const session = await stripeRes.json<any>();
    if (!stripeRes.ok) {
        return errorResponse(502, `stripe: ${session?.error?.message || 'checkout creation failed'}`, env, req);
    }
    return jsonResponse({ url: session.url, session_id: session.id }, env, undefined, req);
}

// =================================================================
// Commerce: Stripe webhook + Resend email
// =================================================================

async function handleStripeWebhook(req: Request, env: Env, ctx: ExecutionContext): Promise<Response> {
    const sig = req.headers.get('Stripe-Signature') || '';
    const raw = await req.text();
    const ok = await verifyStripeSignature(raw, sig, env.STRIPE_WEBHOOK_SECRET);
    if (!ok) return errorResponse(400, 'invalid stripe signature', env, req);

    const event = JSON.parse(raw);
    if (event.type === 'checkout.session.completed') {
        const session = event.data.object;
        const email = session.customer_details?.email || session.customer_email || '';
        const amount = session.amount_total as number;
        const releaseId = session.metadata?.release_id || null;
        const trackId   = session.metadata?.track_id   || null;

        const orderId = crypto.randomUUID();
        const downloadToken = crypto.randomUUID();
        const expiresAt = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString();   // 7 days

        await env.DB.prepare(
            `INSERT INTO orders
                (id, stripe_session_id, stripe_payment_intent, customer_email,
                 release_id, track_id, amount_paid_cents, currency,
                 download_token, download_expires_at)
             VALUES (?, ?, ?, ?, ?, ?, ?, 'usd', ?, ?)
             ON CONFLICT(stripe_session_id) DO NOTHING`
        ).bind(
            orderId, session.id, session.payment_intent || null,
            email, releaseId, trackId, amount, downloadToken, expiresAt,
        ).run();

        // Look up display name for the email
        let title = 'your purchase';
        if (releaseId) {
            const r = await env.DB.prepare(`SELECT name FROM releases WHERE id = ?`).bind(releaseId).first<{ name: string }>();
            if (r) title = r.name;
        }

        const downloadUrl = `${env.PUBLIC_SITE_ORIGIN.replace(/\/$/, '')}/download/${downloadToken}`;
        ctx.waitUntil(sendDownloadEmail(env, email, title, downloadUrl, amount));
        await env.DB.prepare(`UPDATE orders SET fulfilled_at = CURRENT_TIMESTAMP WHERE id = ?`).bind(orderId).run();
    }

    return new Response('ok', { status: 200 });
}

async function verifyStripeSignature(payload: string, sigHeader: string, secret: string): Promise<boolean> {
    if (!sigHeader || !secret) return false;
    const parts = Object.fromEntries(sigHeader.split(',').map(p => p.split('=')));
    const t = parts.t;
    const v1 = parts.v1;
    if (!t || !v1) return false;
    const signed = `${t}.${payload}`;
    const enc = new TextEncoder();
    const key = await crypto.subtle.importKey(
        'raw', enc.encode(secret), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign'],
    );
    const sigBytes = await crypto.subtle.sign('HMAC', key, enc.encode(signed));
    const hex = Array.from(new Uint8Array(sigBytes))
        .map(b => b.toString(16).padStart(2, '0')).join('');
    // constant-time compare
    if (hex.length !== v1.length) return false;
    let diff = 0;
    for (let i = 0; i < hex.length; i++) diff |= hex.charCodeAt(i) ^ v1.charCodeAt(i);
    return diff === 0;
}

async function sendDownloadEmail(env: Env, to: string, title: string, downloadUrl: string, amountCents: number): Promise<void> {
    if (!env.RESEND_API_KEY || !to) return;
    const dollars = (amountCents / 100).toFixed(2);
    const subject = `Your holdenu download: ${title}`;
    const html = `
        <div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 540px; margin: 0 auto; padding: 24px; background: #0a0a14; color: #ECECEC;">
            <h1 style="font-size: 18px; letter-spacing: 0.12em; color: #fbbf24; margin-bottom: 12px;">▸ HOLDENU.COM</h1>
            <p>Thanks for supporting Be Holden U with a $${dollars} purchase of <strong>${escapeHtml(title)}</strong>.</p>
            <p>Your download link is good for 7 days:</p>
            <p style="margin: 24px 0;">
                <a href="${downloadUrl}" style="background: rgba(251,191,36,0.18); border: 1px solid rgba(251,191,36,0.7); color: #fbbf24; padding: 10px 18px; border-radius: 4px; text-decoration: none;">
                    ↓ Download
                </a>
            </p>
            <p style="font-size: 12px; color: #9ca3af; margin-top: 32px;">
                If the link expires you can reply to this email and I'll re-issue.<br>
                — Anthony at Be Holden U
            </p>
        </div>
    `.trim();

    await fetch('https://api.resend.com/emails', {
        method: 'POST',
        headers: {
            'Authorization': `Bearer ${env.RESEND_API_KEY}`,
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            from: 'Be Holden U <hello@holdenu.com>',
            to: [to],
            subject,
            html,
        }),
    });
}

function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c] as string));
}

