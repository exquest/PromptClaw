interface ShellOptions {
    title: string;
    description: string;
    ogImage: string;
    canonical: string;
    ogType: string;        // 'music.album' | 'music.song' | 'website'
    spaParam: string;      // 'release=<id>' or 'track=<id>'
    siteOrigin: string;
}

// Returns a small HTML doc with OG/Twitter meta tags + a meta-refresh
// to the SPA at /. Crawlers (Twitter, Discord, Slack, FB, Google) read
// the meta tags here. Humans get redirected to the SPA which knows how
// to open the right side panel via the ?release= / ?track= param.
function renderShell(opts: ShellOptions): string {
    const target = `${opts.siteOrigin}/?${opts.spaParam}`;
    const t = escapeHtml(opts.title);
    const d = escapeHtml(opts.description);
    const c = escapeHtml(opts.canonical);
    const i = escapeHtml(opts.ogImage);
    const tg = escapeHtml(target);
    return `<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${t}</title>
    <meta name="description" content="${d}">
    <link rel="canonical" href="${c}">
    <meta http-equiv="refresh" content="0; url=${tg}">

    <!-- Open Graph -->
    <meta property="og:type" content="${escapeHtml(opts.ogType)}">
    <meta property="og:title" content="${t}">
    <meta property="og:description" content="${d}">
    <meta property="og:image" content="${i}">
    <meta property="og:url" content="${c}">
    <meta property="og:site_name" content="Be Holden U">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="${t}">
    <meta name="twitter:description" content="${d}">
    <meta name="twitter:image" content="${i}">
</head>
<body style="background:#0a0a14;color:#ECECEC;font-family:system-ui,sans-serif;text-align:center;padding:4rem 1rem;">
    <p>Loading <strong>${t}</strong>…</p>
    <p style="margin-top:1rem;"><a href="${tg}" style="color:#fbbf24;">enter holdenu.com →</a></p>
    <script>setTimeout(function(){location.href=${JSON.stringify(target)};}, 50);</script>
</body>
</html>`;
}

function notFoundHtml(message: string, env: Env): string {
    return `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>404 — holdenu.com</title>
<meta http-equiv="refresh" content="2; url=${escapeHtml(env.PUBLIC_SITE_ORIGIN)}/">
<style>body{background:#0a0a14;color:#ECECEC;font-family:system-ui,sans-serif;text-align:center;padding:4rem 1rem;}a{color:#fbbf24;}</style>
</head><body><h1>${escapeHtml(message)}</h1><p><a href="${escapeHtml(env.PUBLIC_SITE_ORIGIN)}/">→ back to holdenu.com</a></p></body></html>`;
}

async function serveSitemap(env: Env): Promise<Response> {
    const releases = await env.DB.prepare(
        `SELECT id, release_date FROM releases WHERE release_date <= datetime('now') ORDER BY release_date DESC`
    ).all<{ id: string; release_date: string }>();

    const tracks = await env.DB.prepare(
        `SELECT DISTINCT rt.track_id, MAX(r.release_date) AS rd
           FROM release_tracks rt JOIN releases r ON r.id = rt.release_id
          WHERE r.release_date <= datetime('now')
          GROUP BY rt.track_id`
    ).all<{ track_id: string; rd: string }>();

    const origin = env.PUBLIC_SITE_ORIGIN.replace(/\/$/, '');
    const urls: string[] = [];
    urls.push(`<url><loc>${origin}/</loc><changefreq>weekly</changefreq><priority>1.0</priority></url>`);
    for (const r of releases.results) {
        urls.push(`<url><loc>${origin}/release/${encodeURIComponent(r.id)}</loc><lastmod>${r.release_date.split(' ')[0]}</lastmod><priority>0.9</priority></url>`);
    }
    for (const t of tracks.results) {
        urls.push(`<url><loc>${origin}/track/${encodeURIComponent(t.track_id)}</loc><lastmod>${(t.rd || '').split(' ')[0]}</lastmod><priority>0.8</priority></url>`);
    }
    const xml = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${urls.join('\n')}
</urlset>`;
    return new Response(xml, {
        headers: {
            'Content-Type': 'application/xml; charset=utf-8',
            'Cache-Control': 'public, max-age=600',
        },
    });
}

function serveRobots(env: Env): Response {
    const origin = env.PUBLIC_SITE_ORIGIN.replace(/\/$/, '');
    const txt = `User-agent: *
Allow: /
Disallow: /api/
Disallow: /download/

Sitemap: ${origin}/sitemap.xml
`;
    return new Response(txt, {
        headers: { 'Content-Type': 'text/plain; charset=utf-8' },
    });
}

async function serveArtwork(req: Request, env: Env, releaseId: string): Promise<Response> {
    const row = await env.DB.prepare(
        `SELECT artwork_key FROM releases WHERE id = ?`
    ).bind(releaseId).first<{ artwork_key: string | null }>();
    if (!row || !row.artwork_key) return errorResponse(404, 'no artwork on file', env, req);
    const obj = await env.MEDIA.get(row.artwork_key);
    if (!obj) return errorResponse(404, 'artwork missing in storage', env, req);
    const headers = new Headers(corsHeaders(env, req));
    headers.set('Content-Type', obj.httpMetadata?.contentType || 'image/jpeg');
    headers.set('Content-Length', String(obj.size));
    headers.set('Cache-Control', 'public, max-age=86400, immutable');
    return new Response(obj.body, { status: 200, headers });
}

// =================================================================
// Public: signed download
// =================================================================

async function serveDownload(req: Request, env: Env, token: string): Promise<Response> {
    const row = await env.DB.prepare(
        `SELECT id, release_id, track_id, download_expires_at, download_count, customer_email
           FROM orders WHERE download_token = ?`
    ).bind(token).first<{
        id: string; release_id: string | null; track_id: string | null;
        download_expires_at: string; download_count: number; customer_email: string;
    }>();
    if (!row) return errorResponse(404, 'invalid download token', env, req);
    if (new Date(row.download_expires_at) < new Date()) {
        return errorResponse(410, 'download link expired — reply to your email to re-issue', env, req);
    }

    // Resolve which file to deliver. Prefer FLAC (lossless purchase).
    let key: string | null = null;
    let filename = 'holdenu-download';
    if (row.track_id) {
        const t = await env.DB.prepare(
            `SELECT rt.audio_flac_key, rt.audio_aac_key, rt.title_override, r.name AS rel_name
               FROM release_tracks rt JOIN releases r ON r.id = rt.release_id
              WHERE rt.track_id = ? ORDER BY r.release_date DESC LIMIT 1`
        ).bind(row.track_id).first<{
            audio_flac_key: string | null; audio_aac_key: string | null;
            title_override: string | null; rel_name: string;
        }>();
        if (t) {
            key = t.audio_flac_key || t.audio_aac_key;
            filename = `${(t.title_override || row.track_id).replace(/[^A-Za-z0-9_-]+/g, '_')}.${(key || '').split('.').pop()}`;
        }
    } else if (row.release_id) {
        // For release-level purchases we'd zip up the tracks. Phase-3 v1
        // delivers the first track's FLAC; full-release zip is a TODO.
        const t = await env.DB.prepare(
            `SELECT audio_flac_key, audio_aac_key, track_id
               FROM release_tracks WHERE release_id = ? ORDER BY track_order LIMIT 1`
        ).bind(row.release_id).first<{ audio_flac_key: string | null; audio_aac_key: string | null; track_id: string }>();
        if (t) {
            key = t.audio_flac_key || t.audio_aac_key;
            filename = `${row.release_id}.${(key || '').split('.').pop()}`;
        }
    }
    if (!key) return errorResponse(404, 'no audio file on file for this order yet — reply to email', env, req);

    const obj = await env.MEDIA.get(key);
    if (!obj) return errorResponse(404, 'audio missing in storage', env, req);

    await env.DB.prepare(`UPDATE orders SET download_count = download_count + 1 WHERE id = ?`).bind(row.id).run();

    const headers = new Headers();
    headers.set('Content-Type', obj.httpMetadata?.contentType || 'application/octet-stream');
    headers.set('Content-Length', String(obj.size));
    headers.set('Content-Disposition', `attachment; filename="${filename}"`);
    return new Response(obj.body, { status: 200, headers });
}

