ction:\\\\\\\\\\\\\\\\n         assert detect_onset(0.005, 0.001, release_threshold=0.01) == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"silence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+# === detect_click_transients ===\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+class TestClickDetection:\\\\\\\\\\\\\\\\n+    def test_clean_sine_has_no_clicks(self):\\\\\\\\\\\\\\\\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=6000)\\\\\\\\\\\\\\\\n+        result = detect_click_transients(samples, 48000)\\\\\\\\\\\\\\\\n+        assert result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == 0\\\\\\\\\\\\\\\\n+        assert result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"events\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == []\\\\\\\\\\\\\\\\n+        assert result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"suppressed_as_periodic\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] is False\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def test_single_impulse_is_detected(self):\\\\\\\\\\\\\\\\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=6000)\\\\\\\\\\\\\\\\n+        samples[24000] = 32000\\\\\\\\\\\\\\\\n+        result = detect_click_transients(samples, 48000)\\\\\\\\\\\\\\\\n+        assert result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == 1\\\\\\\\\\\\\\\\n+        assert len(result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"events\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]) == 1\\\\\\\\\\\\\\\\n+        event = result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"events\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][0]\\\\\\\\\\\\\\\\n+        assert abs(event[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"time_seconds\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] - 0.5) < 0.005\\\\\\\\\\\\\\\\n+        assert event[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"width_samples\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] <= 4\\\\\\\\\\\\\\\\n+        assert event[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"residual\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] > 0.5\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def test_sparse_click_burst_is_retained(self):\\\\\\\\\\\\\\\\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=5000)\\\\\\\\\\\\\\\\n+        for idx in (9600, 10176, 10752, 11328, 11904):\\\\\\\\\\\\\\\\n+            samples[idx] = 32000\\\\\\\\\\\\\\\\n+        result = detect_click_transients(samples, 48000)\\\\\\\\\\\\\\\\n+        assert result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == 5\\\\\\\\\\\\\\\\n+        assert result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"suppressed_as_periodic\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] is False\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def test_dense_impulse_train_is_suppressed_as_periodic(self):\\\\\\\\\\\\\\\\n+        samples = _silence(48000, 1.0)\\\\\\\\\\\\\\\\n+        for idx in range(0, len(samples), 240):\\\\\\\\\\\\\\\\n+            samples[idx] = 32000\\\\\\\\\\\\\\\\n+        result = detect_click_transients(samples, 48000)\\\\\\\\\\\\\\\\n+        assert result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] == 0\\\\\\\\\\\\\\\\n+        assert result[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"suppressed_as_periodic\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] is True\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n # === classify_audio_content ===\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\ndiff --git a/tests/test_continuous_learner.py b/tests/test_continuous_learner.py\\\\\\\\\\\\\\\\nindex a6fedc3..5100aee 100644\\\\\\\\\\\\\\\\n--- a/tests/test_continuous_learner.py\\\\\\\\\\\\\\\\n+++ b/tests/test_continuous_learner.py\\\\\\\\\\\\\\\\n@@ -22,6 +22,12 @@ class TestRecording:\\\\\\\\\\\\\\\\n         assert cl.growth.total_songs == 1\\\\\\\\\\\\\\\\n         assert \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"D\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in cl.growth.keys_explored\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+    def test_start_song_tracks_context_tags(self):\\\\\\\\\\\\\\\\n+        cl = ContinuousLearner()\\\\\\\\\\\\\\\\n+        cl.start_song(1, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"D\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\