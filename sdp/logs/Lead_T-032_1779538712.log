      0,
      1,
      pickNumber(previousFeatures, ["motion"], Math.min(1, onsetRate / 8))
    );
    const texture = pickFiniteNumber(
      [source.texture, visual.texture],
      0,
      1,
      pickNumber(previousFeatures, ["texture"], 0.35)
    );
    const density = pickFiniteNumber(
      [source.density, visual.density],
      0,
      1,
      pickNumber(previousFeatures, ["density"], Math.min(1, onsetRate / 10))
    );
    const salience = pickFiniteNumber(
      [source.salience, visual.salience],
      0,
      1,
      pickNumber(previousFeatures, ["salience"], Math.max(rms, motion))
    );
    const arcPhase = pickString(
      [source.arc_phase, source.arcPhase, sceneObject.arc_phase, sceneObject.arcPhase, sceneObject.phase],
      previousFeatures.arc_phase || ""
    );
    const scene = pickString(
      [sceneObject.name, sceneObject.current, source.current_scene, source.scene_name, source.scene, arcPhase],
      previousFeatures.scene || "awaiting-live-features"
    );
    const tuning = pickString(
      [tuningObject.name, tuningObject.current, tuningObject.system, source.tuning_system_name, source.tuningSystemName, source.tuning],
      previousFeatures.tuning || "unknown"
    );
    const capturedAt = pickString(
      [source.captured_at, source.capturedAt, source.timestamp, audio.captured_at],
      previousFeatures.captured_at || ""
    );
    const dspBlocks = Array.isArray(source.dsp_blocks)
      ? source.dsp_blocks
      : Array.isArray(visual.dsp_blocks)
        ? visual.dsp_blocks
        : (Array.isArray(previousFeatures.dsp_blocks) ? previousFeatures.dsp_blocks : []);

    return Object.assign({}, previousFeatures, source, {
      source: pickString([source.source], previousFeatures.source || "live-features"),
      captured_at: capturedAt,
      rms: rms,
      amplitude: rms,
      pitch_hz: pitch,
      centroid_hz: centroid,
      spectral_centroid_hz: centroid,
      onset_rate_hz: onsetRate,
      brightness: brightness,
      motion: motion,
      texture: texture,
      density: density,
      salience: salience,
      scene: scene,
      arc_phase: arcPhase,
      tuning: tuning,
      dsp_blocks: dspBlocks,
      artistic_identity: pickString([source.artistic_identity, visual.artistic_identity], previousFeatures.artistic_identity || ""),
