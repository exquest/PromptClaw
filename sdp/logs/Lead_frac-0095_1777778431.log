from typing import Any

from fastapi.testclient import TestClient

from cypherclaw.narrative_api.app import create_app


EVENTS = [
    {
        "id": "evt-001",
        "type": "world.bootstrap",
        "domain": "shared",
        "payload": {"note": "world bootstrapped"},
        "created_at": "2026-05-01T00:00:00Z",
    },
