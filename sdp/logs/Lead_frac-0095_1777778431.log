+            {"id": "entity-2", "type": "npc", "domain": "deniable"},
+        ]
+        assert event_rows == [
+            {"id": "event-1", "kind": "spawn", "domain": "shared"},
+            {"id": "event-2", "kind": "raid.completed", "domain": "deniable"},
+        ]
+
