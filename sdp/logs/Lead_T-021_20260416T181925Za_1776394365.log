from __future__ import annotations

import collections

from cypherclaw.render.events import Event
from cypherclaw.render.rules.motif_memory import MotifMemoryRule, VARIATION_MENU


def _make_motif(pitch_start: int = 60, role: str = "melody") -> list[Event]:
    e1 = Event(role=role)
    e1.pitch = pitch_start # type: ignore
    e1.nominal_dur_sec = 0.5 # type: ignore
    
    e2 = Event(role=role)
    e2.pitch = pitch_start + 2 # type: ignore
    e2.nominal_dur_sec = 0.25 # type: ignore
    
    e3 = Event(role=role)
    e3.pitch = pitch_start + 4 # type: ignore
    e3.nominal_dur_sec = 0.25 # type: ignore
    return [e1, e2, e3]


def test_motif_memory_hashes_by_pitch_class_and_rhythm() -> None:
    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=8)
    m1 = _make_motif(60) # C4
    m2 = _make_motif(72) # C5 - same pitch class
    
    # Both should hash to the same value
    h1 = rule._hash_motif(m1)
    h2 = rule._hash_motif(m2)
    assert h1 == h2
    
    # Different rhythm -> different hash
    m3 = _make_motif(60)
    m3[0].nominal_dur_sec = 0.75 # type: ignore
    h3 = rule._hash_motif(m3)
    assert h1 != h3


def test_motif_memory_return_home() -> None:
    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=8, seed=42)
    motif = _make_motif()
    
    # Iteration 1
    assert rule.apply(motif) == "original"
    
    # Iterations 2-8
    for i in range(2, 9):
        var = rule.apply(motif)
        assert var in VARIATION_MENU
        assert var != "original"
        
    # Iteration 9 (return home)
    assert rule.apply(motif) == "original"


def test_motif_memory_recency_weighting() -> None:
    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=100, seed=123)
    motif = _make_motif()
    
    # Advance to build up history
    rule.apply(motif) # iteration 1 -> original
    
    # Let's apply many times and track distribution
    counts = collections.Counter()
    for _ in range(100):
        # Different motifs so we don't hit return-home
        m = _make_motif(pitch_start=60 + _)
        var = rule.apply(m) # m is new, so it returns "original"
        # wait, we want to test variations, so we should apply the SAME motif
    
    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=1000, seed=123)
    motif = _make_motif()
    rule.apply(motif) # 1 -> original
    
    vars_seen = []
    for _ in range(50):
        vars_seen.append(rule.apply(motif))
        
    # Because of inverse recency weighting, we should see a relatively even distribution
    # over time, avoiding long runs of the same variation.
    counts = collections.Counter(vars_seen)
    assert len(counts) == len(VARIATION_MENU)
    for v in VARIATION_MENU:
        assert counts[v] > 0
        
    # Check that consecutive repeats are rare or nonexistent
    consecutive_repeats = 0
    for i in range(1, len(vars_seen)):
        if vars_seen[i] == vars_seen[i-1]:
            consecutive_repeats += 1
            
    assert consecutive_repeats < 5 # Inverse recency should heavily penalize repeats


def test_motif_memory_lru_decay() -> None:
    rule = MotifMemoryRule(max_cache_size=2, return_home_iterations=8)
    
    m1 = _make_motif(60)
    m2 = _make_motif(62)
    m3 = _make_motif(64)
    
    assert rule.apply(m1) == "original" # m1 in cache
    assert rule.apply(m2) == "original" # m1, m2 in cache
    
    # m1 is now oldest. if we apply m3, m1 should be evicted
    assert rule.apply(m3) == "original" # m2, m3 in cache
    
    # Since m1 was evicted, applying it again should treat it as new (iteration 1 -> original)
    assert rule.apply(m1) == "original"
    
    # Applying m2 should result in variation (it was in cache)
    # wait, when m1 was inserted, m2 became oldest.
    assert rule.apply(m2) == "original" # wait, applying m1 evicted m2!
    # Let's trace:
    # m1 inserted -> [m1]
    # m2 inserted -> [m1, m2]
    # m3 inserted -> evicts m1 -> [m2, m3]
    # m1 inserted -> evicts m2 -> [m3, m1]
    # m2 inserted -> evicts m3 -> [m1, m2]
    # So m2 is treated as new, returns "original".
    
    # Let's just make sure m1 returns original when evicted and re-entered
    rule = MotifMemoryRule(max_cache_size=2, return_home_iterations=8)
    assert rule.apply(_make_motif(60)) == "original" # m1: count=1
    assert rule.apply(_make_motif(60)) != "original" # m1: count=2
    
    # evict m1
    rule.apply(_make_motif(62))
    rule.apply(_make_motif(64))
    
    # m1 should be forgotten
    assert rule.apply(_make_motif(60)) == "original" # count=1


def test_motif_memory_role_gating() -> None:
    rule = MotifMemoryRule(max_cache_size=10, return_home_iterations=8)
    
    # Ostinato is grid-locked, shouldn't be varied
    motif = _make_motif(role="ostinato")
    
    for _ in range(10):
        assert rule.apply(motif) == "original"

