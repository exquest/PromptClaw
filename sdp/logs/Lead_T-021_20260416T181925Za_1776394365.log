from __future__ import annotations

import collections
import hashlib
import random
from typing import Any

from cypherclaw.render.events import Event
from cypherclaw.render.role_gate import role_is_eligible

VARIATION_MENU = (
    "transposition",
    "inversion",
    "retrograde",
    "rhythmic augmentation",
    "re-voicing",
    "partial fragmentation",
)

class MotifMemoryRule:
    """R9 Motif Memory: LRU cache of motif hashes with variation menu and return-home decay."""

    rule_id = "R9"

    def __init__(
        self,
        max_cache_size: int = 16,
        return_home_iterations: int = 8,
        seed: int | None = None
    ) -> None:
        self.max_cache_size = max_cache_size
        self.return_home_iterations = return_home_iterations
        self._rng = random.Random(seed)
        
        self._motif_counts: dict[str, int] = collections.defaultdict(int)
        self._lru_cache: collections.OrderedDict[str, bool] = collections.OrderedDict()
        
        self._variation_last_used: dict[str, int] = {v: 0 for v in VARIATION_MENU}
        self._variation_counter = 0

    def applies_to(self, role: str, metadata: dict[str, str] | None = None) -> bool:
        return role_is_eligible(role, metadata)

    def _hash_motif(self, events: list[Event]) -> str:
        """Hash motifs by pitch-class + rhythm signature."""
        parts = []
        for e in events:
            pc = getattr(e, 'pitch', 0) % 12
            dur = getattr(e, 'nominal_dur_sec', 0.0)
            parts.append(f"{pc}:{dur:.3f}")
        return hashlib.md5(",".join(parts).encode("utf-8")).hexdigest()

    def _select_variation(self) -> str:
        """Select a variation weighted inversely by recency."""
        weights = []
        for v in VARIATION_MENU:
            age = self._variation_counter - self._variation_last_used[v]
            weights.append(max(1, age))
            
        chosen = self._rng.choices(VARIATION_MENU, weights=weights, k=1)[0]
        self._variation_counter += 1
        self._variation_last_used[chosen] = self._variation_counter
        return chosen

    def apply(self, events: list[Event]) -> str:
        """
        Apply motif memory to a list of events representing a phrase/motif.
        Returns the variation to apply, or 'original' if unchanged.
        """
        if not events:
            return "original"

        role = getattr(events[0], 'role', "")
        metadata = getattr(events[0], 'metadata', {})
        if not self.applies_to(role, metadata):
            return "original"

        motif_hash = self._hash_motif(events)
        
        self._motif_counts[motif_hash] += 1
        count = self._motif_counts[motif_hash]
        
        if motif_hash in self._lru_cache:
            self._lru_cache.move_to_end(motif_hash)
        else:
            self._lru_cache[motif_hash] = True
            if len(self._lru_cache) > self.max_cache_size:
                oldest_hash, _ = self._lru_cache.popitem(last=False)
                if oldest_hash in self._motif_counts:
                    del self._motif_counts[oldest_hash]
        
        if count % self.return_home_iterations == 1:
            return "original"
            
        return self._select_variation()

