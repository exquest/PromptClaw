+class MotifMemory:
+    """Fixed-capacity LRU cache for motif recall metadata."""
+
+    def __init__(self, capacity: int = 16) -> None:
+        if capacity < 1:
+            raise ValueError("MotifMemory capacity must be positive")
+        self.capacity = capacity
