    }
    assert columns["domain"] == {
        "type": "TEXT",
        "notnull": 0,
        "default": "'shared'",
    }

    connection.execute(
        "INSERT INTO entities (id, type, domain) VALUES "
        "('entity-2', 'npc', 'deniable')"
    )
    inserted_domain = connection.execute(
        "SELECT domain FROM entities WHERE id = 'entity-2'"
