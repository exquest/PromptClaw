+                        "operation": "set",
+                        "field": "current_state",
+                        "value": "wounded",
+                    }
+                ]
+            },
+            {"mutations": []},
+            {
+                "mutations": [
+                    {
+                        "operation": "set",
+                        "field": "id",
+                        "value": "other-id",
+                    }
+                ]
+            },
+            {
