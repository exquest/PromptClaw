+                        "value": "wounded",
+                    }
+                ]
+            },
+            headers={"X-Narrative-Auth": "test-token"},
+        )
+
+        assert resp.status_code == 503
+
+    def test_auth_enabled_missing_header_returns_401(self):
+        store = MutableEntityStore()
