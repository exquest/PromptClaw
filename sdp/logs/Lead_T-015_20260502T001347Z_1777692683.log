"""Entry point so ``python -m cypherclaw.narrative_api`` boots the API."""
from __future__ import annotations

import os

import uvicorn

from .app import create_app


def _resolve_host() -> str:
    return os.environ.get("NARRATIVE_BIND_HOST", "127.0.0.1")


def _resolve_port() -> int:
    return int(os.environ.get("NARRATIVE_BIND_PORT", "8765"))


def main() -> None:
    from cypherclaw.first_boot import bootstrap_identity
    bootstrap_identity()
    app = create_app(auth_token=os.environ.get("NARRATIVE_AUTH_TOKEN") or None)
    uvicorn.run(
        app,
        host=_resolve_host(),
        port=_resolve_port(),
        log_level=os.environ.get("NARRATIVE_LOG_LEVEL", "info"),
    )


if __name__ == "__main__":
    main()

