+                    {
+                        "operation": "set",
+                        "field": "current_state",
+                        "value": "wounded",
+                    }
+                ]
+            },
+        )
+
+        assert resp.status_code == 401
+        assert store.update_calls == []
+
+    def test_auth_enabled_correct_header_succeeds(self):
+        store = MutableEntityStore()
+        client = TestClient(create_app(event_store=store, auth_token="test-token"))
+
