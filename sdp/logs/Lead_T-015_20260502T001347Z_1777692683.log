+        store = MutableEntityStore()
+        client = TestClient(create_app(event_store=store, auth_token="test-token"))
+        headers = {"X-Narrative-Auth": "test-token"}
+
+        resp = client.patch(
+            "/world/entities/fighter-1",
+            json={
+                "mutations": [
+                    {
+                        "target_entity": "fighter-1",
