+        commission=commission,
+        brief=brief,
+        form=form,
+        family="ember",
+        cadence_state="occupied_day",
+        progression_profile="lift",
+        song_num=30,
+        mood={"energy": 0.74, "valence": 0.62, "arousal": 0.72},
+    )
+
+    production_arc = tree.arrangement_plan["production_arc"]
