+    total_duration_s = max(1.0, sum(section.target_duration_s for section in sections))
+    cycle_minutes = max(0.001, float(commission.arc_cycle_minutes or 30.0))
+    cursor_s = 0.0
+    production_arc: dict[str, dict[str, str]] = {}
