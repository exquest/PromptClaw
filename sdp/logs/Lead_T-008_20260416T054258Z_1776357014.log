+        "Divination",
+        "Emergence",
+        "Conversation",
+        "Convergence",
+        "Crystallization",
+    ]
+    assert set(production_arc) == {section.scene_name for section in tree.sections}
+
+    compiled = compile_score_tree_to_tracker(
