+        observer_description="active room with a full installation arc",
+        cadence_state="occupied_day",
+        day_phase="day",
+        time_of_day="evening",
+        occupancy_state="occupied_active",
+        attention_score=0.72,
+        experimentation_bias=0.96,
+    )
