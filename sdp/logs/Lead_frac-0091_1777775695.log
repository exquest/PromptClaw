+        quarter_tone_hz = quarter_tone_to_freq(root_midi + 0.5)
+
+        assert just_chord[0] < just_chord[1] < just_chord[2]
+        assert partials == sorted(partials)
+        assert c4_hz < quarter_tone_hz < midi_to_freq(root_midi + 1)
+
+        snapshot = {
+            "key": key.name,
+            "root": {
+                "note": "C4",
+                "midi": root_midi,
