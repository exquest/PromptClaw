    "melodic_minor": MELODIC_MINOR,
    "major_pentatonic": MAJOR_PENTATONIC,
    "minor_pentatonic": MINOR_PENTATONIC,
    "whole_tone": WHOLE_TONE,
    "octatonic_hw": OCTATONIC_HW,
    "octatonic_wh": OCTATONIC_WH,
    "blues": BLUES,
    "hirajoshi": HIRAJOSHI,
