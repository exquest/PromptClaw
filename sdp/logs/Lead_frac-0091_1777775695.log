 """Tests for music_theory.py -- pitch, interval, scale, and microtonal helpers."""
 from __future__ import annotations
 
+import json
 import os
 import sys
 
@@ -504,3 +505,128 @@
         assert abs(freqs[0] - 440.0) < 0.1
