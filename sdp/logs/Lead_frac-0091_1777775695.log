]


def _unique_intervals(intervals: Sequence[int]) -> tuple[int, ...]:
    seen: set[int] = set()
    result: list[int] = []
    for interval in intervals:
        pc = interval % 12
        if pc not in seen:
            seen.add(pc)
            result.append(interval)
    return tuple(result)


