+const test = require("node:test");
+const assert = require("node:assert/strict");
+
+const worker = require("../.tmp/test-build/index.js").default;
+
+class FakeR2Bucket {
+    constructor() {
+        this.objects = new Map();
+    }
+
+    async put(key, value, options = {}) {
+        const bytes = await this.bytesFrom(value);
+        const object = {
+            key,
+            body: bytes,
+            size: bytes.byteLength,
+            etag: `etag-${this.objects.size + 1}`,
+            httpMetadata: options.httpMetadata || {},
+            customMetadata: options.customMetadata || {},
+        };
+        this.objects.set(key, object);
+        return { key, size: object.size, etag: object.etag };
+    }
+
+    async get(key) {
+        const object = this.objects.get(key);
+        if (!object) return null;
+        return {
+            ...object,
+            arrayBuffer: async () => object.body.buffer.slice(
+                object.body.byteOffset,
+                object.body.byteOffset + object.body.byteLength,
+            ),
+        };
+    }
+
+    async list(options = {}) {
+        const prefix = options.prefix || "";
+        const objects = Array.from(this.objects.values())
+            .filter((object) => object.key.startsWith(prefix))
+            .map((object) => ({
+                key: object.key,
+                size: object.size,
+                etag: object.etag,
+                httpMetadata: object.httpMetadata,
+                customMetadata: object.customMetadata,
+            }));
+        return { objects };
+    }
+
+    async bytesFrom(value) {
+        if (value instanceof Uint8Array) return value;
+        if (value instanceof ArrayBuffer) return new Uint8Array(value);
+        if (typeof value === "string") return new TextEncoder().encode(value);
+        if (value && typeof value.arrayBuffer === "function") {
+            return new Uint8Array(await value.arrayBuffer());
+        }
+        if (value && typeof value.getReader === "function") {
+            const reader = value.getReader();
+            const chunks = [];
+            let total = 0;
+            while (true) {
+                const { value: chunk, done } = await reader.read();
+                if (done) break;
+                const bytes = chunk instanceof Uint8Array ? chunk : new Uint8Array(chunk);
+                chunks.push(bytes);
+                total += bytes.byteLength;
+            }
+            const merged = new Uint8Array(total);
+            let offset = 0;
+            for (const chunk of chunks) {
+                merged.set(chunk, offset);
+                offset += chunk.byteLength;
+            }
+            return merged;
+        }
+        throw new TypeError("unsupported R2 put body");
+    }
+}
+
+function makeEnv() {
+    return {
+        DB: {},
+        MEDIA: new FakeR2Bucket(),
+        ADMIN_TOKEN: "segment-token",
+        STRIPE_SECRET_KEY: "sk_test_unused",
+        STRIPE_WEBHOOK_SECRET: "whsec_unused",
+        RESEND_API_KEY: "re_unused",
+        PUBLIC_SITE_ORIGIN: "https://holdenu.com",
+        ENVIRONMENT: "test",
+    };
+}
+
+test("stores an authenticated CypherClaw segment in R2", async () => {
+    const env = makeEnv();
+    const segment = new Uint8Array([79, 103, 103, 83, 1, 2, 3, 4]);
+    const request = new Request("https://explorer.holdenu.com/api/cypherclaw/segment", {
+        method: "POST",
+        headers: {
+            Authorization: "Bearer segment-token",
+            "Content-Type": "audio/ogg; codecs=opus",
+            "X-CypherClaw-Sequence": "42",
+            "X-CypherClaw-Captured-At": "2026-05-23T09:30:00Z",
+            "X-CypherClaw-Duration": "6.000",
+            "X-CypherClaw-Scene": "Second Return",
+            "X-CypherClaw-Tuning": "slendro",
+        },
+        body: segment,
+    });
+
+    const response = await worker.fetch(request, env, { waitUntil() {} });
+    const payload = await response.json();
+
+    assert.equal(response.status, 201);
+    assert.equal(payload.ok, true);
+    assert.equal(payload.key, "cypherclaw/live/2026-05-23/seg-42.opus");
+    assert.equal(payload.sequence, 42);
+    assert.equal(payload.size, segment.byteLength);
+
+    const listing = await env.MEDIA.list({ prefix: "cypherclaw/live/2026-05-23/" });
+    assert.deepEqual(listing.objects.map((object) => object.key), [
+        "cypherclaw/live/2026-05-23/seg-42.opus",
+    ]);
+
+    const stored = await env.MEDIA.get(payload.key);
+    assert.ok(stored);
+    assert.deepEqual(new Uint8Array(await stored.arrayBuffer()), segment);
+    assert.equal(stored.httpMetadata.contentType, "audio/ogg; codecs=opus");
+    assert.deepEqual(stored.customMetadata, {
+        captured_at: "2026-05-23T09:30:00.000Z",
+        duration: "6.000",
+        scene: "Second Return",
+        sequence: "42",
+        tuning: "slendro",
+    });
+});
+
+test("rejects unauthenticated CypherClaw segment posts", async () => {
+    const env = makeEnv();
+    const request = new Request("https://explorer.holdenu.com/api/cypherclaw/segment", {
+        method: "POST",
+        headers: {
+            "X-CypherClaw-Sequence": "7",
+            "X-CypherClaw-Captured-At": "2026-05-23T09:30:00Z",
+        },
+        body: new Uint8Array([1, 2, 3]),
+    });
+
+    const response = await worker.fetch(request, env, { waitUntil() {} });
+    const payload = await response.json();
