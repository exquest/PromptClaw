   133	async function receiveCypherClawSegment(req: Request, env: Env): Promise<Response> {
   134	    if (!req.body) return errorResponse(400, 'request body required', env, req);
   135	
   136	    const sequenceHeader = req.headers.get('X-CypherClaw-Sequence') || '';
   137	    if (!/^\d+$/.test(sequenceHeader)) {
   138	        return errorResponse(400, 'X-CypherClaw-Sequence must be a non-negative integer', env, req);
   139	    }
   140	    const sequence = Number(sequenceHeader);
   141	    if (!Number.isSafeInteger(sequence)) {
   142	        return errorResponse(400, 'X-CypherClaw-Sequence is outside the safe integer range', env, req);
   143	    }
   144	
   145	    const capturedAtHeader = req.headers.get('X-CypherClaw-Captured-At');
   146	    const capturedAt = capturedAtHeader ? new Date(capturedAtHeader) : new Date();
   147	    if (Number.isNaN(capturedAt.getTime())) {
   148	        return errorResponse(400, 'X-CypherClaw-Captured-At must be a valid ISO timestamp', env, req);
   149	    }
   150	
   151	    const dateKey = capturedAt.toISOString().slice(0, 10);
   152	    const key = `cypherclaw/live/${dateKey}/seg-${sequence}.opus`;
   153	    const contentType = req.headers.get('Content-Type') || CYPHERCLAW_SEGMENT_CONTENT_TYPE;
   154	    const customMetadata: Record<string, string> = {
   155	        sequence: String(sequence),
   156	        captured_at: capturedAt.toISOString(),
   157	    };
   158	
   159	    const duration = req.headers.get('X-CypherClaw-Duration');
   160	    const scene = req.headers.get('X-CypherClaw-Scene');
   161	    const tuning = req.headers.get('X-CypherClaw-Tuning');
   162	    if (duration) customMetadata.duration = duration;
   163	    if (scene) customMetadata.scene = scene;
   164	    if (tuning) customMetadata.tuning = tuning;
   165	
