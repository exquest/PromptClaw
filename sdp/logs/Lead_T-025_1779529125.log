    return jsonResponse({ url: session.url, session_id: session.id }, env, undefined, req);
}

// =================================================================
// Commerce: Stripe webhook + Resend email
// =================================================================

async function handleStripeWebhook(req: Request, env: Env, ctx: ExecutionContext): Promise<Response> {
    const sig = req.headers.get('Stripe-Signature') || '';
    const raw = await req.text();
    const ok = await verifyStripeSignature(raw, sig, env.STRIPE_WEBHOOK_SECRET);
    if (!ok) return errorResponse(400, 'invalid stripe signature', env, req);

    const event = JSON.parse(raw);
    if (event.type === 'checkout.session.completed') {
        const session = event.data.object;
        const email = session.customer_details?.email || session.customer_email || '';
        const amount = session.amount_total as number;
        const releaseId = session.metadata?.release_id || null;
        const trackId   = session.metadata?.track_id   || null;

        const orderId = crypto.randomUUID();
        const downloadToken = crypto.randomUUID();
        const expiresAt = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString();   // 7 days

        await env.DB.prepare(
            `INSERT INTO orders
                (id, stripe_session_id, stripe_payment_intent, customer_email,
                 release_id, track_id, amount_paid_cents, currency,
                 download_token, download_expires_at)
             VALUES (?, ?, ?, ?, ?, ?, ?, 'usd', ?, ?)
             ON CONFLICT(stripe_session_id) DO NOTHING`
        ).bind(
            orderId, session.id, session.payment_intent || null,
            email, releaseId, trackId, amount, downloadToken, expiresAt,
        ).run();

        // Look up display name for the email
        let title = 'your purchase';
        if (releaseId) {
            const r = await env.DB.prepare(`SELECT name FROM releases WHERE id = ?`).bind(releaseId).first<{ name: string }>();
            if (r) title = r.name;
        }

        const downloadUrl = `${env.PUBLIC_SITE_ORIGIN.replace(/\/$/, '')}/download/${downloadToken}`;
        ctx.waitUntil(sendDownloadEmail(env, email, title, downloadUrl, amount));
        await env.DB.prepare(`UPDATE orders SET fulfilled_at = CURRENT_TIMESTAMP WHERE id = ?`).bind(orderId).run();
    }

    return new Response('ok', { status: 200 });
}

async function verifyStripeSignature(payload: string, sigHeader: string, secret: string): Promise<boolean> {
    if (!sigHeader || !secret) return false;
    const parts = Object.fromEntries(sigHeader.split(',').map(p => p.split('=')));
    const t = parts.t;
    const v1 = parts.v1;
    if (!t || !v1) return false;
    const signed = `${t}.${payload}`;
    const enc = new TextEncoder();
    const key = await crypto.subtle.importKey(
        'raw', enc.encode(secret), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign'],
    );
    const sigBytes = await crypto.subtle.sign('HMAC', key, enc.encode(signed));
    const hex = Array.from(new Uint8Array(sigBytes))
        .map(b => b.toString(16).padStart(2, '0')).join('');
    // constant-time compare
    if (hex.length !== v1.length) return false;
    let diff = 0;
    for (let i = 0; i < hex.length; i++) diff |= hex.charCodeAt(i) ^ v1.charCodeAt(i);
    return diff === 0;
}

async function sendDownloadEmail(env: Env, to: string, title: string, downloadUrl: string, amountCents: number): Promise<void> {
    if (!env.RESEND_API_KEY || !to) return;
    const dollars = (amountCents / 100).toFixed(2);
    const subject = `Your holdenu download: ${title}`;
    const html = `
        <div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 540px; margin: 0 auto; padding: 24px; background: #0a0a14; color: #ECECEC;">
            <h1 style="font-size: 18px; letter-spacing: 0.12em; color: #fbbf24; margin-bottom: 12px;">▸ HOLDENU.COM</h1>
            <p>Thanks for supporting Be Holden U with a $${dollars} purchase of <strong>${escapeHtml(title)}</strong>.</p>
            <p>Your download link is good for 7 days:</p>
            <p style="margin: 24px 0;">
                <a href="${downloadUrl}" style="background: rgba(251,191,36,0.18); border: 1px solid rgba(251,191,36,0.7); color: #fbbf24; padding: 10px 18px; border-radius: 4px; text-decoration: none;">
                    ↓ Download
                </a>
            </p>
            <p style="font-size: 12px; color: #9ca3af; margin-top: 32px;">
                If the link expires you can reply to this email and I'll re-issue.<br>
                — Anthony at Be Holden U
            </p>
        </div>
    `.trim();

    await fetch('https://api.resend.com/emails', {
        method: 'POST',
        headers: {
            'Authorization': `Bearer ${env.RESEND_API_KEY}`,
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            from: 'Be Holden U <hello@holdenu.com>',
            to: [to],
            subject,
            html,
        }),
    });
}

function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c] as string));
}

// =================================================================
// Discoverability: pretty URLs, OG cards, sitemap, robots
// =================================================================

async function serveReleasePage(req: Request, env: Env, releaseId: string): Promise<Response> {
    const release = await env.DB.prepare(
        `SELECT id, name, type, release_date, price_min_cents,
                artwork_key, description, bandcamp_url, spotify_url, apple_url
           FROM releases
          WHERE id = ? AND release_date <= datetime('now')`
    ).bind(releaseId).first<{
        id: string; name: string; type: string; release_date: string;
        price_min_cents: number; artwork_key: string | null;
        description: string | null;
        bandcamp_url: string | null; spotify_url: string | null; apple_url: string | null;
    }>();

    if (!release) {
        return new Response(notFoundHtml('Release not found', env), {
            status: 404,
            headers: { 'Content-Type': 'text/html; charset=utf-8' },
        });
    }
    const tracks = await env.DB.prepare(
        `SELECT track_id, track_order, title_override, duration_seconds
           FROM release_tracks WHERE release_id = ? ORDER BY track_order`
    ).bind(releaseId).all();

    const trackCount = tracks.results.length;
    const desc = release.description
        || `${trackCount} track${trackCount === 1 ? '' : 's'} from Be Holden U — listen, browse the 3D catalog, fly through the catalog explorer at holdenu.com.`;
    const ogImage = release.artwork_key
        ? `${env.PUBLIC_SITE_ORIGIN}/api/artwork/${encodeURIComponent(release.id)}`
        : `${env.PUBLIC_SITE_ORIGIN}/og-default.jpg`;
    const canonical = `${env.PUBLIC_SITE_ORIGIN}/release/${encodeURIComponent(release.id)}`;

    const html = renderShell({
        title: `${release.name} — holdenu.com`,
        description: desc,
        ogImage,
        canonical,
        ogType: 'music.album',
        spaParam: `release=${encodeURIComponent(release.id)}`,
        siteOrigin: env.PUBLIC_SITE_ORIGIN,
    });

    return new Response(html, {
        headers: {
            'Content-Type': 'text/html; charset=utf-8',
            'Cache-Control': 'public, max-age=300, s-maxage=300',
        },
    });
}

async function serveTrackPage(req: Request, env: Env, trackId: string): Promise<Response> {
    const row = await env.DB.prepare(
        `SELECT rt.track_id, rt.title_override, r.id AS release_id, r.name AS release_name,
                r.artwork_key, r.description
           FROM release_tracks rt
           JOIN releases r ON r.id = rt.release_id
          WHERE rt.track_id = ? AND r.release_date <= datetime('now')
          ORDER BY r.release_date DESC LIMIT 1`
    ).bind(trackId).first<{
        track_id: string; title_override: string | null;
        release_id: string; release_name: string;
        artwork_key: string | null; description: string | null;
    }>();
    if (!row) {
        return new Response(notFoundHtml('Track not found', env), {
            status: 404,
            headers: { 'Content-Type': 'text/html; charset=utf-8' },
        });
    }
    const trackTitle = row.title_override || row.track_id;
    const desc = `From ${row.release_name} on Be Holden U. Stream + own at holdenu.com.`;
    const ogImage = row.artwork_key
        ? `${env.PUBLIC_SITE_ORIGIN}/api/artwork/${encodeURIComponent(row.release_id)}`
        : `${env.PUBLIC_SITE_ORIGIN}/og-default.jpg`;
    const canonical = `${env.PUBLIC_SITE_ORIGIN}/track/${encodeURIComponent(trackId)}`;

    const html = renderShell({
        title: `${trackTitle} — holdenu.com`,
        description: desc,
        ogImage,
        canonical,
        ogType: 'music.song',
        spaParam: `track=${encodeURIComponent(trackId)}`,
        siteOrigin: env.PUBLIC_SITE_ORIGIN,
    });
    return new Response(html, {
        headers: {
            'Content-Type': 'text/html; charset=utf-8',
            'Cache-Control': 'public, max-age=300, s-maxage=300',
        },
    });
}

interface ShellOptions {
    title: string;
    description: string;
    ogImage: string;
    canonical: string;
    ogType: string;        // 'music.album' | 'music.song' | 'website'
    spaParam: string;      // 'release=<id>' or 'track=<id>'
    siteOrigin: string;
}

// Returns a small HTML doc with OG/Twitter meta tags + a meta-refresh
// to the SPA at /. Crawlers (Twitter, Discord, Slack, FB, Google) read
// the meta tags here. Humans get redirected to the SPA which knows how
// to open the right side panel via the ?release= / ?track= param.
function renderShell(opts: ShellOptions): string {
    const target = `${opts.siteOrigin}/?${opts.spaParam}`;
    const t = escapeHtml(opts.title);
    const d = escapeHtml(opts.description);
    const c = escapeHtml(opts.canonical);
    const i = escapeHtml(opts.ogImage);
    const tg = escapeHtml(target);
    return `<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${t}</title>
    <meta name="description" content="${d}">
    <link rel="canonical" href="${c}">
    <meta http-equiv="refresh" content="0; url=${tg}">

    <!-- Open Graph -->
    <meta property="og:type" content="${escapeHtml(opts.ogType)}">
    <meta property="og:title" content="${t}">
    <meta property="og:description" content="${d}">
    <meta property="og:image" content="${i}">
    <meta property="og:url" content="${c}">
    <meta property="og:site_name" content="Be Holden U">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="${t}">
    <meta name="twitter:description" content="${d}">
    <meta name="twitter:image" content="${i}">
</head>
<body style="background:#0a0a14;color:#ECECEC;font-family:system-ui,sans-serif;text-align:center;padding:4rem 1rem;">
    <p>Loading <strong>${t}</strong>…</p>
    <p style="margin-top:1rem;"><a href="${tg}" style="color:#fbbf24;">enter holdenu.com →</a></p>
    <script>setTimeout(function(){location.href=${JSON.stringify(target)};}, 50);</script>
</body>
</html>`;
}

function notFoundHtml(message: string, env: Env): string {
    return `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>404 — holdenu.com</title>
<meta http-equiv="refresh" content="2; url=${escapeHtml(env.PUBLIC_SITE_ORIGIN)}/">
<style>body{background:#0a0a14;color:#ECECEC;font-family:system-ui,sans-serif;text-align:center;padding:4rem 1rem;}a{color:#fbbf24;}</style>
</head><body><h1>${escapeHtml(message)}</h1><p><a href="${escapeHtml(env.PUBLIC_SITE_ORIGIN)}/">→ back to holdenu.com</a></p></body></html>`;
}

async function serveSitemap(env: Env): Promise<Response> {
    const releases = await env.DB.prepare(
        `SELECT id, release_date FROM releases WHERE release_date <= datetime('now') ORDER BY release_date DESC`
    ).all<{ id: string; release_date: string }>();

    const tracks = await env.DB.prepare(
        `SELECT DISTINCT rt.track_id, MAX(r.release_date) AS rd
           FROM release_tracks rt JOIN releases r ON r.id = rt.release_id
          WHERE r.release_date <= datetime('now')
          GROUP BY rt.track_id`
    ).all<{ track_id: string; rd: string }>();

    const origin = env.PUBLIC_SITE_ORIGIN.replace(/\/$/, '');
    const urls: string[] = [];
    urls.push(`<url><loc>${origin}/</loc><changefreq>weekly</changefreq><priority>1.0</priority></url>`);
    for (const r of releases.results) {
        urls.push(`<url><loc>${origin}/release/${encodeURIComponent(r.id)}</loc><lastmod>${r.release_date.split(' ')[0]}</lastmod><priority>0.9</priority></url>`);
    }
    for (const t of tracks.results) {
        urls.push(`<url><loc>${origin}/track/${encodeURIComponent(t.track_id)}</loc><lastmod>${(t.rd || '').split(' ')[0]}</lastmod><priority>0.8</priority></url>`);
    }
    const xml = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${urls.join('\n')}
</urlset>`;
    return new Response(xml, {
        headers: {
            'Content-Type': 'application/xml; charset=utf-8',
            'Cache-Control': 'public, max-age=600',
        },
    });
}

function serveRobots(env: Env): Response {
    const origin = env.PUBLIC_SITE_ORIGIN.replace(/\/$/, '');
    const txt = `User-agent: *
Allow: /
Disallow: /api/
Disallow: /download/

Sitemap: ${origin}/sitemap.xml
`;
    return new Response(txt, {
        headers: { 'Content-Type': 'text/plain; charset=utf-8' },
    });
}

async function serveArtwork(req: Request, env: Env, releaseId: string): Promise<Response> {
    const row = await env.DB.prepare(
        `SELECT artwork_key FROM releases WHERE id = ?`
    ).bind(releaseId).first<{ artwork_key: string | null }>();
    if (!row || !row.artwork_key) return errorResponse(404, 'no artwork on file', env, req);
    const obj = await env.MEDIA.get(row.artwork_key);
    if (!obj) return errorResponse(404, 'artwork missing in storage', env, req);
    const headers = new Headers(corsHeaders(env, req));
    headers.set('Content-Type', obj.httpMetadata?.contentType || 'image/jpeg');
    headers.set('Content-Length', String(obj.size));
    headers.set('Cache-Control', 'public, max-age=86400, immutable');
    return new Response(obj.body, { status: 200, headers });
}

// =================================================================
// Public: signed download
// =================================================================

