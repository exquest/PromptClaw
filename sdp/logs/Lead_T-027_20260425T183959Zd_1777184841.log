    assert library.find(arc_phase="Crystallization") == []
    assert library.find(character_all=["wind", "water"]) == []
    assert library.find(pitch_band=(2000.0, 3000.0)) == []
    assert library.find(mood_range=(-1.0, -0.9)) == []
