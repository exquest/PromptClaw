+        enabled_env = {CYPHERCLAW_V2_COUPLING_ENV: "true"}
+
+        assert read_affective_state_bus(
+            _ControlBusReader(1.5),
+            env=enabled_env,
+        ) == 1.0
+        assert read_affective_state_bus(
+            _ControlBusReader(-0.25),
+            env=enabled_env,
+        ) == 0.0
+
