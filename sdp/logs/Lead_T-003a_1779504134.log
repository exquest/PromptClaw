def test_rollout_report_flags_drive_existing_behavior() -> None:
    report = rollout_control_report(
        {
            CURRICULUM_EXERCISE_ENV: "0",
            PREVIEW_RENDER_ENV: "0",
            SELF_CRITIQUE_ENV: "1",
