sdp/verification/t-009@20260425t183959z-verify.md:50:{"type":"tool_use","timestamp":"2026-04-25T22:03:41.483Z","tool_name":"write_file","tool_id":"write_file_1777154621483_0","parameters":{"content":"\nimport os\nimport sys\nimport numpy as np\nimport wave\nimport sqlite3\nfrom pathlib import Path\n\n# Add the tools directory to path\nsys.path.insert(0, os.path.join(os.getcwd(), \"my-claw\", \"tools\"))\nfrom sample_capture_daemon import save_capture\n\ndef verify_capture():\n    test_root = Path(\"temp_test_capture\")\n    if test_root.exists():\n        import shutil\n        shutil.rmtree(test_root)\n    test_root.mkdir()\n\n    sample_rate = 48000\n    # 1 second of 440Hz tone at -20dBFS\n    t = np.arange(sample_rate) / sample_rate\n    samples = (0.1 * np.sin(2 * np.pi * 440.0 * t)).astype(np.float32)\n\n    capture = save_capture(\n        samples,\n        source=\"room\",\n        sample_rate=sample_rate,\n        capture_root=test_root,\n        context={\"organism\": {\"arc_phase\": \"test\"}},\n        captured_at=1777152600.0  # 2026-04-25T21:30:00Z\n    )\n\n    print(f\"Captured to: {capture.path}\")\n    print(f\"Gain applied: {capture.gain_db} dB\")\n\n    # Verify WAV properties\n    with wave.open(str(capture.path), \"rb\") as f:\n        print(f\"Channels: {f.getnchannels()}\")\n        print(f\"Sample width: {f.getsampwidth()}\")\n        print(f\"Framerate: {f.getframerate()}\")\n        assert f.getnchannels() == 1\n        assert f.getsampwidth() == 3  # 24-bit\n        assert f.getframerate() == 48000\n\n    # Verify filename\n    filename = capture.path.name\n    print(f\"Filename: {filename}\")\n    assert filename.startswith(\"room_20260425T213000Z_test_\")\n    assert filename.endswith(\".wav\")\n\n    # Verify DB\n    index_path = test_root / \"index.sqlite\"\n    assert index_path.exists()\n    with sqlite3.connect(str(index_path)) as con:\n        row = con.execute(\"SELECT source, gain_db FROM samples WHERE sample_id = ?\", (capture.sample_id,)).fetchone()\n        print(f\"DB Row: {row}\")\n        assert row[0] == \"room\"\n        assert abs(row[1] - capture.gain_db) < 1e-6\n\n    print(\"Manual verification SUCCESS\")\n\nif __name__ == \"__main__\":\n    verify_capture()\n","file_path":"manual_verify_t009.py"}}
