+    hull = lower[:-1] + upper[:-1]
+    area = 0.0
+    for index, point in enumerate(hull):
+        next_point = hull[(index + 1) % len(hull)]
+        area += point[0] * next_point[1] - next_point[0] * point[1]
+    return abs(area) / 2.0
