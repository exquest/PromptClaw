+            "novelty_peaks": 0,
+            "silence_ms": 0.0,
+        },
+        applied_rules=(),
+        quantities={},
+    )
+    
+    metrics = compute_metrics(part)
+    
+    # Should fail all metrics since there's zero variation
+    for key, (low, high) in PASS_BANDS.items():
+        assert not (low <= metrics[key] <= high), f"{key} should fail band {low}-{high} but got {metrics[key]}"
+
