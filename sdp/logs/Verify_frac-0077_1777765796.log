+        clap_centroid = [0.1, 0.2, 0.3]
+
+        gate = _should_queue_now(
+            "evening_reflection",
+            mood,
+            learning,
+            now=10_000.0,
+            last_enqueued_at=None,
+        )
+        assert gate is True
+
+        row_id = duet_composer._post_song_generation_hook(
+            SimpleNamespace(metadata={"arc_phase": "Emergence"}),
+            learning,
+            mood,
