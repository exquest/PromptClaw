+        duet_composer = _duet_composer(monkeypatch)
+        queue = _FakeQueue()
+        conditioner = _ConditionerAdapter()
+        monkeypatch.setattr(duet_composer, "_generation_queue", queue)
+        monkeypatch.setattr(duet_composer, "_generation_conditioner", conditioner)
+
+        learning = {
