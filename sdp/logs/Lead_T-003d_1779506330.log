        assert nominal_depths == {
            "vib_depth": 0.25,
            "trem_depth": 0.5,
            "spectral_granulation_amount": 0.125,
        }
        assert scaled is not nominal_depths
        assert scale_modulator_depths({}, multiplier=1.5) == {}
        assert scale_modulator_depths({"vib_depth": 0.25}, multiplier=0.0) == {
            "vib_depth": 0.0,
        }

