+                modulator_depths=nominal_depths,
+                control_bus_reader=reader,
+                env=enabled_env,
+            )
+
+            sent_args = osc.send_message.call_args[0][1]
+            rendered_params = dict(zip(sent_args[4::2], sent_args[5::2], strict=True))
