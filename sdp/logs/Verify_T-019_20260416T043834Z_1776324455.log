def groove_for_section(
    *,
    groove_state: str = "",
    groove_identity: str = "",
    groove_family: str = "",
    entrainment_bpm: float | None = None,
) -> GrooveProfile:
    """Resolve a :class:`GrooveProfile` from available groove descriptors.

    Priority: *groove_identity* (commission) > *groove_state* (section) >
    *groove_family* (hook engine).  If none match, return a neutral default.
    """

    for key in (groove_identity, groove_state, groove_family):
        profile = _GROOVE_PROFILES.get(key)
        if profile is not None:
            if entrainment_bpm is not None and entrainment_bpm > 0:
                return GrooveProfile(
                    groove_type=profile.groove_type,
                    swing_ratio=profile.swing_ratio,
                    push_pull_ms=profile.push_pull_ms,
                    microtiming_depth=profile.microtiming_depth,
                    polyrhythm=profile.polyrhythm,
                    polymeter=profile.polymeter,
                    entrainment_bpm=entrainment_bpm,
                    breath_points=profile.breath_points,
                    section_identity=profile.section_identity,
                )
            return profile

    return GrooveProfile(
        groove_type=_DEFAULT_PROFILE.groove_type,
        swing_ratio=_DEFAULT_PROFILE.swing_ratio,
        push_pull_ms=_DEFAULT_PROFILE.push_pull_ms,
        microtiming_depth=_DEFAULT_PROFILE.microtiming_depth,

