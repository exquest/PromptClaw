+    """Apply one decoded MIDI message into the tracked keyboard state."""
+
+    msg_type = status & 0xF0
+    if msg_type == 0x90:
+        note, velocity = data1, data2
+        midi_state.note_on(note, velocity)
+        if velocity > 0:
+            active_notes[note] = {
+                "freq": midi_to_freq(note),
+                "name": note_to_name(note),
+                "velocity": velocity,
+                "time": now,
