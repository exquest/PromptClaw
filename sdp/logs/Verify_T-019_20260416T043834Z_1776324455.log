+def repair_stale_run_lock(lock_path: Path) -> bool:
+    """Remove a stale run.lock that points at a dead PID."""
+    check = _check_run_lock(lock_path)
+    if check["ok"]:
+        return False
+    if "stale run.lock" not in str(check.get("message", "")).lower():
+        return False
+    lock_path.unlink(missing_ok=True)
+    return True
+
