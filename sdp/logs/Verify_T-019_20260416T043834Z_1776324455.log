+    Score,
+    generate_bass_line,
+    generate_countermelody,
+)
+from .harmonic_planner import is_minorish_key
+from .instrument_patches import (
+    InstrumentPatch,
+    normalize_patch_voice,
+    select_instrument_patch,
+)
+
+
+_ROLE_TO_LANE_NAME = {
