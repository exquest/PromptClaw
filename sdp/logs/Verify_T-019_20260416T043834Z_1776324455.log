+    conn.execute(
+        "UPDATE tasks SET status = 'running', updated_at = ? WHERE task_id = ?",
+        ("2026-04-02T00:00:00Z", "T-001@20260401T000000Z"),
+    )
+    conn.commit()
+    conn.close()
+
+    result = subprocess.run(
