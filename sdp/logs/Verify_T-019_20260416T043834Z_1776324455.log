+            result = subprocess.run(["vmstat", "1", "2"], capture_output=True, text=True, timeout=5)
+            data_lines = [line.strip() for line in result.stdout.splitlines() if line.strip()]
+            for line in reversed(data_lines):
+                parts = line.split()
+                if len(parts) >= 17 and parts[0].lstrip("-").isdigit():
+                    io_wait = int(parts[-2])
+                    health["checks"]["io_wait"] = f"{io_wait}%"
+                    if io_wait > 25:
+                        health["warnings"].append(f"High I/O wait: {io_wait}%")
+                    break
+    except Exception as e:
+        health["warnings"].append(f"I/O check failed: {e}")
+
     # 4. Zombie/D-state processes
     try:
         result = subprocess.run(["ps", "aux"], capture_output=True, text=True, timeout=5)
