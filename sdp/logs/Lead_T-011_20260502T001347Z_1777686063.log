                "world_db_reachable": True,
                "ollama_reachable": True,
                "version": "1.0.0",
                "uptime_seconds": 1.0,
            },
        )

    transport = httpx.MockTransport(handler)
    bridge = WorldBridge(
        base_url="http://narrative.test",
        timeout=5.0,
        auth_token="s3cret",
        client=httpx.Client(base_url="http://narrative.test", transport=transport,
                            headers={"X-Narrative-Auth": "s3cret", "Accept": "application/json"}),
    )

    bridge.health()


