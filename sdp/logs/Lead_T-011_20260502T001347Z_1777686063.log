"""HTTPX-based client for the cypherclaw narrative HTTP service.

This is the only permitted crossing point between Deniable's campaign DB and
the shared narrative engine's world state. See
``deniable_narrative_integration_v1.md`` §2 and the cypherclaw narrative HTTP
service PRD for the wire schema.
"""

from __future__ import annotations

from dataclasses import dataclass, field
from types import TracebackType
from typing import Any, Literal, Self

import httpx

from deniable.settings import settings

DomainFilter = Literal["shared", "cypherclaw", "deniable"]


@dataclass(frozen=True)
class HealthStatus:
    """Response shape for ``GET /health`` per cypherclaw narrative API CN-003."""

    status: str
    narrative_engine_importable: bool
    world_db_reachable: bool
    ollama_reachable: bool
    version: str
    uptime_seconds: float


@dataclass(frozen=True)
class WorldEntity:
    """A row from the shared narrative ``entities`` table.

    Properties is left as an opaque mapping; the engine evolves freely and the
    bridge does not own that schema.
    """

    id: str
    type: str
    name: str
    domain: DomainFilter
    properties: dict[str, Any] = field(default_factory=dict)


@dataclass(frozen=True)
class StoryBeat:
    """Serialized ``StoryBeat`` returned by ``POST /beats/next`` (CN-005).

    The full schema is owned by the narrative engine and translated downstream
    by ``DeniableTranslator`` (T-065). This skeleton keeps the wire payload as
    a raw mapping so the bridge does not have to track engine-side changes.
    """

    id: str
    cycle_number: int
    arc_position: float
    payload: dict[str, Any]


class NarrativeServiceError(RuntimeError):
    """Raised when the cypherclaw narrative service is unreachable or errors."""


class WorldBridge:
    """Thin HTTP client for the cypherclaw narrative HTTP service."""

    def __init__(
        self,
        base_url: str | None = None,
        timeout: float | None = None,
        auth_token: str | None = None,
        client: httpx.Client | None = None,
    ) -> None:
        self._base_url = (base_url or settings.DENIABLE_NARRATIVE_BASE_URL).rstrip("/")
        self._timeout = (
            timeout if timeout is not None else settings.DENIABLE_NARRATIVE_TIMEOUT_SECONDS
        )
        self._auth_token = (
            auth_token if auth_token is not None else settings.DENIABLE_NARRATIVE_AUTH_TOKEN
        )
        self._client = client or httpx.Client(
            base_url=self._base_url,
            timeout=self._timeout,
            headers=self._default_headers(),
        )
        self._owns_client = client is None

    def _default_headers(self) -> dict[str, str]:
        headers = {"Accept": "application/json"}
        if self._auth_token:
            headers["X-Narrative-Auth"] = self._auth_token
        return headers

    def __enter__(self) -> Self:
        return self

    def __exit__(
        self,
        exc_type: type[BaseException] | None,
        exc: BaseException | None,
        tb: TracebackType | None,
    ) -> None:
        self.close()

    def close(self) -> None:
        if self._owns_client:
            self._client.close()

    def health(self) -> HealthStatus:
        """Return the narrative service health snapshot (CN-003)."""
        payload = self._get_json("/health")
        return HealthStatus(
            status=str(payload["status"]),
            narrative_engine_importable=bool(payload["narrative_engine_importable"]),
            world_db_reachable=bool(payload["world_db_reachable"]),
            ollama_reachable=bool(payload["ollama_reachable"]),
            version=str(payload["version"]),
            uptime_seconds=float(payload["uptime_seconds"]),
        )

    def get_world_entities(
        self,
        domain: DomainFilter = "shared",
        entity_type: str | None = None,
        limit: int | None = None,
        offset: int | None = None,
    ) -> list[WorldEntity]:
        """Return entities filtered by domain/type per CN-006."""
        params: dict[str, str | int] = {"domain": domain}
        if entity_type is not None:
            params["type"] = entity_type
        if limit is not None:
            params["limit"] = limit
        if offset is not None:
            params["offset"] = offset

        payload = self._get_json("/world/entities", params=params)
        rows = payload["entities"] if isinstance(payload, dict) else payload
        return [_world_entity_from_payload(row) for row in rows]

    def next_beat(
        self,
        cycle_number: int,
        domain_filter: DomainFilter = "deniable",
        arc_position_target: float | None = None,
        force_arc_event: str | None = None,
    ) -> StoryBeat:
        """Request the next ``StoryBeat`` from the engine per CN-005."""
        body: dict[str, Any] = {
            "cycle_number": cycle_number,
            "domain_filter": domain_filter,
        }
        if arc_position_target is not None:
            body["arc_position_target"] = arc_position_target
        if force_arc_event is not None:
            body["force_arc_event"] = force_arc_event

        payload = self._post_json("/beats/next", body)
        return StoryBeat(
            id=str(payload["id"]),
            cycle_number=int(payload.get("cycle_number", cycle_number)),
            arc_position=float(payload.get("arc_position", 0.0)),
            payload=dict(payload),
        )

    def _get_json(
        self, path: str, params: dict[str, str | int] | None = None
    ) -> Any:
        try:
            response = self._client.get(path, params=params)
            response.raise_for_status()
        except httpx.HTTPError as exc:
            raise NarrativeServiceError(
                f"GET {path} failed against {self._base_url}: {exc}"
            ) from exc
        return response.json()

    def _post_json(self, path: str, body: dict[str, Any]) -> Any:
        try:
            response = self._client.post(path, json=body)
            response.raise_for_status()
        except httpx.HTTPError as exc:
            raise NarrativeServiceError(
                f"POST {path} failed against {self._base_url}: {exc}"
            ) from exc
        return response.json()


def _world_entity_from_payload(payload: dict[str, Any]) -> WorldEntity:
    domain = payload.get("domain", "shared")
    if domain not in ("shared", "cypherclaw", "deniable"):
        raise NarrativeServiceError(f"Unexpected entity domain: {domain!r}")
    return WorldEntity(
        id=str(payload["id"]),
        type=str(payload["type"]),
        name=str(payload["name"]),
        domain=domain,
        properties=dict(payload.get("properties", {})),
    )

