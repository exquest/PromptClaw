def test_next_beat_posts_request_body() -> None:
    captured: dict[str, object] = {}

    def handler(request: httpx.Request) -> httpx.Response:
        assert request.method == "POST"
        assert request.url.path == "/beats/next"
        captured["body"] = json.loads(request.content.decode())
        return httpx.Response(
            200,
            json={
                "id": "beat-001",
                "cycle_number": 7,
                "arc_position": 0.42,
                "active_characters": ["fighter-dax"],
                "tone_vector": {"tension": 0.8},
            },
        )

    client = _client_with_handler(httpx.MockTransport(handler))
    bridge = WorldBridge(client=client)

    beat = bridge.next_beat(
        cycle_number=7,
        domain_filter="deniable",
        arc_position_target=0.5,
        force_arc_event="act_i_loss",
    )

    assert captured["body"] == {
        "cycle_number": 7,
        "domain_filter": "deniable",
        "arc_position_target": 0.5,
        "force_arc_event": "act_i_loss",
    }
    assert isinstance(beat, StoryBeat)
    assert beat.id == "beat-001"
    assert beat.cycle_number == 7
    assert beat.arc_position == 0.42
    assert beat.payload["tone_vector"] == {"tension": 0.8}


def test_http_error_raises_narrative_service_error() -> None:
    def handler(request: httpx.Request) -> httpx.Response:
        return httpx.Response(503, json={"detail": "engine offline"})

    client = _client_with_handler(httpx.MockTransport(handler))
    bridge = WorldBridge(client=client)

    with pytest.raises(NarrativeServiceError, match="GET /health failed"):
        bridge.health()


