        args.watch_dir,
        stop_event,
        dispatch=dispatch_intake_file,
        poll_interval=args.poll_interval,
        use_watchdog=not args.poll,
    )
    LOGGER.info("midi_intake_daemon_exiting")
    return 0


if __name__ == "__main__":
    sys.exit(main())

