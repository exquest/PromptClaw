+def test_morph_phrase_endpoint_rejects_frame_count_without_phrase_curve() -> None:
+    client = TestClient(create_app())
+
+    response = client.post(
+        "/api/v1/composer/morph-phrase",
+        json={
+            "source_voice": "pluck",
+            "target_voice": "bowed",
+            "morph_curve_type": "linear",
