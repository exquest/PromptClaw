+        },
+    )
+
+    assert response.status_code == 422
+    assert "phrase_frame_count requires phrase_curve" in response.text
+
+    validation_only = client.post(
+        "/api/v1/composer/morph-phrase",
+        json={
+            "source_voice": "pluck",
+            "target_voice": "bowed",
