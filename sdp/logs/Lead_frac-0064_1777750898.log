+            "duration_sec": 0.25,
+            "seed": 99,
+            "model": "musicgen-medium",
+        }
+
+        results = [client.generate(dict(request)) for _ in range(3)]
+        payloads = [Path(result["audio_path"]).read_bytes() for result in results]
+
+        assert {result["prediction_id"] for result in results} == {
