+        client = LocalAdaClient(output_dir=tmp_path / "json", sample_rate=8_000)
+        typed_request = _request(prompt="json-safe local request", seed=31)
+        mapping_request = {
+            "request_hash": "json-map",
+            "prompt": "json mapping preview",
