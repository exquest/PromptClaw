import math
from dataclasses import dataclass
from cypherclaw.render.events import Event

@dataclass
class PhraseArchRule:
    tempo_deviation_pct: float = 4.0
    amp_deviation_pct: float = 4.0
    peak: float = 0.6
    k: float = 1.0
    arc_shape: str = "parabolic"

    def _get_base_arch(self, x: float) -> float:
        if self.arc_shape == "parabolic":
            return -4 * (x - self.peak)**2 + 1
        elif self.arc_shape == "cosine":
            return math.cos((x - self.peak) * math.pi)
        elif self.arc_shape == "flat":
            return 0.0
        elif self.arc_shape == "inverted":
            return 4 * (x - self.peak)**2 - 1
        elif self.arc_shape == "asymmetric-Bezier":
            # Simple asymmetric curve peaking at self.peak
            if x <= self.peak and self.peak > 0:
                t = x / self.peak
                return 1.0 - (1.0 - t)**2
            elif self.peak < 1:
                t = (x - self.peak) / (1.0 - self.peak)
                return 1.0 - t**2
            return 0.0
        return -4 * (x - self.peak)**2 + 1

    def apply(self, event: Event) -> None:
        x = event.normalized_phrase_position
        arch_val = self._get_base_arch(x)
        
        tempo_arch_mult = 1.0 + self.k * arch_val * (self.tempo_deviation_pct / 100.0)
        amp_arch_mult = 1.0 + self.k * arch_val * (self.amp_deviation_pct / 100.0)
        
        # Compose multiplicatively with SectionEnvelope.tempo_base
        section_tempo_base = 1.0
        if event.section_envelope is not None:
            section_tempo_base = event.section_envelope.tempo_base
            
        event.tempo_mult *= (tempo_arch_mult * section_tempo_base)
        event.amp_mult *= amp_arch_mult

