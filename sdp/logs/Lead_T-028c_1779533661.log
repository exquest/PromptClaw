 // =================================================================
+// Public: CypherClaw live feature bootstrap feed
+// =================================================================
+
+interface CypherClawFeatureSnapshot {
+    source: string;
+    captured_at: string;
+    rms: number;
+    pitch_hz: number;
+    centroid_hz: number;
+    scene: string;
+    tuning: string;
+}
+
+function serveCypherClawLiveFeatures(req: Request, env: Env): Response {
+    const payload: CypherClawFeatureSnapshot = {
+        source: 'worker-bootstrap',
+        captured_at: new Date().toISOString(),
+        rms: 0.07,
+        pitch_hz: 196,
+        centroid_hz: 900,
+        scene: 'awaiting-live-features',
+        tuning: 'unknown',
+    };
+    const lines = [
+        ': cypherclaw live features bootstrap',
+        'retry: 5000',
+        'event: features',
+        `data: ${JSON.stringify(payload)}`,
+        '',
+        '',
+    ];
+    const headers = new Headers(corsHeaders(env, req));
+    headers.set('Content-Type', 'text/event-stream; charset=utf-8');
+    headers.set('Cache-Control', 'no-cache');
+    headers.set('X-Accel-Buffering', 'no');
+    return new Response(lines.join('\n'), { status: 200, headers });
+}
+
