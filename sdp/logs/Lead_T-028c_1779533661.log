<script>
(function () {
  "use strict";

  function markPlaybackMode(audio, mode) {
    audio.setAttribute("data-playback-mode", mode);
  }

  function initCypherClawAudio() {
    const audio = document.getElementById("cypherclaw-live-audio");
    if (!audio) return;

    const streamUrl = audio.getAttribute("data-stream-url") || "/api/cypherclaw/live.m3u8";
    if (audio.canPlayType("application/vnd.apple.mpegurl")) {
      audio.src = streamUrl;
      markPlaybackMode(audio, "native-hls");
      return;
    }

    if (window.Hls && Hls.isSupported()) {
      const hls = new Hls({ liveSyncDurationCount: 3, maxLiveSyncPlaybackRate: 1.5 });
      hls.loadSource(streamUrl);
      hls.attachMedia(audio);
      window.cypherclawLiveHls = hls;
      markPlaybackMode(audio, "hls-js");
      return;
    }

    audio.src = streamUrl;
    markPlaybackMode(audio, "direct-fallback");
  }

  window.initCypherClawAudio = initCypherClawAudio;
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCypherClawAudio, { once: true });
  } else {
    initCypherClawAudio();
  }
})();
</script>
</body>
