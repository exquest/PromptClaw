    assert.equal(uriLines.length, 10);
    assert.equal(uriLines[0], `/api/cypherclaw/segment/cypherclaw/live/${todayKey()}/seg-105.opus`);
    assert.equal(uriLines[9], `/api/cypherclaw/segment/cypherclaw/live/${todayKey()}/seg-114.opus`);
    assert.ok(body.includes("#EXT-X-MEDIA-SEQUENCE:105"));
});

