+    }
+    context.setTransform(1, 0, 0, 1, 0, 0);
+    return { width: displayWidth, height: displayHeight, ratio };
+  }
+
+  function drawVisualizerFrame(timestamp) {
+    const state = window.cypherclawVisualizerState;
+    if (!state || !state.canvas || !state.context) return;
+
+    const canvas = state.canvas;
+    const context = state.context;
+    const dims = resizeVisualizerCanvas(canvas, context);
+    const features = state.latestFeatures || {};
+    const rms = clampNumber(pickNumber(features, ["rms", "amplitude"], 0.07), 0, 1, 0.07);
+    const pitch = clampNumber(pickNumber(features, ["pitch_hz", "pitchHz"], 196), 55, 1760, 196);
+    const centroid = clampNumber(pickNumber(features, ["centroid_hz", "spectral_centroid_hz"], 900), 120, 6000, 900);
+    const pulse = 0.55 + Math.sin(timestamp / 620) * 0.45;
+    const pitchY = dims.height - ((pitch - 55) / (1760 - 55)) * dims.height;
+    const sweepX = (timestamp / 34) % Math.max(1, dims.width);
+    const radius = 28 + rms * 170;
+    const hue = 28 + Math.min(180, centroid / 34);
+
+    context.fillStyle = "rgba(12, 15, 15, 0.82)";
+    context.fillRect(0, 0, canvas.width, canvas.height);
+    context.setTransform(dims.ratio, 0, 0, dims.ratio, 0, 0);
+
+    const gradient = context.createRadialGradient(sweepX, pitchY, 4, sweepX, pitchY, Math.max(radius * 2.1, 120));
+    gradient.addColorStop(0, "hsla(" + hue + ", 68%, 68%, " + (0.34 + rms * 0.36) + ")");
+    gradient.addColorStop(0.42, "hsla(168, 42%, 60%, " + (0.14 + rms * 0.22) + ")");
+    gradient.addColorStop(1, "rgba(17, 18, 18, 0)");
+    context.fillStyle = gradient;
+    context.beginPath();
+    context.arc(sweepX, pitchY, Math.max(radius * (0.82 + pulse * 0.18), 18), 0, Math.PI * 2);
+    context.fill();
+
+    context.strokeStyle = "rgba(242, 238, 229, 0.12)";
+    context.lineWidth = 1;
+    for (let i = 1; i < 8; i += 1) {
+      const y = (dims.height / 8) * i;
+      context.beginPath();
+      context.moveTo(0, y);
+      context.lineTo(dims.width, y + Math.sin(timestamp / 1100 + i) * 12);
+      context.stroke();
+    }
+
+    context.strokeStyle = "rgba(208, 154, 84, " + (0.24 + rms * 0.44) + ")";
+    context.lineWidth = 2 + rms * 5;
+    context.beginPath();
+    context.moveTo(0, pitchY);
+    for (let x = 0; x <= dims.width; x += 48) {
+      context.lineTo(x, pitchY + Math.sin((timestamp / 420) + x / 80) * (10 + rms * 35));
+    }
+    context.stroke();
+
+    context.fillStyle = "rgba(242, 238, 229, 0.62)";
+    context.beginPath();
+    context.arc(Math.max(12, Math.min(dims.width - 12, sweepX)), Math.max(12, Math.min(dims.height - 12, pitchY)), 4 + rms * 14, 0, Math.PI * 2);
+    context.fill();
+    canvas.setAttribute("data-visualizer-state", "drawing");
+    state.frameRequest = requestAnimationFrame(drawVisualizerFrame);
+  }
+
+  function handleFeatureMessage(event) {
+    const state = window.cypherclawVisualizerState;
+    if (!state || !state.canvas) return;
+
+    try {
+      const payload = JSON.parse(event.data);
+      state.latestFeatures = Object.assign({}, state.latestFeatures, payload, {
+        received_at_ms: Date.now()
+      });
+      window.cypherclawLiveFeatures = state.latestFeatures;
+      state.canvas.setAttribute("data-feed-state", "live");
+      state.canvas.setAttribute("data-visualizer-state", "live");
+    } catch (_err) {
+      state.canvas.setAttribute("data-feed-state", "bad-message");
+    }
+  }
+
+  function connectCypherClawFeatureFeed(canvas) {
+    const featuresUrl = canvas.getAttribute("data-live-features-url") || "/api/cypherclaw/live-features";
+    if (!("EventSource" in window)) {
+      canvas.setAttribute("data-feed-state", "unsupported");
+      return;
+    }
+
+    if (window.cypherclawLiveFeatureSource && typeof window.cypherclawLiveFeatureSource.close === "function") {
+      const source = window.cypherclawLiveFeatureSource;
+      source.close();
+    }
+
+    const source = new EventSource(featuresUrl);
+    source.addEventListener("message", handleFeatureMessage);
+    source.addEventListener("features", handleFeatureMessage);
+    source.addEventListener("open", function () {
+      canvas.setAttribute("data-feed-state", "connected");
+    });
+    source.addEventListener("error", function () {
+      canvas.setAttribute("data-feed-state", "feed-error");
+    });
+    window.cypherclawLiveFeatureSource = source;
+    canvas.setAttribute("data-feed-state", "connecting");
+  }
+
+  function initCypherClawVisualizer() {
+    const canvas = document.getElementById("cypherclaw-visualizer");
+    if (!canvas) return;
+
+    const context = canvas.getContext("2d");
+    if (!context) {
+      canvas.setAttribute("data-visualizer-state", "unsupported");
+      return;
+    }
+
+    const state = {
+      canvas: canvas,
+      context: context,
+      latestFeatures: {
+        source: "ambient",
+        rms: 0.07,
+        pitch_hz: 196,
+        centroid_hz: 900,
+        scene: "awaiting-live-features",
+        tuning: "unknown"
+      },
+      frameRequest: 0
+    };
+    window.cypherclawVisualizerState = state;
+    window.cypherclawLiveFeatures = state.latestFeatures;
+    canvas.setAttribute("data-visualizer-state", "ready");
+    requestAnimationFrame(drawVisualizerFrame);
+    connectCypherClawFeatureFeed(canvas);
+  }
+
+  function initCypherClawPage() {
+    initCypherClawAudio();
+    initCypherClawVisualizer();
+  }
+
   window.initCypherClawAudio = initCypherClawAudio;
+  window.initCypherClawVisualizer = initCypherClawVisualizer;
   if (document.readyState === "loading") {
-    document.addEventListener("DOMContentLoaded", initCypherClawAudio, { once: true });
+    document.addEventListener("DOMContentLoaded", initCypherClawPage, { once: true });
   } else {
-    initCypherClawAudio();
+    initCypherClawPage();
   }
 })();
