+    const features = state.latestFeatures || {};
+    const rms = clampNumber(pickNumber(features, ["rms", "amplitude"], 0.07), 0, 1, 0.07);
+    const pitch = clampNumber(pickNumber(features, ["pitch_hz", "pitchHz"], 196), 55, 1760, 196);
+    const centroid = clampNumber(pickNumber(features, ["centroid_hz", "spectral_centroid_hz"], 900), 120, 6000, 900);
+    const pulse = 0.55 + Math.sin(timestamp / 620) * 0.45;
+    const pitchY = dims.height - ((pitch - 55) / (1760 - 55)) * dims.height;
+    const sweepX = (timestamp / 34) % Math.max(1, dims.width);
+    const radius = 28 + rms * 170;
+    const hue = 28 + Math.min(180, centroid / 34);
+
+    context.fillStyle = "rgba(12, 15, 15, 0.82)";
+    context.fillRect(0, 0, canvas.width, canvas.height);
+    context.setTransform(dims.ratio, 0, 0, dims.ratio, 0, 0);
+
+    const gradient = context.createRadialGradient(sweepX, pitchY, 4, sweepX, pitchY, Math.max(radius * 2.1, 120));
+    gradient.addColorStop(0, "hsla(" + hue + ", 68%, 68%, " + (0.34 + rms * 0.36) + ")");
+    gradient.addColorStop(0.42, "hsla(168, 42%, 60%, " + (0.14 + rms * 0.22) + ")");
+    gradient.addColorStop(1, "rgba(17, 18, 18, 0)");
+    context.fillStyle = gradient;
