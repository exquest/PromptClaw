const test = require("node:test");
const assert = require("node:assert/strict");

const worker = require("../.tmp/test-build/index.js").default;

class FakeR2Bucket {
    constructor() {
        this.objects = new Map();
    }

    async put(key, value, options = {}) {
        const bytes = await this.bytesFrom(value);
        const object = {
            key,
            body: bytes,
            size: bytes.byteLength,
            etag: `etag-${this.objects.size + 1}`,
            httpMetadata: options.httpMetadata || {},
            customMetadata: options.customMetadata || {},
        };
        this.objects.set(key, object);
        return { key, size: object.size, etag: object.etag };
    }

    async get(key, options = {}) {
        const object = this.objects.get(key);
        if (!object) return null;
        const ctorBody = () => {
            const stream = new ReadableStream({
                start(controller) {
                    controller.enqueue(object.body);
                    controller.close();
                },
            });
            return stream;
        };
        const result = {
            key: object.key,
            size: object.size,
            etag: object.etag,
            httpMetadata: object.httpMetadata,
            customMetadata: object.customMetadata,
            body: ctorBody(),
            arrayBuffer: async () => object.body.buffer.slice(
                object.body.byteOffset,
                object.body.byteOffset + object.body.byteLength,
            ),
        };
        if (options.range) result.range = options.range;
        return result;
    }

    async list(options = {}) {
        const prefix = options.prefix || "";
        const objects = Array.from(this.objects.values())
            .filter((object) => object.key.startsWith(prefix))
            .map((object) => ({
                key: object.key,
                size: object.size,
                etag: object.etag,
                httpMetadata: object.httpMetadata,
                customMetadata: object.customMetadata,
            }));
        return { objects };
    }

    async bytesFrom(value) {
        if (value instanceof Uint8Array) return value;
        if (value instanceof ArrayBuffer) return new Uint8Array(value);
        if (typeof value === "string") return new TextEncoder().encode(value);
        if (value && typeof value.arrayBuffer === "function") {
            return new Uint8Array(await value.arrayBuffer());
        }
        if (value && typeof value.getReader === "function") {
            const reader = value.getReader();
            const chunks = [];
            let total = 0;
            while (true) {
                const { value: chunk, done } = await reader.read();
                if (done) break;
                const bytes = chunk instanceof Uint8Array ? chunk : new Uint8Array(chunk);
                chunks.push(bytes);
                total += bytes.byteLength;
            }
            const merged = new Uint8Array(total);
            let offset = 0;
            for (const chunk of chunks) {
                merged.set(chunk, offset);
                offset += chunk.byteLength;
            }
            return merged;
        }
        throw new TypeError("unsupported R2 put body");
    }
}

function makeEnv() {
    return {
        DB: {},
        MEDIA: new FakeR2Bucket(),
        ADMIN_TOKEN: "segment-token",
        STRIPE_SECRET_KEY: "sk_test_unused",
        STRIPE_WEBHOOK_SECRET: "whsec_unused",
        RESEND_API_KEY: "re_unused",
        PUBLIC_SITE_ORIGIN: "https://holdenu.com",
        ENVIRONMENT: "test",
    };
}

function todayKey() {
    return new Date().toISOString().slice(0, 10);
}

async function seedSegment(env, sequence, body, customMetadata = {}) {
    const key = `cypherclaw/live/${todayKey()}/seg-${sequence}.opus`;
    await env.MEDIA.put(key, body, {
        httpMetadata: { contentType: "audio/ogg; codecs=opus" },
        customMetadata: { sequence: String(sequence), ...customMetadata },
    });
    return key;
}

test("serves an empty but well-formed playlist when no segments exist", async () => {
    const env = makeEnv();
    const request = new Request("https://explorer.holdenu.com/api/cypherclaw/live.m3u8");
    const response = await worker.fetch(request, env, { waitUntil() {} });
    const body = await response.text();

    assert.equal(response.status, 200);
    assert.equal(response.headers.get("Content-Type"), "application/vnd.apple.mpegurl");
    const lines = body.split("\n");
    assert.equal(lines[0], "#EXTM3U");
    assert.ok(lines.includes("#EXT-X-VERSION:3"));
    assert.ok(lines.includes("#EXT-X-TARGETDURATION:6"));
    assert.ok(lines.includes("#EXT-X-MEDIA-SEQUENCE:0"));
});

test("serves a valid HLS playlist of recent segments in order", async () => {
    const env = makeEnv();
    const segBody = new Uint8Array([79, 103, 103, 83, 1, 2, 3, 4]);
    // Seed out of order to verify sort.
    await seedSegment(env, 17, segBody, { duration: "6.000" });
    await seedSegment(env, 15, segBody, { duration: "5.872" });
    await seedSegment(env, 16, segBody, { duration: "6.100" });

    const request = new Request("https://explorer.holdenu.com/api/cypherclaw/live.m3u8");
    const response = await worker.fetch(request, env, { waitUntil() {} });
    const body = await response.text();

    assert.equal(response.status, 200);
    const lines = body.split("\n");
    assert.equal(lines[0], "#EXTM3U");
    assert.ok(lines.includes("#EXT-X-VERSION:3"));
    assert.ok(lines.includes("#EXT-X-TARGETDURATION:7"));
    assert.ok(lines.includes("#EXT-X-MEDIA-SEQUENCE:15"));

    // Each segment contributes one EXTINF + one URI line, in ascending order.
    const seg15Idx = lines.indexOf(`/api/cypherclaw/segment/cypherclaw/live/${todayKey()}/seg-15.opus`);
    const seg16Idx = lines.indexOf(`/api/cypherclaw/segment/cypherclaw/live/${todayKey()}/seg-16.opus`);
    const seg17Idx = lines.indexOf(`/api/cypherclaw/segment/cypherclaw/live/${todayKey()}/seg-17.opus`);
    assert.ok(seg15Idx > 0, "seg-15 URI present");
    assert.ok(seg16Idx > seg15Idx, "seg-16 follows seg-15");
    assert.ok(seg17Idx > seg16Idx, "seg-17 follows seg-16");
    assert.equal(lines[seg15Idx - 1], "#EXTINF:5.872,");
    assert.equal(lines[seg16Idx - 1], "#EXTINF:6.100,");
    assert.equal(lines[seg17Idx - 1], "#EXTINF:6.000,");
});

