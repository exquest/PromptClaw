+
+  function handleFeatureMessage(event) {
+    const state = window.cypherclawVisualizerState;
+    if (!state || !state.canvas) return;
+
+    try {
+      const payload = JSON.parse(event.data);
+      state.latestFeatures = Object.assign({}, state.latestFeatures, payload, {
+        received_at_ms: Date.now()
+      });
+      window.cypherclawLiveFeatures = state.latestFeatures;
+      state.canvas.setAttribute("data-feed-state", "live");
+      state.canvas.setAttribute("data-visualizer-state", "live");
+    } catch (_err) {
+      state.canvas.setAttribute("data-feed-state", "bad-message");
+    }
+  }
+
+  function connectCypherClawFeatureFeed(canvas) {
+    const featuresUrl = canvas.getAttribute("data-live-features-url") || "/api/cypherclaw/live-features";
+    if (!("EventSource" in window)) {
+      canvas.setAttribute("data-feed-state", "unsupported");
+      return;
+    }
+
+    if (window.cypherclawLiveFeatureSource && typeof window.cypherclawLiveFeatureSource.close === "function") {
