# holdenu-api — Cloudflare Worker

Backs holdenu.com with the release flow, public catalog data, audio
streaming, and (Phase 3) Stripe commerce.

## First-time setup

```bash
cd worker
npm install
npx wrangler login

# Create resources (one-time)
npx wrangler d1 create holdenu                # → paste database_id into wrangler.toml
npx wrangler r2 bucket create holdenu-media

# Edit wrangler.toml: replace REPLACE_WITH_* placeholders

# Migrate D1 (local first)
npm run db:migrate:local
npm run db:migrate:remote

# Set secrets (production)
npx wrangler secret put ADMIN_TOKEN
npx wrangler secret put STRIPE_SECRET_KEY
npx wrangler secret put STRIPE_WEBHOOK_SECRET
npx wrangler secret put RESEND_API_KEY
```

For local development create `worker/.dev.vars`:

```
ADMIN_TOKEN=dev-token-change-me
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...
```

## Run

```bash
npm run dev          # serves at http://localhost:8787
```

The workspace (catalog-explorer) reads `HOLDENU_API_BASE` from
`data/local.js` (gitignored) and falls back to localhost:8787 in dev.

## Routes

| Method | Path                          | Auth   | Purpose                          |
|--------|-------------------------------|--------|----------------------------------|
| GET    | /api/releases                 | public | Visible releases + tracks        |
| GET    | /api/public-annotations       | public | Sanitized annotations            |
| GET    | /api/stream/:trackId          | public | Byte-range audio proxy from R2   |
| GET    | /download/:token              | public | Paid download (token from order) |
| POST   | /api/cypherclaw/segment      | admin  | Store live CypherClaw segment in R2 |
| POST   | /api/checkout                 | public | Create Stripe Checkout Session   |
| POST   | /api/webhook/stripe           | sig    | Stripe webhook (sig-verified)    |
| POST   | /api/release                  | admin  | Create/update release event      |
| POST   | /api/upload-url               | admin  | Sign R2 upload URL               |
| POST   | /api/sync                     | admin  | Mirror workspace annotations     |

Admin endpoints expect `Authorization: Bearer <ADMIN_TOKEN>`.
name = "holdenu-api"
main = "src/index.ts"
compatibility_date = "2026-04-30"
account_id = "1b3ac984f4bf54899baa018edfd94c78"

# Routes — mount the Worker at /api/* on the same origin as the
# catalog-explorer Pages site so the frontend can use relative URLs
# (no CORS hops, no auth-credential cross-origin gotchas). For local
# development run `wrangler dev` and the workspace will hit
# http://localhost:8787 (see HOLDENU_API_BASE in the workspace config).
[[routes]]
pattern = "explorer.holdenu.com/api/*"
zone_name = "holdenu.com"

# CypherClaw v2 public presence (PRD CC-023): the live stream landing
# page is served from a dedicated subdomain. `custom_domain = true`
# binds the entire hostname to this Worker and lets Cloudflare manage
# the DNS record + universal-SSL certificate.
[[routes]]
pattern = "cypherclaw.holdenu.com"
custom_domain = true

# ---------------------------------------------------------------
# D1: relational state (releases, release_tracks, annotations, orders)
# Create with:
#   wrangler d1 create holdenu
# Then paste the returned database_id below.
# ---------------------------------------------------------------
[[d1_databases]]
binding = "DB"
database_name = "holdenu"
database_id = "03f12188-ba6b-4b18-9443-dcc9d1d0b7ee"
migrations_dir = "migrations"

# ---------------------------------------------------------------
# R2: audio + artwork object storage. Zero egress fees.
# Create with:
#   wrangler r2 bucket create holdenu-media
# ---------------------------------------------------------------
[[r2_buckets]]
binding = "MEDIA"
bucket_name = "holdenu-media"

# ---------------------------------------------------------------
# Secrets (set via `wrangler secret put <name>`):
#   ADMIN_TOKEN          — bearer token the workspace sends to gate
#                          /api/release and /api/sync
#   STRIPE_SECRET_KEY    — sk_live_... (or sk_test_... in dev)
#   STRIPE_WEBHOOK_SECRET — whsec_... for /api/webhook/stripe
#   RESEND_API_KEY       — for transactional download emails
# ---------------------------------------------------------------

[vars]
ENVIRONMENT = "production"
PUBLIC_SITE_ORIGIN = "https://holdenu.com"

[env.dev]
[env.dev.vars]
ENVIRONMENT = "development"
PUBLIC_SITE_ORIGIN = "http://localhost:8765"

