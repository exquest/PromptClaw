tant\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"content\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\" during the implementation of the call-response gating rule.\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"delta\\\\\\\\\\\\\\\":true}\\\\\\\\n+{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"tool_use\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"timestamp\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"2026-04-17T04:05:11.173Z\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"tool_name\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"run_shell_command\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"tool_id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"run_shell_command_1776398711173_0\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"parameters\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"git show 555d8cc\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"description\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"Viewing the full diff of the T-024 implementation commit.\\\\\\\\\\\\\\\"}}\\\\\\\\n+{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"tool_result\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"timestamp\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"2026-04-17T04:05:11.546Z\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"tool_id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"run_shell_command_1776398711173_0\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"success\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"commit 555d8cccbe539dbab866127f4f5757dd3ca1e0a5 (HEAD -> feat/graceful-degradation)\\\\\\\\\\\\\\\\nAuthor: Anthony Ainsworth <anthony@cascadiantech.com>\\\\\\\\\\\\\\\\nDate:   Thu Apr 16 21:03:07 2026 -0700\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    feat(render): implement R11 call-response gating [T-024@20260416T181925Z]\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    Follower phrase intent complements leader's realized performance:\\\\\\\\\\\\\\\\n    leader build → follower descends from apex, leader pause → follower fills.\\\\\\\\\\\\\\\\n    Respects call_response_role metadata (leader/follower/solo/tacet).\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndiff --git a/src/cypherclaw/render/rules/call_response.py b/src/cypherclaw/render/rules/call_response.py\\\\\\\\\\\\\\\\nnew file mode 100644\\\\\\\\\\\\\\\\nindex 0000000..9d352e8\\\\\\\\\\\\\\\\n--- /dev/null\\\\\\\\\\\\\\\\n+++ b/src/cypherclaw/render/rules/call_response.py\\\\\\\\\\\\\\\\n@@ -0,0 +1,100 @@\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"R11 Call-Response Gating: follower phrase intent complements leader's realized performance.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+from __future__ import annotations\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+from collections.abc import Mapping\\\\\\\\\\\\\\\\n+from dataclasses import dataclass\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+from cypherclaw.render.events import Event\\\\\\\\\\\\\\\\n+from cypherclaw.render.role_gate import role_is_eligible\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+_CR_ROLE_KEYS = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"call_response_role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"cr_role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ensemble_role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+_FOLLOWER_VALUES = frozenset({\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"follower\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"follow\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"response\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"support\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"})\\\\\\\\\\\\\\\\n+_LEADER_VALUES = frozenset({\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"leader\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lead\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"call\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"})\\\\\\\\\\\\\\\\n+_SKIP_VALUES = frozenset({\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"solo\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"tacet\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"silent\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"})\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+@dataclass\\\\\\\\\\\\\\\\n+class PerformedPart:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Snapshot of the leader voice's realized phrase shape at a given position.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    contour_apex: float = 0.0\\\\\\\\\\\\\\\\n+    amp_curve: float = 1.0\\\\\\\\\\\\\\\\n+    is_building: bool = False\\\\\\\\\\\\\\\\n+    is_pausing: bool = False\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _call_response_role(metadata: Mapping[str, object] | None) -> str | None:\\\\\\\\\\\\\\\\n+    if not metadata:\\\\\\\\\\\\\\\\n+        return None\\\\\\\\\\\\\\\\n+    for key in _CR_ROLE_KEYS:\\\\\\\\\\\\\\\\n+        value = metadata.get(key)\\\\\\\\\\\\\\\\n+        if value is not None:\\\\\\\\\\\\\\\\n+            text = str(value).strip().lower()\\\\\\\\\\\\\\\\n+            if text in _FOLLOWER_VALUES:\\\\\\\\\\\\\\\\n+                return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"follower\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+            if text in _LEADER_VALUES:\\\\\\\\\\\\\\\\n+                return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"leader\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+            if text in _SKIP_VALUES:\\\\\\\\\\\\\\\\n+                return text\\\\\\\\\\\\\\\\n+    return None\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+@dataclass\\\\\\\\\\\\\\\\n+class CallResponseRule:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"R11: follower phrase intent complements leader's realized performance.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    complement_strength: float = 0.5\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    rule_id = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"R11\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def applies_to(\\\\\\\\\\\\\\\\n+        self, role: str, metadata: Mapping[str, object] | None = None\\\\\\\\\\\\\\\\n+    ) -> bool:\\\\\\\\\\\\\\\\n+        if not role_is_eligible(role, metadata):\\\\\\\\\\\\\\\\n+            return False\\\\\\\\\\\\\\\\n+        return _call_response_role(metadata) == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"follower\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def apply(\\\\\\\\\\\\\\\\n+        self, event: Event, leader_part: PerformedPart | None = None\\\\\\\\\\\\\\\\n+    ) -> None:\\\\\\\\\\\\\\\\n+        if leader_part is None:\\\\\\\\\\\\\\\\n+            return\\\\\\\\\\\\\\\\n+        if not self.applies_to(event.role, event.metadata):\\\\\\\\\\\\\\\\n+            return\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+        k = self.complement_strength\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+        if leader_part.is_building:\\\\\\\\\\\\\\\\n+            self._descend_from_apex(event, leader_part, k)\\\\\\\\\\\\\\\\n+        elif leader_part.is_pausing:\\\\\\\\\\\\\\\\n+            self._fill(event, leader_part, k)\\\\\\\\\\\\\\\\n+        else:\\\\\\\\\\\\\\\\n+            self._complement(event, leader_part, k)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def _descend_from_apex(\\\\\\\\\\\\\\\\n+        self, event: Event, leader: PerformedPart, k: float\\\\\\\\\\\\\\\\n+    ) -> None:\\\\\\\\\\\\\\\\n+        event.amp_mult *= 1.0 - k * leader.amp_curve * 0.6\\\\\\\\\\\\\\\\n+        event.contour_apex = (\\\\\\\\\\\\\\\\n+            event.contour_apex * (1.0 - k)\\\\\\\\\\\\\\\\n+            + (1.0 - leader.contour_apex) * k\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\n+        event.tempo_mult *= 1.0 + k * 0.02\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def _fill(\\\\\\\\\\\\\\\\n+        self, event: Event, leader: PerformedPart, k: float\\\\\\\\\\\\\\\\n+    ) -> None:\\\\\\\\\\\\\\\\n+        event.amp_mult *= 1.0 + k * 0.5\\\\\\\\\\\\\\\\n+        event.contour_apex += k * (1.0 - leader.amp_curve) * 0.4\\\\\\\\\\\\\\\\n+        event.tempo_mult *= 1.0 - k * 0.02\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    def _complement(\\\\\\\\\\\\\\\\n+        self, event: Event, leader: PerformedPart, k: float\\\\\\\\\\\\\\\\n+    ) -> None:\\\\\\\\\\\\\\\\n+        complement = 1.0 - leader.amp_curve\\\\\\\\\\\\\\\\n+        event.amp_mult *= 1.0 + k * (complement - 0.5) * 0.4\\\\\\\\\\\\\\\\n+        event.contour_apex = (\\\\\\\\\\\\\\\\n+            event.contour_apex * (1.0 - k * 0.3)\\\\\\\\\\\\\\\\n+            + (1.0 - leader.contour_apex) * k * 0.3\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\ndiff --git a/tests/test_call_response.py b/tests/test_call_response.py\\\\\\\\\\\\\\\\nnew file mode 100644\\\\\\\\\\\\\\\\nindex 0000000..772227a\\\\\\\\\\\\\\\\n--- /dev/null\\\\\\\\\\\\\\\\n+++ b/tests/test_call_response.py\\\\\\\\\\\\\\\\n@@ -0,0 +1,150 @@\\\\\\\\\\\\\\\\n+from cypherclaw.render.events import Event\\\\\\\\\\\\\\\\n+from cypherclaw.render.rules.call_response import (\\\\\\\\\\\\\\\\n+    CallResponseRule,\\\\\\\\\\\\\\\\n+    PerformedPart,\\\\\\\\\\\\\\\\n+)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _pearson(xs: list[float], ys: list[float]) -> float:\\\\\\\\\\\\\\\\n+    n = len(xs)\\\\\\\\\\\\\\\\n+    mean_x = sum(xs) / n\\\\\\\\\\\\\\\\n+    mean_y = sum(ys) / n\\\\\\\\\\\\\\\\n+    cov = sum((x - mean_x) * (y - mean_y) for x, y in zip(xs, ys))\\\\\\\\\\\\\\\\n+    var_x = sum((x - mean_x) ** 2 for x in xs)\\\\\\\\\\\\\\\\n+    var_y = sum((y - mean_y) ** 2 for y in ys)\\\\\\\\\\\\\\\\n+    if var_x == 0 or var_y == 0:\\\\\\\\\\\\\\\\n+        return 0.0\\\\\\\\\\\\\\\\n+    return cov / (var_x**0.5 * var_y**0.5)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _make_follower(position: float = 0.0) -> Event:\\\\\\\\\\\\\\\\n+    return Event(\\\\\\\\\\\\\\\\n+        normalized_phrase_position=position,\\\\\\\\\\\\\\\\n+        role=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        contour_apex=0.5,\\\\\\\\\\\\\\\\n+        amp_mult=1.0,\\\\\\\\\\\\\\\\n+        tempo_mult=1.0,\\\\\\\\\\\\\\\\n+        metadata={\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"call_response_role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"follower\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"},\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_complementarity_on_two_voice_fixture():\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Follower contour inversely correlates with leader (r < -0.3).\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    rule = CallResponseRule(complement_strength=0.8)\\\\\\\\\\\\\\\\n+    n = 10\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    leader_parts: list[PerformedPart] = []\\\\\\\\\\\\\\\\n+    for i in range(n):\\\\\\\\\\\\\\\\n+        pos = i / (n - 1)\\\\\\\\\\\\\\\\n+        amp = pos / 0.7 if pos <= 0.7 else 1.0 - (pos - 0.7) / 0.3\\\\\\\\\\\\\\\\n+        amp = max(0.0, min(1.0, amp))\\\\\\\\\\\\\\\\n+        leader_parts.append(\\\\\\\\\\\\\\\\n+            PerformedPart(\\\\\\\\\\\\\\\\n+                contour_apex=amp,\\\\\\\\\\\\\\\\n+                amp_curve=amp,\\\\\\\\\\\\\\\\n+                is_building=pos <= 0.7,\\\\\\\\\\\\\\\\n+                is_pausing=False,\\\\\\\\\\\\\\\\n+            )\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    follower_events = [_make_follower(i / (n - 1)) for i in range(n)]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    for event, leader in zip(follower_events, leader_parts):\\\\\\\\\\\\\\\\n+        rule.apply(event, leader)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    leader_amps = [lp.amp_curve for lp in leader_parts]\\\\\\\\\\\\\\\\n+    follower_amps = [e.amp_mult for e in follower_events]\\\\\\\\\\\\\\\\n+    follower_apexes = [e.contour_apex for e in follower_events]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    assert _pearson(leader_amps, follower_amps) < -0.3\\\\\\\\\\\\\\\\n+    assert _pearson(leader_amps, follower_apexes) < -0.3\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_leader_role_unchanged():\\\\\\\\\\\\\\\\n+    rule = CallResponseRule()\\\\\\\\\\\\\\\\n+    event = Event(\\\\\\\\\\\\\\\\n+        role=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        amp_mult=1.0,\\\\\\\\\\\\\\\\n+        contour_apex=0.5,\\\\\\\\\\\\\\\\n+        metadata={\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"call_response_role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"leader\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"},\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+    rule.apply(event, PerformedPart(amp_curve=0.8, is_building=True))\\\\\\\\\\\\\\\\n+    assert event.amp_mult == 1.0\\\\\\\\\\\\\\\\n+    assert event.contour_apex == 0.5\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_solo_role_unchanged():\\\\\\\\\\\\\\\\n+    rule = CallResponseRule()\\\\\\\\\\\\\\\\n+    event = Event(\\\\\\\\\\\\\\\\n+        role=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        amp_mult=1.0,\\\\\\\\\\\\\\\\n+        contour_apex=0.5,\\\\\\\\\\\\\\\\n+        metadata={\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"call_response_role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"solo\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"},\\\\\\\\\\\\\\\\n+    )\\\\\\\\\\\\\\\\n+    rule.apply(event, PerformedPart(amp_curve=0.8, is_building=True))\\\\\\\\\\\\\\\\n+    assert event.amp_mult == 1.0\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_tacet_role_unchanged():\\\\\\\\\\\\\\\\n+    rule = CallResponseRule()\\\\\\\\\\\\\\\\n+    event = Event(\\\\\\\\\\\\\\\\n+        role=\\\\\\\\\\\\\\\\\\\\\\\\\