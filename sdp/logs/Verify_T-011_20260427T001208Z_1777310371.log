-{"type":"tool_use","timestamp":"2026-04-27T01:35:20.458Z","tool_name":"write_file","tool_id":"write_file_1777253720457_0","parameters":{"content":"\"\"\"Tests for Modal generation client parity and behavior.\"\"\"\n\nimport inspect\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom my_claw.tools.senseweave.generation.client_modal import ModalClient\nfrom my_claw.tools.senseweave.generation.client_replicate import ReplicateClient\n\n\ndef test_modal_client_satisfies_protocol() -> None:\n    \"\"\"ModalClient should have the same signature as ReplicateClient.generate.\"\"\"\n    modal_sig = inspect.signature(ModalClient.generate)\n    rep_sig = inspect.signature(ReplicateClient.generate)\n    \n    # We drop the 'self' parameter to compare signatures if needed,\n    # but since both are unbound methods, the signatures should match perfectly.\n    assert modal_sig == rep_sig\n\n\n@patch(\"my_claw.tools.senseweave.generation.client_modal.modal.Function.lookup\")\ndef test_modal_client_computes_cost(mock_lookup: MagicMock) -> None:\n    \"\"\"ModalClient should calculate cost using prediction metadata.\"\"\"\n    mock_func = MagicMock()\n    mock_lookup.return_value = mock_func\n    \n    # Mocking modal's function response which should contain execution timing\n    # or the result should contain it.\n    mock_call_result = MagicMock()\n    # Assume the returned object from Modal contains audio data and timing metadata.\n    # E.g. {\"audio\": b\"...\", \"duration_sec\": 5.0, \"predict_time_sec\": 3.0}\n    mock_call_result.get.side_effect = lambda k, d=None: {\"predict_time_sec\": 10.0}.get(k, d)\n    mock_func.remote.return_value = mock_call_result\n\n    client = ModalClient()\n    # Dummy request dictionary\n    req = {\"model\": \"musicgen-medium\", \"prompt\": \"test prompt\", \"duration_sec\": 5.0}\n    result = client.generate(req)\n    \n    # 10.0 seconds * per-second A10G rate (e.g., $0.000293 for A10G roughly -> but let's see what cost it returns)\n    assert result.get(\"cost_usd\") is not None\n    assert result[\"cost_usd\"] > 0.0\n","file_path":"tests/test_client_modal.py"}}
