+"""Tests for deterministic SenseWeave render replay."""
+from __future__ import annotations
+
+import hashlib
+import json
+import os
+import sys
+import wave
+from pathlib import Path
+from typing import Any
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "my-claw", "tools"))
