+            phrase_id="phrase-a",
+            section_id="intro",
+            voice_id="lead",
+            role="melody",
+            pitch=67,
+            nominal_beat=1.0,
+            nominal_dur_beats=0.5,
+            intent_tag="build",
+        ),
+    ]
+
+
+def _delta_track() -> list[dict[str, Any]]:
+    return [
+        {
+            "event_id": "evt-1",
+            "onset_sec": 0.012,
+            "dur_sec": 0.73125,
