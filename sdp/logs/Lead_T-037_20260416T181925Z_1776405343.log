            "dur_sec": 0.73125,
            "velocity": 0.82,
            "timing_deviation_ms": 3.2,
            "articulation": "legato",
            "sensor_tempo_scale": 1.03,
            "sensor_amp_scale": 0.94,
            "sensor_brightness": 0.2,
            "rule_stack": ["R7", "R8"],
            "seed_path": [17, 1],
        },
        {
            "event_id": "evt-2",
            "onset_sec": 0.498,
            "dur_sec": 0.205,
            "velocity": 0.58,
            "timing_deviation_ms": -1.4,
