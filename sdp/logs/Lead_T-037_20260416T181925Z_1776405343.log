+    seen: set[str] = set()
+    for event in events:
+        for rule in event.rule_stack:
+            if rule not in seen:
+                seen.add(rule)
+                rules.append(rule)
+    return tuple(rules)
+
+
+def event_payload(event: Event | Mapping[str, Any]) -> dict[str, Any]:
+    """Return a JSON-safe event payload suitable for delta-track persistence."""
+    if isinstance(event, Event):
+        return event.to_json_dict()
+    if is_dataclass(event) and not isinstance(event, type):
+        return Event.from_json_dict(dict(event)).to_json_dict()
+    return dict(event)

