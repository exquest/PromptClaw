+            ts=11.5,
+            voice="bowed",
+            scene="Verse",
+            tuning="gamelan_slendro",
+        ),
+    )
+
+    assert [event.channel for event in events] == [2, 2, 2, 2]
+    assert events[-1].pitch_bend_value == 8192
+    assert [event.to_dict() for event in events] == [
+        {
+            "event_type": "note_on",
+            "status": 0x92,
+            "data1": 64,
+            "data2": 96,
+            "ts": 10.5,
+            "voice": "bowed",
+            "scene": "Verse",
+            "tuning": "gamelan_slendro",
