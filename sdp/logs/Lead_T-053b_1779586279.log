+        ({**base, "status": 0x80}, "status"),
+        ({**base, "data1": 128}, "data1"),
+        ({**base, "data2": 0}, "velocity"),
+        ({**base, "ts": float("nan")}, "ts"),
+        ({**base, "voice": 42}, "voice"),
