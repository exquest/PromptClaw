+        event_type=MIDI_EVENT_NOTE_ON,
+        status=_status_for_channel(0x90, channel),
+        data1=note,
+        data2=velocity,
+        ts=ts,
+        voice=voice,
+        scene=scene,
+        tuning=tuning,
+        metadata=_metadata_or_empty(metadata),
+    )
