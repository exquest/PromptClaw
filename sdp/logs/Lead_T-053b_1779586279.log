+    for malformed in (
+        {},
+        {**payload, "event_type": "cc"},
+        {**payload, "metadata": []},
+        {**payload, "tuning": None},
+    ):
+        with pytest.raises(ValueError):
+            mod.validate_live_midi_event_payload(malformed)
+
