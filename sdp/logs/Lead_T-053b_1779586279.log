+) -> LiveMidiEvent:
+    """Construct a validated live MIDI pitch-bend event from a 14-bit value."""
+
+    _validate_pitch_bend_value(value)
+    return LiveMidiEvent(
+        event_type=MIDI_EVENT_PITCH_BEND,
+        status=_status_for_channel(0xE0, channel),
+        data1=value & 0x7F,
