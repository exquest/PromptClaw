index 0000000000000000000000000000000000000000..ca23a1d3b2b20ddba711192843b044bd2d49f8a9
--- /dev/null
+++ b/tests/test_cypherclaw_musicianship_roadmap.py
@@ -0,0 +1,57 @@
+"""Static regression tests for the musicianship roadmap sampler update."""
+from pathlib import Path
+
+
+ROADMAP_PATH = Path("docs/cypherclaw-musicianship-roadmap.md")
+
+
+def test_roadmap_names_signature_quintet_and_sampler_role() -> None:
+    content = ROADMAP_PATH.read_text(encoding="utf-8")
+    lowered = content.lower()
+
+    assert "current ensemble snapshot" in lowered
+    assert "quintet" in lowered
+    for voice in (
+        "sw_bell_warm",
+        "sw_bowed",
+        "sw_breath",
+        "sw_pad",
+        "sw_sampler",
+    ):
+        assert voice in content
+
+    for role_term in (
+        "melody",
+        "counter",
+        "color",
+        "foundation",
+        "memory voice",
+    ):
+        assert role_term in lowered
+
+
+def test_roadmap_records_landed_and_pending_quintet_status() -> None:
+    content = ROADMAP_PATH.read_text(encoding="utf-8")
+    lowered = content.lower()
+
+    assert "landed now" in lowered
+    assert "still pending" in lowered
+    assert "quartet" in lowered
+
+    for landed_ref in (
+        "sample_capture_daemon.py",
+        "sampler_buffers.py",
+        "sampler_dispatch.py",
+        "sampler_effects.scd",
+        "sampler_silent_quintet_member",
+    ):
+        assert landed_ref in content
+
+    for pending_ref in (
+        "artist_identity.py",
+        "tests/test_artist_identity.py",
+        "SampleLibrary",
+        "SampleSelector",
+        "sw_sampler.scd",
+    ):
+        assert pending_ref in content

Spec, regression test, roadmap update, and bookkeeping are committed. Full validation passed cleanly; only unrelated pre-existing SDP/log/temp files remain dirty in the worktree.
  ✓ Read the roadmap, sampler PRD, current code/tests, and current task-tracking artifacts to establish the real quintet status.
  ✓ Record assumptions/exploration context, then write specs/t-013@20260425t183959za-spec.md and task notes updates.
  ✓ Add a focused failing regression test for the roadmap’s quintet composition/role/status content.
  ✓ Update docs/cypherclaw-musicianship-roadmap.md plus required changelog/progress entries to satisfy the spec.
  ✓ Run targeted verification, review diffs, and commit only the task-scoped files.
