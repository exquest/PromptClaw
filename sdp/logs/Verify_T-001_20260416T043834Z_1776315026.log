                "--no-pager",
            ],
            capture_output=True,
            text=True,
            timeout=2,
            check=False,
        )
    except Exception:
        return []

    matches = []
    for line in completed.stdout.splitlines():
        lowered = line.lower()
        if any(token in lowered for token in ("resync", "xrun", "underrun", "overrun")):

