{"type":"tool_result","timestamp":"2026-04-16T21:14:52.208Z","tool_id":"run_shell_command_1776374092021_0","status":"success","output":"\"\"\"Tests for the EMSD curriculum catalog and scaffold generator.\"\"\"\nfrom __future__ import annotations\n\nimport json\nimport os\nimport sys\n\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\", \"my-claw\"))\n\nfrom curriculum.bootstrap import materialize_curriculum\nfrom curriculum.catalog import COURSE_CATALOG, ExerciseSpec, course_by_code, curriculum_totals, scaffold_relpaths\nfrom curriculum.verify import verify_exercise\n\n\n# ------------------------------------------------------------------\n# Existing catalog shape tests\n# ------------------------------------------------------------------\n\ndef test_curriculum_catalog_matches_declared_degree_shape() -> None:\n    totals = curriculum_totals()\n\n    assert totals == {\"courses\": 40, \"credits\": 120}\n    assert len(COURSE_CATALOG) == 40\n\n\ndef test_course_lookup_exposes_capstone_and_core_prerequisites() -> None:\n    capstone = course_by_code(\"EMSD-499\")\n    theory = course_by_code(\"EMSD-110\")\n\n    assert capstone.title.startswith(\"Capstone\")\n    assert \"EMSD-401\" in capstone.prerequisites\n    assert theory.prerequisites == ()\n\n\ndef test_scaffold_relpaths_follow_standard_course_layout() -> None:\n    paths = scaffold_relpaths(course_by_code(\"EMSD-201\"))\n\n    assert \"EMSD-201/README.md\" in paths\n    assert \"EMSD-201/reference/01-overview.md\" in paths\n    assert \"EMSD-201/prompts/composition.md\" in paths\n    assert \"EMSD-201/exercises/README.md\" in paths\n\n\ndef test_materialize_curriculum_creates_course_scaffolds(tmp_path) -> None:\n    materialize_curriculum(tmp_path)\n\n    assert (tmp_path / \"EMSD-101\" / \"README.md\").exists()\n    assert (tmp_path / \"EMSD-201\" / \"reference\" / \"01-overview.md\").exists()\n    assert (tmp_path / \"EMSD-401\" / \"prompts\" / \"analysis.md\").exists()\n    assert (tmp_path / \"EMSD-499\" / \"COMPLETION.md\").exists()"}
{"type":"tool_use","timestamp":"2026-04-16T21:15:10.361Z","tool_name":"write_file","tool_id":"write_file_1776374110361_0","parameters":{"content":"# Task T-022 Specification: Build SuperCollider recipe references without coupling tests to live audio\n\n## Problem Statement\nThe project needs a comprehensive set of SuperCollider recipe references to support curriculum exercises. These recipes must be discoverable from existing curriculum documentation but tested without relying on live audio server execution, which can cause flaky tests and coupling issues.\n\n## Technical Approach\n- Create a new directory `my-claw/curriculum/recipes/supercollider/`.\n- Create a markdown recipe file for each required topic: MIDI-to-frequency, intervals, scales, chord voicings, swing, polyrhythm, subtractive, FM, additive, granular, physical modeling, spectral freeze, EQ, compression, sidechain, reverb, delay, master bus, groups, buses, patterns, and envelopes.\n- Each recipe file will include descriptive text, code examples (SuperCollider language), and required metadata/labels to categorize them.\n- Link to these recipes in `my-claw/curriculum/EMSD-102/reference/01-overview.md` and `my-claw/curriculum/EMSD-130/reference/01-overview.md` to ensure they are discoverable.\n- Write tests in `tests/test_supercollider_recipes.py` that check for the existence of these files and verify they contain the required frontmatter labels. The tests will parse the markdown directly (static analysis) without booting `scsynth`.\n\n## Edge Cases\n- **Missing or malformed frontmatter/labels**: Tests will enforce a strict format.\n- **Broken links in curriculum reference docs**: Tests will optionally check that references are properly formatted.\n\n## Acceptance Criteria\n- reference recipes exist for MIDI-to-frequency, intervals, scales, chord voicings, swing, polyrhythm, subtractive, FM, additive, granular, physical modeling, spectral freeze, EQ, compression, sidechain, reverb, delay, master bus, groups, buses, patterns, and envelopes.\n    - VERIFY: `pytest tests/test_supercollider_recipes.py::test_recipe_files_exist`\n- recipes are discoverable from curriculum/reference docs.\n    - VERIFY: `pytest tests/test_supercollider_recipes.py::test_recipes_linked_in_curriculum`\n- tests verify recipe files and required labels exist.\n    - VERIFY: `pytest tests/test_supercollider_recipes.py::test_recipe_files_contain_labels`\n","file_path":"specs/t-022@20260416t054258z-spec.md"}}
{"type":"tool_result","timestamp":"2026-04-16T21:15:10.387Z","tool_id":"write_file_1776374110361_0","status":"success"}
{"type":"tool_use","timestamp":"2026-04-16T21:15:34.023Z","tool_name":"write_file","tool_id":"write_file_1776374134023_0","parameters":{"content":"import os\nfrom pathlib import Path\n\nRECIPE_NAMES = [\n    \"midi-to-frequency\",\n    \"intervals\",\n    \"scales\",\n    \"chord-voicings\",\n    \"swing\",\n    \"polyrhythm\",\n    \"subtractive\",\n    \"fm\",\n    \"additive\",\n    \"granular\",\n    \"physical-modeling\",\n    \"spectral-freeze\",\n    \"eq\",\n    \"compression\",\n    \"sidechain\",\n    \"reverb\",\n    \"delay\",\n    \"master-bus\",\n    \"groups\",\n    \"buses\",\n    \"patterns\",\n    \"envelopes\",\n]\n\ndef test_recipe_files_exist() -> None:\n    recipe_dir = Path(\"my-claw/curriculum/recipes/supercollider\")\n    assert recipe_dir.exists(), \"Recipe directory does not exist\"\n    \n    for recipe in RECIPE_NAMES:\n        recipe_file = recipe_dir / f\"{recipe}.md\"\n        assert recipe_file.exists(), f\"Recipe file {recipe_file} is missing\"\n\ndef test_recipe_files_contain_labels() -> None:\n    recipe_dir = Path(\"my-claw/curriculum/recipes/supercollider\")\n    \n    for recipe in RECIPE_NAMES:\n        recipe_file = recipe_dir / f\"{recipe}.md\"\n        if not recipe_file.exists():\n            continue\n            \n        content = recipe_file.read_text()\n        \n        # We require a labels line in each recipe\n        # For instance: \"Labels: supercollider, recipe\"\n        assert \"Labels: supercollider, recipe\" in content, f\"Recipe {recipe_file} is missing required labels\"\n\ndef test_recipes_linked_in_curriculum() -> None:\n    overview_102 = Path(\"my-claw/curriculum/EMSD-102/reference/01-overview.md\")\n    overview_130 = Path(\"my-claw/curriculum/EMSD-130/reference/01-overview.md\")\n    \n    content_102 = overview_102.read_text()\n    content_130 = overview_130.read_text()\n    \n    combined_content = content_102 + \"\\n\" + content_130\n    \n    # We require that somewhere in these two files, there is a link to the recipes directory\n    assert \"recipes/supercollider\" in combined_content, \"Recipes directory is not discoverable from EMSD-102 or EMSD-130 reference docs\"\n","file_path":"tests/test_supercollider_recipes.py"}}
