async function loadRuntime() {
    const env = makeEnv();
    const request = new Request("https://cypherclaw.holdenu.com/", { method: "GET" });
    const response = await worker.fetch(request, env, { waitUntil() {} });
    const html = await response.text();
    return makeCanvasRuntime(extractInlinePageScript(html));
}

test("visualizer runtime normalizes nested live feature events and renders from them", async () => {
    const runtime = await loadRuntime();

    assert.equal(runtime.eventSources.length, 1);
    assert.equal(runtime.eventSources[0].url, "/api/cypherclaw/live-features");

    runtime.eventSources[0].dispatch("features", {
        data: JSON.stringify({
            source: "glyph-fanout",
            captured_at: "2026-05-23T12:00:00Z",
            audio: {
                rms: 0.42,
                pitch_hz: 440,
                spectral_centroid_hz: 2200,
                onset_rate_hz: 3.25,
            },
            visual: {
                brightness: 0.78,
                motion: 0.66,
                texture: 0.31,
                density: 0.72,
                salience: 0.58,
            },
            scene: {
                name: "Second Return",
                arc_phase: "Conversation",
            },
            tuning: {
                name: "slendro",
            },
            dsp_blocks: ["parallel_delay"],
            artistic_identity: "threads the room through amber delay",
        }),
    });
    runtime.runNextFrame(240);

    const features = runtime.window.cypherclawLiveFeatures;
    assert.equal(features.source, "glyph-fanout");
    assert.equal(features.rms, 0.42);
    assert.equal(features.pitch_hz, 440);
    assert.equal(features.centroid_hz, 2200);
    assert.equal(features.onset_rate_hz, 3.25);
    assert.equal(features.brightness, 0.78);
    assert.equal(features.motion, 0.66);
    assert.equal(features.texture, 0.31);
    assert.equal(features.density, 0.72);
    assert.equal(features.salience, 0.58);
    assert.equal(features.scene, "Second Return");
    assert.equal(features.arc_phase, "Conversation");
    assert.equal(features.tuning, "slendro");
    assert.deepEqual(features.dsp_blocks, ["parallel_delay"]);
    assert.equal(features.event_count, 1);

    assert.equal(runtime.canvas.getAttribute("data-feed-state"), "live");
    assert.equal(runtime.canvas.getAttribute("data-last-scene"), "Second Return");
    assert.equal(runtime.canvas.getAttribute("data-last-tuning"), "slendro");
    assert.equal(runtime.canvas.getAttribute("data-feed-events"), "1");
    assert.ok(Number(runtime.canvas.getAttribute("data-render-count")) >= 1);
    assert.ok(runtime.drawCalls.some((call) => call.op === "fillRect"));
    assert.ok(
        runtime.drawCalls.some((call) => call.op === "arc" && call.args[2] > 80),
        "incoming RMS drives a visibly larger rendered pulse",
    );
});

