+  const MIDI_EVENT_QUEUE_LIMIT = 128;
+
+  function integerInRange(value, min, max) {
+    return typeof value === "number" && Number.isInteger(value) && value >= min && value <= max;
+  }
+
+  function normalizeCypherClawMidiEvent(payload) {
+    const source = objectValue(payload);
+    const status = source.status;
+    const note = source.data1;
+    const velocity = source.data2;
+    const ts = source.ts;
+
+    if (!integerInRange(status, 0, 255) || !integerInRange(note, 0, 127) || !integerInRange(velocity, 0, 127)) {
+      return null;
+    }
+    if (typeof ts !== "number" || !Number.isFinite(ts)) {
+      return null;
+    }
+
+    const command = status & 240;
+    let type = null;
+    if (command === 144 && velocity > 0) {
+      type = "note_on";
+    } else if (command === 128 || (command === 144 && velocity === 0)) {
+      type = "note_off";
+    }
+    if (type === null) {
+      return null;
+    }
+
+    return {
+      type: type,
+      status: status,
+      note: note,
+      velocity: velocity,
+      channel: (status & 15) + 1,
+      ts: ts,
+      received_at_ms: Date.now()
+    };
+  }
+
+  function midiWebSocketUrl(midiUrl) {
+    if (/^wss?:\\/\\//i.test(midiUrl)) {
+      return midiUrl;
+    }
+    if (/^https?:\\/\\//i.test(midiUrl)) {
+      return midiUrl.replace(/^http/i, "ws");
+    }
+    const locationInfo = window.location || {};
+    const protocol = locationInfo.protocol === "http:" ? "ws:" : "wss:";
+    const host = locationInfo.host || "cypherclaw.holdenu.com";
+    const path = midiUrl.charAt(0) === "/" ? midiUrl : "/" + midiUrl;
+    return protocol + "//" + host + path;
+  }
+
+  function publishMidiQueueState(state) {
+    window.cypherclawLiveMidiEvents = state.midiEvents;
+    state.canvas.setAttribute("data-midi-events", String(state.midiEvents.length));
+  }
+
+  function enqueueCypherClawMidiEvent(state, event) {
+    state.midiEvents.push(event);
+    if (state.midiEvents.length > state.midiEventLimit) {
+      state.midiEvents.splice(0, state.midiEvents.length - state.midiEventLimit);
+    }
+    state.canvas.setAttribute("data-midi-state", "live");
+    publishMidiQueueState(state);
+  }
+
   function normalizeCypherClawFeaturePayload(payload, previous) {
     const source = objectValue(payload);
     const audio = objectValue(source.audio);
@@ -561,6 +631,59 @@
     canvas.setAttribute("data-feed-state", "connecting");
   }

+  function handleMidiMessage(event) {
+    const state = window.cypherclawVisualizerState;
+    if (!state || !state.canvas) return;
+
+    try {
+      const payload = JSON.parse(event.data);
+      const midiEvent = normalizeCypherClawMidiEvent(payload);
+      if (midiEvent === null) {
+        return;
+      }
+      enqueueCypherClawMidiEvent(state, midiEvent);
+    } catch (_err) {
+      state.canvas.setAttribute("data-midi-state", "bad-message");
+    }
+  }
+
+  function connectCypherClawMidiFeed(canvas) {
+    const state = window.cypherclawVisualizerState;
+    const midiUrl = canvas.getAttribute("data-live-midi-url") || "/api/cypherclaw/live-midi";
+    if (!state) return;
+
+    if (!("WebSocket" in window)) {
+      canvas.setAttribute("data-midi-state", "unsupported");
+      return;
+    }
+
+    if (window.cypherclawLiveMidiSocket && typeof window.cypherclawLiveMidiSocket.close === "function") {
+      window.cypherclawLiveMidiSocket.close();
+    }
+
+    const socketUrl = midiWebSocketUrl(midiUrl);
+    let socket;
+    try {
+      socket = new WebSocket(socketUrl);
+    } catch (_err) {
+      canvas.setAttribute("data-midi-state", "socket-error");
+      return;
+    }
+
+    socket.addEventListener("open", function () {
+      canvas.setAttribute("data-midi-state", "connected");
+    });
+    socket.addEventListener("message", handleMidiMessage);
+    socket.addEventListener("error", function () {
+      canvas.setAttribute("data-midi-state", "socket-error");
+    });
+    socket.addEventListener("close", function () {
+      canvas.setAttribute("data-midi-state", "closed");
+    });
+    window.cypherclawLiveMidiSocket = socket;
+    canvas.setAttribute("data-midi-state", "connecting");
+  }
