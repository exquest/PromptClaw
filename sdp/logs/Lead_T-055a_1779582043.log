+test("GET / connects the visualizer to live MIDI with a WebSocket client", async () => {
+    const env = makeEnv();
+    const request = new Request("https://cypherclaw.holdenu.com/", { method: "GET" });
+    const response = await worker.fetch(request, env, { waitUntil() {} });
+    const body = await response.text();
+
+    assert.equal(response.status, 200);
+    assert.match(body, /data-live-midi-url="\/api\/cypherclaw\/live-midi"/);
+    assert.match(body, /function connectCypherClawMidiFeed\(canvas\)/);
+    assert.match(body, /function normalizeCypherClawMidiEvent\(payload\)/);
+    assert.match(body, /new WebSocket\(socketUrl\)/);
+    assert.match(body, /socket\.addEventListener\("message", handleMidiMessage\)/);
+    assert.match(body, /window\.cypherclawLiveMidiSocket = socket/);
+    assert.match(body, /window\.cypherclawLiveMidiEvents = state\.midiEvents/);
+    assert.match(body, /data-midi-state/);
+    assert.match(body, /data-midi-events/);
+    assert.doesNotMatch(body.toLowerCase(), /listener count|viewer count|analytics/);
