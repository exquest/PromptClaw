+    });
+    runtime.webSockets[0].dispatch("message", {
+        data: JSON.stringify({ status: 145, data1: 64, data2: 0, ts: 1779568086.5 }),
+    });
+    runtime.webSockets[0].dispatch("message", {
+        data: JSON.stringify({ status: 130, data1: 67, data2: 42, ts: 1779568086.75 }),
+    });
+    runtime.webSockets[0].dispatch("message", {
+        data: JSON.stringify({ status: 176, data1: 74, data2: 99, ts: 1779568087 }),
+    });
+    runtime.webSockets[0].dispatch("message", { data: "{not-json" });
+    runtime.webSockets[0].dispatch("message", {
