+test("visualizer runtime opens live MIDI WebSocket and queues normalized note events", async () => {
+    const runtime = await loadRuntime();
+
+    assert.equal(runtime.webSockets.length, 1);
+    assert.equal(runtime.webSockets[0].url, "wss://cypherclaw.holdenu.com/api/cypherclaw/live-midi");
+
+    runtime.webSockets[0].dispatch("open");
+    assert.equal(runtime.canvas.getAttribute("data-midi-state"), "connected");
+
+    runtime.webSockets[0].dispatch("message", {
+        data: JSON.stringify({ status: 144, data1: 60, data2: 100, ts: 1779568086.25 }),
+    });
+    runtime.webSockets[0].dispatch("message", {
+        data: JSON.stringify({ status: 145, data1: 64, data2: 0, ts: 1779568086.5 }),
+    });
+    runtime.webSockets[0].dispatch("message", {
+        data: JSON.stringify({ status: 130, data1: 67, data2: 42, ts: 1779568086.75 }),
+    });
+    runtime.webSockets[0].dispatch("message", {
+        data: JSON.stringify({ status: 176, data1: 74, data2: 99, ts: 1779568087 }),
+    });
+    runtime.webSockets[0].dispatch("message", { data: "{not-json" });
+    runtime.webSockets[0].dispatch("message", {
+        data: JSON.stringify({ status: 144, data1: 128, data2: 100, ts: 1779568088 }),
+    });
+
+    const events = runtime.window.cypherclawLiveMidiEvents;
+    assert.equal(events.length, 3);
+    assert.deepEqual(events.map((event) => event.type), ["note_on", "note_off", "note_off"]);
+    assert.deepEqual(events.map((event) => event.note), [60, 64, 67]);
+    assert.deepEqual(events.map((event) => event.velocity), [100, 0, 42]);
+    assert.deepEqual(events.map((event) => event.channel), [1, 2, 3]);
+    assert.equal(events[0].status, 144);
+    assert.equal(events[0].ts, 1779568086.25);
+    assert.equal(typeof events[0].received_at_ms, "number");
+    assert.equal(runtime.window.cypherclawVisualizerState.midiEvents, events);
+    assert.equal(runtime.canvas.getAttribute("data-midi-state"), "live");
+    assert.equal(runtime.canvas.getAttribute("data-midi-events"), "3");
+
+    runtime.webSockets[0].dispatch("close");
+    assert.equal(runtime.canvas.getAttribute("data-midi-state"), "closed");
+    assert.equal(runtime.window.cypherclawLiveMidiEvents.length, 3);
+});
+
+test("visualizer runtime keeps the live MIDI event queue bounded", async () => {
+    const runtime = await loadRuntime();
+    const socket = runtime.webSockets[0];
+
+    for (let i = 0; i < 140; i += 1) {
+        socket.dispatch("message", {
+            data: JSON.stringify({ status: 144, data1: i % 128, data2: 64, ts: i }),
+        });
+    }
+
+    const events = runtime.window.cypherclawLiveMidiEvents;
+    assert.equal(events.length, 128);
+    assert.equal(events[0].ts, 12);
+    assert.equal(events[0].note, 12);
+    assert.equal(events[127].ts, 139);
+    assert.equal(events[127].note, 11);
+    assert.equal(runtime.canvas.getAttribute("data-midi-events"), "128");
+});
+
