  function clampNumber(value, min, max, fallback) {
    const n = Number(value);
    if (!Number.isFinite(n)) return fallback;
    return Math.min(max, Math.max(min, n));
  }

  function pickNumber(features, names, fallback) {
    for (const name of names) {
      if (Object.prototype.hasOwnProperty.call(features, name)) {
        return clampNumber(features[name], -1000000, 1000000, fallback);
      }
    }
    return fallback;
  }

  function objectValue(value) {
    return value && typeof value === "object" && !Array.isArray(value) ? value : {};
  }

  function pickFiniteNumber(values, min, max, fallback) {
    for (const value of values) {
      const n = Number(value);
      if (Number.isFinite(n)) {
        return Math.min(max, Math.max(min, n));
      }
    }
    return fallback;
  }

  function stringValue(value) {
    if (typeof value === "string" && value.trim()) return value;
    if (typeof value === "number" && Number.isFinite(value)) return String(value);
    return null;
  }

  function pickString(values, fallback) {
    for (const value of values) {
      const candidate = stringValue(value);
      if (candidate) return candidate;
    }
    return fallback;
  }

  function normalizeCypherClawFeaturePayload(payload, previous) {
    const source = objectValue(payload);
    const audio = objectValue(source.audio);
    const visual = objectValue(source.visual);
    const sceneObject = objectValue(source.scene);
    const tuningObject = objectValue(source.tuning);
    const previousFeatures = objectValue(previous);
    const previousEventCount = Number(previousFeatures.event_count || 0);

    const rms = pickFiniteNumber(
      [source.rms, source.amplitude, audio.rms, audio.amplitude],
      0,
      1,
      pickNumber(previousFeatures, ["rms", "amplitude"], 0.07)
    );
    const pitch = pickFiniteNumber(
      [source.pitch_hz, source.pitchHz, audio.pitch_hz, audio.pitchHz],
      55,
      1760,
      pickNumber(previousFeatures, ["pitch_hz", "pitchHz"], 196)
    );
    const centroid = pickFiniteNumber(
      [source.centroid_hz, source.spectral_centroid_hz, audio.centroid_hz, audio.spectral_centroid_hz],
      120,
      6000,
      pickNumber(previousFeatures, ["centroid_hz", "spectral_centroid_hz"], 900)
    );
    const onsetRate = pickFiniteNumber(
      [source.onset_rate_hz, source.onset_rate, audio.onset_rate_hz, audio.onset_rate],
      0,
      24,
      pickNumber(previousFeatures, ["onset_rate_hz", "onset_rate"], 0)
    );
    const brightness = pickFiniteNumber(
      [source.brightness, visual.brightness],
      0,
      1,
      pickNumber(previousFeatures, ["brightness"], Math.min(1, centroid / 6000))
    );
    const motion = pickFiniteNumber(
      [source.motion, visual.motion],
      0,
      1,
      pickNumber(previousFeatures, ["motion"], Math.min(1, onsetRate / 8))
    );
    const texture = pickFiniteNumber(
      [source.texture, visual.texture],
      0,
      1,
      pickNumber(previousFeatures, ["texture"], 0.35)
    );
    const density = pickFiniteNumber(
      [source.density, visual.density],
      0,
      1,
      pickNumber(previousFeatures, ["density"], Math.min(1, onsetRate / 10))
    );
    const salience = pickFiniteNumber(
      [source.salience, visual.salience],
      0,
      1,
      pickNumber(previousFeatures, ["salience"], Math.max(rms, motion))
    );
    const arcPhase = pickString(
      [source.arc_phase, source.arcPhase, sceneObject.arc_phase, sceneObject.arcPhase, sceneObject.phase],
      previousFeatures.arc_phase || ""
    );
    const scene = pickString(
      [sceneObject.name, sceneObject.current, source.current_scene, source.scene_name, source.scene, arcPhase],
      previousFeatures.scene || "awaiting-live-features"
    );
    const tuning = pickString(
      [tuningObject.name, tuningObject.current, tuningObject.system, source.tuning_system_name, source.tuningSystemName, source.tuning],
      previousFeatures.tuning || "unknown"
    );
    const capturedAt = pickString(
      [source.captured_at, source.capturedAt, source.timestamp, audio.captured_at],
      previousFeatures.captured_at || ""
    );
    const dspBlocks = Array.isArray(source.dsp_blocks)
      ? source.dsp_blocks
      : Array.isArray(visual.dsp_blocks)
        ? visual.dsp_blocks
        : (Array.isArray(previousFeatures.dsp_blocks) ? previousFeatures.dsp_blocks : []);

    return Object.assign({}, previousFeatures, source, {
      source: pickString([source.source], previousFeatures.source || "live-features"),
      captured_at: capturedAt,
      rms: rms,
      amplitude: rms,
      pitch_hz: pitch,
      centroid_hz: centroid,
      spectral_centroid_hz: centroid,
      onset_rate_hz: onsetRate,
      brightness: brightness,
      motion: motion,
      texture: texture,
      density: density,
      salience: salience,
      scene: scene,
      arc_phase: arcPhase,
      tuning: tuning,
      dsp_blocks: dspBlocks,
      artistic_identity: pickString([source.artistic_identity, visual.artistic_identity], previousFeatures.artistic_identity || ""),
      event_count: previousEventCount + 1,
      received_at_ms: Date.now()
    });
  }

  function resizeVisualizerCanvas(canvas, context) {
    const rect = canvas.getBoundingClientRect ? canvas.getBoundingClientRect() : { width: canvas.width, height: canvas.height };
    const ratio = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
    const displayWidth = Math.max(1, Math.round(rect.width || canvas.width));
    const displayHeight = Math.max(1, Math.round(rect.height || canvas.height));
    const backingWidth = Math.round(displayWidth * ratio);
    const backingHeight = Math.round(displayHeight * ratio);
    if (canvas.width !== backingWidth || canvas.height !== backingHeight) {
      canvas.width = backingWidth;
      canvas.height = backingHeight;
    }
    context.setTransform(1, 0, 0, 1, 0, 0);
    return { width: displayWidth, height: displayHeight, ratio };
  }

  function drawVisualizerFrame(timestamp) {
    const state = window.cypherclawVisualizerState;
    if (!state || !state.canvas || !state.context) return;

    const canvas = state.canvas;
    const context = state.context;
    const dims = resizeVisualizerCanvas(canvas, context);
    const features = state.latestFeatures || {};
    const rms = clampNumber(pickNumber(features, ["rms", "amplitude"], 0.07), 0, 1, 0.07);
    const pitch = clampNumber(pickNumber(features, ["pitch_hz", "pitchHz"], 196), 55, 1760, 196);
    const centroid = clampNumber(pickNumber(features, ["centroid_hz", "spectral_centroid_hz"], 900), 120, 6000, 900);
    const brightness = clampNumber(pickNumber(features, ["brightness"], centroid / 6000), 0, 1, 0.2);
    const motion = clampNumber(pickNumber(features, ["motion"], 0.08), 0, 1, 0.08);
    const texture = clampNumber(pickNumber(features, ["texture"], 0.35), 0, 1, 0.35);
    const density = clampNumber(pickNumber(features, ["density"], 0.18), 0, 1, 0.18);
    const salience = clampNumber(pickNumber(features, ["salience"], rms), 0, 1, rms);
    const onsetRate = clampNumber(pickNumber(features, ["onset_rate_hz", "onset_rate"], 0), 0, 24, 0);
    const pulse = 0.55 + Math.sin(timestamp / (620 - motion * 220)) * 0.45;
    const pitchY = dims.height - ((pitch - 55) / (1760 - 55)) * dims.height;
    const sweepX = (timestamp / Math.max(14, 34 - motion * 16 - onsetRate * 0.35)) % Math.max(1, dims.width);
    const radius = 28 + rms * 170 + salience * 34;
    const hue = 28 + Math.min(180, centroid / 34) + brightness * 26;

    context.fillStyle = "rgba(12, 15, 15, 0.82)";
    context.fillRect(0, 0, canvas.width, canvas.height);
    context.setTransform(dims.ratio, 0, 0, dims.ratio, 0, 0);

    const gradient = context.createRadialGradient(sweepX, pitchY, 4, sweepX, pitchY, Math.max(radius * 2.1, 120));
    gradient.addColorStop(0, "hsla(" + hue + ", 68%, 68%, " + (0.34 + rms * 0.36) + ")");
    gradient.addColorStop(0.42, "hsla(168, 42%, 60%, " + (0.14 + rms * 0.22) + ")");
    gradient.addColorStop(1, "rgba(17, 18, 18, 0)");
    context.fillStyle = gradient;
    context.beginPath();
    context.arc(sweepX, pitchY, Math.max(radius * (0.82 + pulse * 0.18), 18), 0, Math.PI * 2);
    context.fill();

    context.strokeStyle = "rgba(242, 238, 229, 0.12)";
    context.lineWidth = 1;
    const guideCount = 5 + Math.round(density * 7);
    for (let i = 1; i < guideCount; i += 1) {
      const y = (dims.height / guideCount) * i;
      context.beginPath();
      context.moveTo(0, y + Math.cos(timestamp / 1400 + i) * texture * 10);
      context.lineTo(dims.width, y + Math.sin(timestamp / 1100 + i) * (12 + motion * 20));
      context.stroke();
    }

    context.strokeStyle = "rgba(208, 154, 84, " + (0.24 + rms * 0.44) + ")";
    context.lineWidth = 2 + rms * 5;
    context.beginPath();
    context.moveTo(0, pitchY);
    for (let x = 0; x <= dims.width; x += 48) {
      context.lineTo(x, pitchY + Math.sin((timestamp / 420) + x / 80) * (10 + rms * 35));
    }
    context.stroke();

    context.fillStyle = "rgba(242, 238, 229, 0.62)";
    context.beginPath();
    context.arc(Math.max(12, Math.min(dims.width - 12, sweepX)), Math.max(12, Math.min(dims.height - 12, pitchY)), 4 + rms * 14, 0, Math.PI * 2);
    context.fill();
    state.renderedFrames = (state.renderedFrames || 0) + 1;
    canvas.setAttribute("data-render-count", String(state.renderedFrames));
    canvas.setAttribute("data-last-scene", String(features.scene || ""));
    canvas.setAttribute("data-last-tuning", String(features.tuning || ""));
    canvas.setAttribute("data-visualizer-state", "drawing");
    state.frameRequest = requestAnimationFrame(drawVisualizerFrame);
  }

  function handleFeatureMessage(event) {
    const state = window.cypherclawVisualizerState;
    if (!state || !state.canvas) return;

    try {
      const payload = JSON.parse(event.data);
      state.latestFeatures = normalizeCypherClawFeaturePayload(payload, state.latestFeatures);
      window.cypherclawLiveFeatures = state.latestFeatures;
      state.canvas.setAttribute("data-feed-state", "live");
      state.canvas.setAttribute("data-visualizer-state", "live");
      state.canvas.setAttribute("data-feed-events", String(state.latestFeatures.event_count || 0));
      state.canvas.setAttribute("data-last-scene", String(state.latestFeatures.scene || ""));
      state.canvas.setAttribute("data-last-tuning", String(state.latestFeatures.tuning || ""));
    } catch (_err) {
      state.canvas.setAttribute("data-feed-state", "bad-message");
    }
  }

  function connectCypherClawFeatureFeed(canvas) {
    const featuresUrl = canvas.getAttribute("data-live-features-url") || "/api/cypherclaw/live-features";
    if (!("EventSource" in window)) {
      canvas.setAttribute("data-feed-state", "unsupported");
      return;
    }

    if (window.cypherclawLiveFeatureSource && typeof window.cypherclawLiveFeatureSource.close === "function") {
      const source = window.cypherclawLiveFeatureSource;
      source.close();
    }

    const source = new EventSource(featuresUrl);
    source.addEventListener("message", handleFeatureMessage);
    source.addEventListener("features", handleFeatureMessage);
    source.addEventListener("open", function () {
      canvas.setAttribute("data-feed-state", "connected");
    });
    source.addEventListener("error", function () {
      canvas.setAttribute("data-feed-state", "feed-error");
    });
    window.cypherclawLiveFeatureSource = source;
    canvas.setAttribute("data-feed-state", "connecting");
  }

  function initCypherClawVisualizer() {
    const canvas = document.getElementById("cypherclaw-visualizer");
