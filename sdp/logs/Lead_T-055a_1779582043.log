+    }
+
+    const command = status & 240;
+    let type = null;
+    if (command === 144 && velocity > 0) {
+      type = "note_on";
+    } else if (command === 128 || (command === 144 && velocity === 0)) {
+      type = "note_off";
+    }
+    if (type === null) {
+      return null;
+    }
+
+    return {
+      type: type,
+      status: status,
+      note: note,
+      velocity: velocity,
+      channel: (status & 15) + 1,
+      ts: ts,
+      received_at_ms: Date.now()
