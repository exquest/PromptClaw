PUBLIC_SITE_ORIGIN = "https://holdenu.com"

[env.dev]
[[env.dev.durable_objects.bindings]]
name = "LIVE_MIDI_ROOM"
class_name = "LiveMidiRoom"

[[env.dev.migrations]]
tag = "v1"
new_sqlite_classes = ["LiveMidiRoom"]

[env.dev.vars]
