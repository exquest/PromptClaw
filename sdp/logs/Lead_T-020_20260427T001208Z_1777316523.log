+def _generated_content_ratio(score: Mapping[str, object]) -> float | None:
+    counts = _generated_content_counts(score)
+    if counts is None:
+        return None
+    generated, total = counts
+    if total <= 0.0:
+        return None
+    return generated / total
+
+
+def _generated_content_counts(
