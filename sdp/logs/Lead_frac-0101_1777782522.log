+            if harmonic_shift["tension"] >= 0.75:
+                band = "high"
+            elif harmonic_shift["tension"] >= 0.35:
+                band = "mid"
+            else:
+                band = "low"
+            summaries.append((expression, band, harmonic_shift["suggest_extensions"]))
+
+        assert summaries == [
+            (16, "low", False),
+            (64, "mid", False),
+            (112, "high", True),
