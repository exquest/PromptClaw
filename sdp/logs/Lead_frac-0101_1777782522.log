def _is_trivial_return(body: list[ast.stmt]) -> bool:
    """Check if a function body is just a trivial return."""
    if len(body) == 1 and isinstance(body[0], ast.Return):
        ret = body[0].value
        if ret is None:
            return True
        if isinstance(ret, ast.Constant):
            return True
        if isinstance(ret, ast.List | ast.Dict | ast.Tuple):
            return True
    return False


