}

_STATE_TIME_KEYS = ("last_activity", "last_update", "timestamp", "updated")
_KEYBOARD_MAX_AGE_S = 15.0
_GARDEN_MAX_AGE_S = 180.0
_INNER_MAX_AGE_S = 180.0
