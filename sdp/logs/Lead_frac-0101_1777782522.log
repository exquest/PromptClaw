@dataclass(frozen=True)
class HarmonicPlan:
    """The resolved harmonic center and its scene-level modulation path."""

    key: str
    root: str
    mode: str
    source: str
    chord_palette: str
    voicing_profile: str
    modulation_intent: str
    scene_keys: dict[str, str]
    section_functions: dict[str, str]
    section_cadences: dict[str, str]
