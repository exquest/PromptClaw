# ---------------------------------------------------------------------------
# Helper: build a telemetry-like row dict
# ---------------------------------------------------------------------------


def _telem_row(
    *,
    agent: str = "claude",
    tier: str = "T2",
    input_tokens: int = 1000,
    output_tokens: int = 500,
    duration_seconds: float = 120.0,
    outcome: str = "pass",
    lead_model_profile: str = '{"model": "claude-sonnet-4"}',
    created_at: str = "2026-03-01T12:00:00Z",
    task_id: str = "R-1",
) -> dict[str, object]:
    return {
        "agent": agent,
        "tier": tier,
        "input_tokens": input_tokens,
        "output_tokens": output_tokens,
        "duration_seconds": duration_seconds,
        "outcome": outcome,
        "lead_model_profile": lead_model_profile,
        "created_at": created_at,
        "task_id": task_id,
    }


