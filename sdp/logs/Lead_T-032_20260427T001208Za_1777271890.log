nits but does not define that unit locally, so this task assumes it is a host-managed prerequisite and wires the dependency without inventing a second JACK service. No new dependencies or migrations are required. The auto-generated `bootstrap_identity()` hardening items are already covered elsewhere in the current tree; because this task touches boot/service startup, the existing startup identity tests will be re-run as verification anchors rather than reworking unrelated startup code.\\\\\\\\\\\\\\\\n./src/cypherclaw/__init__.py:    bootstrap_identity,\\\\\\\\\\\\\\\\n./src/cypherclaw/__init__.py:    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bootstrap_identity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\nBinary file ./src/cypherclaw/__pycache__/first_boot.cpython-311.pyc matches\\\\\\\\\\\\\\\\nBinary file ./src/cypherclaw/__pycache__/__init__.cpython-311.pyc matches\\\\\\\\\\\\\\\\n./src/cypherclaw/first_boot.py:def bootstrap_identity(\\\\\\\\\\\\\\\\ncommit 709dcc90329a6fc4610714801989a6c60a81d7b1 (HEAD -> feat/graceful-degradation)\\\\\\\\\\\\\\\\nAuthor: Anthony Ainsworth <anthony@cascadiantech.com>\\\\\\\\\\\\\\\\nDate:   Sat Apr 25 17:52:28 2026 -0700\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    feat(sampler-dispatch): sample-aware harmonic transposition to current key [T-019@20260425T183959Z]\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    Adds `transpose_to_key(record, key_name) -> int` which maps a sample's\\\\\\\\\\\\\\\\n    detected `pitch_hz` to the nearest in-key pitch class via the artist's\\\\\\\\\\\\\\\\n    B-rooted key vocabulary (parsed through harmonic_planner). Low-confidence\\\\\\\\\\\\\\\\n    records (`pitch_confidence < 0.4`) pass through with 0 semitones so the\\\\\\\\\\\\\\\\n    sample plays as atonal texture.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndiff --git a/my-claw/tools/senseweave/sampler_dispatch.py b/my-claw/tools/senseweave/sampler_dispatch.py\\\\\\\\\\\\\\\\nindex 3446e34..05c27d4 100644\\\\\\\\\\\\\\\\n--- a/my-claw/tools/senseweave/sampler_dispatch.py\\\\\\\\\\\\\\\\n+++ b/my-claw/tools/senseweave/sampler_dispatch.py\\\\\\\\\\\\\\\\n@@ -20,12 +20,16 @@ evening_reflection); T-020 / CCS-026 fills in the remaining ArtistModes.\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n from __future__ import annotations\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+import math\\\\\\\\\\\\\\\\n import threading\\\\\\\\\\\\\\\\n from dataclasses import dataclass, field\\\\\\\\\\\\\\\\n from typing import Any, Callable, Protocol\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+from .harmonic_planner import _ROOT_TO_INDEX, key_root, scale_semitones_for_key\\\\\\\\\\\\\\\\n from .sampler_buffers import BufferLoader\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+_PITCH_CONFIDENCE_FLOOR = 0.4\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n class _OSCSender(Protocol):\\\\\\\\\\\\\\\\n     def send_message(self, address: str, args: list) -> None: ...\\\\\\\\\\\\\\\\n@@ -100,6 +104,34 @@ def _amp_with_gain_db(amp: float, gain_db: float) -> float:\\\\\\\\\\\\\\\\n     return amp * (10.0 ** (gain_db / 20.0))\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+def transpose_to_key(record: Any, key_name: str) -> int:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Integer semitone shift mapping `record.pitch_hz` to the nearest in-key pitch.\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    `key_name` is parsed via `harmonic_planner` (B-rooted modes such as\\\\\\\\\\\\\\\\n+    `Bm`, `B:dorian`, `B:phrygian` are the artist's home palette). When\\\\\\\\\\\\\\\\n+    `record.pitch_confidence < 0.4` the sample is treated as atonal\\\\\\\\\\\\\\\\n+    texture and 0 is returned. Returns the smallest absolute semitone\\\\\\\\\\\\\\\\n+    offset, choosing the shorter direction across the octave wrap.\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    confidence = float(getattr(record, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pitch_confidence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 0.0) or 0.0)\\\\\\\\\\\\\\\\n+    if confidence < _PITCH_CONFIDENCE_FLOOR:\\\\\\\\\\\\\\\\n+        return 0\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    pitch_hz = float(getattr(record, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pitch_hz\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 0.0) or 0.0)\\\\\\\\\\\\\\\\n+    if pitch_hz <= 0.0:\\\\\\\\\\\\\\\\n+        return 0\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    pitch_class = round(69 + 12 * math.log2(pitch_hz / 440.0)) % 12\\\\\\\\\\\\\\\\n+    root_idx = _ROOT_TO_INDEX.get(key_root(key_name), _ROOT_TO_INDEX[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"B\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"])\\\\\\\\\\\\\\\\n+    in_key_pcs = {(root_idx + s) % 12 for s in scale_semitones_for_key(key_name)}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    for distance in range(7):\\\\\\\\\\\\\\\\n+        for offset in (-distance, distance) if distance else (0,):\\\\\\\\\\\\\\\\n+            if (pitch_class + offset) % 12 in in_key_pcs:\\\\\\\\\\\\\\\\n+                return offset\\\\\\\\\\\\\\\\n+    return 0\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n class SamplerDispatcher:\\\\\\\\\\\\\\\\n     \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Allocates node ids and ships sampler events to scsynth via OSC.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\ndiff --git a/tests/test_sampler_dispatch.py b/tests/test_sampler_dispatch.py\\\\\\\\\\\\\\\\nindex fb58db4..264193b 100644\\\\\\\\\\\\\\\\n--- a/tests/test_sampler_dispatch.py\\\\\\\\\\\\\\\\n+++ b/tests/test_sampler_dispatch.py\\\\\\\\\\\\\\\\n@@ -15,6 +15,7 @@ from senseweave.sampler_dispatch import (\\\\\\\\\\\\\\\\n     FX_PRESETS_BY_MODE,\\\\\\\\\\\\\\\\n     SamplerDispatcher,\\\\\\\\\\\\\\\\n     SamplerHandle,\\\\\\\\\\\\\\\\n+    transpose_to_key,\\\\\\\\\\\\\\\\n )\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n@@ -321,3 +322,51 @@ def test_play_sampler_forwards_fx_preset(tmp_path: Path) -> None:\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n     addresses = [call[0] for call in osc.calls]\\\\\\\\\\\\\\\\n     assert addresses == [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/b_alloc\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/b_allocRead\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/n_set\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/s_new\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+class _PitchedRecord:\\\\\\\\\\\\\\\\n+    def __init__(self, pitch_hz: float, pitch_confidence: float = 0.9) -> None:\\\\\\\\\\\\\\\\n+        self.pitch_hz = pitch_hz\\\\\\\\\\\\\\\\n+        self.pitch_confidence = pitch_confidence\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_transpose_to_key_in_key_pitch_returns_zero() -> None:\\\\\\\\\\\\\\\\n+    # B aeolian = B C# D E F# G A; A4 (440 Hz) is in scale.\\\\\\\\\\\\\\\\n+    assert transpose_to_key(_PitchedRecord(440.0), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Bm\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") == 0\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_transpose_to_key_picks_nearest_in_key_pitch() -> None:\\\\\\\\\\\\\\\\n+    # B aeolian pitch classes: {11, 1, 2, 4, 6, 7, 9}. C5 (~523.25) is pc 0;\\\\\\\\\\\\\\\\n+    # nearest in-key is B (pc 11), one semitone down.\\\\\\\\\\\\\\\\n+    assert transpose_to_key(_PitchedRecord(523.25), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Bm\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") == -1\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_transpose_to_key_octave_wrap_prefers_short_path() -> None:\\\\\\\\\\\\\\\\n+    # C5 in B major scale {11, 1, 3, 4, 6, 8, 10}: B is one semitone down (-1)\\\\\\\\\\\\\\\\n+    # via wrap, not 11 semitones up. Verifies wrap handling.\\\\\\\\\\\\\\\\n+    assert transpose_to_key(_PitchedRecord(523.25), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"B\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") == -1\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_transpose_to_key_low_confidence_returns_zero() -> None:\\\\\\\\\\\\\\\\n+    # Out-of-key pitch but low confidence — atonal texture, no transposition.\\\\\\\\\\\\\\\\n+    assert transpose_to_key(_PitchedRecord(523.25, pitch_confidence=0.39), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Bm\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") == 0\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_transpose_to_key_confidence_at_threshold_transposes() -> None:\\\\\\\\\\\\\\\\n+    # Confidence exactly 0.4 still transposes (>= floor).\\\\\\\\\\\\\\\\n+    assert transpose_to_key(_PitchedRecord(523.25, pitch_confidence=0.4), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Bm\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") == -1\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_transpose_to_key_zero_pitch_returns_zero() -> None:\\\\\\\\\\\\\\\\n+    assert transpose_to_key(_PitchedRecord(0.0, pitch_confidence=1.0), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Bm\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") == 0\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_transpose_to_key_c_major_known_combination() -> None:\\\\\\\\\\\\\\\\n+    # C# (~277.18) → C major scale {0,2,4,5,7,9,11}: nearest is C (-1) or D (+1);\\\\\\\\\\\\\\\\n+    # algorithm prefers the negative direction on ties.\\\\\\\\\\\\\\\\n+    assert transpose_to_key(_PitchedRecord(277.18), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") == -1\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def test_transpose_to_key_handles_higher_octave() -> None:\\\\\\\\\\\\\\\\n+    # A6 (1760 Hz) in B aeolian — A is in scale, no transposition.\\\\\\\\\\\\\\\\n+    assert transpose_to_key(_PitchedRecord(1760.0), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Bm\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") == 0\\\\\\\\\\\\\\\"}\\\\\\\\n++{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"message\