        "duration_sec": 30.0,
    }
    result = client._submit_prediction(request)

    assert getattr(result, "id", None) == "pred-123"
    assert predictions.calls == [
        {
            "model": "meta/musicgen",
            "input": {"prompt": "ambient pad", "duration_sec": 30.0},
        }
    ]
    assert fake.client_tokens == ["test"]


