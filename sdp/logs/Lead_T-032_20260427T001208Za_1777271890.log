"""Usage and cost summary for ``sdp-cli stats analyze`` (T-026@20260301T202210Z).

Pure functions that aggregate token usage from telemetry rows and compute
estimated costs using a static per-model pricing table.  No DB access.
"""

from __future__ import annotations

import json
from collections.abc import Mapping
from dataclasses import dataclass, field

TelemetryRow = Mapping[str, object]


# ---------------------------------------------------------------------------
# Pricing model
# ---------------------------------------------------------------------------


@dataclass(frozen=True)
class ModelTokenPricing:
    """Per-model token pricing in USD per million tokens."""

    input_price_per_m: float
    output_price_per_m: float


_FALLBACK_PRICING = ModelTokenPricing(input_price_per_m=3.0, output_price_per_m=15.0)

# Ordered list of (substring, pricing) — first match wins.
_PRICING_TABLE: list[tuple[str, ModelTokenPricing]] = [
    ("claude-opus-4", ModelTokenPricing(15.0, 75.0)),
    ("claude-sonnet-4", ModelTokenPricing(3.0, 15.0)),
    ("claude-haiku", ModelTokenPricing(0.80, 4.0)),
    ("gpt-4o", ModelTokenPricing(2.5, 10.0)),
    ("o3", ModelTokenPricing(10.0, 40.0)),
    ("codex-mini", ModelTokenPricing(1.50, 6.0)),
]


def resolve_model_pricing(model_profile: str) -> ModelTokenPricing:
    """Match *model_profile* against known pricing patterns.

    Matching is case-insensitive and uses substring containment.
    Returns :data:`_FALLBACK_PRICING` when no pattern matches.
    """
    lowered = model_profile.lower()
    for pattern, pricing in _PRICING_TABLE:
        if pattern in lowered:
            return pricing
    return _FALLBACK_PRICING


def uses_fallback_pricing(model_profile: str) -> bool:
    """Return ``True`` when *model_profile* does not match any known pricing."""
    lowered = model_profile.lower()
    return not any(pattern in lowered for pattern, _ in _PRICING_TABLE)


# ---------------------------------------------------------------------------
# Summary data models
# ---------------------------------------------------------------------------


@dataclass(frozen=True)
class ProviderModelUsage:
    """Aggregated token usage and cost for one provider/model group."""

    provider: str
    model: str
    total_input_tokens: int
    total_output_tokens: int
    total_tokens: int
    estimated_cost_usd: float
    task_count: int


@dataclass(frozen=True)
class TierTokenAverage:
    """Average tokens per task for one tier."""

    tier: str
    task_count: int
    avg_input_tokens: float
    avg_output_tokens: float
    avg_total_tokens: float


@dataclass(frozen=True)
class UsageCostSummary:
    """Complete usage and cost summary for stats analyze."""

    by_provider_model: list[ProviderModelUsage]
    by_tier: list[TierTokenAverage]
    grand_total_input_tokens: int
    grand_total_output_tokens: int
    grand_total_tokens: int
    grand_total_cost_usd: float
    fallback_pricing_models: list[str] = field(default_factory=list)


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def _safe_int(value: object) -> int:
    """Coerce *value* to int, returning 0 on failure."""
    if isinstance(value, int):
        return value
    try:
        return int(str(value))
    except (TypeError, ValueError):
        return 0


def _extract_model_from_profile(profile_str: str) -> str:
    """Extract model identifier from a JSON profile string.

    Supports two profile shapes:

    1. Real ``ModelProfile.to_json()`` payloads with ``model_family`` /
       ``model_version`` (and optionally ``provider``).
    2. Legacy / test payloads with a flat ``model`` (or ``model_id`` /
       ``model_name``) key.
    """
    if not profile_str or profile_str == "{}":
        return ""
    try:
        data = json.loads(profile_str)
        if isinstance(data, dict):
            # Prefer structured model_family / model_version fields
            family = str(data.get("model_family", "")).strip()
            version = str(data.get("model_version", "")).strip()
            if family and version:
                return f"{family}-{version}"
            if family:
                return family

            # Fall back to flat key conventions
            for key in ("model", "model_id", "model_name"):
                val = data.get(key)
                if val and isinstance(val, str):
                    return str(val)
    except (json.JSONDecodeError, TypeError):
        pass
    return ""


def _provider_from_agent(agent: str) -> str:
    """Map agent field to provider name."""
    return str(agent).strip().lower() if agent else "unknown"


def _model_from_row(row: TelemetryRow) -> str:
    """Extract model identifier from a telemetry row."""
    profile = str(row.get("lead_model_profile", "{}"))
    model = _extract_model_from_profile(profile)
    if model:
        return model
    # Fall back to agent name
    return _provider_from_agent(str(row.get("agent", "")))


# ---------------------------------------------------------------------------
# Core aggregation
# ---------------------------------------------------------------------------


def compute_usage_cost_summary(
    rows: list[TelemetryRow],
) -> UsageCostSummary:
    """Aggregate token usage and cost from telemetry rows.

    Groups by provider (derived from ``agent``) and model (derived from
    ``lead_model_profile``).  Computes per-tier averages and grand totals.
    """
    if not rows:
        return UsageCostSummary(
            by_provider_model=[],
            by_tier=[],
            grand_total_input_tokens=0,
            grand_total_output_tokens=0,
            grand_total_tokens=0,
            grand_total_cost_usd=0.0,
        )

    # --- Aggregate by provider/model ---
    pm_input: dict[tuple[str, str], int] = {}
    pm_output: dict[tuple[str, str], int] = {}
    pm_count: dict[tuple[str, str], int] = {}

    # --- Aggregate by tier ---
    tier_input: dict[str, int] = {}
    tier_output: dict[str, int] = {}
    tier_count: dict[str, int] = {}

    for row in rows:
        provider = _provider_from_agent(str(row.get("agent", "")))
        model = _model_from_row(row)
        tier = str(row.get("tier", "UNKNOWN")).strip()
        inp = _safe_int(row.get("input_tokens", 0))
        out = _safe_int(row.get("output_tokens", 0))

        key = (provider, model)
        pm_input[key] = pm_input.get(key, 0) + inp
        pm_output[key] = pm_output.get(key, 0) + out
        pm_count[key] = pm_count.get(key, 0) + 1

        tier_input[tier] = tier_input.get(tier, 0) + inp
        tier_output[tier] = tier_output.get(tier, 0) + out
        tier_count[tier] = tier_count.get(tier, 0) + 1

    # --- Build provider/model usage entries ---
    grand_input = 0
    grand_output = 0
    grand_cost = 0.0
    pm_entries: list[ProviderModelUsage] = []
    fallback_models: list[str] = []

    for (provider, model) in sorted(pm_input.keys()):
        total_in = pm_input[(provider, model)]
        total_out = pm_output[(provider, model)]
        total_tok = total_in + total_out
        pricing = resolve_model_pricing(model)
        if model and uses_fallback_pricing(model):
            fallback_models.append(model)
        cost = (total_in / 1_000_000.0) * pricing.input_price_per_m + (
            total_out / 1_000_000.0
        ) * pricing.output_price_per_m

        pm_entries.append(
            ProviderModelUsage(
                provider=provider,
                model=model,
                total_input_tokens=total_in,
                total_output_tokens=total_out,
                total_tokens=total_tok,
                estimated_cost_usd=round(cost, 4),
                task_count=pm_count[(provider, model)],
            )
        )
        grand_input += total_in
        grand_output += total_out
        grand_cost += cost

    # --- Build tier average entries ---
    tier_entries: list[TierTokenAverage] = []
    for tier in sorted(tier_count.keys()):
        count = tier_count[tier]
        tier_entries.append(
            TierTokenAverage(
                tier=tier,
                task_count=count,
                avg_input_tokens=round(tier_input[tier] / count, 1),
                avg_output_tokens=round(tier_output[tier] / count, 1),
                avg_total_tokens=round(
                    (tier_input[tier] + tier_output[tier]) / count, 1,
                ),
            )
        )

    return UsageCostSummary(
        by_provider_model=pm_entries,
        by_tier=tier_entries,
        grand_total_input_tokens=grand_input,
        grand_total_output_tokens=grand_output,
        grand_total_tokens=grand_input + grand_output,
        grand_total_cost_usd=round(grand_cost, 4),
        fallback_pricing_models=fallback_models,
    )


__all__ = [
    "ModelTokenPricing",
    "ProviderModelUsage",
    "TierTokenAverage",
    "UsageCostSummary",
    "compute_usage_cost_summary",
    "resolve_model_pricing",
    "uses_fallback_pricing",
]

