        assert t1.avg_input_tokens == 2_000.0
        assert t1.avg_output_tokens == 1_000.0
        assert t1.avg_total_tokens == 3_000.0

        t2 = tier_map["T2"]
        assert t2.task_count == 1
        assert t2.avg_input_tokens == 10_000.0
        assert t2.avg_output_tokens == 5_000.0
        assert t2.avg_total_tokens == 15_000.0

    def test_zero_tokens(self) -> None:
        """AC-8: All zero-token rows still produce valid summary with zeros."""
        from sdp.pipeline.cost_summary import compute_usage_cost_summary

        rows = [
