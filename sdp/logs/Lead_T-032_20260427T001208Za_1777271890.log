from __future__ import annotations

from sdp.pipeline.admission import check_quota_admission
from sdp.state.db import insert_agent_usage_snapshot, store_quota_snapshot
from sdp.state.models import QuotaSnapshot


def _snapshot(provider: str, used_pct: float, confidence: str = "observed") -> QuotaSnapshot:
    return QuotaSnapshot(
        provider=provider,
        window_name="primary",
        metric_kind="percent",
        used_pct=used_pct,
        remaining=100.0 - used_pct,
        limit_total=100.0,
        reset_at="2026-03-10T00:00:00Z",
        confidence=confidence,
        source="test",
        collected_at="2026-03-09T00:00:00Z",
    )


def test_admits_when_quota_available(tmp_db: str) -> None:
    store_quota_snapshot(tmp_db, _snapshot("openai", 50.0))

    result = check_quota_admission(tmp_db)
    assert result.admitted is True
    assert result.reason == "quota available"


def test_denies_when_all_exhausted(tmp_db: str) -> None:
    for provider in ("anthropic", "openai", "google"):
        store_quota_snapshot(tmp_db, _snapshot(provider, 95.0))

    result = check_quota_admission(tmp_db)
    assert result.admitted is False
    assert ">=95% used" in result.reason


def test_admits_when_only_estimated_data(tmp_db: str) -> None:
    store_quota_snapshot(tmp_db, _snapshot("google", 99.0, confidence="estimated"))

    result = check_quota_admission(tmp_db)
    assert result.admitted is True
    assert result.reason == "no quota data available"


def test_admits_when_no_data(tmp_db: str) -> None:
    result = check_quota_admission(tmp_db)
    assert result.admitted is True
    assert result.reason == "no quota data available"


def test_force_overrides_denial(tmp_db: str) -> None:
    for provider in ("anthropic", "openai", "google"):
        store_quota_snapshot(tmp_db, _snapshot(provider, 99.0))

    result = check_quota_admission(tmp_db, force=True)
    assert result.admitted is True
    assert "--force" in result.reason


def test_admission_uses_derived_openai_live_windows(tmp_db: str) -> None:
    insert_agent_usage_snapshot(
        tmp_db,
        provider="openai",
        model_key="openai/gpt-5.4",
        window_type="minute",
        dimension="tokens",
        used=98_000,
        remaining=2_000,
        limit_total=100_000,
        reset_at="2026-03-10T00:01:00Z",
        collected_at="2026-03-10T00:00:00Z",
        source="response:tokens",
        confidence="authoritative",
    )

    result = check_quota_admission(tmp_db)

    assert result.admitted is False
    assert ">=95% used" in result.reason

