 succeeded in 0ms:
"""Predicted token cost per task using historical telemetry (T-002@20260301T202210Z).

Computes p50 and p90 estimates for input and output token consumption,
segmented by task tier (T1/T2/T3), task type, and model profile.  Falls
back to global median when the matched segment has fewer than
``min_samples`` records.
"""

from __future__ import annotations

import math
from collections.abc import Sequence
from dataclasses import dataclass

_DEFAULT_MIN_SAMPLES = 5


@dataclass(frozen=True)
class TokenSample:
    """A single historical token-usage observation."""

    input_tokens: float
    output_tokens: float
    tier: str
    task_type: str
    model_profile: str


@dataclass(frozen=True)
class TokenCostPrediction:
    """Predicted token cost at p50 and p90 for input and output tokens."""

    input_p50: float
    input_p90: float
    output_p50: float
    output_p90: float
    sample_count: int
    confidence: str  # "segment" | "global_fallback" | "no_data"


def _is_valid_token_value(value: float) -> bool:
    """Return True when *value* is a finite, non-negative number."""
    return math.isfinite(value) and value >= 0


def _is_valid_sample(sample: TokenSample) -> bool:
    """Return True when both token fields are valid."""
    return _is_valid_token_value(sample.input_tokens) and _is_valid_token_value(
        sample.output_tokens
    )


def compute_percentile(values: Sequence[float], percentile: float) -> float:
    """Compute a percentile using the nearest-rank method.

    Parameters
    ----------
    values:
        Sequence of numeric values (need not be sorted).
    percentile:
        Desired percentile in ``[0, 100]``.  Values outside this range
        are clamped.

    Returns
    -------
    float
        The percentile value, or ``0.0`` when *values* is empty.
    """
    if not values:
        return 0.0

    sorted_vals = sorted(values)
    clamped = max(0.0, min(100.0, float(percentile)))
    # Nearest-rank: rank = ceil(P/100 * N), 1-indexed
    rank = math.ceil(clamped / 100.0 * len(sorted_vals))
    # Clamp rank to valid index range (at least 1)
    rank = max(1, min(rank, len(sorted_vals)))
    return sorted_vals[rank - 1]


def predict_token_cost(
    *,
    tier: str,
    task_type: str,
    model_profile: str,
    samples: Sequence[TokenSample],
    min_samples: int = _DEFAULT_MIN_SAMPLES,
) -> TokenCostPrediction:
    """Predict input/output token cost at p50 and p90.

    Parameters
    ----------
    tier:
        Task tier (``"T1"``, ``"T2"``, ``"T3"``).
    task_type:
        Categorised task type key (e.g. ``"implementation"``).
    model_profile:
        Model profile identifier (e.g. ``"claude-sonnet-4"``).
    samples:
        Historical token-usage observations.
    min_samples:
        Minimum segment size before falling back to global median.

    Returns
    -------
    TokenCostPrediction
        Prediction result with p50/p90 estimates, sample count, and
        confidence level (``"segment"``, ``"global_fallback"``, or
        ``"no_data"``).
    """
    valid_samples = [s for s in samples if _is_valid_sample(s)]

    if not valid_samples:
        return TokenCostPrediction(
            input_p50=0.0,
            input_p90=0.0,
            output_p50=0.0,
            output_p90=0.0,
            sample_count=0,
            confidence="no_data",
        )

    # Segment by tier + task_type + model_profile
    segment = [
        s
        for s in valid_samples
        if s.tier == tier and s.task_type == task_type and s.model_profile == model_profile
    ]

    if len(segment) >= min_samples:
        input_vals = [s.input_tokens for s in segment]
        output_vals = [s.output_tokens for s in segment]
        return TokenCostPrediction(
            input_p50=compute_percentile(input_vals, 50),
            input_p90=compute_percentile(input_vals, 90),
            output_p50=compute_percentile(output_vals, 50),
            output_p90=compute_percentile(output_vals, 90),
            sample_count=len(segment),
            confidence="segment",
        )

    # Fallback to global
    input_vals = [s.input_tokens for s in valid_samples]
    output_vals = [s.output_tokens for s in valid_samples]
    return TokenCostPrediction(
        input_p50=compute_percentile(input_vals, 50),
        input_p90=compute_percentile(input_vals, 90),
        output_p50=compute_percentile(output_vals, 50),
        output_p90=compute_percentile(output_vals, 90),
        sample_count=len(valid_samples),
        confidence="global_fallback",
    )


__all__ = [
    "TokenCostPrediction",
    "TokenSample",
    "compute_percentile",
    "predict_token_cost",
]

