        # Find codex group
        codex_group = [g for g in summary.by_provider_model if g.provider == "codex"]
        assert len(codex_group) == 1
        assert codex_group[0].total_input_tokens == 8_000
        assert codex_group[0].total_output_tokens == 4_000
        assert codex_group[0].total_tokens == 12_000
