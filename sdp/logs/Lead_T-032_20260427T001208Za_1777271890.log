"""Safe simultaneous project count per provider/model (T-003@20260301T202210Z).

Computes ``floor((remaining_tokens - reserve) / projected_tokens_per_project)``
where project-level token projection uses the rolling p90 task cost multiplied
by average tasks per project run.  Reserve buffer is configurable (default 20%
of limit).
"""

from __future__ import annotations

import math
from collections.abc import Sequence
from dataclasses import dataclass

_DEFAULT_RESERVE_FRACTION = 0.20


@dataclass(frozen=True)
class UsageSnapshot:
    """Input snapshot of current usage state for a single provider/model."""

    provider: str
    model: str
    remaining_tokens: float
    token_limit: float


@dataclass(frozen=True)
class ProjectCostProjection:
    """Projected token cost for one project run."""

    task_p90_cost: float
    avg_tasks_per_project: float
    projected_tokens_per_project: float


@dataclass(frozen=True)
class CapacityResult:
    """Result of safe simultaneous project count computation."""

    provider: str
    model: str
    max_simultaneous_projects: int
    remaining_after_reserve: float
    projected_per_project: float
    reserve_tokens: float
    confidence: str  # "ok" | "no_projection" | "invalid_input"


def compute_project_cost(
    *,
    task_p90_cost: float,
    avg_tasks_per_project: float,
) -> ProjectCostProjection:
    """Build a project cost projection from p90 cost and average task count.

    Parameters
    ----------
    task_p90_cost:
        Rolling p90 token cost per task.
    avg_tasks_per_project:
        Average number of tasks per project run.

    Returns
    -------
    ProjectCostProjection
        Immutable projection with ``projected_tokens_per_project =
        task_p90_cost * avg_tasks_per_project``.
    """
    return ProjectCostProjection(
        task_p90_cost=task_p90_cost,
        avg_tasks_per_project=avg_tasks_per_project,
        projected_tokens_per_project=task_p90_cost * avg_tasks_per_project,
    )


def _is_finite(value: float) -> bool:
    """Return True when *value* is a finite number."""
    return math.isfinite(value)


def compute_project_capacity(
    *,
    usage: UsageSnapshot,
    task_p90_cost: float,
    avg_tasks_per_project: float,
    reserve_fraction: float = _DEFAULT_RESERVE_FRACTION,
) -> CapacityResult:
    """Compute safe simultaneous project count for a provider/model.

    Parameters
    ----------
    usage:
        Current usage snapshot (remaining tokens and token limit).
    task_p90_cost:
        Rolling p90 token cost per task.
    avg_tasks_per_project:
        Average number of tasks per project run.
    reserve_fraction:
        Fraction of ``token_limit`` to hold in reserve (default ``0.20``).
        Clamped to ``[0, 1]``.

    Returns
    -------
    CapacityResult
        Immutable result with ``max_simultaneous_projects``, reserve and
        projection details, and confidence level (``"ok"``,
        ``"no_projection"``, or ``"invalid_input"``).
    """
    norm_provider = usage.provider.strip().lower()
    norm_model = usage.model.strip().lower()

    # Validate all numeric inputs are finite
    if not all(
        _is_finite(v)
        for v in (
            usage.remaining_tokens,
            usage.token_limit,
            task_p90_cost,
            avg_tasks_per_project,
            reserve_fraction,
        )
    ):
        return CapacityResult(
            provider=norm_provider,
            model=norm_model,
            max_simultaneous_projects=0,
            remaining_after_reserve=0.0,
            projected_per_project=0.0,
            reserve_tokens=0.0,
            confidence="invalid_input",
        )

    # Clamp reserve_fraction to [0, 1]
    clamped_fraction = max(0.0, min(1.0, reserve_fraction))
    reserve_tokens = usage.token_limit * clamped_fraction
    remaining_after_reserve = usage.remaining_tokens - reserve_tokens

    # Compute projected tokens per project
    projected_per_project = task_p90_cost * avg_tasks_per_project

    # Handle zero or negative projection (division by zero guard)
    if projected_per_project <= 0:
        return CapacityResult(
            provider=norm_provider,
            model=norm_model,
            max_simultaneous_projects=0,
            remaining_after_reserve=remaining_after_reserve,
            projected_per_project=projected_per_project,
            reserve_tokens=reserve_tokens,
            confidence="no_projection",
        )

    # Handle zero or negative remaining after reserve
    if remaining_after_reserve <= 0:
        return CapacityResult(
            provider=norm_provider,
            model=norm_model,
            max_simultaneous_projects=0,
            remaining_after_reserve=remaining_after_reserve,
            projected_per_project=projected_per_project,
            reserve_tokens=reserve_tokens,
            confidence="ok",
        )

    # Core computation: floor(remaining_after_reserve / projected_per_project)
    max_projects = int(remaining_after_reserve // projected_per_project)

    return CapacityResult(
        provider=norm_provider,
        model=norm_model,
        max_simultaneous_projects=max_projects,
        remaining_after_reserve=remaining_after_reserve,
        projected_per_project=projected_per_project,
        reserve_tokens=reserve_tokens,
        confidence="ok",
    )


