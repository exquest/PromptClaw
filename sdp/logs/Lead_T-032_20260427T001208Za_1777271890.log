}


def _default_model_profiles() -> dict[str, ModelProfile]:
    """Return default model profiles from configuration.

    Maps each agent in ``DEFAULT_AGENT_POOL`` to a ``ModelProfile`` built from
    the corresponding profile dict in ``config.defaults``. Only the first two
    pool entries are mapped (to the Claude and Codex profile dicts).
    """
    profiles: dict[str, ModelProfile] = {}
    _profile_dicts: tuple[dict[str, str], ...] = (
        DEFAULT_CLAUDE_MODEL_PROFILE,
        DEFAULT_CODEX_MODEL_PROFILE,
    )
    for idx, agent in enumerate(DEFAULT_AGENT_POOL):
        if idx < len(_profile_dicts):
            profiles[agent] = ModelProfile(**_profile_dicts[idx])
    return profiles

