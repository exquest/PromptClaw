        assert summary.grand_total_output_tokens == 0
        assert summary.grand_total_tokens == 0
        assert summary.grand_total_cost_usd == 0.0

        # Still produces provider/model and tier entries
        assert len(summary.by_provider_model) >= 1
        assert len(summary.by_tier) >= 1

    def test_empty_rows(self) -> None:
        """Empty input produces empty summary."""
        from sdp.pipeline.cost_summary import compute_usage_cost_summary

        summary = compute_usage_cost_summary([])

        assert summary.by_provider_model == []
        assert summary.by_tier == []
        assert summary.grand_total_tokens == 0
        assert summary.grand_total_cost_usd == 0.0


