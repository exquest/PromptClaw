def _is_valid_strategy(strategy: str) -> bool:
    """Return True if strategy is a known static strategy or ``always:<provider>`` pattern."""
    lowered = strategy.lower()
    if lowered in _STATIC_STRATEGIES:
        return True
    if lowered in DEFAULT_STRATEGY_ALIASES:
        return True
    if lowered.startswith("always:"):
        provider = lowered.removeprefix("always:")
        return bool(provider)
    return False


def resolve_strategy(strategy: str) -> str:
    """Resolve legacy strategy aliases to canonical form.

    Maps ``always_claude`` → ``always:anthropic``, ``always_codex`` → ``always:openai``.
    Other strategy names (including ``always:<provider>``) pass through in lowercase.
    """
    lowered = strategy.strip().lower()
    return DEFAULT_STRATEGY_ALIASES.get(lowered, lowered)


def _model_profile_from_payload(value: object) -> ModelProfile | None:
    payload: object = value
    if isinstance(value, Mapping):
        payload = value.get("model_profile", value)

    if isinstance(payload, ModelProfile):
        profile = payload
    elif isinstance(payload, Mapping):
        profile = ModelProfile(
            provider=str(payload.get("provider", "")).strip().lower(),
            model_family=str(payload.get("model_family", "")).strip().lower(),
            model_version=str(payload.get("model_version", "")).strip(),
            effort_level=str(payload.get("effort_level", "")).strip().lower() or "standard",
            command_fingerprint=str(payload.get("command_fingerprint", "")).strip(),
        )
    elif isinstance(payload, str):
        raw = payload.strip()
        if not raw:
            return None
        try:
            decoded = json.loads(raw)
        except (json.JSONDecodeError, TypeError, ValueError):
            return None
        if not isinstance(decoded, Mapping):
            return None
        profile = ModelProfile(
            provider=str(decoded.get("provider", "")).strip().lower(),
            model_family=str(decoded.get("model_family", "")).strip().lower(),
            model_version=str(decoded.get("model_version", "")).strip(),
            effort_level=str(decoded.get("effort_level", "")).strip().lower() or "standard",
            command_fingerprint=str(decoded.get("command_fingerprint", "")).strip(),
        )
    else:
        return None

    if not profile.provider and not profile.model_family and not profile.model_version:
        return None
    return profile


def _resolved_active_model_profiles(
    active_profiles: Mapping[str, object] | None,
) -> dict[str, ModelProfile]:
    if active_profiles is None:
        return _default_model_profiles()

    resolved: dict[str, ModelProfile] = {}
    for agent_name, profile_data in active_profiles.items():
        profile = _model_profile_from_payload(profile_data)
        if profile is not None:
            resolved[str(agent_name)] = profile
    return resolved


def _agent_for_model_profile(
    model_profile: ModelProfile,
    active_profiles: Mapping[str, object] | None,
) -> str | None:
    target_provider = model_profile.provider.strip().lower()
    if not target_provider:
        return None
    for agent_name, profile in _resolved_active_model_profiles(active_profiles).items():
        if profile.provider.strip().lower() == target_provider:
            return agent_name
    return None


def _agent_for_provider(
    provider: str,
    active_profiles: Mapping[str, object] | None,
) -> str | None:
    """Resolve a provider name to an agent name using model-profile metadata."""
    return _agent_for_model_profile(
        ModelProfile(provider=provider.strip().lower()),
        active_profiles,
    )


_ROTATION_TIEBREAK_EPSILON = 1e-6


def _rotation_tiebreak(
    lead_provider: str,
    last_lead_provider: str | None,
    unique_providers: tuple[str, ...],
) -> float:
    """Compute a tiny tie-breaking bonus for round-robin provider rotation.

    When multiple providers have equal scores after penalty application,
    this gives a negligible epsilon bonus to the provider that comes next
    in the sorted rotation order after ``last_lead_provider``. This ensures
    deterministic round-robin across 3+ providers.

    Returns 0.0 when no last provider exists, the pool has fewer than 3
    providers, or the lead_provider is the penalized one.
    """
    if last_lead_provider is None or len(unique_providers) < 3:
        return 0.0
    if lead_provider == last_lead_provider:
        return 0.0

    sorted_providers = sorted(unique_providers)
    try:
        last_idx = sorted_providers.index(last_lead_provider)
    except ValueError:
        return 0.0

    next_provider = sorted_providers[(last_idx + 1) % len(sorted_providers)]
    if lead_provider == next_provider:
        return _ROTATION_TIEBREAK_EPSILON
    return 0.0


