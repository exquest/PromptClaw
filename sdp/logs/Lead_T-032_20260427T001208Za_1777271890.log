    """
    if not inputs:
        return CapacityPlan(
            providers=(),
            overall_max_projects=0,
            limiting_provider="",
            limiting_model="",
            has_data=False,
        )

    results: list[tuple[CapacityResult, UsageSnapshot]] = []
    for usage, p90_cost, avg_tasks, reserve_frac in inputs:
        cap = compute_project_capacity(
            usage=usage,
            task_p90_cost=p90_cost,
            avg_tasks_per_project=avg_tasks,
            reserve_fraction=reserve_frac,
        )
        results.append((cap, usage))

    # Find overall minimum max_projects
    overall_max = min(cap.max_simultaneous_projects for cap, _ in results)

    # Find limiting provider: lowest max_projects, then alphabetical on tie
    limiting_cap = min(
        results,
        key=lambda pair: (pair[0].max_simultaneous_projects, pair[0].provider),
    )[0]

    providers = tuple(
        ProviderCapacity(
            provider=cap.provider,
            model=cap.model,
            remaining_tokens=usage.remaining_tokens,
            token_limit=usage.token_limit,
            reserve_tokens=cap.reserve_tokens,
            projected_per_project=cap.projected_per_project,
            max_projects=cap.max_simultaneous_projects,
            confidence=cap.confidence,
            is_limiting=(cap.provider == limiting_cap.provider
                         and cap.model == limiting_cap.model),
        )
        for cap, usage in results
    )

    return CapacityPlan(
        providers=providers,
        overall_max_projects=overall_max,
        limiting_provider=limiting_cap.provider,
        limiting_model=limiting_cap.model,
        has_data=True,
    )


@dataclass(frozen=True)
class GlobalConcurrencyResult:
    """Aggregated safe concurrency across all providers and operator config."""

    safe_concurrency: int
    provider_capacities: dict[str, int]
    configured_worker_bound: int
    binding_constraint: str  # "provider:<name>" | "configured_worker_bound" | ""
    confidence: str  # "ok" | "no_capacity_data" | "degraded"


def compute_global_safe_concurrency(
    *,
    provider_capacities: Sequence[CapacityResult],
    configured_worker_bound: int,
) -> GlobalConcurrencyResult:
    """Compute safe concurrency as min(all provider maximums, configured_worker_bound).

    Parameters
    ----------
    provider_capacities:
        Per-provider capacity results from ``compute_project_capacity()``.
    configured_worker_bound:
        Operator-configured upper bound on concurrent worker projects.

    Returns
    -------
    GlobalConcurrencyResult
        Frozen result with the global safe concurrency integer, per-provider
        breakdown, binding constraint identification, and confidence level.
    """
    if not provider_capacities:
        return GlobalConcurrencyResult(
            safe_concurrency=0,
            provider_capacities={},
            configured_worker_bound=configured_worker_bound,
            binding_constraint="",
            confidence="no_capacity_data",
        )

    # Build per-provider max_projects, degrading unhealthy providers to 0
    degraded = False
    effective: dict[str, int] = {}
    for cap in provider_capacities:
        if cap.confidence in ("invalid_input", "no_projection"):
            effective[cap.provider] = 0
            degraded = True
        else:
            effective[cap.provider] = cap.max_simultaneous_projects

    # Clamp worker bound
    clamped_bound = max(0, configured_worker_bound)

    # Find min provider
    min_provider_name = min(effective, key=lambda p: effective[p])
    min_provider_val = effective[min_provider_name]

    # Compute global min across providers and worker bound
    if clamped_bound < min_provider_val:
        safe = clamped_bound
        binding = "configured_worker_bound"
    elif clamped_bound == min_provider_val:
        # Tie: provider wins (first by iteration)
        safe = min_provider_val
        binding = f"provider:{min_provider_name}"
    else:
        safe = min_provider_val
        binding = f"provider:{min_provider_name}"

    confidence = "degraded" if degraded else "ok"

    return GlobalConcurrencyResult(
        safe_concurrency=safe,
        provider_capacities=effective,
        configured_worker_bound=configured_worker_bound,
        binding_constraint=binding,
        confidence=confidence,
    )


