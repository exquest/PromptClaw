@dataclass(frozen=True)
class MultiProviderAdmissionResult:
    """Admission result across all enabled provider entities."""

    admitted: bool
    hard_blocked: bool
    gate_mode: str  # "hard" | "soft"
    reason: str
    confidence_floor: str
    provider_states: tuple[ProviderAdmissionState, ...]
    plans: tuple[AdmissionPlan, ...]


def check_admission(
    *,
    usage: UsageSnapshot,
    task_p90_cost: float,
    avg_tasks_per_project: float,
    reserve_fraction: float = 0.20,
    current_projects: int = 1,
) -> AdmissionResult:
    """Evaluate whether a pipeline run should be admitted.

    Parameters
    ----------
    usage:
        Current token usage snapshot for the provider/model.
    task_p90_cost:
        Rolling p90 token cost per task.
    avg_tasks_per_project:
        Average number of tasks per project run.
    reserve_fraction:
        Fraction of ``token_limit`` to hold in reserve (default ``0.20``).
    current_projects:
        Number of projects requesting capacity (default ``1``).

    Returns
    -------
    AdmissionResult
        Frozen result with ``admitted`` flag, human-readable ``reason``,
        and capacity details.
    """
    cap = compute_project_capacity(
        usage=usage,
        task_p90_cost=task_p90_cost,
        avg_tasks_per_project=avg_tasks_per_project,
        reserve_fraction=reserve_fraction,
    )

    if cap.confidence == "invalid_input":
        return AdmissionResult(
            admitted=False,
            reason=(
                f"Admission denied: invalid capacity inputs "
                f"(remaining={usage.remaining_tokens}, "
                f"limit={usage.token_limit}, "
                f"p90_cost={task_p90_cost}, "
                f"avg_tasks={avg_tasks_per_project}). "
                f"max_projects={cap.max_simultaneous_projects}"
            ),
            max_projects=cap.max_simultaneous_projects,
            remaining_after_reserve=cap.remaining_after_reserve,
            projected_per_project=cap.projected_per_project,
            reserve_tokens=cap.reserve_tokens,
            confidence=cap.confidence,
        )

    if cap.confidence == "no_projection":
        return AdmissionResult(
            admitted=False,
            reason=(
                f"Admission denied: cannot project token burn "
                f"(p90_cost={task_p90_cost}, "
                f"avg_tasks={avg_tasks_per_project}). "
                f"max_projects={cap.max_simultaneous_projects}"
            ),
            max_projects=cap.max_simultaneous_projects,
            remaining_after_reserve=cap.remaining_after_reserve,
            projected_per_project=cap.projected_per_project,
            reserve_tokens=cap.reserve_tokens,
            confidence=cap.confidence,
        )

    if cap.max_simultaneous_projects < current_projects:
        return AdmissionResult(
            admitted=False,
            reason=(
                f"Admission denied: capacity insufficient. "
                f"remaining={usage.remaining_tokens}, "
                f"reserve={cap.reserve_tokens}, "
                f"remaining_after_reserve={cap.remaining_after_reserve}, "
                f"projected_per_project={cap.projected_per_project}, "
                f"max_projects={cap.max_simultaneous_projects}, "
                f"requested={current_projects}"
            ),
            max_projects=cap.max_simultaneous_projects,
            remaining_after_reserve=cap.remaining_after_reserve,
            projected_per_project=cap.projected_per_project,
            reserve_tokens=cap.reserve_tokens,
            confidence=cap.confidence,
        )

    return AdmissionResult(
        admitted=True,
        reason=(
            f"Admission granted: max_projects={cap.max_simultaneous_projects}, "
            f"requested={current_projects}, "
            f"remaining_after_reserve={cap.remaining_after_reserve}"
        ),
        max_projects=cap.max_simultaneous_projects,
        remaining_after_reserve=cap.remaining_after_reserve,
        projected_per_project=cap.projected_per_project,
        reserve_tokens=cap.reserve_tokens,
        confidence=cap.confidence,
    )


def _confidence_rank(confidence: str) -> int:
    return _CONFIDENCE_RANK.get(confidence.strip().lower(), 0)


def check_quota_admission(db_path: str, *, force: bool = False) -> AdmissionResult:
    """Admit work when at least one provider has reliable quota headroom.

    Only ``authoritative`` and ``observed`` quota data can deny admission.
    ``estimated`` and ``unknown`` data never hard-gate a run.
    """
    providers = ("anthropic", "openai", "google")
    all_exhausted = True
    any_known = False
    best_confidence = "unknown"

    for provider in providers:
        headroom, confidence = get_quota_headroom(db_path, provider)
        normalized_confidence = confidence.strip().lower() or "unknown"
        if normalized_confidence in {"authoritative", "observed"}:
            any_known = True
            if _confidence_rank(normalized_confidence) > _confidence_rank(best_confidence):

