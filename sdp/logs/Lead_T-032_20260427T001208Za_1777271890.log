class TestComputePercentileBasic:
    """Verify nearest-rank percentile on small data sets."""

    def test_single_element(self) -> None:
        assert compute_percentile([42.0], 50) == 42.0
        assert compute_percentile([42.0], 90) == 42.0

    def test_two_elements_p50(self) -> None:
        result = compute_percentile([10.0, 20.0], 50)
        assert result == 10.0

    def test_two_elements_p90(self) -> None:
        result = compute_percentile([10.0, 20.0], 90)
        assert result == 20.0

    def test_ten_elements_p50(self) -> None:
        data = [float(i) for i in range(1, 11)]  # 1..10
        result = compute_percentile(data, 50)
        assert result == 5.0

    def test_ten_elements_p90(self) -> None:
        data = [float(i) for i in range(1, 11)]  # 1..10
        result = compute_percentile(data, 90)
        assert result == 9.0

    def test_percentile_clamps_below_zero(self) -> None:
        result = compute_percentile([1.0, 2.0, 3.0], -10)
        assert result == 1.0

    def test_percentile_clamps_above_100(self) -> None:
        result = compute_percentile([1.0, 2.0, 3.0], 150)
        assert result == 3.0

    def test_unsorted_input_is_handled(self) -> None:
        """compute_percentile must sort internally, not require sorted input."""
        result = compute_percentile([30.0, 10.0, 20.0], 50)
        assert result == compute_percentile([10.0, 20.0, 30.0], 50)


