class ProviderCapacity:
    """Capacity result for a single provider in a capacity plan."""

    provider: str
    model: str
    remaining_tokens: float
    token_limit: float
    reserve_tokens: float
    projected_per_project: float
    max_projects: int
    confidence: str
    is_limiting: bool


