"""Admission control gate for pipeline runs (T-006@20260301T202210Z).

Evaluates whether a new pipeline run can proceed without crossing the
provider token reserve threshold.  Delegates to
:func:`~sdp.pipeline.capacity.compute_project_capacity` for the core
capacity computation and wraps the result with an admit/deny decision.

Multi-provider admission extends the original single-provider gate with:
- per-provider runtime state records
- candidate lead/verify plan feasibility checks
- confidence-aware soft/hard gating
"""

from __future__ import annotations

from collections import defaultdict
from collections.abc import Sequence
from dataclasses import dataclass, replace

from sdp.pipeline.capacity import UsageSnapshot, compute_project_capacity
from sdp.state.db import get_quota_headroom


@dataclass(frozen=True)
class AdmissionResult:
    """Result of an admission control check."""

    admitted: bool
    reason: str
    max_projects: int = 0
    remaining_after_reserve: float = 0.0
    projected_per_project: float = 0.0
    reserve_tokens: float = 0.0
    confidence: str = "unknown"  # "ok" | "no_projection" | "invalid_input" | quota labels


_CONFIDENCE_RANK = {
    "unknown": 0,
    "estimated": 1,
    "observed": 2,
    "authoritative": 3,
}


@dataclass(frozen=True)
class ProviderAdmissionState:
    """Admission state for one provider/agent entity."""

    agent: str
    provider: str
    lead_model_signature: str
    verify_model_signature: str
    remaining_tokens: float
    token_limit: float
    reserve_tokens: float
    remaining_after_reserve: float
    remaining_pct: float
    confidence: str
    source: str
    collected_at: str
    reset_at: str
    lead_projected_cost: float
    verify_projected_cost: float
    lead_max_projects: int
    verify_max_projects: int
    status: str
    gate_mode: str

    def to_dict(self) -> dict[str, object]:
        """Serialize provider state for run-state/monitor payloads."""
        return {
            "agent": self.agent,
            "provider": self.provider,
            "lead_model_signature": self.lead_model_signature,
            "verify_model_signature": self.verify_model_signature,
            "remaining_tokens": self.remaining_tokens,
            "token_limit": self.token_limit,
            "reserve_tokens": self.reserve_tokens,
            "remaining_after_reserve": self.remaining_after_reserve,
            "remaining_pct": self.remaining_pct,
            "confidence": self.confidence,
            "source": self.source,
            "collected_at": self.collected_at,
            "reset_at": self.reset_at,
            "lead_projected_cost": self.lead_projected_cost,
            "verify_projected_cost": self.verify_projected_cost,
            "lead_max_projects": self.lead_max_projects,
            "verify_max_projects": self.verify_max_projects,
            "status": self.status,
            "gate_mode": self.gate_mode,
        }


@dataclass(frozen=True)
class AdmissionPlan:
    """One evaluated lead/verify plan across provider states."""

    lead_agent: str
    verify_agent: str
    lead_provider: str
    verify_provider: str
    required_providers: tuple[str, ...]
    total_projected_cost: float
    status: str
