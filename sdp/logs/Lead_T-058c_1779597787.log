\\\\\n+\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+def apply_midi_message(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    midi_state: MidiState,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    active_notes: dict[int, dict[str, float | int | str]],\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    recent_pedal_events: list[tuple[float, bool]],\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    status: int,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    data1: int,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    data2: int,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    now: float,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    last_activity: float,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+) -> float:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Apply one decoded MIDI message into the tracked keyboard state.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    msg_type = status & 0xF0\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    if msg_type == 0x90:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+        note, velocity = data1, data2\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+        midi_state.note_on(note, velocity)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+        if velocity > 0:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+            active_notes[note] = {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"freq\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": midi_to_freq(note),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": note_to_name(note),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+       