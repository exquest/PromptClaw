+    voice = char.get("voice", {}) if isinstance(char, Mapping) else {}
+    if isinstance(voice, Mapping):
+        entry.update(voice)
+    if _voice_synth(char) == SAMPLER_SYNTH and isinstance(sampler_summary, Mapping):
+        entry["sample_record"] = dict(sampler_summary)
+    return entry
