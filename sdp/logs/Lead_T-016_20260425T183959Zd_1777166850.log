+
+    resolved_sample_select_kwargs = _sample_select_kwargs_from_piece(piece)
+    if sample_select_kwargs:
+        resolved_sample_select_kwargs.update(dict(sample_select_kwargs))
+
+    metadata: dict[str, Any] = {}
+    cast_ids = select_cast_ids(
