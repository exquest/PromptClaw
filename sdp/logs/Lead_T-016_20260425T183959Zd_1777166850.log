+def _string_tuple(raw: object) -> tuple[str, ...]:
+    if isinstance(raw, str):
+        value = raw.strip()
+        return (value,) if value else ()
+    if not isinstance(raw, Sequence):
+        return ()
+    values: list[str] = []
+    for item in raw:
+        if isinstance(item, str):
+            value = item.strip()
+            if value:
+                values.append(value)
+    return tuple(values)
+
+
+def _coerce_int(raw: object) -> int | None:
+    try:
