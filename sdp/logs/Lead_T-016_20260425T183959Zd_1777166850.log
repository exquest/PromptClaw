+        if isinstance(frame_count, (int, float)) and isinstance(sample_rate, (int, float)):
+            if float(sample_rate) > 0.0:
+                duration_sec = float(frame_count) / float(sample_rate)
     return {
         "id": sample_id,
         "path": str(path) if path is not None else None,
