        assert created == {
            "id": "evt-005",
            "type": "raid.completed",
            "domain": "deniable",
            "payload": {
                "raid_id": "raid-17",
                "outcome": "success",
                "survivors": ["dax", "mira"],
            },
            "created_at": "2026-05-01T04:15:00Z",
        }
        assert store.append_calls == [
            {
                "event_type": "raid.completed",
                "domain": "deniable",
                "payload": {
                    "raid_id": "raid-17",
                    "outcome": "success",
                    "survivors": ["dax", "mira"],
                },
                "created_at": "2026-05-01T04:15:00Z",
