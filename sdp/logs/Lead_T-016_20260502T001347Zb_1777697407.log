        {"id": "e3", "domain": "private", "type": "character", "name": "Bob"},
        {"id": "e4", "domain": "shared", "type": "item", "name": "Sword"},
        {"id": "e5", "domain": "deniable", "type": "character", "name": "Charlie"},
    ])

