"""Regression tests for scripts/smoke_narrative.py."""

from __future__ import annotations

import importlib.util
import threading
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path
from types import ModuleType
from typing import Iterator

import pytest


SCRIPT_PATH = Path(__file__).resolve().parents[1] / "scripts" / "smoke_narrative.py"


def _load_script() -> ModuleType:
    spec = importlib.util.spec_from_file_location("smoke_narrative", SCRIPT_PATH)
    assert spec is not None and spec.loader is not None
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


class _Handler(BaseHTTPRequestHandler):
    routes: dict[str, tuple[int, bytes]] = {}
    seen_auth: list[tuple[str, str | None]] = []

    def log_message(self, format: str, *args: object) -> None:  # noqa: A003
        return

    def do_GET(self) -> None:  # noqa: N802
        type(self).seen_auth.append((self.path, self.headers.get("Authorization")))
        status, body = self.routes.get(self.path, (404, b"not found"))
        self.send_response(status)
        self.send_header("Content-Type", "text/plain")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


@pytest.fixture()
def http_server() -> Iterator[tuple[str, type[_Handler]]]:
    handler_cls = type("Handler", (_Handler,), {"routes": {}, "seen_auth": []})
    server = HTTPServer(("127.0.0.1", 0), handler_cls)
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()
    try:
        host, port = server.server_address[:2]
        yield f"http://{host}:{port}", handler_cls
    finally:
        server.shutdown()
        server.server_close()
        thread.join(timeout=1)


def test_main_returns_zero_when_all_endpoints_2xx(
    http_server: tuple[str, type[_Handler]], capsys: pytest.CaptureFixture[str]
) -> None:
    base_url, handler = http_server
    handler.routes = {"/healthz": (200, b"ok"), "/readyz": (200, b"ready")}
    module = _load_script()

    rc = module.main(["--base-url", base_url])

    out = capsys.readouterr().out
    assert rc == 0
    assert "/healthz: 200 ok" in out
    assert "/readyz: 200 ready" in out


def test_main_returns_nonzero_when_any_endpoint_non_2xx(
    http_server: tuple[str, type[_Handler]], capsys: pytest.CaptureFixture[str]
) -> None:
    base_url, handler = http_server
    handler.routes = {"/healthz": (200, b"ok"), "/readyz": (503, b"down")}
    module = _load_script()

    rc = module.main(["--base-url", base_url])

    out = capsys.readouterr().out
    assert rc == 1
    assert "/healthz: 200 ok" in out
    assert "/readyz: 503 down" in out


def test_main_returns_nonzero_when_unreachable(
    capsys: pytest.CaptureFixture[str],
) -> None:
    module = _load_script()

    # Port 1 is reserved/unused — connection should fail fast.
    rc = module.main(["--base-url", "http://127.0.0.1:1"])

    out = capsys.readouterr().out
    assert rc == 1
    assert "/healthz: ERROR" in out
    assert "/readyz: ERROR" in out


def test_main_sends_bearer_authorization_header_when_token_provided(
    http_server: tuple[str, type[_Handler]],
) -> None:
    base_url, handler = http_server
    handler.routes = {"/healthz": (200, b"ok"), "/readyz": (200, b"ready")}
    module = _load_script()

    rc = module.main(["--base-url", base_url, "--token", "secret-123"])

    assert rc == 0
    paths = [path for path, _ in handler.seen_auth]
    auths = [auth for _, auth in handler.seen_auth]
    assert paths == ["/healthz", "/readyz"]
    assert auths == ["Bearer secret-123", "Bearer secret-123"]


def test_main_omits_authorization_header_when_no_token(
    http_server: tuple[str, type[_Handler]],
) -> None:
    base_url, handler = http_server
    handler.routes = {"/healthz": (200, b"ok"), "/readyz": (200, b"ready")}
    module = _load_script()

    rc = module.main(["--base-url", base_url])

    assert rc == 0
    auths = [auth for _, auth in handler.seen_auth]
    assert auths == [None, None]


def test_body_preview_is_truncated(
    http_server: tuple[str, type[_Handler]], capsys: pytest.CaptureFixture[str]
) -> None:
    base_url, handler = http_server
    big_body = b"x" * 1000
    handler.routes = {"/healthz": (200, big_body), "/readyz": (200, b"ok")}
    module = _load_script()

    rc = module.main(["--base-url", base_url])

    out = capsys.readouterr().out
    assert rc == 0
    assert "..." in out
    healthz_line = next(line for line in out.splitlines() if line.startswith("/healthz"))
    assert len(healthz_line) < 400

