+    assert payload["clicks"] == 1
+    assert payload["transformations"] == ["slice_rearrange", "pitch_window"]
+    assert payload["samples_played"][0]["sample_id"] == "self-quote-1"
+    assert payload["samples_used"][0]["sample_id"] == "self-quote-1"
