-import json
-import os
-from dataclasses import dataclass, asdict, field
-from typing import List, Dict, Any, Optional
-from pathlib import Path
-
-# The storage path as defined by the requirement
-JOURNAL_PATH = Path("samples/usage_journal.jsonl")
-
-@dataclass
-class SamplePlay:
-    sample_id: str
-    source: str
-    transposition: int
-    fx_preset: str
-    played_at_row: int
-
-@dataclass
-class JournalEntry:
-    piece_id: str
-    timestamp: str
-    samples_played: List[SamplePlay]
-    arc_payoff: str
-
-    def to_dict(self) -> Dict[str, Any]:
-        return asdict(self)
-
-    @classmethod
-    def from_dict(cls, data: Dict[str, Any]) -> "JournalEntry":
-        samples_played = [SamplePlay(**sp) for sp in data.get("samples_played", [])]
-        return cls(
-            piece_id=data["piece_id"],
-            timestamp=data["timestamp"],
-            samples_played=samples_played,
-            arc_payoff=data.get("arc_payoff", "")
-        )
-
-def append_to_journal(entry: JournalEntry, path: Path = JOURNAL_PATH) -> None:
-    """Appends a JournalEntry to the JSONL file and ensures fsync for atomicity/durability."""
-    path.parent.mkdir(parents=True, exist_ok=True)
-    with open(path, "a") as f:
-        f.write(json.dumps(entry.to_dict()) + "\n")
-        f.flush()
-        os.fsync(f.fileno())
-
-def read_journal(path: Path = JOURNAL_PATH) -> List[JournalEntry]:
-    """Reads all journal entries from the JSONL file."""
-    entries = []
-    if not path.exists():
-        return entries
-    with open(path, "r") as f:
-        for line in f:
-            if line.strip():
-                entries.append(JournalEntry.from_dict(json.loads(line)))
-    return entries
-
-
-@dataclass
-class SampleUsageTracker:
-    """Accumulate ``SamplePlay`` events emitted during a piece's playback.
-
-    The composer opens a tracker for each piece via :meth:`start_piece`,
-    calls :meth:`record_play` whenever it dispatches a sample (capturing
-    sample id, pitch transposition, fx/filter preset, and the row at
-    which the trigger fired), then calls :meth:`finish_piece` to fold
-    the accumulated plays into a :class:`JournalEntry` ready for
-    :func:`append_to_journal`.
-    """
-
-    piece_id: Optional[str] = None
-    timestamp: Optional[str] = None
-    samples_played: List[SamplePlay] = field(default_factory=list)
-
-    @property
-    def is_active(self) -> bool:
-        return self.piece_id is not None
-
-    def start_piece(self, piece_id: str, timestamp: str) -> None:
-        self.piece_id = piece_id
-        self.timestamp = timestamp
-        self.samples_played = []
-
-    def record_play(
-        self,
-        *,
-        sample_id: str,
-        source: str,
-        transposition: int,
-        fx_preset: str,
-        played_at_row: int,
-    ) -> SamplePlay:
-        if self.piece_id is None:
-            raise RuntimeError("SampleUsageTracker.record_play called before start_piece")
-        play = SamplePlay(
-            sample_id=sample_id,
-            source=source,
-            transposition=transposition,
-            fx_preset=fx_preset,
-            played_at_row=played_at_row,
-        )
-        self.samples_played.append(play)
-        return play
-
-    def finish_piece(self, arc_payoff: str = "") -> JournalEntry:
-        if self.piece_id is None or self.timestamp is None:
-            raise RuntimeError("SampleUsageTracker.finish_piece called before start_piece")
-        entry = JournalEntry(
-            piece_id=self.piece_id,
-            timestamp=self.timestamp,
-            samples_played=list(self.samples_played),
-            arc_payoff=arc_payoff,
-        )
-        self.piece_id = None
-        self.timestamp = None
-        self.samples_played = []
-        return entry
-
-
-def derive_arc_payoff_summary(*, arc_payoff_score: float, sample_count: int) -> str:
-    """Render a short textual summary from a numeric arc-payoff score and
-    the number of samples that played in the piece."""
-    if arc_payoff_score >= 0.6:
-        band = "strong"
-    elif arc_payoff_score >= 0.3:
-        band = "moderate"
-    else:
-        band = "weak"
-    return f"{band} payoff (score={arc_payoff_score:.2f}) over {sample_count} sample(s)"
-
-
-def post_piece_hook(
-    tracker: SampleUsageTracker,
-    *,
-    arc_payoff_score: float,
-    journal_path: Path = JOURNAL_PATH,
-) -> JournalEntry:
-    """Composer post-piece hook: consumes ``tracker`` state, derives an
-    arc-payoff summary from ``arc_payoff_score``, folds the accumulated
-    plays into a :class:`JournalEntry` (resetting the tracker), and
-    appends the entry to ``journal_path``.
-
-    Returns the appended ``JournalEntry`` so callers can log or inspect
-    it. Raises ``RuntimeError`` (via ``finish_piece``) if the tracker
-    has no active piece.
-    """
-    sample_count = len(tracker.samples_played)
-    summary = derive_arc_payoff_summary(
-        arc_payoff_score=arc_payoff_score,
-        sample_count=sample_count,
-    )
-    entry = tracker.finish_piece(arc_payoff=summary)
-    append_to_journal(entry, path=journal_path)
-    return entry
