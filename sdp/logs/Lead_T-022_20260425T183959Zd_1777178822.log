+        assert json.loads(sample_event.metadata["sample_gesture_transforms"]) == [
+            "slice_rearrange",
+            "granular_cloud",
+        ]
+        assert sample_event.scene_metadata["sample_gesture_mode"] == "grain_cloud"
+
 
