    assert [sp.sample_id for sp in entry_a.samples_played] == ["a1", "a2"]
    assert [sp.sample_id for sp in entry_b.samples_played] == ["b1"]
    assert entry_a.arc_payoff == "A done"
    assert entry_b.arc_payoff == "B done"


