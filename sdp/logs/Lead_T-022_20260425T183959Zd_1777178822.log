+            if transform in seen:
+                continue
+            seen.add(transform)
+            ordered.append(transform)
+    return ordered
+
+
+def _int_value(value: object, default: int = 0) -> int:
+    try:
+        return int(float(value))
+    except (TypeError, ValueError):
