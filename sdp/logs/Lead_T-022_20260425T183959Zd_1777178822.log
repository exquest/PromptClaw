+    if isinstance(values, str):
+        text = values.strip()
+        if not text:
+            return []
+        try:
+            decoded = json.loads(text)
+        except json.JSONDecodeError:
+            return [text]
+        if isinstance(decoded, list):
+            return [str(value) for value in decoded if str(value).strip()]
