index 0000000000000000000000000000000000000000..f2013379561358644dc036e919649ffa8ce5e7a2
--- /dev/null
+++ b/tests/test_usage_journal_integration.py
@@ -0,0 +1,155 @@
+from __future__ import annotations
+
+import json
+import os
+import sys
+from pathlib import Path
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "my-claw", "tools"))
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "my-claw", "tools", "senseweave"))
+
+from inner_life.world_model import WorldModel
+from senseweave.composition_gate import evaluate_score_tree
+from senseweave.form_grammar import plan_form
+from senseweave.music_tracker_runtime import schedule_song
+from senseweave.piece_brief import build_piece_brief
+from senseweave.piece_commission import commission_piece
+from senseweave.recursive_composer import compose_score_tree
+from senseweave.tracker_compiler import compile_score_tree_to_tracker
+from senseweave.usage_journal import (
+    SampleUsageTracker,
+    post_piece_hook,
+    read_journal,
+    record_scheduled_sample_event,
+)
+
+
+def _compose_short_piece():
+    commission = commission_piece(
+        cadence_state="occupied_day",
+        day_phase="day",
+        weekly_phase="midweek",
+        attention_score=0.52,
+        narrative_pressure=0.64,
+        occupancy_state="occupied_active",
+        repertoire_entries=[object()] * 12,
+        song_num=15,
+        hour=17,
+    )
+    world = WorldModel(
+        observer_description="bright room with taps and small motions near the desk",
+        cadence_state="occupied_day",
+        day_phase="day",
+        time_of_day="evening",
+        occupancy_state="occupied_active",
+        attention_score=0.52,
+        experimentation_bias=0.64,
+    )
+    brief = build_piece_brief(
+        world=world,
+        commission=commission,
+        family="ember",
+        cadence_state="occupied_day",
+        progression_profile="lift",
+    )
+    form = plan_form(commission=commission, brief=brief, family="ember")
+    tree = compose_score_tree(
+        commission=commission,
+        brief=brief,
+        form=form,
+        family="ember",
+        cadence_state="occupied_day",
+        progression_profile="lift",
+        song_num=15,
+        mood={"energy": 0.58, "valence": 0.6, "arousal": 0.54},
+    )
+    target_section = next(
+        (
+            name
+            for name in ("Development", "Arrival", "Lift", "Theme")
+            if any(section.scene_name == name for section in tree.sections)
+        ),
+        tree.sections[0].scene_name,
+    )
+    tree.arrangement_plan.setdefault("sample_gestures", {})[target_section] = {
+        "source": "contact_mic",
+        "mode": "grain_cloud",
+        "voice": "sample_grain",
+        "transforms": ["slice_rearrange", "granular_cloud", "reverse_accents"],
+        "density": 0.72,
+        "max_events": 6,
+    }
+    return tree, target_section
+
+
+def test_short_composed_piece_writes_populated_usage_journal_entry(tmp_path: Path) -> None:
+    tree, target_section = _compose_short_piece()
+    report = evaluate_score_tree(tree)
+    assert report.approved is True, f"gate failures: {report.failures}"
+
+    compiled = compile_score_tree_to_tracker(
+        tree,
+        mood={"energy": 0.58, "valence": 0.6, "arousal": 0.54},
+        family_name="ember",
+        patch_name="house_procession",
+        cadence_state="occupied_day",
+        progression_profile="lift",
+    )
+    assert any(scene.name == target_section for scene in compiled.tracker_song.scenes)
+
+    journal_path = tmp_path / "usage_journal.jsonl"
+    tracker = SampleUsageTracker()
+    tracker.start_piece(piece_id=tree.piece_id, timestamp="2026-04-25T19:45:00Z")
+    emitted = []
+
+    def _on_event(event) -> None:
+        emitted.append(event)
+        record_scheduled_sample_event(tracker, event)
+
+    result = schedule_song(
+        compiled.tracker_song,
+        play_event=_on_event,
+        sleep_fn=lambda _seconds: None,
+        state_path=tmp_path / "tracker_state.json",
+        time_fn=lambda: 4500.0,
+    )
+
+    assert result.completed is True
+    sample_events = [event for event in emitted if event.role == "sample"]
+    assert sample_events
+
+    entry = post_piece_hook(
+        tracker,
+        arc_payoff_score=0.72,
+        journal_path=journal_path,
+        mode="evening_reflection",
+        clicks=0,
+    )
+
+    assert entry.piece_id == tree.piece_id
+    assert entry.mode == "evening_reflection"
+    assert entry.arc_payoff.startswith("strong")
+    assert entry.transformations == [
+        "slice_rearrange",
+        "granular_cloud",
+        "reverse_accents",
+    ]
+    assert len(entry.samples_played) == len(sample_events)
+    assert entry.samples_played[0].source == "contact_mic"
+    assert entry.samples_played[0].sample_id
+
+    on_disk = read_journal(path=journal_path)
+    assert len(on_disk) == 1
+    assert on_disk[0].transformations == entry.transformations
+    assert on_disk[0].samples_played
+
+    raw = json.loads(journal_path.read_text(encoding="utf-8").splitlines()[0])
+    assert raw["piece_id"] == tree.piece_id
+    assert raw["mode"] == "evening_reflection"
+    assert raw["samples_used"]
+    assert raw["transformations"] == [
+        "slice_rearrange",
+        "granular_cloud",
+        "reverse_accents",
+    ]
+    assert raw["arc_payoff"]

diff --git a/CHANGELOG.md b/CHANGELOG.md
index b03fe0acdd6d8a84980dcde1411b0834d3f4076f..972bfdfd11e176bc0faaf4ba0adc114a12095b28
--- a/CHANGELOG.md
+++ b/CHANGELOG.md
@@ -2,6 +2,7 @@
 
 ## Unreleased
 
+- Added the missing CCS-028 sample-usage journal seam for tracker pieces: `senseweave.usage_journal` now serializes the richer per-piece sampler fields (`started_at`, `mode`, `samples_used`, `transformations`, `clicks`) while preserving the legacy `timestamp` / `samples_played` aliases, `music_tracker_runtime.ScheduledTrackerEvent` now carries sample-gesture metadata through playback emission, `duet_composer.py` now records actual emitted sample-lane events into the post-piece journal hook, and new regression coverage in `tests/test_usage_journal.py`, `tests/test_music_tracker_runtime.py`, and `tests/test_usage_journal_integration.py` composes a short score-tree piece end to end and proves the written journal entry contains populated sample usage, transformations, and arc payoff data.
 - Added focused regression coverage for the operator-diagnostics sampler line (`OperatorDiagnostics.sample_source`) in `tests/test_operator_diagnostics_sample_status.py`, pinning the four discrete states the formatter must produce: sampling-only renders `currently sampling …` without a playback fragment, playing-only renders `playing sample …` without a sampling fragment, both-active joins the two phrases with ` · `, and the all-idle case degrades to `unavailable` so the daemon never serializes an empty sampler line.
 - Added a repo-backed `inkplate_display.py` renderer seam for the sampler status surface: it reuses `senseweave.sample_status.face_display_sample_status_text(...)` so the e-ink display follows the same combined plan+playback wording as the face display, and it truncates long sampler lines against the configured e-ink text width with Pillow-based measurement plus `...` instead of letting them overflow. Added regression coverage in `tests/test_inkplate_display.py` for helper wiring, width-fit truncation, fit-without-truncation, and empty-state degradation.
 - Wired the combined sampler plan+playback status line into the face display renderer so the small face monitor mirrors operator diagnostics: added `senseweave.sample_status.face_display_sample_status_text(...)` as a thin wrapper that opts into `combine_activity_and_playback=True`, and updated `my-claw/tools/face_display.py` to call it in place of the legacy either/or `sample_status_text(...)` while preserving the existing 24pt centered placement and degradation guards. Coverage in `tests/test_face_display_sample_status.py` pins the combined wording, plan-only fallback, monitor-offline degradation, and the renderer call site.
