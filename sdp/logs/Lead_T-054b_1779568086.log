+        const noteOn = JSON.stringify({ status: 144, data1: 60, data2: 100, ts: 1779568086.25 });
+        pairs[0][1].dispatch("message", { data: noteOn });
+
+        assert.deepEqual(pairs[0][1].sent, []);
+        assert.deepEqual(pairs[1][1].sent, [noteOn]);
+        assert.deepEqual(pairs[2][1].sent, [noteOn]);
+
+        const noteOff = JSON.stringify({ status: 128, data1: 60, data2: 0, ts: 1779568086.75 });
+        pairs[1][1].dispatch("message", { data: noteOff });
+
+        assert.deepEqual(pairs[0][1].sent, [noteOff]);
+        assert.deepEqual(pairs[1][1].sent, [noteOn]);
+        assert.deepEqual(pairs[2][1].sent, [noteOn, noteOff]);
+    } finally {
+        restoreResponse();
+        globalThis.WebSocketPair = originalWebSocketPair;
+    }
+});
+
+test("LiveMidiRoom drops malformed or invalid MIDI event messages without broadcasting", async () => {
+    const { FakeWebSocketPair, pairs } = makeFakeWebSocketPairFactory();
+    const originalWebSocketPair = globalThis.WebSocketPair;
+    globalThis.WebSocketPair = FakeWebSocketPair;
+    const restoreResponse = installUpgradeResponseShim();
+
+    try {
+        const room = new LiveMidiRoom({}, makeBaseEnv());
+        const request = new Request("https://cypherclaw.holdenu.com/api/cypherclaw/live-midi", {
+            method: "GET",
+            headers: { Upgrade: "websocket" },
+        });
+
+        await room.fetch(request);
+        await room.fetch(request);
+
+        const invalidMessages = [
+            "not json",
+            JSON.stringify([144, 60, 100, 1]),
+            "null",
+            JSON.stringify({ status: 144, data1: 60, data2: 100 }),
+            JSON.stringify({ status: 144, data1: 60, data2: 100, ts: 1, voice: "lead" }),
+            JSON.stringify({ status: 144.5, data1: 60, data2: 100, ts: 1 }),
+            JSON.stringify({ status: -1, data1: 60, data2: 100, ts: 1 }),
+            JSON.stringify({ status: 256, data1: 60, data2: 100, ts: 1 }),
+            JSON.stringify({ status: 144, data1: "60", data2: 100, ts: 1 }),
+            '{"status":144,"data1":60,"data2":100,"ts":1e309}',
+        ];
+
+        for (const message of invalidMessages) {
+            pairs[0][1].dispatch("message", { data: message });
+        }
+        pairs[0][1].dispatch("message", { data: new Uint8Array([144, 60, 100]) });
+
+        assert.equal(room.clientCount(), 2);
+        assert.deepEqual(pairs[0][1].sent, []);
+        assert.deepEqual(pairs[1][1].sent, []);
+    } finally {
+        restoreResponse();
+        globalThis.WebSocketPair = originalWebSocketPair;
+    }
+});
+
+test("LiveMidiRoom drops dead sockets on send failure and keeps broadcasting to live clients", async () => {
+    const { FakeWebSocketPair, pairs } = makeFakeWebSocketPairFactory();
+    const originalWebSocketPair = globalThis.WebSocketPair;
+    globalThis.WebSocketPair = FakeWebSocketPair;
+    const restoreResponse = installUpgradeResponseShim();
+
+    try {
+        const room = new LiveMidiRoom({}, makeBaseEnv());
+        const request = new Request("https://cypherclaw.holdenu.com/api/cypherclaw/live-midi", {
+            method: "GET",
+            headers: { Upgrade: "websocket" },
+        });
+
+        await room.fetch(request);
+        await room.fetch(request);
+        await room.fetch(request);
+        pairs[1][1].failOnSend = true;
+
+        const first = JSON.stringify({ status: 176, data1: 74, data2: 80, ts: 1779568087 });
+        pairs[0][1].dispatch("message", { data: first });
+
+        assert.equal(room.clientCount(), 2);
+        assert.deepEqual(pairs[0][1].sent, []);
+        assert.deepEqual(pairs[1][1].sent, []);
+        assert.deepEqual(pairs[2][1].sent, [first]);
+
+        const second = JSON.stringify({ status: 176, data1: 74, data2: 81, ts: 1779568088 });
+        pairs[0][1].dispatch("message", { data: second });
+
+        assert.equal(room.clientCount(), 2);
+        assert.deepEqual(pairs[1][1].sent, []);
+        assert.deepEqual(pairs[2][1].sent, [first, second]);
+    } finally {
+        restoreResponse();
+        globalThis.WebSocketPair = originalWebSocketPair;
+    }
+});
