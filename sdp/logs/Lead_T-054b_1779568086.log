+            if (message === null) {
+                return;
+            }
+            this.broadcastMidiEvent(server, message);
+        };
         server.addEventListener('close', removeClient);
         server.addEventListener('error', removeClient);
+        server.addEventListener('message', relayMidiEvent);
 
         return new Response(null, {
             status: 101,
@@ -749,6 +813,23 @@
     clientCount(): number {
         return this.clients.size;
     }
+
+    private broadcastMidiEvent(sender: WebSocket, message: string): void {
+        const deadClients: WebSocket[] = [];
+        for (const client of this.clients) {
+            if (client === sender) {
+                continue;
+            }
+            try {
+                client.send(message);
+            } catch (_error) {
+                deadClients.push(client);
+            }
+        }
+        for (const client of deadClients) {
+            this.clients.delete(client);
+        }
+    }
 }
 
