/**
 * holdenu API — Cloudflare Worker
 *
 * Routes:
 *   GET  /api/releases               — public; list visible releases + their tracks
 *   GET  /api/public-annotations     — public; sanitized annotations
 *   GET  /api/stream/:trackId        — public; byte-range proxy to R2 audio
 *   POST /api/cypherclaw/segment     — admin; ingest live CypherClaw segment
 *   GET  /api/cypherclaw/live.m3u8   — public; rolling HLS playlist of recent segments
 *   GET  /api/cypherclaw/segment/... — public; serve a stored CypherClaw segment
 *   GET  /api/cypherclaw/live-midi   — public; WebSocket to the live MIDI room
 *   POST /api/checkout               — public; Stripe Checkout Session
 *   POST /api/webhook/stripe         — webhook; signature-verified
 *   GET  /download/:token            — public; serve paid downloads
 *   POST /api/release                — admin; create/update release event
 *   POST /api/upload-url             — admin; mint upload token
 *   POST /api/upload/:token          — admin; receive file body, write to R2
 *   POST /api/sync                   — admin; mirror workspace annotations
 */

export interface Env {
    DB: D1Database;
    MEDIA: R2Bucket;
    ADMIN_TOKEN: string;
    STRIPE_SECRET_KEY: string;
    STRIPE_WEBHOOK_SECRET: string;
    RESEND_API_KEY: string;
    PUBLIC_SITE_ORIGIN: string;
    ENVIRONMENT: string;
    LIVE_MIDI_ROOM: DurableObjectNamespace;
}

const CORS_BASE = {
    'Access-Control-Allow-Methods': 'GET, POST, PUT, OPTIONS',
    'Access-Control-Allow-Headers': 'Authorization, Content-Type, Range, If-Range, X-CypherClaw-Sequence, X-CypherClaw-Captured-At, X-CypherClaw-Duration, X-CypherClaw-Scene, X-CypherClaw-Tuning, X-CypherClaw-Source',
    'Access-Control-Expose-Headers': 'Content-Length, Content-Range, Accept-Ranges',
    'Access-Control-Max-Age': '86400',
};
const CYPHERCLAW_SEGMENT_PATH = '/api/cypherclaw/segment';
const CYPHERCLAW_SEGMENT_PREFIX = '/api/cypherclaw/segment/';
const CYPHERCLAW_PLAYLIST_PATH = '/api/cypherclaw/live.m3u8';
const CYPHERCLAW_LIVE_FEATURES_PATH = '/api/cypherclaw/live-features';
const CYPHERCLAW_LIVE_MIDI_PATH = '/api/cypherclaw/live-midi';
const CYPHERCLAW_SEGMENT_CONTENT_TYPE = 'audio/ogg; codecs=opus';
const CYPHERCLAW_LIVE_PLAYLIST_WINDOW = 10;
const CYPHERCLAW_LIVE_TARGET_DURATION = 6;
const CYPHERCLAW_LIVE_HOST = 'cypherclaw.holdenu.com';
const CYPHERCLAW_ARCHIVE_PREFIX = 'cypherclaw/archive/';
const CYPHERCLAW_ARCHIVE_FEED_LIMIT = 12;

function corsHeaders(_env: Env, _req?: Request): Record<string, string> {
    // Always allow any origin. CORS is a browser-side mechanism and
    // does not provide auth. Our admin write endpoints are protected
    // by Authorization: Bearer regardless. The public read endpoints
    // are intentionally open. Real origin restriction (if ever needed)
    // belongs at the Cloudflare WAF / firewall layer, not here.
    return {
        ...CORS_BASE,
        'Access-Control-Allow-Origin': '*',
    };
}

function jsonResponse(body: unknown, env: Env, init: ResponseInit = {}, req?: Request): Response {
    return new Response(JSON.stringify(body), {
        ...init,
        headers: {
            'Content-Type': 'application/json',
            ...corsHeaders(env, req),
            ...(init.headers || {}),
        },
    });
}
function errorResponse(status: number, message: string, env: Env, req?: Request): Response {
    return jsonResponse({ error: message }, env, { status }, req);
}
function requireAdmin(req: Request, env: Env): Response | null {
    const auth = req.headers.get('Authorization') || '';
    const token = auth.startsWith('Bearer ') ? auth.slice(7) : '';
    if (!token || token !== env.ADMIN_TOKEN) {
        return errorResponse(401, 'admin auth required', env, req);
    }
    return null;
}

export default {
    async fetch(req: Request, env: Env, ctx: ExecutionContext): Promise<Response> {
        const url = new URL(req.url);
        const pathname = url.pathname;

        if (req.method === 'OPTIONS') {
            return new Response(null, { headers: corsHeaders(env, req) });
        }

        try {
            // CypherClaw live presence (PRD CC-024): on the cypherclaw.holdenu.com
            // custom-domain binding, serve the static stream scaffold at the site root.
            if (url.hostname === CYPHERCLAW_LIVE_HOST && pathname === '/' && (req.method === 'GET' || req.method === 'HEAD')) {
                return await serveCypherClawLanding(env, req, req.method === 'HEAD');
            }

            // Public reads
            if (pathname === '/api/releases' && req.method === 'GET')           return await listReleases(req, env);
            if (pathname === '/api/public-annotations' && req.method === 'GET') return await listPublicAnnotations(req, env);
            if (pathname.startsWith('/api/stream/') && req.method === 'GET')    return await streamTrack(req, env, decodeURIComponent(pathname.slice('/api/stream/'.length)));
            if (pathname === CYPHERCLAW_PLAYLIST_PATH && req.method === 'GET')  return await serveCypherClawPlaylist(req, env);
            if (pathname === CYPHERCLAW_LIVE_FEATURES_PATH && req.method === 'GET') return serveCypherClawLiveFeatures(req, env);
            if (pathname === CYPHERCLAW_LIVE_MIDI_PATH && req.method === 'GET') return await serveCypherClawLiveMidi(req, env);
            if (pathname.startsWith(CYPHERCLAW_SEGMENT_PREFIX) && req.method === 'GET') return await serveCypherClawSegment(req, env, decodeURIComponent(pathname.slice(CYPHERCLAW_SEGMENT_PREFIX.length)));
            if (pathname.startsWith('/api/artwork/') && req.method === 'GET')   return await serveArtwork(req, env, decodeURIComponent(pathname.slice('/api/artwork/'.length)));
            if (pathname.startsWith('/download/') && req.method === 'GET')      return await serveDownload(req, env, decodeURIComponent(pathname.slice('/download/'.length)));

            // Discoverability — pretty URLs for crawlers + sharing
            if (pathname === '/sitemap.xml' && req.method === 'GET')            return await serveSitemap(env);
            if (pathname === '/robots.txt' && req.method === 'GET')             return serveRobots(env);
            if (pathname.startsWith('/release/') && req.method === 'GET')       return await serveReleasePage(req, env, decodeURIComponent(pathname.slice('/release/'.length)));
            if (pathname.startsWith('/album/') && req.method === 'GET')         return await serveReleasePage(req, env, decodeURIComponent(pathname.slice('/album/'.length)));
            if (pathname.startsWith('/track/') && req.method === 'GET')         return await serveTrackPage(req, env, decodeURIComponent(pathname.slice('/track/'.length)));

            // Public commerce
            if (pathname === '/api/checkout' && req.method === 'POST')          return await createCheckout(req, env);

