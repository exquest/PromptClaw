+interface LiveMidiEvent {
+    status: number;
+    data1: number;
+    data2: number;
+    ts: number;
+}
+
+const LIVE_MIDI_EVENT_KEYS = new Set(['status', 'data1', 'data2', 'ts']);
+
+function parseLiveMidiEventMessage(data: unknown): string | null {
+    if (typeof data !== 'string') {
+        return null;
+    }
+
+    let parsed: unknown;
+    try {
+        parsed = JSON.parse(data);
+    } catch (_error) {
+        return null;
+    }
+
+    return isLiveMidiEvent(parsed) ? data : null;
+}
+
+function isLiveMidiEvent(value: unknown): value is LiveMidiEvent {
+    if (value === null || typeof value !== 'object' || Array.isArray(value)) {
+        return false;
+    }
+
+    const record = value as Record<string, unknown>;
+    const keys = Object.keys(record);
+    if (keys.length !== LIVE_MIDI_EVENT_KEYS.size) {
+        return false;
+    }
+    if (!keys.every((key) => LIVE_MIDI_EVENT_KEYS.has(key))) {
+        return false;
+    }
+
+    return (
+        isMidiByte(record.status) &&
+        isMidiByte(record.data1) &&
+        isMidiByte(record.data2) &&
+        typeof record.ts === 'number' &&
+        Number.isFinite(record.ts)
+    );
+}
+
+function isMidiByte(value: unknown): value is number {
+    return typeof value === 'number' && Number.isInteger(value) && value >= 0 && value <= 255;
+}
+
 async function serveCypherClawLiveMidi(req: Request, env: Env): Promise<Response> {
     if (!isWebSocketUpgrade(req)) {
         return webSocketUpgradeRequiredResponse(env, req);
@@ -737,8 +788,16 @@
         const removeClient = (_event: Event): void => {
             this.clients.delete(server);
         };
+        const relayMidiEvent = (event: MessageEvent): void => {
+            const message = parseLiveMidiEventMessage(event.data);
+            if (message === null) {
+                return;
+            }
+            this.broadcastMidiEvent(server, message);
+        };
         server.addEventListener('close', removeClient);
         server.addEventListener('error', removeClient);
+        server.addEventListener('message', relayMidiEvent);
 
