+
+        assert.equal(room.clientCount(), 2);
+        assert.deepEqual(pairs[0][1].sent, []);
+        assert.deepEqual(pairs[1][1].sent, []);
+        assert.deepEqual(pairs[2][1].sent, [first]);
+
+        const second = JSON.stringify({ status: 176, data1: 74, data2: 81, ts: 1779568088 });
+        pairs[0][1].dispatch("message", { data: second });
+
+        assert.equal(room.clientCount(), 2);
+        assert.deepEqual(pairs[1][1].sent, []);
+        assert.deepEqual(pairs[2][1].sent, [first, second]);
+    } finally {
+        restoreResponse();
+        globalThis.WebSocketPair = originalWebSocketPair;
+    }
+});
