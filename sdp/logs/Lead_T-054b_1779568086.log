+test("LiveMidiRoom broadcasts valid JSON MIDI events to every client except the sender", async () => {
+    const { FakeWebSocketPair, pairs } = makeFakeWebSocketPairFactory();
+    const originalWebSocketPair = globalThis.WebSocketPair;
+    globalThis.WebSocketPair = FakeWebSocketPair;
+    const restoreResponse = installUpgradeResponseShim();
+
+    try {
+        const room = new LiveMidiRoom({}, makeBaseEnv());
+        const request = new Request("https://cypherclaw.holdenu.com/api/cypherclaw/live-midi", {
+            method: "GET",
+            headers: { Upgrade: "websocket" },
+        });
+
+        await room.fetch(request);
+        await room.fetch(request);
+        await room.fetch(request);
+        assert.equal(room.clientCount(), 3);
+
+        const noteOn = JSON.stringify({ status: 144, data1: 60, data2: 100, ts: 1779568086.25 });
+        pairs[0][1].dispatch("message", { data: noteOn });
+
+        assert.deepEqual(pairs[0][1].sent, []);
+        assert.deepEqual(pairs[1][1].sent, [noteOn]);
+        assert.deepEqual(pairs[2][1].sent, [noteOn]);
+
+        const noteOff = JSON.stringify({ status: 128, data1: 60, data2: 0, ts: 1779568086.75 });
+        pairs[1][1].dispatch("message", { data: noteOff });
+
+        assert.deepEqual(pairs[0][1].sent, [noteOff]);
+        assert.deepEqual(pairs[1][1].sent, [noteOn]);
+        assert.deepEqual(pairs[2][1].sent, [noteOn, noteOff]);
+    } finally {
+        restoreResponse();
+        globalThis.WebSocketPair = originalWebSocketPair;
+    }
+});
