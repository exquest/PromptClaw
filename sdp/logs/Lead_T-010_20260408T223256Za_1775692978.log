+def _normalize_monitor_snapshot(text: str) -> str:
+    cleaned = re.sub(r"\x1b\[[0-?]*[ -/]*[@-~]", "", text or "")
+    lines = [line.rstrip() for line in cleaned.replace("\r\n", "\n").replace("\r", "\n").split("\n")]
+    return "\n".join(lines).strip()
