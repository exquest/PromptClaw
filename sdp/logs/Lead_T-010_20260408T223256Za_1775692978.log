+        raw_value = scope.get(f"selector_{agent}_remaining_tokens")
+        if raw_value is None:
+            continue
+        try:
+            remaining = float(raw_value)
+        except (TypeError, ValueError):
+            continue
+        if remaining <= 0:
+            disabled.add(agent)
+    return disabled
