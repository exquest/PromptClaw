 li_bridge = LifeImproverBridge()
 
 from quota_monitor import QuotaMonitor, is_quota_error
@@ -192,6 +193,11 @@
     state_file=TOOLS_DIR / ".agent_selector_state.json",
 )
 
+OLLAMA_HEALTH_PORTS: tuple[tuple[str, int], ...] = (
+    ("socket0", 11434),
