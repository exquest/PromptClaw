+def _normalize_task_filter(words: list[str]) -> str | None:
+    if not words:
+        return None
+    normalized = "_".join(word.strip().lower() for word in words if word.strip())
+    if not normalized:
+        return None
+    normalized = normalized.replace("-", "_")
+    return _TASK_FILTER_ALIASES.get(normalized)
