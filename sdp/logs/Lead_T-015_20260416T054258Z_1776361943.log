+    key = _normalize_quality_key(quality)
+    canonical = _CHORD_QUALITY_ALIASES.get(key)
+    if canonical is None:
+        raise ValueError(f"unknown chord quality: {quality!r}")
+    return canonical, CHORD_INTERVALS[canonical]
