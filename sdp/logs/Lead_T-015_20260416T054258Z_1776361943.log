+    if match is None:
+        raise ValueError(f"invalid chord symbol: {symbol!r}")
+
+    root, quality = match.groups()
+    quality = quality.strip()
+    if "/" in quality:
+        left, right = quality.rsplit("/", 1)
+        if right and right[0].upper() in {"A", "B", "C", "D", "E", "F", "G"}:
+            quality = left
