+    "dominant7": "7",
+    "major7": "maj7",
+    "ma7": "maj7",
+    "major9": "maj9",
+    "major11": "maj11",
+    "major13": "maj13",
+    "min7": "m7",
+    "minor7": "m7",
+    "min9": "m9",
+    "minor9": "m9",
+    "min11": "m11",
+    "minor11": "m11",
+    "min13": "m13",
+    "minor13": "m13",
+    "minmaj7": "mmaj7",
+    "minorMajor7": "mmaj7",
+    "minormajor7": "mmaj7",
+    "mm7": "mmaj7",
+    "mM7": "mmaj7",
