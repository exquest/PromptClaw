+    "maj9": (0, 4, 7, 11, 14),
+    "m9": (0, 3, 7, 10, 14),
+    "11": (0, 4, 7, 10, 14, 17),
+    "maj11": (0, 4, 7, 11, 14, 17),
+    "m11": (0, 3, 7, 10, 14, 17),
+    "9sus4": (0, 5, 7, 10, 14),
+    "13": (0, 4, 7, 10, 14, 17, 21),
+    "maj13": (0, 4, 7, 11, 14, 17, 21),
+    "m13": (0, 3, 7, 10, 14, 17, 21),
+    # Altered dominants
+    "7b5": (0, 4, 6, 10),
+    "7#5": (0, 4, 8, 10),
+    "7b9": (0, 4, 7, 10, 13),
+    "7#9": (0, 4, 7, 10, 15),
+    "7#11": (0, 4, 7, 10, 18),
+    "7b13": (0, 4, 7, 10, 20),
+    "7b9b13": (0, 4, 7, 10, 13, 20),
