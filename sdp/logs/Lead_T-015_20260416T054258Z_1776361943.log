+        object.__setattr__(self, "max_midi", max_midi)
+        object.__setattr__(self, "min_spacing", min_spacing)
+        object.__setattr__(self, "max_spacing", max_spacing)
+        object.__setattr__(self, "max_voicings", max_voicings)
