+
+_CHORD_QUALITY_ALIASES: dict[str, str] = {
+    "": "major",
+    "maj": "major",
+    "major": "major",
+    "m": "minor",
+    "min": "minor",
+    "minor": "minor",
+    "dim": "diminished",
