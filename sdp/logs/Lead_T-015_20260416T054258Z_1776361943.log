+def _normalize_quality_key(quality: str) -> str:
+    raw = quality.strip()
+    if raw.startswith("-"):
+        return "m" + raw[1:].replace(" ", "").replace("_", "").replace("-", "").lower()
+    if raw in {"M", "M7", "M9", "M11", "M13"}:
+        return "maj" + raw[1:]
