+def _spacing_ok(voicing: tuple[int, ...], config: VoicingConfig) -> bool:
+    return all(
+        config.min_spacing <= higher - lower <= config.max_spacing
+        for lower, higher in zip(voicing, voicing[1:])
+    )
+
