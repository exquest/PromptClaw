 # ---------------------------------------------------------------------------
+# Chord construction and voicing
+# ---------------------------------------------------------------------------
+
+ChordRoot = int | str
+VoicingStyle = Literal[
+    "close",
+    "open",
+    "drop2",
+    "drop3",
+    "rootless",
+    "guide_tone",
+]
