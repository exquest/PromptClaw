+@dataclass(frozen=True, init=False)
+class VoicingConfig:
+    """Register and spacing constraints for generated chord voicings."""
+
+    min_midi: int
+    max_midi: int
+    min_spacing: int
+    max_spacing: int
+    max_voicings: int
+
+    def __init__(
+        self,
+        min_midi: int = 48,
+        max_midi: int = 84,
