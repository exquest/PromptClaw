+    """Build a chord from a root note/pitch class and quality name."""
+
+    canonical, intervals = _resolve_chord_quality(quality)
+    return Chord(
+        root=_root_to_pitch_class(root),
+        quality=canonical,
+        intervals=_unique_intervals(intervals),
+    )
