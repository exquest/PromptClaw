+def generate_voicings(
+    chord: Chord | str,
+    *,
+    style: VoicingStyle | str = "close",
+    config: VoicingConfig | None = None,
+) -> list[tuple[int, ...]]:
+    """Generate unique voicings that satisfy register and spacing limits."""
