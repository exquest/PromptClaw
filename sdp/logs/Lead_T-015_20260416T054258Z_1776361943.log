+    "dominant7": "7",
+    "major7": "maj7",
+    "ma7": "maj7",
+    "major9": "maj9",
+    "major11": "maj11",
+    "major13": "maj13",
+    "min7": "m7",
+    "minor7": "m7",
+    "min9": "m9",
+    "minor9": "m9",
+    "min11": "m11",
+    "minor11": "m11",
+    "min13": "m13",
+    "minor13": "m13",
+    "minmaj7": "mmaj7",
+    "minorMajor7": "mmaj7",
+    "minormajor7": "mmaj7",
+    "mm7": "mmaj7",
+    "mM7": "mmaj7",
+    "halfdim7": "m7b5",
+    "halfdiminished7": "m7b5",
+    "ø": "m7b5",
+    "ø7": "m7b5",
+    "o7": "dim7",
+    "°7": "dim7",
+    "sus": "sus4",
+    "6/9": "69",
+    "m6/9": "m69",
+    "min6": "m6",
+    "minor6": "m6",
+    "min69": "m69",
