+        return min(
+            voicings,
+            key=lambda notes: (
+                _voice_leading_cost(notes, previous),
+                notes[-1] - notes[0],
+                notes,
+            ),
+        )
+
+    register_center = (resolved_config.min_midi + resolved_config.max_midi) / 2.0
+    return min(
+        voicings,
+        key=lambda notes: (
+            abs(_average_pitch(notes) - register_center),
+            notes[-1] - notes[0],
+            notes,
+        ),
+    )
