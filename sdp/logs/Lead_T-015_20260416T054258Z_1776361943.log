+    key = style.lower().replace("-", "_").replace(" ", "_")
+    aliases = {
+        "drop_2": "drop2",
+        "drop_3": "drop3",
+        "guide": "guide_tone",
+        "guide_tones": "guide_tone",
+        "guidetone": "guide_tone",
+        "root_less": "rootless",
+    }
+    normalized = aliases.get(key, key)
+    valid = {"close", "open", "drop2", "drop3", "rootless", "guide_tone"}
