--- _classify_depth_python <function _classify_depth_python at 0x106e445e0>
def _classify_depth_python(path: Path) -> ModuleDepth:
    """Classify a Python module's implementation depth via AST analysis."""
    try:
        source = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        # Source file is not UTF-8 (e.g., vendored Big5 / GBK / latin-1 test
        # fixtures). Fall back to permissive decode so we still report depth=0.
        try:
            source = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return ModuleDepth(
                path=str(path),
                module_name=path.stem,
                depth=-1,
                reason="unreadable file",
            )
    except OSError:
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="unreadable file",
        )
    lines = source.splitlines()
    line_count = len(lines)

    try:
        tree = ast.parse(source)
    except SyntaxError as e:
        return ModuleDepth(
            path=str(path), module_name=path.stem,
            depth=-1, reason=f"syntax error: {e}",
            line_count=line_count,
        )

    classes = []
    functions = []
    not_implemented = 0
    trivial_returns = 0
    real_logic = 0
    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef] = []

    for node in ast.walk(tree):
        if isinstance(node, ast.ClassDef):
            classes.append(node.name)
        elif isinstance(node, ast.FunctionDef | ast.AsyncFunctionDef):
            if _is_public_function(node):
                functions.append(node.name)
                public_function_nodes.append(node)

            # Analyze function body
            body = node.body
            # Skip docstrings
            if body and isinstance(body[0], ast.Expr) and isinstance(body[0].value, ast.Constant):
                body = body[1:]

            if not body:
                trivial_returns += 1
                continue

            body_source = ast.get_source_segment(source, node) or ""

            if 'NotImplementedError' in body_source:
                not_implemented += 1
            elif _is_trivial_return(body) or (
                len(body) <= 3
                and not any(
                    isinstance(statement, ast.If | ast.For | ast.While | ast.Try)
                    for statement in body
                )
            ):
                trivial_returns += 1
            else:
                real_logic += 1

    total_funcs = not_implemented + trivial_returns + real_logic
    if total_funcs == 0:
        depth = 0
        reason = "no functions found"
    elif not_implemented == total_funcs:
        depth = 0
        reason = "all functions raise NotImplementedError"
    elif not_implemented > 0:
        depth = 0
        reason = f"{not_implemented}/{total_funcs} not implemented"
    elif trivial_returns == total_funcs:
        depth = 1
        reason = "all functions return trivial values"
    elif trivial_returns > real_logic:
        depth = 1
        reason = f"{trivial_returns}/{total_funcs} trivial, {real_logic} real"
    elif real_logic > 0 and line_count < 100:
        depth = 2
        reason = f"simple implementations ({line_count} lines)"
    elif real_logic > 0 and line_count < 300:
        depth = 3
        reason = f"full implementations ({line_count} lines, {real_logic} real functions)"
    else:
        depth = 3
        reason = f"substantial ({line_count} lines, {real_logic} real functions)"

    matching_tests = _find_matching_test_files(path)
    test_coverage, max_single_file_coverage = _compute_test_coverage(
        path.stem, functions, matching_tests
    )
    test_boosted = max_single_file_coverage > 0.8

    if depth == 3:
        if not matching_tests:
            depth = 2
            reason = f"{reason.split('(')[0].strip()} (no tests)"
        elif _qualifies_for_depth_four(
            source=source,
            line_count=line_count,
            public_function_nodes=public_function_nodes,
            matching_tests=matching_tests,
            test_boosted=test_boosted,
        ):
            depth = 4
            reason = (
                f"polished ({line_count} lines, {_docstring_coverage(public_function_nodes):.0%} "
                f"docstrings, tests {_test_line_ratio(line_count, matching_tests):.2f}x)"
            )


    if test_boosted:
        reason += " (test boosted)"

    return ModuleDepth(
        path=str(path),
        module_name=path.stem,
        depth=depth,
        reason=reason,
        classes=classes,
        functions=functions,
        not_implemented_count=not_implemented,
        trivial_return_count=trivial_returns,
        real_logic_count=real_logic,
        test_count=len(matching_tests),
        test_files=[str(t) for t in matching_tests],
        test_coverage=test_coverage,
        test_boosted=test_boosted,
        line_count=line_count,
    )

