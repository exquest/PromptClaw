        narration = narrations[i % len(narrations)]
        decoration = decorations[i % len(decorations)]

        frame = (
            f"```\n"
            f"{sprite}\n"
            f"```\n"
            f"{decoration}\n"
            f"{icon} {narration}"
        )
        frames.append(frame)

    return frames

