+
+def _snapshot_to_summary(snapshot: PetVitalSnapshot) -> dict[str, Any]:
+    payload: dict[str, Any] = {
+        "agent": snapshot.agent,
+        "stage": snapshot.stage,
+        "stage_name": snapshot.stage_name,
