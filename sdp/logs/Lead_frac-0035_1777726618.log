+) -> str:
+    if xp_remaining is None:
+        progress = "max stage"
+    else:
+        progress = f"{xp_remaining} XP to next"
+    return (
+        f"{agent} {stage_name}/{class_label} XP {xp} "
+        f"({progress}) {health_band} {activity_band}"
