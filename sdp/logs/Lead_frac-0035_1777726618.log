+@dataclass(frozen=True)
+class PetVitalSnapshot:
+    """Operator-readable diagnostic snapshot for one pet."""
+
+    agent: str
+    stage: int
+    stage_name: str
+    xp: int
+    xp_in_stage: int
+    xp_to_next_stage: int | None
+    stage_progress: float | None
+    effective_state: str
+    class_label: str
+    health_band: str
+    activity_band: str
+    mood: int
