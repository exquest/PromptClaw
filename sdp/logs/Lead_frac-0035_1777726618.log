+def _mean_snapshot_stat(snapshots: tuple[PetVitalSnapshot, ...], field: str) -> float:
+    if not snapshots:
+        return 0.0
+    values = [float(getattr(snapshot, field)) for snapshot in snapshots]
+    mean_value = sum(values) / len(values)
+    return round(mean_value, 1)
