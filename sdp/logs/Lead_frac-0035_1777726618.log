+        self.tick()
+        with self._lock:
+            pets = dict(self.pets)
+        report = build_pet_fleet_report(pets)
+        return report
+
     def interaction_scene(self, agents: list[str]) -> str:
         """Generate a collaboration scene for active pets."""
         from glyphweave.scenes import CypherClawArt
