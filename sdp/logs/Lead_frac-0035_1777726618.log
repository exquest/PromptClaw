+        total_xp=total_xp,
+        total_tasks=total_tasks,
+        mean_mood=_mean_snapshot_stat(snapshots, "mood"),
+        mean_hunger=_mean_snapshot_stat(snapshots, "hunger"),
+        mean_energy=_mean_snapshot_stat(snapshots, "energy"),
+        health_counts=health_counts,
