+        agent=pet.agent,
+        stage=pet.stage,
+        stage_name=STAGE_NAMES[pet.stage],
+        xp=pet.xp,
+        xp_in_stage=max(pet.xp - current_floor, 0),
+        xp_to_next_stage=xp_remaining,
+        stage_progress=stage_progress_fraction(pet),
