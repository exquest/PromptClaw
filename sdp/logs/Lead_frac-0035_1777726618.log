+def _ordered_pet_items(pets: Mapping[str, Pet]) -> tuple[tuple[str, Pet], ...]:
+    ordered: list[tuple[str, Pet]] = []
+    seen: set[str] = set()
+    for agent in PetManager.AGENTS:
+        pet = pets.get(agent)
+        if pet is not None:
+            ordered.append((agent, pet))
+            seen.add(agent)
+    for agent in sorted(pets):
