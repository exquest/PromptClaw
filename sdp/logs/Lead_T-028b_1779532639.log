async function serveCypherClawSegment(req: Request, env: Env, key: string): Promise<Response> {
    if (!key.startsWith('cypherclaw/')) {
        return errorResponse(404, 'unknown segment path', env, req);
    }

    const range = req.headers.get('Range');
    const obj = range
        ? await env.MEDIA.get(key, { range: parseRange(range) })
        : await env.MEDIA.get(key);
    if (!obj) return errorResponse(404, 'segment missing in storage', env, req);

    const headers = new Headers(corsHeaders(env, req));
    headers.set('Content-Type', obj.httpMetadata?.contentType || CYPHERCLAW_SEGMENT_CONTENT_TYPE);
    headers.set('Accept-Ranges', 'bytes');
    headers.set('Cache-Control', 'public, max-age=300');

    if (range && (obj as any).range) {
        const r = (obj as any).range as R2Range;
        const offset = 'offset' in r ? (r.offset || 0) : 0;
        const length = 'length' in r ? (r.length as number) : (obj.size - offset);
        headers.set('Content-Range', `bytes ${offset}-${offset + length - 1}/${obj.size}`);
        return new Response((obj as R2ObjectBody).body, { status: 206, headers });
    }
    headers.set('Content-Length', String(obj.size));
    return new Response((obj as R2ObjectBody).body, { status: 200, headers });
}

