async function listReleases(req: Request, env: Env): Promise<Response> {
    const now = new Date().toISOString();
    const releasesQuery = await env.DB.prepare(
        `SELECT id, name, type, release_date, price_min_cents,
                artwork_key, description,
                bandcamp_url, spotify_url, apple_url, distrokid_isrc
           FROM releases WHERE release_date <= ?
          ORDER BY release_date DESC`
    ).bind(now).all();

    const releases = releasesQuery.results as Record<string, unknown>[];
    const releaseIds = releases.map(r => r.id as string);
    if (releaseIds.length === 0) return jsonResponse({ releases: [] }, env, undefined, req);

    const placeholders = releaseIds.map(() => '?').join(',');
    const tracksQuery = await env.DB.prepare(
        `SELECT release_id, track_id, track_order, track_price_cents,
                duration_seconds, track_isrc, title_override
           FROM release_tracks WHERE release_id IN (${placeholders})
          ORDER BY release_id, track_order`
    ).bind(...releaseIds).all();

    const tracksByRelease = new Map<string, unknown[]>();
    for (const t of tracksQuery.results as Record<string, unknown>[]) {
        const rid = t.release_id as string;
        if (!tracksByRelease.has(rid)) tracksByRelease.set(rid, []);
        tracksByRelease.get(rid)!.push(t);
    }
    const result = releases.map(r => ({ ...r, tracks: tracksByRelease.get(r.id as string) || [] }));
    return jsonResponse({ releases: result }, env, undefined, req);
}

async function listPublicAnnotations(req: Request, env: Env): Promise<Response> {
    const q = await env.DB.prepare(
        `SELECT track_id, title_override, band_id, artist_credits,
                mood, bpm, year, cover_art_key, updated_at
           FROM public_annotations`
    ).all();
    return jsonResponse({ annotations: q.results }, env, undefined, req);
}

async function streamTrack(req: Request, env: Env, trackId: string): Promise<Response> {
    // Resolve order:
    //  1. audio_files — the V0 MP3 the catalog-explorer uploads when a
    //     song hits "mastered" or later. Doesn't require a release row,
    //     which is the common case for in-progress catalog tracks.
    //  2. release_tracks — the per-release AAC/FLAC keys used for paid
    //     downloads on holdenu.com. Only available after release_date.
    let key: string | null = null;

    const af = await env.DB.prepare(
        `SELECT r2_key FROM audio_files WHERE track_id = ?`
    ).bind(trackId).first<{ r2_key: string }>();
    if (af) key = af.r2_key;

    if (!key) {
        const row = await env.DB.prepare(
            `SELECT rt.audio_aac_key, rt.audio_flac_key
               FROM release_tracks rt
               JOIN releases r ON r.id = rt.release_id
              WHERE rt.track_id = ?
                AND r.release_date <= datetime('now')
              ORDER BY r.release_date DESC LIMIT 1`
        ).bind(trackId).first<{ audio_aac_key: string | null; audio_flac_key: string | null }>();
        if (row) key = row.audio_aac_key || row.audio_flac_key;
    }

    if (!key) return errorResponse(404, 'no audio uploaded for this track yet', env, req);

    const range = req.headers.get('Range');
    const obj = range
        ? await env.MEDIA.get(key, { range: parseRange(range) })
        : await env.MEDIA.get(key);
    if (!obj) return errorResponse(404, 'audio missing in storage', env, req);

    const headers = new Headers(corsHeaders(env, req));
    const ext = key.split('.').pop() || '';
    const ct = ext === 'flac' ? 'audio/flac' : ext === 'mp3' ? 'audio/mpeg' : 'audio/mp4';
    headers.set('Content-Type', ct);
    headers.set('Accept-Ranges', 'bytes');
    headers.set('Cache-Control', 'public, max-age=86400');
    obj.writeHttpMetadata(headers);

    if (range && (obj as any).range) {
        const r = (obj as any).range as R2Range;
        const offset = 'offset' in r ? (r.offset || 0) : 0;
        const length = 'length' in r ? (r.length as number) : (obj.size - offset);
        headers.set('Content-Range', `bytes ${offset}-${offset + length - 1}/${obj.size}`);
        return new Response(obj.body, { status: 206, headers });
    }
    headers.set('Content-Length', String(obj.size));
    return new Response(obj.body, { status: 200, headers });
}

function parseRange(rangeHeader: string): R2Range | undefined {
    const m = /bytes=(\d+)-(\d+)?/.exec(rangeHeader);
    if (!m) return undefined;
    const offset = parseInt(m[1], 10);
    if (m[2]) return { offset, length: parseInt(m[2], 10) - offset + 1 };
    return { offset };
}

// =================================================================
// Admin: release creation
// =================================================================

interface ReleasePayload {
    id: string; name: string;
    type?: 'single' | 'ep' | 'album';
    release_date?: string;
    price_min_cents?: number;
    artwork_key?: string;
    description?: string;
    bandcamp_url?: string; spotify_url?: string; apple_url?: string; distrokid_isrc?: string;
    tracks: Array<{
        track_id: string; track_order?: number; track_price_cents?: number;
        audio_flac_key?: string; audio_aac_key?: string; preview_key?: string;
        duration_seconds?: number; track_isrc?: string; title_override?: string;
    }>;
}

async function createRelease(req: Request, env: Env): Promise<Response> {
    const body = await req.json<ReleasePayload>();
    if (!body || !body.id || !body.name || !Array.isArray(body.tracks) || body.tracks.length === 0) {
        return errorResponse(400, 'id, name, and at least one track required', env, req);
    }
    const releaseDate = body.release_date || new Date().toISOString();
    const priceFloor = body.price_min_cents ?? 100;
    const type = body.type || (body.tracks.length === 1 ? 'single' : 'ep');

    const releaseInsert = env.DB.prepare(
        `INSERT INTO releases (id, name, type, release_date, price_min_cents,
                               artwork_key, description, bandcamp_url, spotify_url,
                               apple_url, distrokid_isrc)
         VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
         ON CONFLICT(id) DO UPDATE SET
            name = excluded.name, type = excluded.type,
            release_date = excluded.release_date,
            price_min_cents = excluded.price_min_cents,
            artwork_key = excluded.artwork_key,
            description = excluded.description,
            bandcamp_url = excluded.bandcamp_url,
            spotify_url = excluded.spotify_url,
            apple_url = excluded.apple_url,
            distrokid_isrc = excluded.distrokid_isrc,
            updated_at = CURRENT_TIMESTAMP`
    ).bind(
        body.id, body.name, type, releaseDate, priceFloor,
        body.artwork_key || null, body.description || null,
        body.bandcamp_url || null, body.spotify_url || null,
        body.apple_url || null, body.distrokid_isrc || null,
    );

    const trackStmts = body.tracks.map((t, idx) => env.DB.prepare(
        `INSERT INTO release_tracks (release_id, track_id, track_order, track_price_cents,
                                     audio_flac_key, audio_aac_key, preview_key,
                                     duration_seconds, track_isrc, title_override)
         VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
         ON CONFLICT(release_id, track_id) DO UPDATE SET
            track_order = excluded.track_order,
            track_price_cents = excluded.track_price_cents,
            audio_flac_key = COALESCE(excluded.audio_flac_key, release_tracks.audio_flac_key),
            audio_aac_key  = COALESCE(excluded.audio_aac_key,  release_tracks.audio_aac_key),
            preview_key    = COALESCE(excluded.preview_key,    release_tracks.preview_key),
            duration_seconds = excluded.duration_seconds,
            track_isrc = excluded.track_isrc,
            title_override = excluded.title_override`
    ).bind(
        body.id, t.track_id, t.track_order ?? idx + 1, t.track_price_cents ?? null,
        t.audio_flac_key || null, t.audio_aac_key || null, t.preview_key || null,
        t.duration_seconds ?? null, t.track_isrc || null, t.title_override || null,
    ));

    await env.DB.batch([releaseInsert, ...trackStmts]);

    return jsonResponse({
        ok: true, release_id: body.id,
        track_count: body.tracks.length,
        release_date: releaseDate,
    }, env, { status: 201 });
}

// =================================================================
// Admin: upload tokens + receive direct PUT
// =================================================================

interface UploadUrlPayload {
    track_id: string;
    // release_id is required only for kinds that index off a release:
    // flac/aac/preview/artwork. 'mp3' is the slug-keyed catalog-wide
    // preview/stream and doesn't need a release.
    release_id?: string;
    kind: 'flac' | 'aac' | 'preview' | 'artwork' | 'mp3';
    content_type?: string;
}

async function signUploadUrl(req: Request, env: Env): Promise<Response> {
    const body = await req.json<UploadUrlPayload>();
    if (!body || !body.track_id || !body.kind) {
        return errorResponse(400, 'track_id and kind required', env, req);
    }
    if (body.kind !== 'mp3' && !body.release_id) {
        return errorResponse(400, `release_id required for kind=${body.kind}`, env, req);
    }
    const safeTrack = body.track_id.replace(/[^A-Za-z0-9_-]+/g, '_');

    let key: string;
    let contentType: string;
    if (body.kind === 'mp3') {
        // Catalog-wide preview/stream — flat keyspace by slug.
        key = `audio/${safeTrack}.mp3`;
        contentType = body.content_type || 'audio/mpeg';
    } else {
        const ext = body.kind === 'flac' ? 'flac'
                  : body.kind === 'aac' ? 'm4a'
                  : body.kind === 'preview' ? 'm4a'
                  : 'jpg';
        const folder = body.kind === 'artwork' ? 'artwork'
                      : body.kind === 'preview' ? 'preview'
                      : 'audio';
        const safeRel = (body.release_id as string).replace(/[^A-Za-z0-9_-]+/g, '_');
        key = `${folder}/${safeRel}/${safeTrack}.${ext}`;
        contentType = body.content_type
                   || (body.kind === 'artwork' ? 'image/jpeg'
                     : body.kind === 'flac'    ? 'audio/flac'
                     : 'audio/mp4');
    }
    const token = crypto.randomUUID();
    const expiresAt = new Date(Date.now() + 60 * 60 * 1000).toISOString();   // 1h

    await env.DB.prepare(
        `INSERT INTO upload_tokens (token, r2_key, content_type, track_id, release_id, kind, expires_at)
         VALUES (?, ?, ?, ?, ?, ?, ?)`
    ).bind(token, key, contentType, body.track_id, body.release_id || '', body.kind, expiresAt).run();

    const origin = new URL(req.url).origin;
    return jsonResponse({
        upload_url: `${origin}/api/upload/${token}`,
        upload_token: token,
        key,
        content_type: contentType,
        expires_at: expiresAt,
        kind: body.kind,
    }, env);
}

async function receiveUpload(req: Request, env: Env, token: string): Promise<Response> {
    if (!token) return errorResponse(400, 'token required', env, req);
    const row = await env.DB.prepare(
        `SELECT r2_key, content_type, track_id, release_id, kind, consumed_at, expires_at
           FROM upload_tokens WHERE token = ?`
    ).bind(token).first<{
        r2_key: string; content_type: string;
        track_id: string; release_id: string; kind: string;
        consumed_at: string | null; expires_at: string;
    }>();
    if (!row) return errorResponse(404, 'unknown upload token', env, req);
    if (row.consumed_at) return errorResponse(409, 'token already used', env, req);
    if (new Date(row.expires_at) < new Date()) return errorResponse(410, 'token expired', env, req);

    if (!req.body) return errorResponse(400, 'request body required', env, req);
    const reqContentType = req.headers.get('Content-Type') || row.content_type;

    // Stream the body straight into R2
    const obj = await env.MEDIA.put(row.r2_key, req.body, {
        httpMetadata: { contentType: reqContentType },
        customMetadata: {
            track_id: row.track_id,
            release_id: row.release_id,
            kind: row.kind,
        },
    });

    // Mark consumed
    await env.DB.prepare(`UPDATE upload_tokens SET consumed_at = CURRENT_TIMESTAMP WHERE token = ?`).bind(token).run();

    // Record the upload depending on kind.
    if (row.kind === 'mp3') {
        // Catalog-wide V0 MP3 stream/preview, keyed by slug only.
        await env.DB.prepare(
            `INSERT INTO audio_files (track_id, r2_key, mime, bytes, uploaded_at)
             VALUES (?, ?, ?, ?, CURRENT_TIMESTAMP)
             ON CONFLICT(track_id) DO UPDATE SET
                r2_key = excluded.r2_key,
                mime   = excluded.mime,
                bytes  = excluded.bytes,
                uploaded_at = CURRENT_TIMESTAMP`
        ).bind(row.track_id, row.r2_key, row.content_type, (obj as any)?.size ?? null).run();
    } else if (row.kind === 'flac' || row.kind === 'aac' || row.kind === 'preview') {
        const col = row.kind === 'flac' ? 'audio_flac_key'
                  : row.kind === 'aac'  ? 'audio_aac_key'
                  : 'preview_key';
        await env.DB.prepare(
            `UPDATE release_tracks SET ${col} = ? WHERE release_id = ? AND track_id = ?`
        ).bind(row.r2_key, row.release_id, row.track_id).run();
    } else if (row.kind === 'artwork') {
        await env.DB.prepare(
            `UPDATE releases SET artwork_key = ? WHERE id = ?`
        ).bind(row.r2_key, row.release_id).run();
    }

    return jsonResponse({
        ok: true, key: row.r2_key, size: (obj as any)?.size, etag: (obj as any)?.etag,
    }, env);
}

// =================================================================
// Admin: annotation sync
// =================================================================

async function syncAnnotations(req: Request, env: Env): Promise<Response> {
    const body = await req.json<{
        annotations: Array<{
            track_id: string;
            title_override?: string | null;
            band_id?: string | null;
            artist_credits?: unknown;
            mood?: string | null;
            bpm?: number | null;
            year?: number | null;
            cover_art_key?: string | null;
        }>;
    }>();
    if (!body || !Array.isArray(body.annotations)) {
        return errorResponse(400, 'annotations array required', env, req);
    }
    const stmts = body.annotations.map(a => env.DB.prepare(
        `INSERT INTO public_annotations
            (track_id, title_override, band_id, artist_credits, mood, bpm, year, cover_art_key, updated_at)
         VALUES (?, ?, ?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP)
         ON CONFLICT(track_id) DO UPDATE SET
            title_override = excluded.title_override,
            band_id = excluded.band_id,
            artist_credits = excluded.artist_credits,
            mood = excluded.mood,
            bpm = excluded.bpm,
            year = excluded.year,
            cover_art_key = excluded.cover_art_key,
            updated_at = CURRENT_TIMESTAMP`
    ).bind(
        a.track_id, a.title_override ?? null, a.band_id ?? null,
        a.artist_credits != null ? JSON.stringify(a.artist_credits) : null,
        a.mood ?? null, a.bpm ?? null, a.year ?? null, a.cover_art_key ?? null,
    ));
    if (stmts.length > 0) await env.DB.batch(stmts);
    return jsonResponse({ ok: true, count: stmts.length }, env, undefined, req);
}

// =================================================================
// Admin: workspace sync (full-state mirror for cross-machine sync)
// =================================================================
//
// public_annotations holds the sanitized subset that holdenu.com
// can serve publicly. workspace_annotations + workspace_meta hold
// the FULL state the catalog-explorer keeps in localStorage —
// admin-only. Each row has updated_at; clients merge last-write-
// wins per row, so two machines can edit different songs without
// stepping on each other.

interface WorkspaceSyncPayload {
    annotations?: Array<{ track_id: string; payload: unknown; updated_at: string }>;
    meta?: Array<{ kind: string; payload: unknown; updated_at: string }>;
}

async function getWorkspaceState(req: Request, env: Env): Promise<Response> {
    const annoQ = await env.DB.prepare(
        `SELECT track_id, payload, updated_at FROM workspace_annotations`
    ).all<{ track_id: string; payload: string; updated_at: string }>();
    const metaQ = await env.DB.prepare(
        `SELECT kind, payload, updated_at FROM workspace_meta`
    ).all<{ kind: string; payload: string; updated_at: string }>();

    const annotations: Record<string, { payload: unknown; updated_at: string }> = {};
    for (const r of annoQ.results) {
        try { annotations[r.track_id] = { payload: JSON.parse(r.payload), updated_at: r.updated_at }; }
        catch { /* drop malformed rows */ }
    }
    const meta: Record<string, { payload: unknown; updated_at: string }> = {};

