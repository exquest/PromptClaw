+
+  function initCypherClawAudio() {
+    const audio = document.getElementById("cypherclaw-live-audio");
+    if (!audio) return;
+
+    const streamUrl = audio.getAttribute("data-stream-url") || "/api/cypherclaw/live.m3u8";
+    if (audio.canPlayType("application/vnd.apple.mpegurl")) {
+      audio.src = streamUrl;
+      markPlaybackMode(audio, "native-hls");
