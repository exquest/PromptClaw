// =================================================================
// Admin: CypherClaw live segment ingest
// =================================================================

async function receiveCypherClawSegment(req: Request, env: Env): Promise<Response> {
    if (!req.body) return errorResponse(400, 'request body required', env, req);

    const sequenceHeader = req.headers.get('X-CypherClaw-Sequence') || '';
    if (!/^\d+$/.test(sequenceHeader)) {
        return errorResponse(400, 'X-CypherClaw-Sequence must be a non-negative integer', env, req);
    }
    const sequence = Number(sequenceHeader);
    if (!Number.isSafeInteger(sequence)) {
        return errorResponse(400, 'X-CypherClaw-Sequence is outside the safe integer range', env, req);
    }

    const capturedAtHeader = req.headers.get('X-CypherClaw-Captured-At');
    const capturedAt = capturedAtHeader ? new Date(capturedAtHeader) : new Date();
    if (Number.isNaN(capturedAt.getTime())) {
        return errorResponse(400, 'X-CypherClaw-Captured-At must be a valid ISO timestamp', env, req);
    }

    const dateKey = capturedAt.toISOString().slice(0, 10);
    const key = `cypherclaw/live/${dateKey}/seg-${sequence}.opus`;
    const contentType = req.headers.get('Content-Type') || CYPHERCLAW_SEGMENT_CONTENT_TYPE;
    const customMetadata: Record<string, string> = {
        sequence: String(sequence),
        captured_at: capturedAt.toISOString(),
    };

    const duration = req.headers.get('X-CypherClaw-Duration');
    const scene = req.headers.get('X-CypherClaw-Scene');
    const tuning = req.headers.get('X-CypherClaw-Tuning');
    if (duration) customMetadata.duration = duration;
    if (scene) customMetadata.scene = scene;
    if (tuning) customMetadata.tuning = tuning;

    const obj = await env.MEDIA.put(key, req.body, {
        httpMetadata: { contentType },
        customMetadata,
    });

    return jsonResponse({
        ok: true,
        key,
        sequence,
        size: obj.size,
        etag: obj.etag,
    }, env, { status: 201 }, req);
}

// =================================================================
// Public: CypherClaw live HLS playlist + segment serving
// =================================================================

interface CypherClawPlaylistEntry {
    key: string;
    sequence: number;
    duration: number;
}

async function serveCypherClawPlaylist(req: Request, env: Env): Promise<Response> {
    // Look at the current UTC date and the prior day to handle midnight
    // rollover — the window of recent segments can straddle the date
    // boundary in the R2 keyspace.
    const now = new Date();
    const todayKey = now.toISOString().slice(0, 10);
    const yesterdayKey = new Date(now.getTime() - 86_400_000).toISOString().slice(0, 10);

    const todayList = await env.MEDIA.list({ prefix: `cypherclaw/live/${todayKey}/` });
    const rawObjects: R2Object[] = [...todayList.objects];
    if (rawObjects.length < CYPHERCLAW_LIVE_PLAYLIST_WINDOW) {
        const yList = await env.MEDIA.list({ prefix: `cypherclaw/live/${yesterdayKey}/` });
        rawObjects.unshift(...yList.objects);
    }

    const parsed: CypherClawPlaylistEntry[] = [];
    for (const obj of rawObjects) {
        const m = /\/seg-(\d+)\.opus$/.exec(obj.key);
        if (!m) continue;
        const sequence = Number(m[1]);
        if (!Number.isSafeInteger(sequence)) continue;
        const durStr = obj.customMetadata?.duration;
        const dur = durStr ? Number(durStr) : NaN;
        parsed.push({
            key: obj.key,
            sequence,
            duration: Number.isFinite(dur) && dur > 0 ? dur : CYPHERCLAW_LIVE_TARGET_DURATION,

