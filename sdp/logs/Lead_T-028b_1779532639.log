test("serves a valid HLS playlist of recent segments in order", async () => {
    const env = makeEnv();
    const segBody = new Uint8Array([79, 103, 103, 83, 1, 2, 3, 4]);
    // Seed out of order to verify sort.
    await seedSegment(env, 17, segBody, { duration: "6.000" });
    await seedSegment(env, 15, segBody, { duration: "5.872" });
    await seedSegment(env, 16, segBody, { duration: "6.100" });

    const request = new Request("https://explorer.holdenu.com/api/cypherclaw/live.m3u8");
    const response = await worker.fetch(request, env, { waitUntil() {} });
    const body = await response.text();

    assert.equal(response.status, 200);
    const lines = body.split("\n");
    assert.equal(lines[0], "#EXTM3U");
    assert.ok(lines.includes("#EXT-X-VERSION:3"));
    assert.ok(lines.includes("#EXT-X-TARGETDURATION:7"));
    assert.ok(lines.includes("#EXT-X-MEDIA-SEQUENCE:15"));

    // Each segment contributes one EXTINF + one URI line, in ascending order.
    const seg15Idx = lines.indexOf(`/api/cypherclaw/segment/cypherclaw/live/${todayKey()}/seg-15.opus`);
    const seg16Idx = lines.indexOf(`/api/cypherclaw/segment/cypherclaw/live/${todayKey()}/seg-16.opus`);
    const seg17Idx = lines.indexOf(`/api/cypherclaw/segment/cypherclaw/live/${todayKey()}/seg-17.opus`);
    assert.ok(seg15Idx > 0, "seg-15 URI present");
    assert.ok(seg16Idx > seg15Idx, "seg-16 follows seg-15");
    assert.ok(seg17Idx > seg16Idx, "seg-17 follows seg-16");
    assert.equal(lines[seg15Idx - 1], "#EXTINF:5.872,");
    assert.equal(lines[seg16Idx - 1], "#EXTINF:6.100,");
    assert.equal(lines[seg17Idx - 1], "#EXTINF:6.000,");
});

