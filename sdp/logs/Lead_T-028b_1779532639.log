+test("GET / renders animated GlyphWeave backdrop image layers", async () => {
+    const env = makeEnv();
+    const request = new Request("https://cypherclaw.holdenu.com/", { method: "GET" });
+    const response = await worker.fetch(request, env, { waitUntil() {} });
+    const body = await response.text();
+
+    assert.equal(response.status, 200);
+    assert.match(body, /<section[^>]+id="glyphweave-backdrop"[^>]+data-glyphweave-state="rendered"/);
+    assert.match(body, /class="glyphweave-layer glyphweave-layer-drift"[^>]+data-glyphweave-layer="drift"[^>]+aria-hidden="true"/);
+    assert.match(body, /class="glyphweave-layer glyphweave-layer-lattice"[^>]+data-glyphweave-layer="lattice"[^>]+aria-hidden="true"/);
+    assert.match(body, /class="glyphweave-layer glyphweave-layer-bloom"[^>]+data-glyphweave-layer="bloom"[^>]+aria-hidden="true"/);
+    assert.match(body, /\.glyphweave-layer[^{]+\{[^}]+background-size: cover/);
+    assert.match(body, /background-image:[^;]+data:image\/svg\+xml/);
+    assert.match(body, /@keyframes glyphweave-drift/);
+    assert.match(body, /@media \(prefers-reduced-motion: reduce\)/);
+});
+
+test("GET / wires live audio playback with native HLS and hls.js fallback", async () => {
+    const env = makeEnv();
+    const request = new Request("https://cypherclaw.holdenu.com/", { method: "GET" });
+    const response = await worker.fetch(request, env, { waitUntil() {} });
+    const body = await response.text();
+
+    assert.equal(response.status, 200);
+    assert.match(body, /<audio[^>]+id="cypherclaw-live-audio"/);
+    assert.match(body, /data-stream-url="\/api\/cypherclaw\/live\.m3u8"/);
+    assert.doesNotMatch(body, /<audio[^>]+autoplay/);
+    assert.match(body, /cdn\.jsdelivr\.net\/npm\/hls\.js@1\/dist\/hls\.min\.js/);
+    assert.match(body, /function initCypherClawAudio\(\)/);
+    assert.match(body, /canPlayType\("application\/vnd\.apple\.mpegurl"\)/);
+    assert.match(body, /Hls\.isSupported\(\)/);
+    assert.match(body, /loadSource\(streamUrl\)/);
+    assert.match(body, /attachMedia\(audio\)/);
+    assert.match(body, /data-playback-mode/);
+    assert.doesNotMatch(body.toLowerCase(), /listener count|viewer count|analytics/);
+});
