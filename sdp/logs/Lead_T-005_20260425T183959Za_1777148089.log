     1	"""Translate EMSD scene and mix intent into live master-bus control."""
     2	from __future__ import annotations
     3	
     4	from typing import Any, Mapping
     5	
     6	from .emsd_runtime import EMSDLiveContext
     7	
     8	
     9	MASTER_NODE_ID = 99999
    10	DEFAULT_MASTER_BUS_VALUES = {
    11	    "amp": 5.0,
    12	    "sampler_amp": 1.0,
    13	    "drive": 0.15,
    14	    "warmth": 0.35,
    15	    "reverb": 0.05,
    16	    "room": 0.5,
    17	}
    18	
    19	
    20	def _clamp(value: float, lower: float, upper: float) -> float:
    21	    return max(lower, min(upper, value))
    22	
    23	
    24	def _automation_default(
    25	    scene: Any,
    26	    lane_name: str,
    27	    default: float,
    28	    *,
    29	    automation_values: Mapping[str, float] | None = None,
    30	) -> float:
    31	    if automation_values is not None and lane_name in automation_values:
    32	        try:
    33	            return float(automation_values[lane_name])
    34	        except (TypeError, ValueError):
    35	            return default
    36	    for lane in getattr(getattr(scene, "pattern", None), "automation", ()):
    37	        if getattr(lane, "name", "") == lane_name:
    38	            try:
    39	                return float(getattr(lane, "default", default))
    40	            except (TypeError, ValueError):
    41	                return default
    42	    return default
    43	
    44	
    45	def master_bus_values_for_scene(
    46	    scene: Any,
    47	    *,
    48	    context: EMSDLiveContext | None,
    49	    theramini_active: bool = False,
    50	    automation_values: Mapping[str, float] | None = None,
    51	) -> dict[str, float]:
    52	    """Return the live `sw_master_smooth` parameter set for one scene."""
    53	    scene_master_amp = _automation_default(scene, "master_amp", 0.6, automation_values=automation_values)
    54	    scene_reverb_send = _automation_default(scene, "reverb_send", 0.12, automation_values=automation_values)
    55	    scene_density = _automation_default(scene, "density", 0.35, automation_values=automation_values)
    56	    sampler_amp = round(_clamp(scene_master_amp, 0.05, 1.0), 3)
    57	    if context is None:
    58	        return {
    59	            "amp": round(_clamp(scene_master_amp * 3.2, 0.8, 5.0), 3),
    60	            "sampler_amp": sampler_amp,
    61	            "drive": round(_clamp(0.12 + scene_density * 0.04, 0.05, 0.35), 3),
    62	            "warmth": round(_clamp(0.28 + (1.0 - scene_density) * 0.12, 0.12, 0.7), 3),
    63	            "reverb": round(_clamp(0.04 + scene_reverb_send * 0.6, 0.02, 0.24), 3),
    64	            "room": round(_clamp(0.4 + scene_reverb_send * 0.8, 0.25, 0.95), 3),
    65	        }
    66	
    67	    mix = context.phase_plan.mix
    68	    lufs_tightness = _clamp(((-mix.target_lufs) - 14.0) / 10.0, 0.0, 1.0)
    69	    ceiling_tightness = _clamp(abs(float(mix.peak_ceiling_dbtp) + 1.0) / 2.0, 0.0, 1.0)
    70	    comp_strength = _clamp((float(mix.bus_comp_ratio) - 1.0) / 4.0, 0.0, 1.0)
    71	    duck_strength = _clamp(float(mix.theramini_duck_db) / 6.0, 0.0, 1.0) if theramini_active else 0.0
    72	
    73	    amp = scene_master_amp * (3.8 - (lufs_tightness * 0.65) - (duck_strength * 0.22))
    74	    drive = 0.1 + (scene_density * 0.05) + (comp_strength * 0.09) + (ceiling_tightness * 0.03)
    75	    warmth = 0.2 + ((1.0 - scene_density) * 0.16) + ((1.0 - comp_strength) * 0.05)
    76	    reverb = 0.03 + (scene_reverb_send * 0.62) + ((1.0 - scene_density) * 0.03)
    77	    room = 0.34 + (scene_reverb_send * 0.85) + (ceiling_tightness * 0.08)
    78	
    79	    return {
    80	        "amp": round(_clamp(amp, 0.8, 5.0), 3),
    81	        "sampler_amp": sampler_amp,
    82	        "drive": round(_clamp(drive, 0.05, 0.35), 3),
    83	        "warmth": round(_clamp(warmth, 0.12, 0.72), 3),
    84	        "reverb": round(_clamp(reverb, 0.02, 0.24), 3),
    85	        "room": round(_clamp(room, 0.25, 0.95), 3),
    86	    }
    87	
    88	
    89	def master_bus_n_set_args(
    90	    scene: Any,
    91	    *,
    92	    context: EMSDLiveContext | None,
    93	    theramini_active: bool = False,
