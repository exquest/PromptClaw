    default_model = "llama3.3:70b-instruct-q4_K_M"

    def __init__(self, responses: list[str]) -> None:
        self.responses = responses
        self.prompts: list[str] = []

    def health(self) -> dict[str, Any]:
        return {"status": "green", "phase": "phase-1-a6000"}

    def query(
        self,
        prompt: str,
