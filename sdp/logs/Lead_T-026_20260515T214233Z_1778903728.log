    state = RunState(
        run_id=run_id,
        title="PAL Shutdown Audit",
        status="running",
        current_phase="audit",
        created_at=created_at,
        updated_at=created_at,
        task_text=task,
        lead_agent="local-allowlist",
        verifier_agent="local-allowlist",
        route_decision={
            "task_type": SHUTDOWN_AUDIT_WORKFLOW_ID,
