def _max_finding_severity(findings: list[dict[str, Any]]) -> str:
    rank = {"ok": 0, "info": 1, "warning": 2, "critical": 3}
    severity = "ok"
    for finding in findings:
        candidate = str(finding.get("severity", "info"))
        if rank.get(candidate, 1) > rank[severity]:
            severity = candidate
    return severity


