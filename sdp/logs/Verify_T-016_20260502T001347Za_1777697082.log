                    "current_state": "healthy",
                    "tags": ["fighter", "wolfpack"],
                },
            }
        ]

        get_resp = client.get(f"/world/entities/{body['id']}", headers=headers)
        assert get_resp.status_code == 200
        assert get_resp.json() == body

