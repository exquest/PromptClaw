            "actions": ["inspect_logs_deep", "rent", "destroy", "start", "stop"],
            "rationale": "Inspect logs; cloud instance lifecycle is not available.",
        }),
        "PAL action summary.",
    ])

    result = run_pal_ops_actions(
        tmp_path,
