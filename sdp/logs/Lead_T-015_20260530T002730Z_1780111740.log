astype(np.float32)\\n\\n    capture = save_capture(\\n        samples,\\n        source=\\\"room\\\",\\n        sample_rate=sample_rate,\\n        capture_root=test_root,\\n        context={\\\"organism\\\": {\\\"arc_phase\\\": \\\"test\\\"}},\\n        captured_at=1777152600.0  # 2026-04-25T21:30:00Z\\n    )\\n\\n    print(f\\\"Captured to: {capture.path}\\\")\\n    print(f\\\"Gain applied: {capture.gain_db} dB\\\")\\n\\n    # Verify WAV properties\\n    with wave.open(str(capture.path), \\\"rb\\\") as f:\\n        print(f\\\"Channels: {f.getnchannels()}\\\")\\n        print(f\\\"Sample width: {f.getsampwidth()}\\\")\\n        print(f\\\"Framerate: {f.getframerate()}\\\")\\n        assert f.getnchannels() == 1\\n        assert f.getsampwidth() == 3  # 24-bit\\n        assert f.getframerate() == 48000\\n\\n    # Verify filename\\n    filename = capture.path.name\\n    print(f\\\"Filename: {filename}\\\")\\n    assert filename.startswith(\\\"room_20260425T213000Z_test_\\\")\\n    assert filename.endswith(\\\".wav\\\")\\n\\n    # Verify DB\\n    index_path = test_root / \\\"index.sqlite\\\"\\n    assert index_path.exists()\\n    with sqlite3.connect(str(index_path)) as con:\\n        row = con.execute(\\\"SELECT source, gain_db FROM samples WHERE sample_id = ?\\\", (capture.sample_id,)).fetchone()\\n        print(f\\\"DB Row: {row}\\\")\\n        assert row[0] == \\\"room\\\"\\n        assert abs(row[1] - capture.gain_db) < 1e-6\\n\\n    print(\\\"Manual verification SUCCESS\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    verify_capture()\\n\",\"file_path\":\"manual_verify_t009.py\"}}\n++./sdp/verification/t-009@20260425t183959z-verify.md:59:{\"type\":\"tool_use\",\"timestamp\":\"2026-04-25T22:03:49.848Z\",\"tool_name\":\"replace\",\"tool_id\":\"replace_1777154629848_0\",\"parameters\":{\"old_string\":\"    capture = save_capture(\\n        samples,\\n        source=\\\"room\\\",\\n        sample_rate=sample_rate,\\n        capture_root=test_root,\\n        context={