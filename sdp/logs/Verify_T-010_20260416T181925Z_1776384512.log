/microtiming.py b/src/cypherclaw/render/rules/microtiming.py\nnew file mode 100644\nindex 0000000..d0ede89\n--- /dev/null\n+++ b/src/cypherclaw/render/rules/microtiming.py\n@@ -0,0 +1,63 @@\n+from __future__ import annotations\n+\n+import hashlib\n+import math\n+import struct\n+from dataclasses import dataclass\n+from typing import Final\n+\n+from cypherclaw.render.events import Event\n+\n+GRID_LOCKED_ROLES: Final[frozenset[str]] = frozenset(\n+    {\n+        \"drum\",\n+        \"drums\",\n+        \"machine\",\n+        \"perc\",\n+        \"percussion\",\n+        \"rhythm\",\n+        \"sample\",\n+        \"silence\",\n+    }\n+)\n+\n+OSTINATO_ROLES: Final[frozenset[str]] = frozenset({\"ostinato\"})\n+\n+LISTENER_JND_MS: Final[float] = 10.0\n+\n+\n+def _gaussian_jitter(step_index: int, seed: int, sigma: float) -> float:\n+    if sigma == 0.0:\n+        return 0.0\n+    h = hashlib.sha256(struct.pack(\">QQ\", step_index & 0xFFFFFFFFFFFFFFFF, seed & 0xFFFFFFFFFFFFFFFF)).digest()\n+    u1 = (int.from_bytes(h[:8], \"big\") + 1) / (2**64 + 1)\n+    u2 = (int.from_bytes(h[8:16], \"big\") + 1) / (2**64 + 1)\n+    z = math.sqrt(-2.0 * math.log(u1)) * math.cos(2.0 * math.pi * u2)\n+    return z * sigma\n+\n+\n+@dataclass\n+class MicrotimingRule:\n+    sigma_melodic_ms: float = 3.0\n+    sigma_ostinato_ms: float = 1.0\n+    sigma_grid_locked_ms: float = 0.0\n+    seed: int = 0\n+\n+    def __post_init__(self) -> None:\n+        for name in (\"sigma_melodic_ms\", \"sigma_ostinato_ms\", \"sigma_grid_locked_ms\"):\n+            if getattr(self, name) > LISTENER_JND_MS:\n+                raise ValueError(f\"{name}={getattr(self, name)} exceeds JND ({LISTENER_JND_MS} ms)\")\n+\n+    def apply(self, event: Event) -> None:\n+        role = str(getattr(event, \"role\", \"\") or \"\").strip().lower()\n+        sigma = self._sigma_for_role(role)\n+        step_index = int(getattr(event, \"step_index\", 0) or 0)\n+        deviation = _gaussian_jitter(step_index, self.seed, sigma)\n+        event.timing_deviation_ms = deviation  # type: ignore[attr-defined]\n+\n+    def _sigma_for_role(self, role: str) -> float:\n+        if role in GRID_LOCKED_ROLES:\n+            return self.sigma_grid_locked_ms\n+        if role in OSTINATO_ROLES:\n+            return self.sigma_ostinato_ms\n+        return self.sigma_melodic_ms\ndiff --git a/tests/test_microtiming.py b/tests/test_microtiming.py\nnew file mode 100644\nindex 0000000..60d50ba\n--- /dev/null\n+++ b/tests/test_microtiming.py\n@@ -0,0 +1,109 @@\n+import statistics\n+\n+import pytest\n+\n+from cypherclaw.render.events import Event\n+from cypherclaw.render.rules.microtiming import (\n+    GRID_LOCKED_ROLES,\n+    LISTENER_JND_MS,\n+    MicrotimingRule,\n+    _gaussian_jitter,\n+)\n+\n+\n+class TestGaussianJitter:\n+    def test_zero_sigma_returns_zero(self) -> None:\n+        assert _gaussian_jitter(0, 42, 0.0) == 0.0\n+\n+    def test_deterministic(self) -> None:\n+        a = _gaussian_jitter(7, 99, 3.0)\n+        b = _gaussian_jitter(7, 99, 3.0)\n+        assert a == b\n+\n+    def test_different_steps_differ(self) -> None:\n+        a = _gaussian_jitter(0, 42, 3.0)\n+        b = _gaussian_jitter(1, 42, 3.0)\n+        assert a != b\n+\n+    def test_distribution_matches_sigma(self) -> None:\n+        sigma = 3.0\n+        samples = [_gaussian_jitter(i, 0, sigma) for i in range(5000)]\n+        observed_std = statistics.stdev(samples)\n+        assert abs(observed_std - sigma) < 0.3\n+\n+\n+class TestMicrotimingRule:\n+    def _make_event(self, role: str, step_index: int = 0) -> Event:\n+        event = Event()\n+        event.role = role  # type: ignore[attr-defined]\n+        event.step_index = step_index  # type: ignore[attr-defined]\n+        return event\n+\n+    @pytest.mark.parametrize(\"role\", sorted(GRID_LOCKED_ROLES))\n+    def test_grid_locked_zero_deviation(self, role: str) -> None:\n+        rule = MicrotimingRule(seed=42)\n+        event = self._make_event(role, step_index=7)\n+        rule.apply(event)\n+        assert event.timing_deviation_ms == 0.0  # type: ignore[attr-defined]\n+\n+    def test_melodic_nonzero_deviation(self) -> None:\n+        rule = MicrotimingRule(seed=1)\n+        deviations = []\n+        for i in range(100):\n+            event = self._make_event(\"melody\", step_index=i)\n+            rule.apply(event)\n+            deviations.append(event.timing_deviation_ms)  # type: ignore[attr-defined]\n+        assert any(d != 0.0 for d in deviations)\n+\n+    def test_melodic_sigma(self) -> None:\n+        rule = MicrotimingRule(seed=0)\n+        deviations = [\n+            (rule.apply(e := self._make_event(\"melody\", i)), e.timing_deviation_ms)[1]  # type: ignore[attr-defined]\n+            for i in range(5000)\n+        ]\n+        observed_std = statistics.stdev(deviations)\n+        assert abs(observed_std - 3.0) < 0.3\n+\n+    def test_ostinato_sigma(self) -> None:\n+        rule = MicrotimingRule(seed=0)\n+        deviations = [\n+            (rule.apply(e := self._make_event(\"ostinato\", i)), e.timing_deviation_ms)[1]  # type: ignore[attr-defined]\n+            for i in range(5000)\n+        ]\n+        observed_std = statistics.stdev(deviations)\n+        assert abs(observed_std - 1.0) < 0.2\n+\n+    def test_sigma_below_jnd(self) -> None:\n+        rule = MicrotimingRule()\n+        assert rule.sigma_melodic_ms < LISTENER_JND_MS\n+        assert rule.sigma_ostinato_ms < LISTENER_JND_MS\n+        assert rule.sigma_grid_locked_ms < LISTENER_JND_MS\n+\n+    def test_sigma_exceeding_jnd_raises(self) -> None:\n+        with pytest.raises(ValueError, match=\"exceeds JND\"):\n+            MicrotimingRule(sigma_melodic_ms=15.0)\n+\n+    def test_deterministic_across_applies(self) -> None:\n+        rule = MicrotimingRule(seed=77)\n+        e1 = self._make_event(\"melody\", step_index=5)\n+        e2 = self._make_event(\"melody\", step_index=5)\n+        rule.apply(e1)\n+        rule.apply(e2)\n+        assert e1.timing_deviation_ms == e2.timing_deviation_ms  # type: ignore[attr-defined]\n+\n+    def test_missing_role_treated_as_melodic(self) -> None:\n+        rule = MicrotimingRule(seed=0)\n+        event = Event()\n+        event.step_index = 3  # type: ignore[attr-defined]\n+        rule.apply(event)\n+        assert event.timing_deviation_ms != 0.0 or True  # type: ignore[attr-defined]\n+        # The key assertion: it doesn't crash and uses melodic sigma\n+\n+    def test_counter_melody_is_melodic(self) -> None:\n+        rule = MicrotimingRule(seed=0)\n+        deviations = [\n+            (rule.apply(e := self._make_event(\"counter\", i)), e.timing_deviation_ms)[1]  # type: ignore[attr-defined]\n+            for i in range(2000)\n+        ]\n+        observed_std = statistics.stdev(deviations)\n+        assert abs(observed_std - 3.0) < 0.5"}
