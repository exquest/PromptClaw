"""Fractal development — progressive depth refinement for SDP tasks.

Adds depth-aware task generation to the SDP pipeline. Instead of building
modules from scratch, the fractal system:

1. Generates a complete skeleton at depth 0 (interfaces only)
2. Each pass deepens all modules by one level
3. Every depth level goes through lead/verify pipeline
4. The project becomes sharper at every scale simultaneously

Depths:
  0 — Skeleton: signatures + NotImplementedError, interface tests pass
  1 — Stub: trivial returns (correct types, wrong values), basic tests pass
  2 — Simple: one-path implementation, end-to-end works
  3 — Full: edge cases, error handling, integration
  4 — Polished: optimized, documented, battle-tested

Commands:
  sdp fractal init <prd.md>     Generate depth-0 skeleton from PRD
  sdp fractal scan [path]       Analyze modules and report current depth
  sdp fractal deepen [--target] Generate tasks for next depth, load into queue
  sdp fractal status            Show resolution map across the project
"""

from __future__ import annotations

import ast
import json
import re
from collections.abc import Callable, Mapping
from dataclasses import dataclass, field
from pathlib import Path
from typing import TYPE_CHECKING, Any

from jinja2 import TemplateNotFound

from sdp.pipeline.alternator import AgentAlternator
from sdp.prompts.builder import PromptBuilder

if TYPE_CHECKING:
    from sdp.agents.base import AgentAdapter, AgentResult
    from sdp.config.settings import SDPSettings

_DEPTH_FOUR_DOCSTRING_THRESHOLD = 0.9
_DEPTH_FOUR_TEST_RATIO_THRESHOLD = 0.5
_DEPTH_FOUR_MARKER_RE = re.compile(r"\b(?:TODO|FIXME|HACK)\b", re.IGNORECASE)

_JS_TS_EXTENSIONS = {".js", ".ts", ".tsx"}

# JS/TS regex heuristics
_JS_NOT_IMPLEMENTED_RE = re.compile(
    r"throw\s+new\s+Error\(\s*['\"]not\s+implemented['\"]", re.IGNORECASE
)
_JS_TRIVIAL_ARROW_RE = re.compile(
    r"=>\s*(?:null|undefined|0|true|false|'[^']*'|\"[^\"]*\"|\[\s*\]|\(\s*\{?\s*\}?\s*\))\s*[;,\n]"
)
_JS_TRIVIAL_RETURN_RE = re.compile(
    r"^\s*return\s+(?:null|undefined|0|true|false|'[^']*'|\"[^\"]*\"|\[\s*\]|\{\s*\})\s*;",
    re.MULTILINE,
)
_JS_LOGIC_BLOCK_RE = re.compile(r"\b(?:if|for|while|switch|try)\s*\(")
_JS_FUNCTION_RE = re.compile(
    r"(?:export\s+)?(?:async\s+)?function\s+(\w+)"
)
_JS_ARROW_FUNC_RE = re.compile(
    r"(?:export\s+)?(?:const|let|var)\s+(\w+)\s*=\s*(?:async\s+)?\("
)
_JS_CLASS_RE = re.compile(r"(?:export\s+)?class\s+(\w+)")
_PYTHON_MODULE_PATH_RE = re.compile(r"^[A-Za-z0-9_./-]+\.py$")
_PYTHON_IDENTIFIER_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")


@dataclass(frozen=True)
class SkeletonCallableSpec:
    """Structured callable definition returned from the skeleton planner."""

    name: str
    signature: str
    docstring: str = ""


@dataclass(frozen=True)
class SkeletonClassSpec:
    """Structured class definition returned from the skeleton planner."""

    name: str
    docstring: str = ""
    methods: tuple[SkeletonCallableSpec, ...] = ()


@dataclass(frozen=True)
class SkeletonModuleSpec:
    """Structured module definition returned from the skeleton planner."""

    path: str
    docstring: str = ""
    classes: tuple[SkeletonClassSpec, ...] = ()
    functions: tuple[SkeletonCallableSpec, ...] = ()


# ── Depth Classification ──────────────────────────────────────

@dataclass
class ModuleDepth:
    """Analysis result for a single module."""
    path: str
    module_name: str
    depth: int  # 0-4
    reason: str
    classes: list[str] = field(default_factory=list)
    functions: list[str] = field(default_factory=list)
    not_implemented_count: int = 0
    trivial_return_count: int = 0
    real_logic_count: int = 0
    test_count: int = 0
    test_files: list[str] = field(default_factory=list)
    test_coverage: float = 0.0
    test_boosted: bool = False
    line_count: int = 0


def classify_depth(source_path: str | Path) -> ModuleDepth:
    """Classify a module's implementation depth.

    Dispatches to language-specific classifiers based on file extension.
    """
    path = Path(source_path)
    if not path.exists():
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="file does not exist",
        )

    if path.suffix in _JS_TS_EXTENSIONS:
        return classify_depth_js(path)
    if path.suffix == ".py":
        return _classify_depth_python(path)

    return ModuleDepth(
        path=str(path),
        module_name=path.stem,
        depth=-1,
        reason=f"unsupported file type: {path.suffix}",
    )


def _classify_depth_python(path: Path) -> ModuleDepth:
    """Classify a Python module's implementation depth via AST analysis."""
    try:
        source = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        # Source file is not UTF-8 (e.g., vendored Big5 / GBK / latin-1 test
        # fixtures). Fall back to permissive decode so we still report depth=0.
        try:
            source = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return ModuleDepth(
                path=str(path),
                module_name=path.stem,
                depth=-1,
                reason="unreadable file",
            )
    except OSError:
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="unreadable file",
        )
    lines = source.splitlines()
    line_count = len(lines)

    try:
        tree = ast.parse(source)
    except SyntaxError as e:
        return ModuleDepth(
            path=str(path), module_name=path.stem,
            depth=-1, reason=f"syntax error: {e}",
            line_count=line_count,
        )

    classes = []
    functions = []
    not_implemented = 0
    trivial_returns = 0
    real_logic = 0
    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef] = []

    for node in ast.walk(tree):
        if isinstance(node, ast.ClassDef):
            classes.append(node.name)
        elif isinstance(node, ast.FunctionDef | ast.AsyncFunctionDef):
            if _is_public_function(node):
                functions.append(node.name)
                public_function_nodes.append(node)

            # Analyze function body
            body = node.body
            # Skip docstrings
            if body and isinstance(body[0], ast.Expr) and isinstance(body[0].value, ast.Constant):
                body = body[1:]

            if not body:
                trivial_returns += 1
                continue

            body_source = ast.get_source_segment(source, node) or ""

            if 'NotImplementedError' in body_source:
                not_implemented += 1
            elif _is_trivial_return(body) or (
                len(body) <= 3
                and not any(
                    isinstance(statement, ast.If | ast.For | ast.While | ast.Try)
                    for statement in body
                )
            ):
                trivial_returns += 1
            else:
                real_logic += 1

    total_funcs = not_implemented + trivial_returns + real_logic
    if total_funcs == 0:
        depth = 0
        reason = "no functions found"
    elif not_implemented == total_funcs:
        depth = 0
        reason = "all functions raise NotImplementedError"
    elif not_implemented > 0:
        depth = 0
        reason = f"{not_implemented}/{total_funcs} not implemented"
    elif trivial_returns == total_funcs:
        depth = 1
        reason = "all functions return trivial values"
    elif trivial_returns > real_logic:
        depth = 1
        reason = f"{trivial_returns}/{total_funcs} trivial, {real_logic} real"
    elif real_logic > 0 and line_count < 100:
        depth = 2
        reason = f"simple implementations ({line_count} lines)"
    elif real_logic > 0 and line_count < 300:
        depth = 3
        reason = f"full implementations ({line_count} lines, {real_logic} real functions)"
    else:
        depth = 3
        reason = f"substantial ({line_count} lines, {real_logic} real functions)"

    matching_tests = _find_matching_test_files(path)
    test_coverage, max_single_file_coverage = _compute_test_coverage(
        path.stem, functions, matching_tests
    )
    test_boosted = max_single_file_coverage > 0.8

    if depth == 3:
        if not matching_tests:
            depth = 2
            reason = f"{reason.split('(')[0].strip()} (no tests)"
        elif _qualifies_for_depth_four(
            source=source,
            line_count=line_count,
            public_function_nodes=public_function_nodes,
            matching_tests=matching_tests,
            test_boosted=test_boosted,
        ):
            depth = 4
            reason = (
                f"polished ({line_count} lines, {_docstring_coverage(public_function_nodes):.0%} "
                f"docstrings, tests {_test_line_ratio(line_count, matching_tests):.2f}x)"
            )


    if test_boosted:
        reason += " (test boosted)"

    return ModuleDepth(
        path=str(path),
        module_name=path.stem,
        depth=depth,
        reason=reason,
        classes=classes,
        functions=functions,
        not_implemented_count=not_implemented,
        trivial_return_count=trivial_returns,
        real_logic_count=real_logic,
        test_count=len(matching_tests),
        test_files=[str(t) for t in matching_tests],
        test_coverage=test_coverage,
        test_boosted=test_boosted,
        line_count=line_count,
    )


def _is_public_function(node: ast.FunctionDef | ast.AsyncFunctionDef) -> bool:
    """Return whether a function contributes to the module's public surface."""
    return node.name == '__init__' or not node.name.startswith('_')


def _qualifies_for_depth_four(
    *,
    source: str,
    line_count: int,
    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef],
    matching_tests: list[Path],
    test_boosted: bool = False,
) -> bool:
    """Return whether a depth-3 module qualifies as polished depth 4."""
    if line_count <= 100:
        return False
    if _DEPTH_FOUR_MARKER_RE.search(source):
        return False
    if _docstring_coverage(public_function_nodes) <= _DEPTH_FOUR_DOCSTRING_THRESHOLD:
        return False
    if test_boosted:
        return True
    return _test_line_ratio(line_count, matching_tests) >= _DEPTH_FOUR_TEST_RATIO_THRESHOLD


def _docstring_coverage(
    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef],
) -> float:
    """Return the fraction of public functions with docstrings."""
    if not public_function_nodes:
        return 0.0

    documented = sum(1 for node in public_function_nodes if ast.get_docstring(node) is not None)
    return documented / len(public_function_nodes)


def _test_line_ratio(source_line_count: int, matching_tests: list[Path]) -> float:
    """Return the total test-to-source line ratio for matching tests."""
    if source_line_count <= 0:
        return 0.0

    test_line_count = 0
    for test_path in matching_tests:
        try:
            test_line_count += len(test_path.read_text().splitlines())
        except OSError:
            continue
    return test_line_count / source_line_count


def _compute_test_coverage(
    module_name: str,
    public_functions: list[str],
    matching_tests: list[Path],
) -> tuple[float, float]:
    """Return (total_coverage, max_single_file_coverage) of public functions."""
    if not public_functions:
        return 0.0, 0.0

    total_imported_funcs: set[str] = set()
    max_single_file_coverage = 0.0

    for test_path in matching_tests:
        try:
            tree = ast.parse(test_path.read_text())
        except (SyntaxError, OSError):
            continue

        file_imported_funcs: set[str] = set()
        for node in ast.walk(tree):
            if isinstance(node, ast.ImportFrom) and node.module and node.module.endswith(
                module_name
            ):
                for alias in node.names:
                    if alias.name in public_functions:
                        file_imported_funcs.add(alias.name)
                        total_imported_funcs.add(alias.name)
        
        file_coverage = len(file_imported_funcs) / len(public_functions)
        if file_coverage > max_single_file_coverage:
            max_single_file_coverage = file_coverage

    total_coverage = len(total_imported_funcs) / len(public_functions)
    return total_coverage, max_single_file_coverage


def _find_matching_test_files(source_path: Path) -> list[Path]:
    """Locate matching test files under the nearest tests directory.

    Python convention: ``test_<module>.py``
    JS/TS convention: ``<module>.test.{js,ts,tsx}``, ``<module>.spec.{js,ts,tsx}``,
    and ``__tests__/<module>.{js,ts,tsx}``
    """
    stem = source_path.stem
    results: list[Path] = []

    if source_path.suffix == ".py":
        pattern = f"test_{stem}.py"
        for parent in source_path.parents:
            tests_dir = parent / "tests"
            if tests_dir.is_dir():
                results.extend(tests_dir.rglob(pattern))
                break
    elif source_path.suffix in _JS_TS_EXTENSIONS:
        js_patterns = [
            f"{stem}.test.js", f"{stem}.test.ts", f"{stem}.test.tsx",
            f"{stem}.spec.js", f"{stem}.spec.ts", f"{stem}.spec.tsx",
        ]
        for parent in source_path.parents:
            # Search tests/ directory
            tests_dir = parent / "tests"
            if tests_dir.is_dir():
                for pat in js_patterns:
                    results.extend(tests_dir.rglob(pat))
            # Search __tests__/ directory
            dunder_tests = parent / "__tests__"
            if dunder_tests.is_dir():
                for ext in (".js", ".ts", ".tsx"):
                    match_path = dunder_tests / f"{stem}{ext}"
                    if match_path.exists():
                        results.append(match_path)
            if results:
                break

    return sorted(set(results))


def _is_trivial_return(body: list[ast.stmt]) -> bool:
    """Check if a function body is just a trivial return."""
    if len(body) == 1 and isinstance(body[0], ast.Return):
        ret = body[0].value
        if ret is None:
            return True
        if isinstance(ret, ast.Constant):
            return True
        if isinstance(ret, ast.List | ast.Dict | ast.Tuple):
            return True
    return False


# ── JS/TS Depth Classification ──────────────────────────────────


def classify_depth_js(source_path: str | Path) -> ModuleDepth:
    """Classify a JS/TS module's implementation depth using regex heuristics."""
    path = Path(source_path)
    if not path.exists():
        return ModuleDepth(
            path=str(path), module_name=path.stem,
            depth=-1, reason="file does not exist",
        )

    try:
        source = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        try:
            source = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return ModuleDepth(
                path=str(path), module_name=path.stem,
                depth=-1, reason="unreadable file",
            )
    except OSError:
        return ModuleDepth(
            path=str(path), module_name=path.stem,
            depth=-1, reason="unreadable file",
        )
    lines = source.splitlines()
    line_count = len(lines)

    # Extract classes and functions
    classes = _JS_CLASS_RE.findall(source)
    functions: list[str] = []
    functions.extend(_JS_FUNCTION_RE.findall(source))
    functions.extend(_JS_ARROW_FUNC_RE.findall(source))

    # Analyze function bodies via regex heuristics
    not_implemented = len(_JS_NOT_IMPLEMENTED_RE.findall(source))
    trivial_arrows = len(_JS_TRIVIAL_ARROW_RE.findall(source))
    trivial_returns = len(_JS_TRIVIAL_RETURN_RE.findall(source))
    total_trivial = trivial_arrows + trivial_returns
    logic_blocks = len(_JS_LOGIC_BLOCK_RE.findall(source))

    total_funcs = len(functions)
    matching_tests = _find_matching_test_files(path)

    # Depth classification
    if total_funcs == 0:
        depth = 0
        reason = "no functions found"
    elif not_implemented > 0:
        depth = 0
        reason = f"{not_implemented}/{total_funcs} not implemented"
    elif total_trivial >= total_funcs and logic_blocks == 0:
        depth = 1
        reason = f"all functions return trivial values ({total_trivial} trivial)"
    elif total_trivial > logic_blocks and logic_blocks == 0:
        depth = 1
        reason = f"{total_trivial}/{total_funcs} trivial, {logic_blocks} real"
    elif logic_blocks > 0 and line_count < 100:
        depth = 2
        reason = f"simple implementations ({line_count} lines)"
    elif logic_blocks > 0 and line_count < 300:
        depth = 3
        reason = f"full implementations ({line_count} lines, {logic_blocks} logic blocks)"
    elif logic_blocks > 0:
        depth = 3
        reason = f"substantial ({line_count} lines, {logic_blocks} logic blocks)"
    else:
        depth = 1
        reason = f"trivial ({total_trivial} trivial returns)"

    # Depth 3 with no tests → cap at 2 (same as Python)
    if depth == 3 and not matching_tests:
        depth = 2
        reason = f"{reason.split('(')[0].strip()} (no tests)"

    return ModuleDepth(
        path=str(path),
        module_name=path.stem,
        depth=depth,
        reason=reason,
        classes=classes,
        functions=functions,
        not_implemented_count=not_implemented,
        trivial_return_count=total_trivial,
        real_logic_count=logic_blocks,
        test_count=len(matching_tests),
        test_files=[str(t) for t in matching_tests],
        test_coverage=0.0,  # JS/TS test coverage analysis not yet supported
        test_boosted=False,
        line_count=line_count,
    )


# ── Scanning ──────────────────────────────────────────────────

_DEFAULT_SCAN_PATTERNS = ("*.py", "*.js", "*.ts", "*.tsx")

# Path components that mean "this is vendored / generated / cache, not project source."
# Matched as exact directory-name components in the path, so ".venv" matches
# "/x/.venv/lib/..." but does NOT match "/x/myvenv/foo".
_EXCLUDED_DIR_COMPONENTS: frozenset[str] = frozenset({
    ".venv",
    "venv",
    "env",
    ".env",          # env directories — distinct from .env files (handled below)
    "node_modules",
    "__pycache__",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache",
    ".tox",
    ".nox",
    "dist",
    "build",
    ".next",
    ".nuxt",
    ".cache",
    ".git",
    ".hg",
    ".svn",
    "htmlcov",
    "coverage",
    "site-packages",  # belt-and-suspenders against vendored Python deps
    ".eggs",
    "egg-info",
    ".idea",
    ".vscode",
    ".DS_Store",
    "vendor",        # Go / PHP / Ruby vendored deps
    "target",        # Rust / Java build dirs
    ".gradle",
    ".sdp",          # SDP runtime state — not source code
})


def _is_excluded_path(path: Path, root: Path) -> bool:
    """Return True if *path* contains any excluded directory component
    between *root* and the file itself."""
    try:
        rel = path.relative_to(root)
    except ValueError:
        rel = path
    for part in rel.parts:
        # `.env` directory matches; `.env` file (no parts after it) does not
        if part in _EXCLUDED_DIR_COMPONENTS:
            return True
        # egg-info as suffix (e.g., "promptclaw.egg-info")
        if part.endswith(".egg-info"):
            return True
    return False


def scan_directory(
    directory: str | Path,
    pattern: str | None = None,
    *,
    patterns: tuple[str, ...] | None = None,
) -> list[ModuleDepth]:
    """Scan a directory and classify all supported modules.

    Excludes vendored / generated / cache directories per
    ``_EXCLUDED_DIR_COMPONENTS`` so we don't deepen third-party code.

    If *pattern* is given, only that glob is used (backward compat).
    Otherwise *patterns* defaults to Python + JS/TS globs.
    """
    if pattern is not None:
        globs: tuple[str, ...] = (pattern,)
    elif patterns is not None:
        globs = patterns
    else:
        globs = _DEFAULT_SCAN_PATTERNS

    seen: set[Path] = set()
    results: list[ModuleDepth] = []
    root = Path(directory).resolve()

    for glob in globs:
        for path in sorted(root.rglob(glob)):
            if path in seen:
                continue
            seen.add(path)
            if _is_excluded_path(path, root):
                continue
            # Skip Python private/init files
            if path.suffix == '.py' and (path.name.startswith('_') or path.name == '__init__.py'):
                continue
            # Skip TypeScript declaration files
            if path.name.endswith('.d.ts'):
                continue
            # Skip JS/TS files starting with _ (private convention)
            if path.suffix in _JS_TS_EXTENSIONS and path.name.startswith('_'):
                continue
            results.append(classify_depth(path))

    return sorted(results, key=lambda m: m.path)


def calculate_depth_distribution(modules: list[ModuleDepth]) -> dict[int, int]:
    """Calculate the distribution of depth levels for valid modules (depth >= 0)."""
    counts: dict[int, int] = {}
    for m in modules:
        if m.depth >= 0:
            counts[m.depth] = counts.get(m.depth, 0) + 1
    return dict(sorted(counts.items()))


def project_depth_score(modules: list[ModuleDepth]) -> float:
    """Calculate the average depth score for valid modules (depth >= 0)."""
    valid_modules = [m for m in modules if m.depth >= 0]
    if not valid_modules:
        return 0.0
    return sum(m.depth for m in valid_modules) / len(valid_modules)


def depth_summary(modules: list[ModuleDepth]) -> dict[int, int]:
    """Count modules at each depth level."""
    counts: dict[int, int] = {}
    for m in modules:
        counts[m.depth] = counts.get(m.depth, 0) + 1
    return dict(sorted(counts.items()))


def modules_needing_attention(
    modules: list[ModuleDepth], target: int
) -> list[ModuleDepth]:
    """Return valid modules whose depth is below *target*, sorted by path."""
    return sorted(
        [m for m in modules if 0 <= m.depth < target],
        key=lambda m: m.path,
    )


def modules_changed_since_last_scan(
    current: list[ModuleDepth], previous: list[ModuleDepth]
) -> list[dict[str, object]]:
    """Compare two module snapshots and return depth changes.

    Returns a list of ``{"module_path": str, "old_depth": int | None,
    "new_depth": int}`` dicts for every module whose depth differs between
    *previous* and *current*.  Modules present in *current* but absent from
    *previous* appear with ``old_depth=None``.  Modules that are only in
    *previous* (i.e. removed) are not included — matching the behaviour of
    the DB-backed ``query_fractal_depth_changes``.
    """
    prev_by_path: dict[str, int] = {m.path: m.depth for m in previous if m.depth >= 0}
    changes: list[dict[str, object]] = []
    for m in current:
        if m.depth < 0:
            continue
        old_depth = prev_by_path.get(m.path)
        if old_depth != m.depth:
            changes.append(
                {"module_path": m.path, "old_depth": old_depth, "new_depth": m.depth}
            )
    return sorted(changes, key=lambda c: str(c["module_path"]))


# ── Task Generation ───────────────────────────────────────────

DEPTH_CRITERIA = {
    0: (
        "Skeleton: class/function signatures exist, interface tests pass, all raise "
        "NotImplementedError"
    ),
    1: (
        "Stub: all functions return correct types (trivial values), basic tests pass, "
        "system importable"
    ),
    2: "Simple: one-path implementation, functions produce meaningful output, end-to-end works",
    3: (
        "Full: edge cases handled, error handling, integration with other modules, "
        "comprehensive tests"
    ),
    4: "Polished: optimized for performance, documented, battle-tested in production",
}

DEPTH_PROMPTS = {
    1: (
        "Replace all NotImplementedError with trivial but type-correct returns. Empty "
        "lists, zero, None, hardcoded strings. The module must be importable and return "
        "the right types."
    ),
    2: (
        "Implement the simplest working version of each function. One algorithm path, no "
        "edge cases. The system should work end-to-end with this module."
    ),
    3: (
        "Full implementation with edge cases, error handling, and integration. Add "
        "comprehensive tests covering normal and error paths."
    ),
    4: "Optimize performance, add documentation, handle all edge cases found in production.",
}


def generate_deepen_task(
    module: ModuleDepth,
    target_depth: int | None = None,
) -> dict[str, Any]:
    """Generate an SDP task spec to deepen a module by one level."""
    current = module.depth
    target = target_depth if target_depth is not None else current + 1

    if target > 4:
        target = 4
    if target <= current:
        return {}

    return {
        "description": (
            f"Deepen {module.module_name} from depth {current} to depth {target}: "
            f"{DEPTH_CRITERIA.get(target, '')}"
        ),
        "tier": "T1" if target <= 1 else "T2",
        "criteria": DEPTH_CRITERIA.get(target, ""),
        "source": "fractal",
        "priority": 5 - target,  # Higher depth = lower priority
        "context": {
            "module_path": module.path,
            "current_depth": current,
            "target_depth": target,
            "prompt_hint": DEPTH_PROMPTS.get(target, ""),
            "classes": module.classes,
            "functions": module.functions,
            "line_count": module.line_count,
        },
    }


def _extract_imports_python(path: Path) -> set[str]:
    """Extract module names imported by a Python file."""
    try:
        tree = ast.parse(path.read_text())
    except (SyntaxError, OSError):
        return set()

    imported: set[str] = set()
    for node in ast.walk(tree):
        if isinstance(node, ast.Import):
            for alias in node.names:
                # Take the top-level module name (e.g. "foo" from "foo.bar")
                imported.add(alias.name.split(".")[0])
        elif isinstance(node, ast.ImportFrom) and node.module:
            imported.add(node.module.split(".")[0])
    return imported


_JS_IMPORT_FROM_RE = re.compile(
    r"""(?:import\s+.*?\s+from\s+['"]([^'"]+)['"]|require\(\s*['"]([^'"]+)['"]\s*\))"""
)


def _extract_imports_js(path: Path) -> set[str]:
    """Extract module names imported by a JS/TS file (local imports only)."""
    try:
        source = path.read_text()
    except OSError:
        return set()

    imported: set[str] = set()
    for m in _JS_IMPORT_FROM_RE.finditer(source):
        specifier = m.group(1) or m.group(2)
        if specifier.startswith("."):
            # Resolve relative import to a bare stem name
            resolved = (path.parent / specifier).resolve()
            imported.add(resolved.stem)
    return imported


def _dependency_sort(modules: list[ModuleDepth]) -> list[ModuleDepth]:
    """Sort modules so that dependencies (imported modules) come before consumers.

    Uses Kahn's algorithm for topological sort. Modules not in any dependency
    relationship preserve their original relative order.
    """
    # Build a lookup from module stem → module
    by_name: dict[str, ModuleDepth] = {}
    for m in modules:
        stem = Path(m.path).stem
        # On collision, keep the first one (matches scan_directory dedup)
        if stem not in by_name:
            by_name[stem] = m

    name_set = set(by_name)

    # Build adjacency: consumer → set of dependencies (within the module set)
    deps: dict[str, set[str]] = {stem: set() for stem in name_set}
    for m in modules:
        stem = Path(m.path).stem
        if stem not in deps:
            continue
        p = Path(m.path)
        if p.suffix == ".py":
            raw_imports = _extract_imports_python(p)
        elif p.suffix in _JS_TS_EXTENSIONS:
            raw_imports = _extract_imports_js(p)
        else:
            raw_imports = set()
        deps[stem] = raw_imports & name_set

    # Kahn's algorithm — compute in-degree (how many modules import this one)
    in_degree: dict[str, int] = {stem: 0 for stem in name_set}
    for stem, dep_set in deps.items():
        for dep in dep_set:
            in_degree[dep] = in_degree.get(dep, 0)
            in_degree[stem] = in_degree.get(stem, 0)
    # Actually: in_degree counts how many modules *depend on* a module?
    # No — for topological sort we want: edge from dep → consumer.
    # in_degree of a node = number of edges pointing to it = number of its dependencies.
    reverse: dict[str, set[str]] = {stem: set() for stem in name_set}
    for consumer, dep_set in deps.items():
        for dep in dep_set:
            reverse[dep].add(consumer)

    in_degree = {stem: len(dep_set) for stem, dep_set in deps.items()}

    # Original order index for stable tie-breaking
    order_idx = {Path(m.path).stem: i for i, m in enumerate(modules)}

    queue: list[tuple[int, str]] = []
    for stem in name_set:
        if in_degree[stem] == 0:
            queue.append((order_idx.get(stem, 0), stem))
    queue.sort()

    sorted_names: list[str] = []
    while queue:
        _, stem = queue.pop(0)
        sorted_names.append(stem)
        for consumer in sorted(reverse.get(stem, set()), key=lambda s: order_idx.get(s, 0)):
            in_degree[consumer] -= 1
            if in_degree[consumer] == 0:
                queue.append((order_idx.get(consumer, 0), consumer))
                queue.sort()

    # Modules in cycles get appended at the end in original order
    remaining = [s for s in name_set if s not in set(sorted_names)]
    remaining.sort(key=lambda s: order_idx.get(s, 0))
    sorted_names.extend(remaining)

    name_to_pos = {name: i for i, name in enumerate(sorted_names)}
    return sorted(modules, key=lambda m: name_to_pos.get(Path(m.path).stem, len(sorted_names)))


def generate_deepen_batch(
    modules: list[ModuleDepth],
    target_depth: int | None = None,
) -> list[dict[str, Any]]:
    """Generate tasks to deepen all modules that are below target depth.

    Modules are ordered by dependency — lower-level modules (utilities, models)
    that are imported by other modules appear before their consumers.
    """
    ordered = _dependency_sort(modules)
    tasks = []
    for m in ordered:
        if m.depth < 0:
            continue  # Skip broken modules
        target = target_depth if target_depth is not None else m.depth + 1
        if target > m.depth:
            task = generate_deepen_task(m, target)
            if task:
                tasks.append(task)
    return tasks


# ── PRD Skeleton Generation ───────────────────────────────────

def _default_skeleton_agent_factory(settings: SDPSettings) -> dict[str, AgentAdapter]:
    """Build the configured SDP agent pool for fractal skeleton generation."""
    from sdp.cli import _build_agents

    return _build_agents(settings)


def _skeleton_prompt(prd_text: str, output_dir: Path) -> str:
    """Render the lead-agent prompt for structured skeleton planning."""
    builder = PromptBuilder()
    context = {
        "prd_text": prd_text,
        "output_dir": str(output_dir),
    }
    try:
        return builder.render("fractal_skeleton.md", context)
    except TemplateNotFound:
        return (
            "You are SDP's lead agent for fractal depth-0 skeleton generation.\n\n"
            "Read the PRD and return JSON only with a top-level `modules` array. "
            "Each module must have `path`, optional `docstring`, optional `classes`, "
            "and optional `functions`. Class items must have `name`, optional "
            "`docstring`, and optional `methods`. Function/method items must have "
            "`name`, `signature`, and optional `docstring`. Signatures must omit the "
            "`def` keyword and use the form `(args) -> ReturnType`.\n\n"
            f"Output directory hint: {output_dir}\n\n"
            "PRD:\n"
            f"{prd_text}\n"
        )


def _select_skeleton_lead_agent(
    settings: SDPSettings,
    agents: Mapping[str, AgentAdapter],
) -> tuple[str, AgentAdapter] | None:
    """Select the lead agent for skeleton generation from the configured pool."""
    available: list[tuple[str, AgentAdapter]] = []
    for name, adapter in agents.items():
        try:
            if adapter.is_available():
                available.append((name, adapter))
        except Exception:
            continue

    if not available:
        return None

    settings.state_db_path.parent.mkdir(parents=True, exist_ok=True)
    alternator = AgentAlternator(
        db_path=str(settings.state_db_path),
        agents=[name for name, _adapter in available],
    )
    lead_name, _verify_name = alternator.peek_next_lead()
    lead_adapter = next((adapter for name, adapter in available if name == lead_name), None)
    if lead_adapter is None:
        lead_name, lead_adapter = available[0]
    return lead_name, lead_adapter


def _invoke_skeleton_lead_agent(
    prd_text: str,
    output_dir: Path,
    *,
    settings: SDPSettings,
    agent_factory: Callable[[SDPSettings], Mapping[str, AgentAdapter]],
) -> AgentResult | None:
    """Invoke the selected lead agent and return its structured planning output."""
    agents = agent_factory(settings)
    selection = _select_skeleton_lead_agent(settings, agents)
    if selection is None:
        return None

    lead_name, lead_adapter = selection
    prompt = _skeleton_prompt(prd_text, output_dir)
    task_id = f"FRAC-INIT-{output_dir.name or 'root'}".upper()
    try:
        return lead_adapter.invoke(
            prompt,
            label=f"FractalInit: {Path(output_dir).name or 'root'}",
            tier="T2",
            task_id=task_id,
            role="lead",
            stream_output=False,
        )
    except Exception:
        return None


def _extract_json_fragment(text: str) -> str | None:
    """Extract the first balanced JSON object or array from free-form text."""
    fence_match = re.search(r"```(?:json)?\s*\n?(.*?)\n?\s*```", text, re.DOTALL)
    candidate = fence_match.group(1).strip() if fence_match else text.strip()

    start = -1
    opening = ""
    for index, char in enumerate(candidate):
        if char in {"{", "["}:
            start = index
            opening = char
            break
    if start < 0:
        return None

    closing = "}" if opening == "{" else "]"
    depth = 0
    in_string = False
    escape = False
    for index in range(start, len(candidate)):
        char = candidate[index]
        if in_string:
            if escape:
                escape = False
                continue
            if char == "\\":
                escape = True
                continue
            if char == '"':
                in_string = False
            continue

        if char == '"':
            in_string = True
            continue
        if char == opening:
            depth += 1
            continue
        if char == closing:
            depth -= 1
            if depth == 0:
                return candidate[start:index + 1]

    return None


def _clean_docstring(text: object) -> str:
    """Normalize user/agent-provided docstring content for safe emission."""
    if not isinstance(text, str):
        return ""
    cleaned = text.strip()
    return cleaned.replace('"""', '\\"\\"\\"')


def _normalize_identifier(value: object) -> str:
    """Return a validated Python identifier or an empty string."""
    if not isinstance(value, str):
        return ""
    text = value.strip()
    if not _PYTHON_IDENTIFIER_RE.fullmatch(text):
        return ""
    return text


def _normalize_signature(value: object) -> str:
    """Return a minimally validated Python signature or an empty string."""
    if not isinstance(value, str):
        return ""
    text = value.strip()
    if not text.startswith("(") or ")" not in text:
        return ""
    return text


def _parse_callable_specs(items: object) -> tuple[SkeletonCallableSpec, ...]:
    """Parse function/method specs from structured agent output."""
    if not isinstance(items, list):
        return ()

    parsed: list[SkeletonCallableSpec] = []
    seen: set[str] = set()
    for item in items:
        if not isinstance(item, dict):
            continue
        name = _normalize_identifier(item.get("name"))
        signature = _normalize_signature(item.get("signature"))
        if not name or not signature or name in seen:
            continue
        seen.add(name)
        parsed.append(
            SkeletonCallableSpec(
                name=name,
                signature=signature,
                docstring=_clean_docstring(item.get("docstring")),
            )
        )
    return tuple(parsed)


def _parse_class_specs(items: object) -> tuple[SkeletonClassSpec, ...]:
    """Parse class specs from structured agent output."""
    if not isinstance(items, list):
        return ()

    parsed: list[SkeletonClassSpec] = []
    seen: set[str] = set()
    for item in items:
        if not isinstance(item, dict):
            continue
        name = _normalize_identifier(item.get("name"))
        if not name or name in seen:
            continue
        seen.add(name)
        parsed.append(
            SkeletonClassSpec(
                name=name,
                docstring=_clean_docstring(item.get("docstring")),
                methods=_parse_callable_specs(item.get("methods")),
            )
        )
    return tuple(parsed)


def _parse_skeleton_modules(stdout: str) -> list[SkeletonModuleSpec] | None:
    """Parse validated module plans from lead-agent JSON output."""
    json_fragment = _extract_json_fragment(stdout)
    if json_fragment is None:
        return None

    try:
        parsed = json.loads(json_fragment)
    except (json.JSONDecodeError, TypeError, ValueError):
        return None

    raw_modules: object = parsed.get("modules") if isinstance(parsed, dict) else parsed

    if not isinstance(raw_modules, list):
        return None

    modules: list[SkeletonModuleSpec] = []
    seen_paths: set[str] = set()
    for item in raw_modules:
        if not isinstance(item, dict):
            continue
        raw_path = item.get("path")
        if not isinstance(raw_path, str):
            continue
        module_path = raw_path.strip().replace("\\", "/")
        if (
            not module_path
            or module_path in seen_paths
            or not _PYTHON_MODULE_PATH_RE.fullmatch(module_path)
            or module_path.startswith("/")
            or "/../" in f"/{module_path}/"
            or module_path.startswith("../")
        ):
            continue

        classes = _parse_class_specs(item.get("classes"))
        functions = _parse_callable_specs(item.get("functions"))
        if not classes and not functions:
            continue

        seen_paths.add(module_path)
        modules.append(
            SkeletonModuleSpec(
                path=module_path,
                docstring=_clean_docstring(item.get("docstring")),
                classes=classes,
                functions=functions,
            )
        )

    return modules or None


def _ensure_package_files(output_dir: Path, module_rel_path: str) -> list[str]:
    """Create missing package `__init__.py` files for a module path."""
    created: list[str] = []
    relative = Path(module_rel_path)
    for package_dir in relative.parents:
        if package_dir == Path("."):
            continue
        init_path = output_dir / package_dir / "__init__.py"
        init_path.parent.mkdir(parents=True, exist_ok=True)
        if init_path.exists():
            continue
        init_path.write_text("", encoding="utf-8")
        created.append(str(init_path))
    root_init = output_dir / "__init__.py"
    if not root_init.exists():
        root_init.write_text("", encoding="utf-8")
        created.append(str(root_init))
    return created


def _render_callable(spec: SkeletonCallableSpec, *, indent: str = "") -> list[str]:
    """Render a function or method at depth 0."""
    lines = [f"{indent}def {spec.name}{spec.signature}:"]
    if spec.docstring:
        lines.append(f'{indent}    """{spec.docstring}"""')
    lines.append(f"{indent}    raise NotImplementedError")
    return lines


def _render_class(spec: SkeletonClassSpec) -> list[str]:
    """Render a class definition at depth 0."""
    lines = [f"class {spec.name}:"]
    if spec.docstring:
        lines.append(f'    """{spec.docstring}"""')

    if spec.methods:
        if spec.docstring:
            lines.append("")
        for index, method in enumerate(spec.methods):
            lines.extend(_render_callable(method, indent="    "))
            if index < len(spec.methods) - 1:
                lines.append("")
    else:
        if spec.docstring:
            lines.append("")
        lines.append("    pass")
    return lines


def _render_skeleton_module(module: SkeletonModuleSpec) -> str:
    """Render a structured module plan as a deterministic depth-0 Python file."""
    module_docstring = module.docstring or f"{Path(module.path).stem} — depth 0 skeleton."
    lines = [
        f'"""{module_docstring}"""',
        "",
        "from __future__ import annotations",
        "",
    ]

    sections: list[list[str]] = []
    for class_spec in module.classes:
        sections.append(_render_class(class_spec))
    for function_spec in module.functions:
        sections.append(_render_callable(function_spec))

    for index, section in enumerate(sections):
        lines.extend(section)
        if index < len(sections) - 1:
            lines.extend(["", ""])

    if not sections:
        lines.append("# No interfaces inferred from PRD.")

    return "\n".join(lines).rstrip() + "\n"


def _generate_skeleton_from_plan(
    modules: list[SkeletonModuleSpec],
    output_dir: Path,
) -> list[str]:
    """Materialize structured module plans into depth-0 skeleton files."""
    created: list[str] = []
    output_dir.mkdir(parents=True, exist_ok=True)

    for module in modules:
        module_path = output_dir / Path(module.path)
        try:
            module_path.relative_to(output_dir)
        except ValueError:
            continue
        module_path.parent.mkdir(parents=True, exist_ok=True)
        created.extend(_ensure_package_files(output_dir, module.path))
        if module_path.exists():
            continue
        module_path.write_text(_render_skeleton_module(module), encoding="utf-8")
        created.append(str(module_path))

    return list(dict.fromkeys(created))


def _generate_skeleton_from_prd_fallback(prd_text: str, output_dir: Path) -> list[str]:
    """Legacy minimal stub generation for when agent planning is unavailable."""
    output_dir.mkdir(parents=True, exist_ok=True)
    created: list[str] = []

    arch_match = re.search(r"```(?:\w+)?\s*\n(.*?)```", prd_text, re.DOTALL)
    if arch_match:
        for line in arch_match.group(1).splitlines():
            match = re.match(r"[├└│─\s]*(\w+\.py)(?:\s|$)", line)
            if match is None:
                continue
            mod_name = match.group(1).replace(".py", "")
            mod_path = output_dir / match.group(1)
            if mod_path.exists():
                continue
            mod_path.write_text(
                f'"""{mod_name} — depth 0 skeleton."""\n\n'
                f"from __future__ import annotations\n\n"
                f"# TODO: Extract classes and methods from PRD requirement\n"
                f"# and generate proper signatures at depth 0.\n",
                encoding="utf-8",
            )
            created.append(str(mod_path))

    init_path = output_dir / "__init__.py"
    if not init_path.exists():
        init_path.write_text("", encoding="utf-8")
        created.append(str(init_path))

    return created


def generate_skeleton_from_prd(
    prd_path: str | Path,
    output_dir: str | Path,
    *,
    settings: SDPSettings | None = None,
    agent_factory: Callable[[SDPSettings], Mapping[str, AgentAdapter]] | None = None,
) -> list[str]:
    """Parse a PRD and generate depth-0 skeleton files.

    Uses the configured SDP lead agent to infer a structured module plan and
    renders deterministic depth-0 Python skeletons from that plan. Falls back
    to the legacy minimal architecture-stub path if agent planning is
    unavailable or unparsable.
    """
    prd_text = Path(prd_path).read_text(encoding="utf-8")
    output_path = Path(output_dir)
    active_settings = settings
    if active_settings is None:
        from sdp.config.settings import load_settings

        active_settings = load_settings()
    active_agent_factory = agent_factory or _default_skeleton_agent_factory

    result = _invoke_skeleton_lead_agent(
        prd_text,
        output_path,
        settings=active_settings,
        agent_factory=active_agent_factory,
    )
    if result is not None and not result.timed_out:
        modules = _parse_skeleton_modules(result.stdout)
        if modules:
            created = _generate_skeleton_from_plan(modules, output_path)
            if created:
                return created

    return _generate_skeleton_from_prd_fallback(prd_text, output_path)


# ── CLI Integration ───────────────────────────────────────────
# These functions are designed to be called from sdp._cli_impl
# via a typer subcommand group.

def cli_scan(path: str = ".", db_path: str | None = None) -> None:
    """Scan and report module depths, persisting results to the state DB."""
    modules = scan_directory(path)
    summary = depth_summary(modules)

    # Persist to DB so monitor and report commands have data
    if db_path is not None:
        persist_scan_results(modules, db_path)
        print(f"Persisted {len([m for m in modules if m.depth >= 0])} module depths to DB.")

    print(f"\nFractal Depth Scan: {path}")
    print("=" * 60)
    for d, count in summary.items():
        label = DEPTH_CRITERIA.get(d, "unknown")[:40]
        bar = "\u2588" * count
        print(f"  Depth {d}: {count:3d} modules  {bar}  ({label})")

    print(f"\n{'Module':<40s} {'Depth':>5s}  {'Lines':>5s}  {'Cov':>6s}  Reason")
    print("-" * 100)
    for m in sorted(modules, key=lambda x: (x.depth, x.module_name)):
        cov_str = f"{m.test_coverage:.0%}" if m.test_count > 0 else "-"
        if getattr(m, 'test_boosted', False):
            cov_str += " *"
        print(
            f"  {m.module_name:<38s} {m.depth:>5d}  {m.line_count:>5d}"
            f"  {cov_str:>6s}  {m.reason[:35]}"
        )


def cli_deepen(path: str = ".", target: int | None = None) -> list[dict[str, Any]]:
    """Generate deepen tasks for all modules below target depth."""
    modules = scan_directory(path)
    tasks = generate_deepen_batch(modules, target)
    print(f"\nGenerated {len(tasks)} deepen tasks:")
    for t in tasks:
        ctx = t.get("context", {})
        print(
            f"  [{t['tier']}] {ctx.get('module_path', '?')}: "
            f"depth {ctx.get('current_depth')} \u2192 {ctx.get('target_depth')}"
        )
    return tasks


def cli_status(path: str = ".") -> None:
    """Show fractal resolution map."""
    modules = scan_directory(path)
    if not modules:
        print("No modules found.")
        return

    print(f"\nFractal Resolution Map: {path}")
    print(f"{'Module':<35s} [0] [1] [2] [3] [4]")
    print("-" * 60)
    for m in sorted(modules, key=lambda x: x.module_name):
        bar = ""
        for d in range(5):
            if d <= m.depth:
                bar += " \u2588\u2588\u2588"
            else:
                bar += " \u2591\u2591\u2591"
        print(f"  {m.module_name:<33s}{bar}")


# ── Depth History Persistence ─────────────────────────────────

def persist_scan_results(modules: list[ModuleDepth], db_path: str) -> None:
    """Persist scan results to the SDP state database.

    Filters out modules with depth < 0 (parse errors, missing files).
    """
    from datetime import UTC, datetime

    from sdp.state._db_impl import Database

    valid = [(m.path, m.depth, m.line_count) for m in modules if m.depth >= 0]
    if not valid:
        db = Database(db_path)
        db.close()
        return

    ts = datetime.now(UTC).isoformat()
    snapshots = [(path, depth, lc, ts) for path, depth, lc in valid]

    db = Database(db_path)
    try:
        db.insert_fractal_depth_batch(snapshots)
    finally:
        db.close()




def generate_report_markdown(
    project_score: float,
    target: int,
    distribution: dict[int, int],
    needs_attention: list[ModuleDepth],
    changes: list[dict[str, object]],
) -> str:
    """Generate a markdown summary of the fractal depth report."""
    lines = [
        "# Fractal Depth Report",
        "",
        f"**Project Score:** {project_score:.2f}",
        f"**Target Depth:** {target}",
        "",
        "## Depth Distribution",
    ]
    for d in sorted(distribution.keys()):
        lines.append(f"- Depth {d}: {distribution[d]} modules")
    lines.append("")

    lines.append("## Modules Needing Attention (Depth < Target)")
    if needs_attention:
        for m in sorted(needs_attention, key=lambda x: x.path):
            boost_marker = " *" if getattr(m, 'test_boosted', False) else ""
            lines.append(f"- `{m.path}` (Depth {m.depth}){boost_marker}")
    else:
        lines.append("None")
    lines.append("")

    lines.append("## Changes Since Last Scan")
    if changes:
        for c in sorted(changes, key=lambda x: str(x["module_path"])):
            old = c["old_depth"] if c["old_depth"] is not None else "None"
            new = c["new_depth"] if c["new_depth"] is not None else "None"
            lines.append(f"- `{c['module_path']}`: {old} -> {new}")
    else:
        lines.append("No changes.")
    lines.append("")

    return "\n".join(lines)


def cli_report(
    path: str = ".", target: int = 4, json_output: bool = False, db_path: str = ".sdp/state.db"
) -> None:
    """Emit a structured summary of project fractal depth."""
    import json

    from sdp.state._db_impl import Database

    # 1. Get the latest timestamp from DB before we scan and persist
    db = Database(db_path)
    try:
        row = db._conn.execute("SELECT MAX(scan_timestamp) FROM fractal_depth_history").fetchone()
        prev_ts = row[0] if row else None
    finally:
        db.close()

    # 2. Scan and persist
    modules = scan_directory(path)
    persist_scan_results(modules, db_path)

    # 3. Compute summary
    distribution = calculate_depth_distribution(modules)
    project_score = project_depth_score(modules)
    needs_attention = modules_needing_attention(modules, target)

    # 4. Get changes since prev_ts
    db = Database(db_path)
    try:
        previous_modules = []
        if prev_ts:
            rows = db._conn.execute(
                "SELECT module_path, depth FROM fractal_depth_history WHERE scan_timestamp = ?",
                (prev_ts,)
            ).fetchall()
            previous_modules = [
                ModuleDepth(path=r[0], module_name="", depth=r[1], reason="") for r in rows
            ]
        changes = modules_changed_since_last_scan(modules, previous_modules)
    finally:
        db.close()

    # 5. Output
    if json_output:
        out = {
            "project_score": round(project_score, 2),
            "target_depth": target,
            "distribution": distribution,
            "needs_attention": [
                {"module": m.path, "depth": m.depth, "test_boosted": m.test_boosted}
                for m in needs_attention
            ],
            "changes": changes,
        }
        print(json.dumps(out, indent=2))
    else:
        print(
            generate_report_markdown(
                project_score, target, distribution, needs_attention, changes
            )
        )


def cli_history(
    db_path: str = ".sdp/state.db",
    module_path: str | None = None,
    since: str | None = None,
) -> None:
    """Show fractal depth history from the state database."""
    from sdp.state._db_impl import Database

    db = Database(db_path)
    try:
        results = db.query_fractal_depth_history(module_path=module_path, since=since)
    finally:
        db.close()

    if not results:
        print("No depth history found.")
        return

    print(f"\n{'Module':<40s} {'Depth':>5s}  {'Lines':>5s}  Timestamp")
    print("-" * 80)
    for r in results:
        print(f"  {r.module_path:<38s} {r.depth:>5d}  {r.line_count:>5d}  {r.scan_timestamp}")


