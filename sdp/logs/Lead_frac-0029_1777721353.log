+@dataclass(frozen=True)
+class AccompanimentPatternSnapshot:
+    """Resolved diagnostic view for one generated accompaniment pattern."""
+
+    pattern_type: int
+    pattern_name: str
+    energy_band: str
+    root_hz: float
+    fifth_hz: float
+    beat_seconds: float
+    loud: float
