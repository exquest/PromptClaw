+    if not isinstance(value, Iterable) or isinstance(value, (bytes, bytearray)):
+        return (str(value).strip().lower(),) if str(value).strip() else ()
+
+    tags: list[str] = []
+    for item in value:
+        tag = str(item).strip().lower()
+        if tag:
+            tags.append(tag)
+    return tuple(tags)
