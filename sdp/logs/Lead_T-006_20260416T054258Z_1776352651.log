+def _rhythmic_sympathy_for_onset_rate(onset_rate: float) -> str:
+    if onset_rate > _FAST_ONSET_THRESHOLD:
+        return "spacious_afterbeats"
+    if onset_rate < _SLOW_ONSET_THRESHOLD:
+        return "long_tone_breath"
+    return "shared_pulse"
+
