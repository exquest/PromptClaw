+        "turn_taking": (),
+        "imitation": (0, 12),
+        "counterpoint": (-5, 3, 7),
+        "accompaniment": (-12, -5, 0),
+        "call_response": (2, 7, 12),
+        "commentary": (3, 5, 10),
+        "completion": (5, 7, 12),
+        "silence_request": (),
+        "solo": (),
+    }
+    return intervals[policy]
+
