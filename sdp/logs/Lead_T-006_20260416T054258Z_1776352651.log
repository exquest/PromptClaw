+) -> tuple[str, str]:
+    if phase == "solo":
+        return "cypherclaw", "none"
+    if phase == "silence":
+        return "none", "none"
+    if speaker == "human":
+        return "theramini", "cypherclaw"
+    if may_play or speaker == "cypherclaw":
