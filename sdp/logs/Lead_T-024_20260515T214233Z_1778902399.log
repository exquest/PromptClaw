+            )
+    else:
+        lines.append("- none")
+
+    lines.append("unmanaged remote files:")
+    if plan.diff.unmanaged_remote:
+        for entry in plan.diff.unmanaged_remote:
+            lines.append(f"- {entry.status.upper()} {entry.target}")
+    else:
+        lines.append("- none")
+    return "\n".join(lines)
