+                "/opt/pal/manual.txt": {"content": "operator managed\n"},
+                "/opt/pal/unchanged.txt": {"content": "same\n"},
+            },
+            sort_keys=True,
+        ),
+        encoding="utf-8",
+    )
+    return remote_inventory_path

