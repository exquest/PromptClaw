+def build_pal_deploy_plan(
+    project_root: Path,
+    *,
+    manifest_path: Path | None = None,
+    remote_inventory: Iterable[PALDeploymentRemoteFile] = (),
+    remote_inventory_source: str = "empty",
+) -> PALDeploymentPlan:
