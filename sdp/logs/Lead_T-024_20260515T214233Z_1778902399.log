    local_sha256: str | None
    remote_sha256: str | None
    local_mode: str | None
    remote_mode: str | None
    local_owner: str | None
    remote_owner: str | None
    local_group: str | None
    remote_group: str | None
    changed_fields: tuple[str, ...] = ()

