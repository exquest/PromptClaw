+            "planned_changes": [entry.to_dict() for entry in self.planned_changes],
+            "unchanged": [entry.to_dict() for entry in self.diff.unchanged],
+            "unmanaged_remote": [entry.to_dict() for entry in self.diff.unmanaged_remote],
