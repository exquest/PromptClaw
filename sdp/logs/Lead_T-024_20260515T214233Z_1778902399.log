+@dataclass(frozen=True)
+class PALDeploymentPlan:
+    manifest: PALDeploymentManifest
+    diff: PALDeploymentDiff
+    remote_inventory_source: str
+    workflow_id: str = "pal_deploy_plan"
+    dry_run: bool = True
+    remote_writes: bool = False
