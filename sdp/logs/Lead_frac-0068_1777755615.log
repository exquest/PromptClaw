+card 2: Loopback [Loopback], device 1: Loopback PCM [Loopback PCM]
+card 3: USB [Scarlett 4i4 USB], device 2: USB Audio [USB Audio]
+""".strip()
+
+        devices = contact_mic_calibration.parse_alsa_devices(listing)
+        scarlett = [
