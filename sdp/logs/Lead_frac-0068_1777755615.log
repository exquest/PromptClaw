+                        "duration_seconds": duration_seconds,
+                        "channels": channels,
+                        "sample_rate": sample_rate,
+                        "device": device,
+                    }
+                )
+                if output_path.stem == "quiet_ambient_180s":
+                    frame = (1000, 3000)
+                else:
+                    frame = (7000, 2000)
+                frames = [frame] * (duration_seconds * sample_rate)
+                _write_wav(
+                    output_path,
+                    channels=channels,
+                    sample_rate=sample_rate,
+                    frames=frames,
+                )
