+
+        scenario_code = contact_mic_calibration.main(["list-scenarios", "--json"])
+        scenario_stdout = capsys.readouterr().out
+        scenario_payload = json.loads(scenario_stdout)
+
+        analyze_code = contact_mic_calibration.main(
