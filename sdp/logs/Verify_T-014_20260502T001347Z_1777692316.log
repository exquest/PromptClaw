   301	        "kind",
   302	        "name",
   303	        "domain",
   304	        "properties",
   305	        "data",
   306	        "attributes",
   307	    }
   308	    for key, value in data.items():
   309	        if key in consumed:
   310	            continue
   311	        properties.setdefault(key, value)
   312	
   313	    raw_props = data.get("properties")
