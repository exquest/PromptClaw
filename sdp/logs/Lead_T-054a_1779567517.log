  @keyframes glyphweave-drift { from { transform: translate3d(-2%, -1%, 0) scale(1.02); } to { transform: translate3d(2%, 1.5%, 0) scale(1.08); } }
  @keyframes glyphweave-lattice { from { transform: rotate(-4deg) translate3d(-1%, 0, 0) scale(1.04); } to { transform: rotate(3deg) translate3d(1%, -1%, 0) scale(1.07); } }
  @keyframes glyphweave-bloom { from { transform: translate3d(1%, -1%, 0) scale(1.02); } to { transform: translate3d(-1.5%, 1%, 0) scale(1.10); } }
