-- ============================================================
-- holdenu D1 schema — Phase 3 additions
-- ============================================================
-- upload_tokens: short-lived tokens minted by /api/upload-url and
-- consumed by /api/upload/:token. The Worker validates each PUT against
-- this table so the upload endpoint stays admin-gated end-to-end.
-- ============================================================

CREATE TABLE IF NOT EXISTS upload_tokens (
    token        TEXT PRIMARY KEY,
    r2_key       TEXT NOT NULL,
    content_type TEXT NOT NULL,
    track_id     TEXT,
    release_id   TEXT,
    kind         TEXT,                 -- 'flac' | 'aac' | 'preview' | 'artwork'
    consumed_at  TEXT,
    expires_at   TEXT NOT NULL,
    created_at   TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX IF NOT EXISTS idx_upload_tokens_expires ON upload_tokens(expires_at);
/Users/anthony/Programming/catalog-explorer/worker/migrations/0003_audio_files.sql
-- ============================================================
-- audio_files — streamable MP3s independent of release events.
-- ============================================================
-- A song can be "mastered" (or later) in the catalog-explorer's
-- pipeline and uploaded for public streaming BEFORE it has a
-- release row on holdenu.com. The explorer auto-fires an upload
-- whenever a pipeline_override hits a stage >= mastered, so
-- /api/stream/<slug> needs a separate index of "this slug has
-- an MP3 in R2" that doesn't depend on the release_tracks table.
--
-- /api/stream/<slug> resolves a key by:
--   1. audio_files (if present) — preview/stream of the V0 MP3
--   2. release_tracks (fallback) — the older flac/aac path used
--      for paid downloads on holdenu.com releases
-- ============================================================

CREATE TABLE IF NOT EXISTS audio_files (
    track_id     TEXT PRIMARY KEY,           -- song slug from the catalog
    r2_key       TEXT NOT NULL,              -- "audio/<slug>.mp3"
    mime         TEXT NOT NULL DEFAULT 'audio/mpeg',
    bytes        INTEGER,                    -- final encoded size
    duration_ms  INTEGER,                    -- from ffprobe
    bitrate_kbps INTEGER,                    -- VBR average from ffprobe
    sha256       TEXT,                       -- of the MP3 body, for re-upload skip
    source_path  TEXT,                       -- original render path on disk (diagnostic)
    uploaded_at  TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP)
);

CREATE INDEX IF NOT EXISTS idx_audio_files_uploaded
    ON audio_files (uploaded_at DESC);
/Users/anthony/Programming/catalog-explorer/worker/migrations/0004_workspace_sync.sql
-- ============================================================
-- Workspace sync — full-state mirror so multiple machines share
-- one source of truth via D1.
-- ============================================================
-- Existing tables:
--   public_annotations   — sanitized, public-readable subset of
--                          annotations for released tracks.
--   releases / release_tracks — release events for holdenu.com.
-- Both are intentionally restricted scope.
--
-- New tables here mirror the full workspace state that the
-- catalog-explorer keeps in localStorage today: track annotations
-- (all fields), manual edges, song credits, custom bands, custom
-- artists. Per-row updated_at lets each machine last-write-wins
-- without clobbering each other's unrelated edits.
-- ============================================================

-- One row per song with the full annotation payload as JSON.
-- Anything in localStorage's track_annotations[<id>] lands here.
CREATE TABLE IF NOT EXISTS workspace_annotations (
    track_id     TEXT PRIMARY KEY,
    payload      TEXT NOT NULL,
    updated_at   TEXT NOT NULL
);

CREATE INDEX IF NOT EXISTS idx_workspace_anno_updated
    ON workspace_annotations (updated_at DESC);

-- Catch-all for "rarely changing global" state: bands, artists,
-- song_credits, manual_edges. One row per kind, payload is JSON.
-- last-write-wins by updated_at — concurrent overlap on these is
-- rare enough that per-row blob is fine.
CREATE TABLE IF NOT EXISTS workspace_meta (
    kind         TEXT PRIMARY KEY,   -- 'bands' | 'artists' | 'song_credits' | 'manual_edges'
    payload      TEXT NOT NULL,
    updated_at   TEXT NOT NULL
);

