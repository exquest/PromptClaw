sify_audio_content,\n@@ -27,6 +28,17 @@ def _silence(sr: int, duration: float) -> list[int]:\n     return [0] * int(sr * duration)\n \n \n+def _saw_wave(freq: float, sr: int, duration: float, amplitude: int = 16000) -> list[int]:\n+    \"\"\"Generate a synthetic saw wave as 16-bit integer samples.\"\"\"\n+    n = int(sr * duration)\n+    period = sr / freq\n+    out = []\n+    for i in range(n):\n+        phase = (i % period) / period\n+        out.append(int(amplitude * ((phase * 2.0) - 1.0)))\n+    return out\n+\n+\n # === detect_amplitude ===\n \n \n@@ -142,6 +154,45 @@ class TestOnsetDetection:\n         assert detect_onset(0.005, 0.001, release_threshold=0.01) == \"silence\"\n \n \n+# === detect_click_transients ===\n+\n+\n+class TestClickDetection:\n+    def test_clean_sine_has_no_clicks(self):\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=6000)\n+        result = detect_click_transients(samples, 48000)\n+        assert result[\"count\"] == 0\n+        assert result[\"events\"] == []\n+        assert result[\"suppressed_as_periodic\"] is False\n+\n+    def test_single_impulse_is_detected(self):\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=6000)\n+        samples[24000] = 32000\n+        result = detect_click_transients(samples, 48000)\n+        assert result[\"count\"] == 1\n+        assert len(result[\"events\"]) == 1\n+        event = result[\"events\"][0]\n+        assert abs(event[\"time_seconds\"] - 0.5) < 0.005\n+        assert event[\"width_samples\"] <= 4\n+        assert event[\"residual\"] > 0.5\n+\n+    def test_sparse_click_burst_is_retained(self):\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=5000)\n+        for idx in (9600, 10176, 10752, 11328, 11904):\n+            samples[idx] = 32000\n+        result = detect_click_transients(samples, 48000)\n+        assert result[\"count\"] == 5\n+        assert result[\"suppressed_as_periodic\"] is False\n+\n+    def test_dense_impulse_train_is_suppressed_as_periodic(self):\n+        samples = _silence(48000, 1.0)\n+        for idx in range(0, len(samples), 240):\n+            samples[idx] = 32000\n+        result = detect_click_transients(samples, 48000)\n+        assert result[\"count\"] == 0\n+        assert result[\"suppressed_as_periodic\"] is True\n+\n+\n # === classify_audio_content ===\n \n \ndiff --git a/tests/test_continuous_learner.py b/tests/test_continuous_learner.py\nindex a6fedc3..5100aee 100644\n--- a/tests/test_continuous_learner.py\n+++ b/tests/test_continuous_learner.py\n@@ -22,6 +22,12 @@ class TestRecording:\n         assert cl.growth.total_songs == 1\n         assert \"D\" in cl.growth.keys_explored\n \n+    def test_start_song_tracks_context_tags(self):\n+        cl = ContinuousLearner()\n+        cl.start_song(1, \"D\", \"waltz\", 90, context_tags=[\"ember\", \"lift\", \"house_garden\"])\n+        assert cl.current_song is not None\n+        assert cl.current_song.context_tags == [\"ember\", \"lift\", \"house_garden\"]\n+\n     def test_record_note(self):\n         cl = ContinuousLearner()\n         cl.start_song(1, \"D\", \"waltz\", 90)\n@@ -117,6 +123,50 @@ class TestEvaluation:\n         if result.get(\"fragment_score\", 0) > 0.5:\n             assert mock_memory.store_fragment.called\n \n+    def test_end_song_stores_context_tags_in_memory(self):\n+        mock_memory = MagicMock()\n+        cl = ContinuousLearner()\n+        cl.start_song(1, \"D\", \"waltz\", 90, context_tags=[\"ember\", \"lift\", \"house_garden\"])\n+        for f, d, a in [(220, 0.5, False), (440, 1.0, True),\n+                         (415, 0.25, False), (330, 0.75, False)]:\n+            cl.record_note(float(f), d, a)\n+        result = cl.end_song(memory=mock_memory)\n+        if result.get(\"fragment_score\", 0) > 0.5:\n+            assert mock_memory.store_fragment.called\n+            context = mock_memory.store_fragment.call_args.args[1]\n+            assert \"ember\" in context\n+            assert \"lift\" in context\n