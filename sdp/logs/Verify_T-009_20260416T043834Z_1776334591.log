ments are returned, ranked by:\n+        1. number of matched keywords\n+        2. fragment score\n+        3. recency\n+        \"\"\"\n+        normalized = [\n+            str(keyword).strip().lower()\n+            for keyword in keywords\n+            if str(keyword).strip()\n+        ]\n+        if not normalized:\n+            return [\n+                fragment\n+                for fragment in self.get_recent(count=count)\n+                if float(fragment.get(\"score\", 0.0) or 0.0) >= min_score\n+            ]\n+\n+        matches: list[tuple[int, float, float, dict]] = []\n+        for fragment in self._fragments:\n+            score = float(fragment.get(\"score\", 0.0) or 0.0)\n+            if score < min_score:\n+                continue\n+            context = str(fragment.get(\"context\", \"\") or \"\").lower()\n+            match_count = sum(1 for keyword in normalized if keyword in context)\n+            if match_count <= 0:\n+                continue\n+            stored_at = float(fragment.get(\"stored_at\", 0.0) or 0.0)\n+            matches.append((match_count, score, stored_at, fragment))\n+\n+        if not matches:\n+            return [\n+                fragment\n+                for fragment in self.get_recent(count=count)\n+                if float(fragment.get(\"score\", 0.0) or 0.0) >= min_score\n+            ]\n+\n+        matches.sort(key=lambda item: (item[0], item[1], item[2]), reverse=True)\n+        return [fragment for *_meta, fragment in matches[:count]]\n+\n     def prune(self, max_fragments: int = 200) -> None:\n         \"\"\"Keep only the top-scored fragments up to max_fragments.\"\"\"\n         if len(self._fragments) <= max_fragments:\ndiff --git a/my-claw/tools/server_health.py b/my-claw/tools/server_health.py\nindex 5342b3a..93fd934 100644\n--- a/my-claw/tools/server_health.py\n+++ b/my-claw/tools/server_health.py\n@@ -89,6 +89,22 @@ def check_health() -> HealthReport:\n     except Exception as e:\n         health[\"warnings\"].append(f\"Load check failed: {e}\")\n \n+    # 3b. I/O wait\n+    try:\n+        if platform.system() == \"Linux\":\n+            result = subprocess.run([\"vmstat\", \"1\", \"2\"], capture_output=True, text=True, timeout=5)\n+            data_lines = [line.strip() for line in result.stdout.splitlines() if line.strip()]\n+            for line in reversed(data_lines):\n+                parts = line.split()\n+                if len(parts) >= 17 and parts[0].lstrip(\"-\").isdigit():\n+                    io_wait = int(parts[-2])\n+                    health[\"checks\"][\"io_wait\"] = f\"{io_wait}%\"\n+                    if io_wait > 25:\n+                        health[\"warnings\"].append(f\"High I/O wait: {io_wait}%\")\n+                    break\n+    except Exception as e:\n+        health[\"warnings\"].append(f\"I/O check failed: {e}\")\n+\n     # 4. Zombie/D-state processes\n     try:\n         result = subprocess.run([\"ps\", \"aux\"], capture_output=True, text=True, timeout=5)\ndiff --git a/my-claw/tools/tamagotchi.py b/my-claw/tools/tamagotchi.py\nindex 44cafb1..b4d5fbd 100644\n--- a/my-claw/tools/tamagotchi.py\n+++ b/my-claw/tools/tamagotchi.py\n@@ -93,6 +93,7 @@ class Pet:\n         self.mood = 80\n         self.hunger = 50\n         self.energy = 100\n+        self.class_name: str | None = None\n         self.incarnation: int = 1\n         self.critical_since: str | None = None\n         self._task_started = False\n@@ -194,7 +195,8 @@ class Pet:\n \n     def get_portrait(self) -> str:\n         \"\"\"Get static portrait for status display.\"\"\"\n-        return get_portrait(self.agent, self.stage)\n+        class_name = getattr(self, \"class_name\", None) or getattr(self, \"dominant_class\", None)\n+        return get_portrait(self.agent, self.stage, class_name=class_name)\n \n     def status_line(self) -> str:\n         \"\"\"Return a compact one-line status summary.\"\"\"\ndiff --git a/my-claw/tools/telegram.py b/my-claw/tools/telegram.py\nindex cd865d8..b4edc44 100644\n--- a/my-claw/tools/telegram.py\n+++ b/my-claw/tools/telegram.py\n@@ -20,6 +20,7 @@ Usage:\n import argparse\n import json\n import os\n+from pathlib import Path\n import sys\n import urllib.request\n import urllib.parse\n@@ -27,6 +28,46 @@ import urllib.error\n \n # Track last seen update to avoid re-reading old messages\n STATE_FILE = os.path.join(os.path.dirname(__file__), \".telegram_state.json\")\n+_ALLOW_LIVE_ENV = \"PROMPTCLAW_ALLOW_LIVE_TELEGRAM\"\n+_POLICY_ENV = \"PROMPTCLAW_TELEGRAM_POLICY\"\n+_TMP_WORKDIR_MARKER = \"/run/cypherclaw-tmp/workdir/\"\n+\n+\n+def _truthy(value: str | None) -> bool:\n+    return (value or \"\").strip().lower() in {\"1\", \"true\", \"yes\", \"on\"}\n+\n+\n+def _send_policy() -> str:\n+    policy = os.environ.get(_POLICY_ENV, \"auto\").strip().lower()\n+    if policy in {\"live\", \"suppress\", \"auto\"}:\n+        return policy\n+    return \"auto\"\n+\n+\n+def _suppress_reason() -> str | None:\n+    if _truthy(os.environ.get(_ALLOW_LIVE_ENV)):\n+        return None\n+\n+    policy = _send_policy()\n+    if policy == \"live\":\n+        return None\n+    if policy == \"suppress\":\n+        return \"suppressed by PROMPTCLAW_TELEGRAM_POLICY=suppress\"\n+\n+    if os.environ.get(\"PYTEST_CURRENT_TEST\"):\n+        return \"suppressed during pytest execution\"\n+    if _truthy(os.environ.get(\"PROMPTCLAW_TEST_MODE\")):\n+        return \"suppressed during PromptClaw test mode\"\n+\n+    cwd = Path.cwd()\n+    script_path = Path(__file__).resolve()\n+    for candidate in (cwd, script_path):\n+        candidate_text = str(candidate)\n+        if \"pytest-of-\" in candidate_text:\n+            return f\"suppressed from pytest temp workdir {candidate}\"\n+        if _TMP_WORKDIR_MARKER in candidate_text:\n+            return f\"suppressed from task-run workdir {candidate}\"\n+    return None\n \n \n def get_telegram_config() -> tuple[str, str]:\n@@ -41,6 +82,15 @@ def get_telegram_config() -> tuple[str, str]