    enforced_roles: Sequence[str] = (),
    scene_metadata: Mapping[str, str] | None = None,
) -> TrackerScene:
    """Build a tracker scene by quantizing selected roles from a score."""

    allowed = tuple(allowed_roles) if allowed_roles is not None else tuple(
