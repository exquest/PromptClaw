    assert [step["row"] for step in steps] == [0, 4, 10, 18]
    assert [step["length_rows"] for step in steps] == [4, 6, 8, 10]
    assert [step["metadata"]["tuning_system_name"] for step in steps] == [
        "gamelan_slendro",
