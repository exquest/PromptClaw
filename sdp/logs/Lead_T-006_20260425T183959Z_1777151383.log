+from sample_capture_daemon import (
+    BUFFER_DURATION_SECONDS,
+    JACK_INPUT_PORTS,
+    JACK_SOURCE_PORTS,
+    SAMPLE_RATE,
+    SampleCaptureDaemon,
+)
+
+
+class _FakeInputPort:
+    def __init__(self, name: str) -> None:
