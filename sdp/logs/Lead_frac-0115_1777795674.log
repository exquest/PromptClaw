+                ),
+            },
+            "third_startle": {
+                "state": self._state_snapshot(third_startle),
+                "face": third_face,
+                "should_mute": should_mute_output(third_startle),
+            },
+        }
+        round_tripped = json.loads(json.dumps(diagnostic, sort_keys=True))
