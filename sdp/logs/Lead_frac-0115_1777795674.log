class TestStartupIdentityModePersistence:
    """Startup bootstrap must persist identity across repeated boots."""

    def test_standalone_bootstrap_reuses_persisted_identity(self, tmp_path):
        identity_path = tmp_path / "identity.json"

        first = bootstrap_identity(
            mode="standalone",
            release="test-release",
            identity_path=identity_path,
        )
        second = bootstrap_identity(
            mode="federated",
            release="ignored-release",
            parent_id="ignored-parent",
            identity_path=identity_path,
        )

        assert identity_path.exists()
        assert second.instance_id == first.instance_id
        assert second.instance_name == first.instance_name
        assert second.mode == "standalone"
        assert second.parent_id is None

    def test_federated_bootstrap_reuses_persisted_identity(self, tmp_path):
        identity_path = tmp_path / "identity.json"

        first = bootstrap_identity(
            mode="federated",
            release="test-release",
            parent_id="origin-home",
            identity_path=identity_path,
