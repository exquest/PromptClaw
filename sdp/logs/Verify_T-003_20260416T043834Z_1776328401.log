"""Catalog for the CypherClaw EMSD curriculum."""
from __future__ import annotations

from dataclasses import dataclass
from pathlib import Path


@dataclass(frozen=True)
class ExerciseSpec:
    """Machine-verifiable exercise specification."""

    id: str
    title: str
    objective: str
    verifier: str  # "structural", "constraint", "spectral", "temporal"
    expected: tuple[str, ...]


@dataclass(frozen=True)
class Course:
    code: str
    title: str
    credits: int
    semester: int
    category: str
    prerequisites: tuple[str, ...] = ()
    live_modules: tuple[str, ...] = ()
    description: str = ""
    learning_objectives: tuple[str, ...] = ()
    topics: tuple[str, ...] = ()
    exercises: tuple[ExerciseSpec, ...] = ()

    def course_dir(self, root: str | Path) -> Path:
        return Path(root) / self.code


def _ex(
    id: str,
    title: str,
    objective: str,
    verifier: str,
    expected: tuple[str, ...],
) -> ExerciseSpec:
    return ExerciseSpec(
        id=id, title=title, objective=objective,
        verifier=verifier, expected=expected,
    )


def _course(
    code: str,
    title: str,
    credits: int,
    semester: int,
    category: str,
    prerequisites: tuple[str, ...] = (),
    live_modules: tuple[str, ...] = (),
    description: str = "",
    learning_objectives: tuple[str, ...] = (),
    topics: tuple[str, ...] = (),
    exercises: tuple[ExerciseSpec, ...] = (),
) -> Course:
    return Course(
        code=code,
        title=title,
        credits=credits,
        semester=semester,
        category=category,
        prerequisites=prerequisites,
        live_modules=live_modules,
        description=description,
        learning_objectives=learning_objectives,
        topics=topics,
        exercises=exercises,
    )


