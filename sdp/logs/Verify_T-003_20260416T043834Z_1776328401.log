+"""Curriculum helpers for CypherClaw's formal music study tracks."""
+
+from .bootstrap import materialize_curriculum
+from .catalog import COURSE_CATALOG, Course, ExerciseSpec, course_by_code, curriculum_totals
+from .verify import VerifyResult, verify_exercise
+
+__all__ = [
+    "COURSE_CATALOG",
+    "Course",
+    "ExerciseSpec",
+    "VerifyResult",
+    "course_by_code",
+    "curriculum_totals",
+    "materialize_curriculum",
+    "verify_exercise",
