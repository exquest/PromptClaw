+
+            if capture(video_device=video_device, frame_path=FRAME):
+                result, previous_pixels = fast_analyze(FRAME, previous_pixels=previous_pixels)
+                person_cue = detect_visual_person_cue(FRAME)
+                now = time.time()
+                someone_here = (
