{"type":"tool_use","timestamp":"2026-04-17T04:36:37.793Z","tool_name":"run_shell_command","tool_id":"run_shell_command_1776400597792_0","parameters":{"command":"cat << 'EOF' > tests/test_restraint.py\nfrom __future__ import annotations\nimport os\nimport sys\n\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\", \"my-claw\", \"tools\"))\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\", \"src\"))\n\nfrom cypherclaw.render.events import Event\nfrom cypherclaw.render.rules.phrase_arch import PhraseArchRule\n\nfrom senseweave.music_tracker import TrackerStep\nfrom senseweave.render.rules.silence_budget import _apply_to_lane, SilenceBudgetRule\nfrom test_silence_budget_rule import _scene, _step\n\ndef test_phrase_arch_restraint_neutral():\n    event = Event(normalized_phrase_position=0.5, metadata={\"restraint\": \"0.0\"})\n    rule = PhraseArchRule(tempo_deviation_pct=4.0, amp_deviation_pct=4.0)\n    rule.apply(event)\n    assert event.metadata[\"phrase_arch_tempo_deviation_pct\"] == \"4.0\"\n\ndef test_phrase_arch_restraint_near_flat():\n    event = Event(normalized_phrase_position=0.5, metadata={\"restraint\": \"1.0\"})\n    rule = PhraseArchRule(tempo_deviation_pct=4.0, amp_deviation_pct=4.0)\n    rule.apply(event)\n    assert event.metadata[\"phrase_arch_tempo_deviation_pct\"] == \"0.0\"\n    # test dynamic range (amp dev) is scaled by 0.3 when restraint=1\n    # amp_deviation_pct = 4.0 * (1 - 1*0.7) = 1.2\n    \ndef test_silence_budget_restraint_neutral_vs_max():\n    rule = SilenceBudgetRule(target_density=0.7, threshold=1.0)\n    \n    # restraint 0: threshold is 1.0. We accumulate 1.05 rest_budget. Trigger tacet.\n    # actual density = 0.\n    steps = [\n        _step(0, 8, phrase_id=\"p1\", velocity=0.0),\n        _step(8, 4, phrase_id=\"p2\", velocity=0.8),\n    ]\n    steps[0].metadata[\"restraint\"] = \"0.0\"\n    scene_0 = _scene(steps)\n    rendered_0 = rule.apply(scene_0, k=1.0, seeds=None, roles=None)\n    out_0 = render