++        return resolve_harmonic_plan(
++            "C",
++            song_num=14,
++            mood={"energy": 0.72, "valence": 0.54, "arousal": 0.66},
++            family="pulse",
++            cadence_state="occupied_day",
++            progression_profile="lift",
++            garden_state={"music_key": "F lydian", "last_update": 999.0},
++            outdoor_state={"brightness": 0.76},
++            midi_state={
++                "playing": True,
