    # Public
    art1 = tmp_path / "1.png"
    art1.write_bytes(b"")
    meta1 = tmp_path / "1.json"
    meta1.write_text(json.dumps({"visibility": "public"}))
    
    # Private
    art2 = tmp_path / "2.png"
    art2.write_bytes(b"")
    meta2 = tmp_path / "2.json"
    meta2.write_text(json.dumps({"visibility": "private"}))
    
    # No sidecar
    art3 = tmp_path / "3.png"
    art3.write_bytes(b"")
    
    pieces = mod.load_playlist()
    assert pieces == [art1]


