\\\\\\\\\\\\"timestamp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": now,\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"playing\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": len(active) > 0,\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"notes_on\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": sorted(note for note in active_notes if now - float(active_notes[note][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"time\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]) < 8.0),\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"notes\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [str(note[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]) for note in active],\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"freqs\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [float(note[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"freq\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]) for note in active],\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"velocities\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [int(note[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"velocity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]) for note in active],\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"last_activity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": last_activity,\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"recent_pedal_events\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [(round(ts, 4), bool(value)) for ts, value in recent_pedal_events[-8:]],\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"active_devices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": active_devices or [],\\\\\\\\\\\\\\\\n+    }\\\\\\\\\\\\\\\\n+    midi_snapshot = midi_state.to_dict()\\\\\\\\\\\\\\\\n+    for key in (\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"last_note\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"last_velocity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sustain_pedal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"expression\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+