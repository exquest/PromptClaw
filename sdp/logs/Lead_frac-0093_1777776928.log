    64	def test_entities_pagination(client, auth_headers):
    65	    # Native store paginates before filtering! 
    66	    # With limit=2, offset=0, store returns e1, e2. Filter domain=shared -> returns e1 (len=1)
    67	    # If we fetch with multiplier, it would fetch more and return up to `limit` items.
    68	    resp1 = client.get("/world/entities?limit=2&offset=0", headers=auth_headers)
    69	    assert resp1.status_code == 200
    70	    data1 = resp1.json()["entities"]
    71	    
    72	    resp2 = client.get("/world/entities?limit=2&offset=2", headers=auth_headers)
    73	    assert resp2.status_code == 200
    74	    data2 = resp2.json()["entities"]
    75	    
    76	    # Actually, we want correct pagination for the client.
    77	    # The client asks for limit=2, offset=0. It should get 2 shared items: e1, e4.
    78	    # The client asks for limit=2, offset=2. It should get 0 shared items.
    79	    
    80	    assert len(data1) == 2
    81	    assert {e["id"] for e in data1} == {"e1", "e4"}
    82	    assert len(data2) == 0
