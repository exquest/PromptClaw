\\\\"\\\\\\\\\\\\\\\\n-import json, os, time, sys\\\\\\\\\\\\\\\\n+from __future__ import annotations\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+import json\\\\\\\\\\\\\\\\n+import os\\\\\\\\\\\\\\\\n+import subprocess\\\\\\\\\\\\\\\\n+import time\\\\\\\\\\\\\\\\n from pathlib import Path\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+from senseweave.harmonic_planner import keyboard_grimoire_from_midi_state\\\\\\\\\\\\\\\\n+from senseweave.midi_state import MidiState, note_to_name\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n STATE_FILE = Path(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/tmp/midi_keyboard_state.json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+_KEYBOARD_HINTS = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"akai\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"max25\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"microkey\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"keyboard\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+_IGNORE_HINTS = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"theremini\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"perform-ve\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"scarlett\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-def midi_to_freq(note):\\\\\\\\\\\\\\\\n+def midi_to_freq(note: int) -> float:\\\\\\\\\\\\\\\\n     return 440.0 * (2 ** ((note - 69) / 12.0))\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-def midi_to_name(note):\\\\\\\\\\\\\\\\n-    names = [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"D\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"D#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"E\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"F\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"F#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"G\\\\\\\\\\\\