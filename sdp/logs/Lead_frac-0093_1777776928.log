+        visible_entities = list_resp.json()["entities"]
+        assert [entity["id"] for entity in visible_entities] == [
+            "guide-shared",
+            "entity-004",
+        ]
+        assert {entity["domain"] for entity in visible_entities} == {
+            "shared",
+            "deniable",
