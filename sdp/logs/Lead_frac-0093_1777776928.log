   497	class MutableEntityStore:
   498	    """Entity store with explicit update persistence for PATCH tests."""
   499	
   500	    def __init__(self) -> None:
   501	        self._by_id: dict[str, dict[str, Any]] = {
   502	            "fighter-1": {
   503	                "id": "fighter-1",
   504	                "type": "character",
   505	                "name": "Dax",
   506	                "domain": "deniable",
   507	                "properties": {
   508	                    "archetype": "marksman",
   509	                    "stats": {"combat": 4, "tech": 2, "resolve": 3},
   510	                    "current_state": "healthy",
   511	                    "campaign_xp": 12,
   512	                    "skills": ["marksman"],
   513	                    "permanent_injuries": ["bruise", "scar"],
   514	                },
   515	            }
   516	        }
   517	        self.update_calls: list[dict[str, Any]] = []
   518	
   519	    def list_entities(self, **_kwargs: Any) -> list[dict[str, Any]]:
   520	        return [deepcopy(entity) for entity in self._by_id.values()]
   521	
   522	    def get_entity(self, entity_id: str) -> dict[str, Any] | None:
   523	        entity = self._by_id.get(entity_id)
   524	        return deepcopy(entity) if entity is not None else None
   525	
   526	    def update_entity(
   527	        self,
   528	        *,
   529	        entity_id: str,
   530	        entity: dict[str, Any],
   531	    ) -> dict[str, Any]:
   532	        self.update_calls.append(
   533	            {"entity_id": entity_id, "entity": deepcopy(entity)}
   534	        )
   535	        self._by_id[entity_id] = deepcopy(entity)
   536	        return deepcopy(entity)
   537	
   538	
