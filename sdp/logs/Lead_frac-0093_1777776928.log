        )\\\\\\\\\\\\\\\\n+            amidi_listing = result.stdout\\\\\\\\\\\\\\\\n+        except Exception:\\\\\\\\\\\\\\\\n+            amidi_listing = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    devices: list[str] = []\\\\\\\\\\\\\\\\n+    for line in amidi_listing.splitlines():\\\\\\\\\\\\\\\\n+        line = line.strip()\\\\\\\\\\\\\\\\n+        if not line.startswith(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"IO  hw:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        lowered = line.lower()\\\\\\\\\\\\\\\\n+        if any(hint in lowered for hint in _IGNORE_HINTS):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        if not any(hint in lowered for hint in _KEYBOARD_HINTS):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        try:\\\\\\\\\\\\\\\\n+            hw = line.split()[1]\\\\\\\\\\\\\\\\n+            card = int(hw.split(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")[0].split(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")[1])\\\\\\\\\\\\\\\\n+        except Exception:\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        path = f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/dev/midi{card}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+        if (not verify_device_paths or os.path.exists(path)) and path not in devices:\\\\\\\\\\\\\\\\n+            devices.append(path)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    if devices:\\\\\\\\\\\\\\\\n+        return sorted(devices)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    fallback = [\\\\\\\\\\\\\\\\n+        path\\\\\\\\\\\\\\\\n+        for path in sorted(Path(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/dev\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").glob(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"midi*\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n+        if path.name not in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"midi3\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"midi8\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}\\\\\\\\\\\\\\\\n+    ]\\\\\\\\\\\\\\\\n+    return [str(path) for path in fallback]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def apply_midi_message(\\\\\\\\\\\\\\\\n+    midi_state: MidiState,\\\\\\\\\\\\\\\\n+    active_notes: dict[int, dict[str, float | int | str]],\\\\\\\\\\\\\\\\n+    recent_pedal_events: list[tuple[float, bool]],\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    status: int,\\\\\\\\\\\\\\\\n+    data1: int,\\\\\\\\\\\\\\\\n+    data2: int,\\\\\\\\\\\\\\\\n+    now: float,\\\\\\\\\\\\\\\\n+    last_activity: float,\\\\\\\\\\\\\\\\n+) -> float:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Apply one decoded MIDI message into the tracked keyboard state.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    msg_type = status & 0xF0\\\\\\\\\\\\\\\\n+    if msg_type == 0x90:\\\\\\\\\\\\\\\\n+        note, velocity = data1, data2\\\\\\\\\\\\\\\\n+        midi_state.note_on(note, velocity)\\\\\\\\\\\\\\\\n+        if velocity > 0:\\\\\\\\\\\\\\\\n+            active_notes[note] = {\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"freq\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": midi_to_freq(note),\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": note_to_name(note),\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"velocity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": velocity,\\\\\\\\\\\\\\\\n+                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"time\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": now,\\\\\\\\\\\\\\\\n+            }\\\\\\\\\\\\\\\\n+            return now\\\\\\\\\\\\\\\\n+        active_notes.pop(note, None)\\\\\\\\\\\\\\\\n+        return last_activity\\\\\\\\\\\\\\\\n+    if msg_type == 0x80:\\\\\\\\\\\\\\\\n+        note = data1\\\\\\\\\\\\\\\\n+        midi_state.note_off(note)\\\\\\\\\\\\\\\\n+        active_note