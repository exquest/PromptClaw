sdp/verification/t-001@20260425t183959zb-verify.md:20:{"type":"tool_result","timestamp":"2026-04-25T19:47:27.825Z","tool_id":"run_shell_command_1777146447667_0","status":"success","output":"commit 90953c8f1575708be7fef2a46d78fb3ac17d7c7e (HEAD -> feat/graceful-degradation)\nAuthor: Anthony Ainsworth <anthony@cascadiantech.com>\nDate:   Sat Apr 25 12:46:57 2026 -0700\n\n    feat(sampler): on_sampler_free releases scsynth buffer + clears id [T-001@20260425T183959Zb]\n    \n    Sends /b_free for the assigned bufnum, nulls record.buffer_id, and\n    no-ops when buffer_id is already None so callers can free idempotently.\n\ndiff --git a/my-claw/tools/senseweave/sampler_buffers.py b/my-claw/tools/senseweave/sampler_buffers.py\nindex f8ca0e1..0a00a29 100644\n--- a/my-claw/tools/senseweave/sampler_buffers.py\n+++ b/my-claw/tools/senseweave/sampler_buffers.py\n@@ -3,9 +3,9 @@\n `BufferLoader.on_sampler_load(record)` allocates an scsynth buffer via\n `/b_alloc` (sized from the WAV header), reads the WAV file into it via\n `/b_allocRead`, and stores the assigned buffer id back on the record.\n-\n-This is the first slice of T-001; the full LRU-evicting `BufferPool`\n-and `OnSamplerFree` half of the protocol arrive in later slices.\n+`BufferLoader.on_sampler_free(record)` releases the buffer via `/b_free`\n+and clears the id; calling it on a record without a live buffer is a\n+no-op so callers can free idempotently.\n \"\"\"\n from __future__ import annotations\n \n@@ -60,3 +60,16 @@ class BufferLoader:\n \n         record.buffer_id = bufnum\n         return bufnum\n+\n+    def on_sampler_free(self, record: BufferRecord) -> None:\n+        \"\"\"Release `record.buffer_id` via `/b_free` and clear it on the record.\n+\n+        No-op when `record.buffer_id is None` (already freed or never loaded);\n+        no OSC traffic is sent in that case.\n+        \"\"\"\n+        bufnum = record.buffer_id\n+        if bufnum is None:\n+            return\n+\n+        self.osc.send_message(\"/b_free\", [bufnum])\n+        record.buffer_id = None\ndiff --git a/tests/test_sampler_buffers.py b/tests/test_sampler_buffers.py\nindex 58ad8ae..c42926d 100644\n--- a/tests/test_sampler_buffers.py\n+++ b/tests/test_sampler_buffers.py\n@@ -1,4 +1,4 @@\n-\"\"\"Tests for the sampler BufferLoader.on_sampler_load OSC handshake.\"\"\"\n+\"\"\"Tests for the sampler BufferLoader load/free OSC handshakes.\"\"\"\n from __future__ import annotations\n \n import os\n@@ -99,3 +99,45 @@ def test_on_sampler_load_raises_when_wav_missing(tmp_path: Path) -> None:\n         raise AssertionError(\"expected FileNotFoundError for missing WAV\")\n     assert osc.calls == []\n     assert record.buffer_id is None\n+\n+\n+def test_on_sampler_free_releases_buffer_and_clears_id(tmp_path: Path) -> None:\n+    wav = tmp_path / \"clip.wav\"\n+    _write_wav(wav, frames=128)\n+    osc = _RecordingOSC()\n+    loader = BufferLoader(osc, start_bufnum=300)\n+    record = BufferRecord(path=wav)\n+    loader.on_sampler_load(record)\n+    osc.calls.clear()\n+\n+    loader.on_sampler_free(record)\n+\n+    assert osc.calls == [(\"/b_free\", [300])]\n+    assert record.buffer_id is None\n+\n+\n+def test_on_sampler_free_is_noop_when_buffer_id_is_none() -> None:\n+    osc = _RecordingOSC()\n+    loader = BufferLoader(osc)\n+    record = BufferRecord(path=\"unused.wav\", buffer_id=None)\n+\n+    loader.on_sampler_free(record)\n+\n+    assert osc.calls == []\n+    assert record.buffer_id is None\n+\n+\n+def test_on_sampler_free_is_idempotent(tmp_path: Path) -> None:\n+    wav = tmp_path / \"clip.wav\"\n+    _write_wav(wav, frames=64)\n+    osc = _RecordingOSC()\n+    loader = BufferLoader(osc, start_bufnum=42)\n+    record = BufferRecord(path=wav)\n+    loader.on_sampler_load(record)\n+\n+    loader.on_sampler_free(record)\n+    loader.on_sampler_free(record)\n+\n+    free_calls = [call for call in osc.calls if call[0] == \"/b_free\"]\n+    assert free_calls == [(\"/b_free\", [42])]\n+    assert record.buffer_id is None"}
