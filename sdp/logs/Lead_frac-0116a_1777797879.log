ies)\\\\n+\\\\n     @app.get(\\\\n         \\\\\\\"/events\\\\\\\",\\\\n         response_model=EventListResponse,\\\\ndiff --git a/src/cypherclaw/narrative_api/schemas.py b/src/cypherclaw/narrative_api/schemas.py\\\\nindex 1c669dc..cf382f6 100644\\\\n--- a/src/cypherclaw/narrative_api/schemas.py\\\\n+++ b/src/cypherclaw/narrative_api/schemas.py\\\\n@@ -105,3 +105,22 @@ class EventListResponse(BaseModel):\\\\n \\\\n     events: list[EventRecord] = Field(default_factory=list)\\\\n     next_event_id: str | None = None\\\\n+\\\\n+class EntityRecord(BaseModel):\\\\n+    \\\\\\\"\\\\\\\"\\\\\\\"Single world entity returned to HTTP clients.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n+\\\\n+    model_config = ConfigDict(extra=\\\\\\\"ignore\\\\\\\")\\\\n+\\\\n+    id: str\\\\n+    type: str | None = None\\\\n+    name: str | None = None\\\\n+    domain: str | None = None\\\\n+    properties: dict[str, Any] = Field(default_factory=dict)\\\\n+\\\\n+\\\\n+class EntityListResponse(BaseModel):\\\\n+    \\\\\\\"\\\\\\\"\\\\\\\"GET /world/entities response.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n+\\\\n+    model_config = ConfigDict(extra=\\\\\\\"ignore\\\\\\\")\\\\n+\\\\n+    entities: list[EntityRecord] = Field(default_factory=list)\\\"}\\n./sdp/logs/Verify_T-014_20260502T001347Z_1777692316.log:+{\\\"type\\\":\\\"tool_result\\\",\\\"timestamp\\\":\\\"2026-05-02T01:07:00.430Z\\\",\\\"tool_id\\\":\\\"run_shell_command_1777684020042_0\\\",\\\"status\\\":\\\"success\\\",\\\"output\\\":\\\"commit e8e7e5394fcf1e08597b184886d3241936a20011\\\\nAuthor: Anthony Ainsworth <anthony@cascadiantech.com>\\\\nDate:   Sat Apr 25 15:08:27 2026 -0700\\\\n\\\\n    feat(image_api): CT Marketing image-generation REST surface (#21, #22, #23)\\\\n    \\\\n    New package src/cypherclaw/image_api/ implementing the contract in\\\\n    specs/external/cypherclaw-image-contract.md:\\\\n      - POST /api/v1/jobs   — submit spec_yaml (Shape A or B), returns job_id\\\\n      - GET  /api/v1/jobs/{job_id} — poll status, returns output_urls when complete\\\\n      - GET  /healthz       — liveness\\\\n    \\\\n    Modules:\\\\n      - schemas.py           Pydantic SubmitRequest/SubmitResponse/StatusResponse\\\\n                             + InternalSpec normalized form + JobStatus enum\\\\n      - spec_parser.py       parse Shape A (explicit prompt) and Shape B\\\\n                             (content-derived from title + description) into\\\\n                             InternalSpec. Deterministic prompt template, no LLM.\\\\n      - jobs_db.py           SQLite job state at /home/user/cypherclaw-data/\\\\n                             image_jobs.db. WAL mode, thread-safe per-call conns.\\\\n                             Lifecycle: queued → running → uploading → terminal.\\\\n      - gemini_backend.py    google-genai wrapper with model override support;\\\\n                             default gemini-3-pro-image-preview (Nano Banana Pro);\\\\n                             lazy SDK import so tests inject fakes cleanly.\\\\n      - s3_uploader.py       boto3 wrapper, scoped to PutObject on jobs/* prefix;\\\\n                             returns direct S3 HTTPS URL.\\\\n      - worker.py            sync core process_job_sync + async schedule_job;\\\\n                             WorkerHooks injection seam for tests.\\\\n      - app.py               FastAPI factory create_app(s, db, hooks) — no module\\\\n                             singleton so importing the package never touches the\\\\n                             filesystem (clean test ergonomics).\\\\n      - __main__.py          uvicorn entry: `python -m cypherclaw.image_api`\\\\n      - config.py            env-var Settings dataclass with from_env classmethod\\\\n    \\\\n    Systemd unit: my-claw/systemd/cypherclaw-image-api.service\\\\n      - User=user, EnvironmentFile=/home/user/cypherclaw/.env (AWS keys)\\\\n      - Restart=always with backoff; hardened (NoNewPrivileges, ProtectSystem,\\\\n        ReadWritePaths=/home/user/cypherclaw-data onl