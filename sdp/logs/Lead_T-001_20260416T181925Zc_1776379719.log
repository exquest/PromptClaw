+                        "voice": "bell",
+                        "dynamic": "mp",
+                        "role": "color",
+                    }
+                ],
+                "key": "C",
+                "tempo_bpm": 120.0,
+                "mood": "neutral",
+                "created_at": 0.0,
+            }
