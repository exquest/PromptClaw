@@ -2,13 +2,27 @@
 from __future__ import annotations
 
 from .ablation import ablate, filter_active_rules
+from .debugger import (
+    AblationRun,
+    LocalizationReport,
+    ProblemRegion,
+    RuleImpact,
+    localize_rule_impacts,
+    run_debugger,
+)
 from .diff import NoteDelta, PhraseDelta, ScoreDelta, diff_scores
 
 __all__ = [
+    "AblationRun",
+    "LocalizationReport",
     "NoteDelta",
     "PhraseDelta",
