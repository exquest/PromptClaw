+
+    report = json.loads(output.read_text())
+    assert exit_code == 0
+    assert report["ranked_rules"][0]["rule_id"] == "melody_leap"
+    assert report["ranked_rules"][0]["single_impact"] == 1.0
+    assert report["ablation_runs"][0]["summary"] == "1 note scale_degree change(s)"

