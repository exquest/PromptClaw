+                "    del seeds",
+                "    active = {getattr(rule, 'rule_id', rule) for rule in rules}",
+                "    degree = 5 if 'melody_leap' in active else score.phrases[0].notes[0].scale_degree",
+                "    voice = 'pad' if 'color_shift' in active else score.phrases[1].voice",
+                "    return Score(",
+                "        phrases=[",
