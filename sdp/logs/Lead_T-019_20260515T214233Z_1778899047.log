+    SHUTDOWN_AUDIT_WORKFLOW_ID: (
+        *PAL_WORKFLOW_COMMON_REQUIRED_ARTIFACTS,
+        "outputs/shutdown-audit.json",
+        "handoffs/shutdown-audit.md",
