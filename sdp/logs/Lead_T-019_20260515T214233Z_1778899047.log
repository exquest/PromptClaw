    def as_dict(self) -> dict[str, Any]:
        files: dict[str, str] = {}
        for name, path in self.files:
            files[name] = str(path)
        return {
            "run_id": self.run_id,
            "root": str(self.root),
            "directories": [str(path) for path in self.directories],
            "files": files,
        }


