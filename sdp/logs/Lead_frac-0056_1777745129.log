+                day_phase="mid_morning",
+                room_activity="quiet",
+                attention_state="ambient",
+                dwell_time_s=3600.0,
+                hour=hour,
+            )
+            assert policy.preferred_sources[0] == "self_bus"
+            assert policy.generated_material_weight > policy.keynote_privilege
