+            assert len(policy.preferred_sources) == len(set(policy.preferred_sources))
+
+    def test_loudness_ceilings_increase_from_sleep_to_away(self) -> None:
+        policies = [_sleep_policy(), _wind_down_policy(), resolve_acoustic_ecology(
