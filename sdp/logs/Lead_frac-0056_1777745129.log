+            assert len(policy.reasons) >= 1
+
+    def test_source_lists_are_unique_and_nonempty(self) -> None:
+        policies = [_sleep_policy(), _wind_down_policy()]
+        for attention_state in ["ambient", "attending", "performance"]:
