+        "workflow_id": SLOW_INFERENCE_WORKFLOW_ID,
+        "status": state.status,
+        "summary_path": state.final_summary_path,
+        "executed_tools": context_tools,
+        "tool_count": len(context_tools),
+        "baseline_tokens_per_second": baseline_tokens_per_second,
+    }
