+def _baseline_tokens_per_second_from_summary(summary: dict[str, Any]) -> float | None:
+    prompts = summary.get("prompts", {})
+    if not isinstance(prompts, dict):
+        return None
+    values: list[float] = []
+    for prompt_summary in prompts.values():
