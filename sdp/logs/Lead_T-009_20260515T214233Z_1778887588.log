+
+    state = RunState(
+        run_id=run_id,
+        title="PAL Slow Inference Context",
+        status="running",
+        current_phase="context",
+        created_at=created_at,
+        updated_at=created_at,
+        task_text=task,
+        lead_agent="local-allowlist",
+        verifier_agent="local-allowlist",
+        route_decision={
