ting = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bright\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    result = {\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"brightness\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": round(brightness, 4),\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lighting\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": lighting,\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"dominant_color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": dominant,\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"motion\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": motion,\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"motion_amount\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": round(motion_amount, 4),\\\\\\\\\\\\\\\\n+        # Bright static rooms produced false positives before; motion or vision text must confirm people.\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"someone_here\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(motion and brightness > 0.08),\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rgb_avg\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [int(r_avg), int(g_avg), int(b_avg)],\\\\\\\\\\\\\\\\n+    }\\\\\\\\\\\\\\\\n+    return result, pixels\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def description_suggests_person(description: str) -> bool:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Infer whether the slow vision model likely saw a person.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    text = description.lower()\\\\\\\\\\\\\\\\n+    return any(token in text for token in PERSON_TOKENS)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def is_ollama_busy_error(error: str) -> bool:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Return whether an error string indicates Ollama queue saturation.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\