irty workspace state is **PASS WITH NOTES**, not FAIL.\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n ## Output Format\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\ndiff --git a/tests/test_audio_analysis.py b/tests/test_audio_analysis.py\\\\\\\\\\\\\\\\nindex 25d9aaa..cc4cc39 100644\\\\\\\\\\\\\\\\n--- a/tests/test_audio_analysis.py\\\\\\\\\\\\\\\\n+++ b/tests/test_audio_analysis.py\\\\\\\\\\\\\\\\n@@ -9,6 +9,7 @@ sys.path.insert(0, os.path.join(os.path.dirname(__file__), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"..\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"my-claw\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"too\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n from audio_analysis import (\\\\\\\\\\\\\\\\n     detect_amplitude,\\\\\\\\\\\\\\\\n+    detect_click_transients,\\\\\\\\\\\\\\\\n     detect_onset,\\\\\\\\\\\\\\\\n     detect_pitch_autocorrelation,\\\\\\\\\\\\\\\\n     classify_audio_content,\\\\\\\\\\\\\\\\n@@ -27,6 +28,17 @@ def _silence(sr: int, duration: float) -> list[int]:\\\\\\\\\\\\\\\\n     return [0] * int(sr * duration)\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+def _saw_wave(freq: float, sr: int, duration: float, amplitude: int = 16000) -> list[int]:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Generate a synthetic saw wave as 16-bit integer samples.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    n = int(sr * duration)\\\\\\\\\\\\\\\\n+    period = sr / freq\\\\\\\\\\\\\\\\n+    out = []\\\\\\\\\\\\\\\\n+    for i in range(n):\\\\\\\\\\\\\\\\n+        phase = (i % period) / period\\\\\\\\\\\\\\\\n+        out.append(int(amplitude * ((phase * 2.0) - 1.0)))\\\\\\\\\\\\\\\\n+    return out\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n # === detect_amplitude ===\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n@@ -142,6 +154,45 @@ class TestOnsetDetection:\\\\\\\\\\\\\\\\n         assert detect_