    def service_impacts(self) -> dict[str, dict[str, int]]:
        impacts: dict[str, dict[str, int]] = {}
        for status, entries in (
            ("added", self.diff.added),
            ("changed", self.diff.changed),
            ("missing", self.diff.missing),
        ):
            for entry in entries:
