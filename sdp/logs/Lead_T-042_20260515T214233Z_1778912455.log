\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n-    elif brightness < 0.15: lighting = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"dim\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n-    elif brightness < 0.4: lighting = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"moderate\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n-    else: lighting = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bright\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n-    prev_pixels = pixels\\\\\\\\\\\\\\\\n-    return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"brightness\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": brightness, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lighting\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": lighting, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"dominant_color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": dominant,\\\\\\\\\\\\\\\\n-            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"motion\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": motion, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"motion_amount\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": motion_amount, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"someone_here\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": someone_here,\\\\\\\\\\\\\\\\n-            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rgb_avg\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [int(r_avg), int(g_avg), int(b_avg)]}\\\\\\\\\\\\\\\\n-\\\\\\\\\\\\\\\\n-def vision_analyze(frame_path):\\\\\\\\\\\\\\\\n-    with open(frame_path, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rb\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") as f:\\\\\\\\\\\\\\\\n-        img_b64 = base64.b64encode(f.read()).decode()\\\\\\\\\\\\\\\\n-    payload = json.dumps({\\\\\\\\\\\\\\\\n-        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"model\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"gemma3:4b\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"messages\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"user\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"content\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": PROMPT, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"images\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [img_b64]}],\\\\\