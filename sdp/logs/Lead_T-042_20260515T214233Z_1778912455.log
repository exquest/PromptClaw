\\\n \\\\\\\\\\\\\\\\n-# Reload SynthDefs from disk\\\\\\\\\\\\\\\\n-DEFDIR=/home/user/cypherclaw/tools/senseweave/synthesis/synthdefs\\\\\\\\\\\\\\\\n-/home/user/cypherclaw/.venv/bin/python3 -c \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+unmute_outputs() {\\\\\\\\\\\\\\\\n+    amixer -D hw:USB sset 'Line 01 Mute' off 2>/dev/null || true\\\\\\\\\\\\\\\\n+    amixer -D hw:USB sset 'Line 02 Mute' off 2>/dev/null || true\\\\\\\\\\\\\\\\n+}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+reset_and_seed_master_chain() {\\\\\\\\\\\\\\\\n+    /home/user/cypherclaw/.venv/bin/python3 - <<'PY'\\\\\\\\\\\\\\\\n from pythonosc import udp_client\\\\\\\\\\\\\\\\n-import os, time\\\\\\\\\\\\\\\\n-c = udp_client.SimpleUDPClient('127.0.0.1', 57110)\\\\\\\\\\\\\\\\n-for f in sorted(os.listdir('${DEFDIR}')):\\\\\\\\\\\\\\\\n-    if f.endswith('.scsyndef'):\\\\\\\\\\\\\\\\n-        data = open(os.path.join('${DEFDIR}', f), 'rb').read()\\\\\\\\\\\\\\\\n-        c.send_message('/d_recv', [data])\\\\\\\\\\\\\\\\n-        time.sleep(0.05)\\\\\\\\\\\\\\\\n-\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n-sleep 0.3\\\\\\\\\\\\\\\\n-\\\\\\\\\\\\\\\\n-/home/user/cypherclaw/.venv/bin/python3 -c \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+import time\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+client = udp_client.SimpleUDPClient(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"127.0.0.1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 57110)\\\\\\\\\\\\\\\\n+client.send_message(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/g_freeAll\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", [0])\\\\\\\\\\\\\\\\n+time.sleep(0.3)\\\\\\\\\\\\\\\\n+client.send_message(\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/s_new\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    [\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sw_master_smooth\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        99999,\\\\\\\\\\\\\\\\n+        1,\\\\\\\\\\\\\\\\n+        0,\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"drive\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\