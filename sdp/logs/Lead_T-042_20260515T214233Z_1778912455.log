queued_from_learning(learning: Any) -> float | None:\\n+    raw = _mapping_value(\\n+        learning,\\n+        \\\"last_generation_enqueued_at\\\",\\n+        \\\"last_enqueued_at\\\",\\n+    )\\n+    if raw is None:\\n+        return None\\n+    try:\\n+        return float(raw)\\n+    except (TypeError, ValueError):\\n+        return None\\n+\\n+\\n def build_generation_request(\\n     *,\\n     mode: Any,\\ndiff --git a/tests/test_generation_composer_hook.py b/tests/test_generation_composer_hook.py\\nindex 6f6e986..6a78df6 100644\\n--- a/tests/test_generation_composer_hook.py\\n+++ b/tests/test_generation_composer_hook.py\\n@@ -47,6 +47,29 @@ def test_should_queue_now_enforces_rate_budget_and_working_gate() -> None:\\n     )\\n \\n \\n+def test_should_queue_now_rate_gate_reads_last_enqueued_from_learning() -> None:\\n+    base = {\\n+        \\\"arc_payoff_score\\\": 0.7,\\n+        \\\"daily_budget_remaining_usd\\\": 1.0,\\n+    }\\n+\\n+    too_soon = dict(base, last_generation_enqueued_at=900.0)\\n+    assert not _should_queue_now(\\n+        \\\"evening_reflection\\\",\\n+        {\\\"energy\\\": 0.6},\\n+        too_soon,\\n+        now=1000.0,\\n+    )\\n+\\n+    cooled_off = dict(base, last_generation_enqueued_at=900.0)\\n+    assert _should_queue_now(\\n+        \\\"evening_reflection\\\",\\n+        {\\\"energy\\\": 0.6},\\n+        cooled_off,\\n+        now=900.0 + 30 * 60,\\n+    )\\n+\\n+\\n def test_should_queue_now_blocks_sampler_dominating_antipattern() -> None:\\n     assert not _should_queue_now(\\n         \\\"solitary\\\",\"}\n+[AGENT] Elapsed: 12.0s / 10m 0s\n+{\"type\":\"message\",\"timestamp\":\"2026-04-27T17:42:28.265Z\",\"role\":\"assistant\",\"content\":\"I will read the full content of the generation composer hook and its corresponding tests to verify they meet\",\"delta\":true}\n+{\"type\":\"message\",\"timestamp\":\"2026-04-27T17:42:28.281Z\",\"role\":\"assistant\",\"content\":\" all acceptance criteria.\",\"delta\":true}\n+{\"type