\\\\\n-# Start audio chain\\\\\\\\\\\\\\\\n-bash /home/user/cypherclaw/scripts/start_audio.sh\\\\\\\\\\\\\\\\n-sleep 5\\\\\\\\\\\\\\\\n-\\\\\\\\\\\\\\\\n-# Start composer\\\\\\\\\\\\\\\\n-bash /home/user/cypherclaw/scripts/restart_composer.sh\\\\\\\\\\\\\\\\n-sleep 2\\\\\\\\\\\\\\\\n+# Core audio/visual stack\\\\\\\\\\\\\\\\n+# The AV boot wrapper owns audio, composer, face, gallery, room listener,\\\\\\\\\\\\\\\\n+# sample playback, and self-listener startup so boot responsibility stays single-source.\\\\\\\\\\\\\\\\n+bash /home/user/cypherclaw/scripts/cypherclaw_av_boot.sh\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-# Displays\\\\\\\\\\\\\\\\n-FACE_DISPLAY=1 nohup $VENV /home/user/cypherclaw/tools/face_display.py &>/dev/null &\\\\\\\\\\\\\\\\n-nohup $VENV /home/user/cypherclaw/tools/gallery_x11.py &>/dev/null &\\\\\\\\\\\\\\\\n+# Dedicated observer vision queue.\\\\\\\\\\\\\\\\n+ensure_observer_ollama_service\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n # Cameras\\\\\\\\\\\\\\\\n-nohup $VENV /home/user/cypherclaw/tools/senseweave/porch_eye.py \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+ensure_singleton_daemon \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/home/user/cypherclaw/tools/senseweave/porch_eye.py .*cY6cUV7hxEIy8k1v\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+    $VENV /home/user/cypherclaw/tools/senseweave/porch_eye.py \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n     \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rtsps://192.168.1.1:7441/cY6cUV7hxEIy8k1v?enableSrtp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n-    --capture-dir /tmp/porch_eye_captures --interval 30 &>/dev/null &\\\\\\\\\\\\\\\\n-nohup $VENV -c \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    --capture-dir \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"${PORCH_CAPTURE_DIR}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" --interval 30\\\\\\\\\\\\\\\\n+ensure_singleton_daemon \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n+  