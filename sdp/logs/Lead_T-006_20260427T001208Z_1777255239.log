        arc_context={"phase": "Emergence", "intensity": 0.5},
        pitch=220.0,
        duration=2.5,
        rms=0.3,
        peak=0.85,
        transient_density=4.0,
    )


def test_to_dict_returns_json_compatible_payload() -> None:
    record = _full_record()
    payload = record.to_dict()
    # Must be JSON-serializable end-to-end.
