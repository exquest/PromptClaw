    assert restored.pitch == 329.63
    assert restored.duration == 4.0


def test_context_fields_preserved_through_dataclasses_replace() -> None:
    base = SampleRecord(
        character_tags=frozenset({"pulse"}),
        arc_context="Emergence",
        pitch=110.0,
        duration=1.0,
