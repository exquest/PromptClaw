+        assert first.onset_sec == 0.125
+        assert first.dur_sec == 0.875
+        assert first.velocity == 0.77
+        assert first.timing_deviation_ms == 4.5
+        assert first.articulation == "tenuto"
+        assert first.sensor_tempo_scale == 1.04
