+                "sensor_brightness": 0.35,
+                "rule_stack": ["R7", "R8", "R7"],
+                "seed_path": [101, 1],
+                "metadata": {"capture": "sidecar", "take": 1},
+            },
+            {
+                "event_id": "evt-2",
+                "pitch": 1001,
+                "role": "ostinato",
+                "nominal_beat": 100.0,
+                "onset_sec": 0.512,
+                "dur_sec": 0.375,
+                "velocity": 0.61,
+                "timing_deviation_ms": -2.25,
+                "articulation": "marcato",
+                "sensor_tempo_scale": 0.97,
