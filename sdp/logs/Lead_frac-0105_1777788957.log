_OSC_EVENT_ADDRESS = "/cypherclaw/event"
_OSC_BUNDLE_HEADER = b"#bundle\x00"
_OSC_IMMEDIATE_TIMETAG = b"\x00\x00\x00\x00\x00\x00\x00\x01"

VALID_ARC_SHAPES: frozenset[str] = frozenset(
