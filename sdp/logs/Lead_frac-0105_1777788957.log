+                "rule_stack": ["R7", "R8", "R7"],
+                "seed_path": [101, 1],
+                "metadata": {"capture": "sidecar", "take": 1},
+            },
+            {
+                "event_id": "evt-2",
+                "pitch": 1001,
+                "role": "ostinato",
+                "nominal_beat": 100.0,
+                "onset_sec": 0.512,
