+        seeds = {"composition_seed": 101, "interpretation_seed": 202}
+        score_events = _score_events()
+        score_payload = _score_payload(score_events)
+        delta_entries = [
+            {
+                "event_id": "evt-1",
+                "pitch": 999,
+                "role": "perc",
