+
+    assert "RenderReplayEndToEndTests" in class_names
+    assert (
+        "test_mapping_score_sidecar_delta_audio_export_and_diagnostics_round_trip"
+        in e2e_method_names
+    )
+    assert result.depth >= 2, result.reason

