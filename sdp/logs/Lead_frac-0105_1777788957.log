+
+        rendered = replay(score_payload, seeds, delta_sidecar)
+
+        assert isinstance(rendered, PerformedPart)
+        assert rendered.applied_rules == ("R7", "R8", "R12")
+        assert rendered.metadata == {
+            "composition_seed": "101",
+            "interpretation_seed": "202",
