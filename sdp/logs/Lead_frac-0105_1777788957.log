+                "onset_sec": 0.125,
+                "dur_sec": 0.875,
+                "velocity": 0.77,
+                "timing_deviation_ms": 4.5,
+                "articulation": "tenuto",
+                "sensor_tempo_scale": 1.04,
+                "sensor_amp_scale": 0.91,
+                "sensor_brightness": 0.35,
+                "rule_stack": ["R7", "R8", "R7"],
+                "seed_path": [101, 1],
+                "metadata": {"capture": "sidecar", "take": 1},
+            },
+            {
+                "event_id": "evt-2",
+                "pitch": 1001,
+                "role": "ostinato",
+                "nominal_beat": 100.0,
+                "onset_sec": 0.512,
+                "dur_sec": 0.375,
+                "velocity": 0.61,
+                "timing_deviation_ms": -2.25,
+                "articulation": "marcato",
+                "sensor_tempo_scale": 0.97,
+                "sensor_amp_scale": 1.08,
+                "sensor_brightness": -0.2,
+                "rule_stack": ["R8", "R12"],
+                "seed_path": [101, 2],
+                "metadata": {"capture": "sidecar", "take": 1},
