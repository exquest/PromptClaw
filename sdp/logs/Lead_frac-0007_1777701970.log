def classify_depth(source_path: str | Path) -> ModuleDepth:
    """Classify a module's implementation depth.

    Dispatches to language-specific classifiers based on file extension.
    """
    path = Path(source_path)
    if not path.exists():
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="file does not exist",
        )

    if path.suffix in _JS_TS_EXTENSIONS:
        return classify_depth_js(path)
    if path.suffix == ".py":
        return _classify_depth_python(path)

    return ModuleDepth(
        path=str(path),
        module_name=path.stem,
        depth=-1,
        reason=f"unsupported file type: {path.suffix}",
    )


