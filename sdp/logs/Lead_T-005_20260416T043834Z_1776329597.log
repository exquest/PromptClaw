+def _sample_voice_for_mode(mode: str) -> str:
+    return {
+        "grain_cloud": "sample_grain",
+        "slice_accents": "sample_slice",
+        "window_echo": "sample_window",
+        "freeze_bed": "sample_freeze",
+        "lowpass_wash": "sample_freeze",
