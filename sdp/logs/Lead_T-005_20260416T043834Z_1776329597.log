        "counter": 3,
        "color": 4,
    },
    "half": {
        "bass": 5,
        "melody": 5,
        "counter": 7,
        "color": 2,
    },
    "deceptive": {
        "bass": 6,
        "melody": 6,
        "counter": 3,
        "color": 4,
    },
    "suspended": {
        "bass": 1,
        "melody": 2,
        "counter": 5,
        "color": 4,
    },
}

_MOOD_TO_ENERGY = {
    "sleeping": 0.08,
    "calm": 0.25,
    "melancholy": 0.32,
    "happy": 0.55,
    "energetic": 0.75,
