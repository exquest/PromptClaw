+
+    assert sample_lane.voice == "sample_grain"
+    assert sample_lane.metadata["sample_gesture_source"] == "contact_mic"
+    assert development.metadata["sample_gesture_mode"] == "grain_cloud"
+    assert len(sample_lane.steps) <= 6

