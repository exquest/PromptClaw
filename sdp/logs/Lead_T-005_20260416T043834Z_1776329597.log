+                "sample_trigger_key": f"{scene_name}:{mode}:{index}",
+            },
+        )
+        for index, row in enumerate(candidate_rows[:event_count])
+    ]
+    return TrackerLane(
+        name="sample_gesture",
+        role="sample",
+        voice=voice,
+        steps=steps,
