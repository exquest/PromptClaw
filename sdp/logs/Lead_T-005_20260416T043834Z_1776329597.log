+            "mode": "grain_cloud",
+            "voice": "sample_grain",
+            "transforms": ["slice_rearrange", "granular_cloud", "reverse_accents"],
+            "density": 0.44,
+            "max_events": 6,
+        }
+    }
+
+    compiled = compile_score_tree_to_tracker(
