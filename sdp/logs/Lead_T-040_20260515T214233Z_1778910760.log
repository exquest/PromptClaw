index 076b7821f470dc762dca89a807ffc9f17c97d636..c72def75c7660b0f0ca138ec0678ce2d01a4550f
--- a/tests/test_pal_deploy.py
+++ b/tests/test_pal_deploy.py
@@ -13,6 +13,7 @@
 from promptclaw.pal_deploy import (
     PALDeploymentManifest,
     PALDeploymentManifestError,
