def _valid_manifest_payload() -> dict[str, object]:
    return {
        "manifest_version": 1,
        "name": "test-pal-manifest",
        "deployment_root": "/opt/pal",
        "mode": "host-managed",
        "files": [
            {
                "source": "ops/templates/file.txt",
