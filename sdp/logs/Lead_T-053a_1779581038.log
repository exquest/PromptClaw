                        midi_state,
                        active_notes,
                        recent_pedal_events,
                        status=status,
                        data1=data[i + 1],
                        data2=data[i + 2],
                        now=now,
                        last_activity=last_activity,
                    )
                    i += 3
                    continue
                if msg_type in (0xC0, 0xD0) and i + 1 < len(data):
                    last_activity = apply_midi_message(
                        midi_state,
                        active_notes,
                        recent_pedal_events,
                        status=status,
                        data1=data[i + 1],
                        data2=0,
                        now=now,
                        last_activity=last_activity,
                    )
                    i += 2
                    continue
                i += 1

        now = time.time()
        active_notes = {
            note: info
            for note, info in active_notes.items()
            if now - float(info["time"]) < 8.0
        }
        write_state(
            state := build_state(
                midi_state,
                active_notes,
                recent_pedal_events,
                last_activity=last_activity,
                now=now,
                active_devices=sorted(fds),
                phrase_tracker=phrase_tracker,
            )
        )
