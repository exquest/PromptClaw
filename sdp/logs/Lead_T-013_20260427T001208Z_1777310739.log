def _roadmap_batch_map_path() -> Path:
    return PROJECT_ROOT / "sdp" / "execution-roadmap.queue-map.json"


def _humanize_prd_filename(filename: str) -> str:
    stem = Path(filename).stem
    if stem.startswith("prd-"):
        stem = stem[4:]
    parts = []
    for piece in stem.split("-"):
        lowered = piece.lower()
        if lowered == "v2":
            parts.append("v2")
        elif lowered == "midi":
            parts.append("MIDI")

