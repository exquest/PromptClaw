def _progress_category(status: str) -> str:
    return _TASK_PROGRESS_CATEGORY_BY_STATUS.get(status, "pending")


def _queue_db_path() -> Path:
    return PROJECT_ROOT / ".sdp" / "state.db"


def _roadmap_doc_path() -> Path:
