+            (
+                (
+                    "systemctl",
+                    "show",
+                    "-p",
+                    "ActiveState",
+                    "-p",
+                    "SubState",
+                    DEPENDENCY,
+                ),
+                _dependency_show(),
+            ),
+            (("kill", "-9", "333"), ""),
+            (
+                (
+                    "systemctl",
+                    "show",
+                    "-p",
+                    "ActiveState",
+                    "-p",
+                    "SubState",
+                    "-p",
+                    "MainPID",
