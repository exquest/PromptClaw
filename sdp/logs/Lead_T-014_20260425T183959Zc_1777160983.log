+            monotonic_fn=lambda: 0.0,
+        )
+
+
+def test_main_reports_success_after_pid_changes(monkeypatch: pytest.MonkeyPatch, capsys: pytest.CaptureFixture[str]) -> None:
+    runner = _FakeRunner(
