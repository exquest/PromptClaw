+                    "show",
+                    "-p",
+                    "ActiveState",
+                    "-p",
+                    "SubState",
+                    "-p",
+                    "MainPID",
+                    "-p",
+                    "ExecMainPID",
+                    "-p",
+                    "After",
+                    "-p",
+                    "Requires",
+                    SERVICE,
