+def test_pal_deployment_diff_detects_metadata_only_changes(tmp_path: Path) -> None:
+    manifest = _write_diff_manifest_project(tmp_path)
+    remote_inventory = build_fake_pal_remote_inventory({
+        "/opt/pal/unchanged.txt": {
