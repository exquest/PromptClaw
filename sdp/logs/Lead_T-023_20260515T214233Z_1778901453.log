+    assert [entry.target for entry in diff.changed] == ["/opt/pal/unchanged.txt"]
+    assert diff.changed[0].changed_fields == ("mode", "owner")
+    assert diff.changed[0].local_sha256 == diff.changed[0].remote_sha256
