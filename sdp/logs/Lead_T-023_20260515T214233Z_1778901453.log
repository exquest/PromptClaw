+            exists = True
+            mode = default_mode
+            owner = default_owner
+            group = default_group
+            source = "fake-remote"
+        content_bytes = _coerce_content_bytes(content)
+        remote_files.append(
+            PALDeploymentRemoteFile(
+                target=target,
+                exists=exists,
+                sha256=_sha256_bytes(content_bytes) if exists else None,
+                mode=mode,
+                owner=owner,
+                group=group,
+                size_bytes=len(content_bytes) if exists else None,
+                source=source,
+            )
+        )
+    return tuple(remote_files)
