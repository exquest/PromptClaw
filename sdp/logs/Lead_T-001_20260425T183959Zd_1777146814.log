    33	
    34	    A placeholder until the full `SampleRecord` (T-024) lands; any record
    35	    with `path` and a settable `buffer_id` attribute satisfies the loader.
    36	    """
    37	
    38	    path: Path | str
    39	    buffer_id: int | None = None
    40	
    41	
    42	class BufferLoader:
    43	    """Allocates scsynth buffers and loads WAV files into them via OSC.
    44	
    45	    Maintains LRU ordering of live records: each load or `touch` marks a
    46	    record most-recently-used, and the least-recently-used record is
    47	    auto-evicted (freed) when a load would push the live set past
    48	    `capacity`.
    49	    """
    50	
    51	    def __init__(
    52	        self,
    53	        osc: OSCSender,
    54	        start_bufnum: int = 100,
    55	        capacity: int = 64,
    56	    ) -> None:
    57	        if capacity < 1:
    58	            raise ValueError("BufferLoader capacity must be positive")
    59	        self.osc = osc
    60	        self._next_bufnum = start_bufnum
    61	        self.capacity = capacity
    62	        self._lru: OrderedDict[int, BufferRecord] = OrderedDict()
    63	
    64	    def on_sampler_load(self, record: BufferRecord) -> int:
    65	        """Allocate a buffer, read `record.path` into it, return the bufnum.
    66	
    67	        Mutates `record` by setting `buffer_id` to the assigned bufnum and
    68	        marking it most-recently-used. If the live set is already at
    69	        `capacity`, the least-recently-used record is freed first.
    70	        Raises `FileNotFoundError` if the WAV path does not exist; no OSC
    71	        traffic is sent in that case and `record.buffer_id` is left alone.
    72	        """
    73	        path = Path(record.path)
    74	        with wave.open(str(path), "rb") as handle:
    75	            num_frames = handle.getnframes()
    76	            num_channels = handle.getnchannels()
    77	
    78	        if len(self._lru) >= self.capacity:
    79	            self.evict_lru()
    80	
    81	        bufnum = self._next_bufnum
    82	        self._next_bufnum += 1
    83	
    84	        self.osc.send_message("/b_alloc", [bufnum, num_frames, num_channels])
    85	        self.osc.send_message("/b_allocRead", [bufnum, str(path), 0, -1])
    86	
    87	        record.buffer_id = bufnum
    88	        self._lru[id(record)] = record
    89	        return bufnum
    90	
    91	    def on_sampler_free(self, record: BufferRecord) -> None:
    92	        """Release `record.buffer_id` via `/b_free` and clear it on the record.
    93	
    94	        No-op when `record.buffer_id is None` (already freed or never loaded);
    95	        no OSC traffic is sent in that case.
    96	        """
    97	        bufnum = record.buffer_id
    98	        if bufnum is None:
    99	            return
   100	
   101	        self.osc.send_message("/b_free", [bufnum])
   102	        record.buffer_id = None
   103	        self._lru.pop(id(record), None)
   104	
   105	    def touch(self, record: BufferRecord) -> None:
   106	        """Mark `record` as most-recently-used.
   107	
   108	        No-op for records not currently tracked (already freed or never
   109	        loaded); no OSC traffic is sent.
   110	        """
   111	        key = id(record)
   112	        if key in self._lru:
   113	            self._lru.move_to_end(key)
   114	
   115	    def evict_lru(self) -> BufferRecord | None:
   116	        """Evict and return the least-recently-used tracked record."""
   117	        if not self._lru:
   118	            return None
   119	
   120	        _, oldest = next(iter(self._lru.items()))
   121	        self.on_sampler_free(oldest)
   122	        return oldest

