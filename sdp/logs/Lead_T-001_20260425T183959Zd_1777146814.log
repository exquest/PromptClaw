tyle and patterns.\n+- Do not clean, revert, commit, or otherwise normalize unrelated pre-existing\n+  workspace changes.\n - Commit your working change immediately.\n \n ## Validation\ndiff --git a/sdp/templates/gemini/lead_t2.md b/sdp/templates/gemini/lead_t2.md\nindex 689b9dd..ed7aea2 100644\n--- a/sdp/templates/gemini/lead_t2.md\n+++ b/sdp/templates/gemini/lead_t2.md\n@@ -26,6 +26,8 @@\n - If you have questions, document them in `ESCALATIONS.md` and proceed with the most reasonable assumption.\n - Follow the project's existing coding style and conventions.\n - Do not refactor code outside the scope of the task.\n+- Do not clean, revert, commit, or otherwise normalize unrelated pre-existing\n+  workspace changes.\n \n ## Validation\n \ndiff --git a/sdp/templates/gemini/verify.md b/sdp/templates/gemini/verify.md\nindex 5356ef6..e0de57c 100644\n--- a/sdp/templates/gemini/verify.md\n+++ b/sdp/templates/gemini/verify.md\n@@ -20,13 +20,15 @@ You are the VERIFY agent. Your job is to check the completed work for correctnes\n ## Review Process\n \n 1.  **Inspect Commits**: Review the commit history (`git log -p -1`) to see what changed.\n-2.  **Run Checks**: Execute the project's validation script or commands (`pytest`, `ruff check .`, etc.).\n-3.  **Evaluate**: Compare the changes against the task description and acceptance criteria.\n+2.  **Check Dirty State**: Run `git status --short`, but only fail on uncommitted changes introduced by this task. Pre-existing unrelated dirty or untracked files are notes only.\n+3.  **Run Checks**: Execute the project's validation script or commands (`pytest`, `ruff check .`, etc.).\n+4.  **Evaluate**: Compare the changes against the task description and acceptance criteria.\n \n ## Verdict Rules\n \n--   **FAIL** is reserved for tests not passing, broken code, or clear spec violations.\n+-   **FAIL** is reserved for tests not passing, broken code, clear spec violations, or uncommitted task-scoped work.\n -   Formatting issues, naming nits, and style deviations are **PASS WITH NOTES**, never FAIL.\n+-   Unrelated pre-existing dirty workspace state is **PASS WITH NOTES**, not FAIL.\n \n ## Output Format\n \ndiff --git a/tests/test_audio_analysis.py b/tests/test_audio_analysis.py\nindex 25d9aaa..cc4cc39 100644\n--- a/tests/test_audio_analysis.py\n+++ b/tests/test_audio_analysis.py\n@@ -9,6 +9,7 @@ sys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\", \"my-claw\", \"too\n \n from audio_analysis import (\n     detect_amplitude,\n+    detect_click_transients,\n     detect_onset,\n     detect_pitch_autocorrelation,\n     classify_audio_content,\n@@ -27,6 +28,17 @@ def _silence(sr: int, duration: float) -> list[int]:\n     return [0] * int(sr * duration)\n \n \n+def _saw_wave(freq: float, sr: int, duration: float, amplitude: int = 16000) -> list[int]:\n+    \"\"\"Generate a synthetic saw wave as 16-bit integer samples.\"\"\"\n+    n = int(sr * duration)\n+    period = sr / freq\n+    out = []\n+    for i in range(n):\n+        phase = (i % period) / period\n+        out.append(int(amplitude * ((phase * 2.0) - 1.0)))\n+    return out\n+\n+\n # === detect_amplitude ===\n \n \n@@ -142,6 +154,45 @@ class TestOnsetDetection:\n         assert detect_onset(0.005, 0.001, release_threshold=0.01) == \"silence\"\n \n \n+# === detect_click_transients ===\n+\n+\n+class TestClickDetection:\n+    def test_clean_sine_has_no_clicks(self):\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=6000)\n+        result = detect_click_transients(samples, 48000)\n+        assert result[\"count\"] == 0\n+        assert result[\"events\"] == []\n+        assert result[\"suppressed_as_periodic\"] is False\n+\n+    def test_single_impulse_is_detected(self):\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=6000)\n+        samples[24000] = 32000\n+        result = detect_click_transients(samples, 48000)\n+        assert result[\"count\"] == 1\n+        assert len(result[\"events\"]) == 1\n+        event = result[\"events\"][0]\n+        assert abs(event[\"time_seconds\"] - 0.5) < 0.005\n+        assert event[\"width_samples\"] <= 4\n+        assert event[\"residual\"] > 0.5\n+\n+    def test_sparse_click_burst_is_retained(self):\n+        samples = _sine_wave(220.0, 48000, 1.0, amplitude=5000)\n+        for idx in (9600, 10176, 10752, 11328, 11904):\n+            samples[idx] = 32000\n+        result = detect_click_transients(samples, 48000)\n+        assert result[\"count\"] == 5\n+        assert result[\"suppressed_as_periodic\"] is False\n+\n+    def test_dense_impulse_train_is_suppressed_as_periodic(self):\n+        samples = _silence(48000, 1.0)\n+        for idx in range(0, len(samples), 240):\n+            samples[idx] = 32000\n+        result = detect_click_transients(samples, 48000)\n+        assert result[\"count\"] == 0\n+        assert result[\"suppressed_as_periodic\"] is True\n+\n+\n # === classify_audio_content ===\n \n \ndiff --git a/tests/test_continuous_learner.py b/tests/test_continuous_learner.py\nindex a6fedc3..5100aee 100644\n--- a/tests/test_continuous_learner.py\n+++ b/tests/test_continuous_learner.py\n@@ -22,6 +22,12 @@ class TestRecording:\n         assert cl.growth.total_songs == 1\n         assert \"D\" in cl.growth.keys_explored\n \n+    def test_start_song_tracks_context_tags(self):\n+        cl = ContinuousLearner()\n+        cl.start_song(1, \"D\", \"waltz\", 90, context_tags=[\"ember\", \"lift\", \"house_garden\"])\n+        assert cl.current_song is not None\n+        assert cl.current_song.context_tags == [\"ember\", \"lift\", \"house_garden\"]\n+\n     def test_record_note(self):\n         cl = ContinuousLearner()\n         cl.start_song(1, \"D\", \"waltz\", 90)\n@@ -117,6 +123,50 @@ class TestEvaluation:\n         if result.get(\"fragment_score\", 0) > 0.5:\n             assert mock_memory.store_fragment.called\n \n+    def test_end_song_stores_context_tags_in_memory(self):\n+        mock_memory = MagicMock()\n+        cl = ContinuousLearner()\n+        cl.start_song(1, \"D\", \"waltz\", 90, context_tags=[\"ember\", \"lift\", \"house_garden\"])\n+        for f, d, a in [(220, 0.5, False), (440, 1.0, True),\n+                         (415, 0.25, False), (330, 0.75, False)]:\n+            cl.record_note(float(f), d, a)\n+        result = cl.end_song(memory=mock_memory)\n+        if result.get(\"fragment_score\", 0) > 0.5:\n+            assert mock_memory.store_fragment.called\n+            context = mock_memory.store_fragment.call_args.args[1]\n+            assert \"ember\" in context\n+            assert \"lift\" in context\n+            assert \"house_garden\" in context\n+\n+    def test_end_song_reports_ear_metrics(self):\n+        cl = ContinuousLearner()\n+        cl.start_song(1, \"D\", \"waltz\", 90)\n+        for f, d, a in [(220, 0.5, False), (440, 1.0, True),\n+                         (415, 0.25, False), (330, 0.75, False)]:\n+            cl.record_note(float(f), d, a)\n+        result = cl.end_song()\n+\n+        assert \"ear_metrics\" in result\n+        assert \"hook_clarity\" in result[\"ear_metrics\"]\n+\n+    def test_recent_fragments_prefers_context_match(self):\n+        cl = ContinuousLearner()\n+        cl.start_song(1, \"D\", \"tracker\", 90, context_tags=[\"drift\", \"settling\"])\n+        for f, d, a in [(220, 0.5, False), (440, 1.0, True),\n+                         (415, 0.25, False), (330, 0.75, False)]:\n+            cl.record_note(float(f), d, a)\n+        cl.end_song()\n+\n+        cl.start_song(2, \"D\", \"tracker\", 90, context_tags=[\"ember\", \"lift\"])\n+        for f, d, a in [(293.66, 0.5, False), (392.0, 1.0, True),\n+                         (369.99, 0.25, False), (329.63, 0.75, False)]:\n+            cl.record_note(float(f), d, a)\n+        cl.end_song()\n+\n+        fragments = cl.recent_fragments(context_tags=[\"ember\", \"lift\"], count=2)\n+        assert fragments\n+        assert all(\"ember\" in frag[\"context\"] for frag in fragments)\n+\n  