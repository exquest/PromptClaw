+"""Depth gate for garden watcher tests."""
+
+from __future__ import annotations
+
+import ast
+from pathlib import Path
+
+from sdp.fractal import classify_depth
+
+
+def test_test_garden_watcher_reaches_depth_two_with_end_to_end_class() -> None:
+    test_path = Path("tests/test_garden_watcher.py")
+    tree = ast.parse(test_path.read_text())
+    class_names = {
+        node.name for node in ast.walk(tree) if isinstance(node, ast.ClassDef)
+    }
+
+    assert "GardenWatcherEndToEndTests" in class_names
+
+    result = classify_depth(str(test_path))
+    assert result.depth >= 2, result.reason

