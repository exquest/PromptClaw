    call_count = {"n": 0}
    success = SimpleNamespace(id="ok", status="succeeded", output=b"")

    class _FlakyPredictions:
        def create(self, **_kwargs: object) -> object:
            call_count["n"] += 1
            if call_count["n"] < 2:
