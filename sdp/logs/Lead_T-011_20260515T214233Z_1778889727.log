+            "rationale": "Restart the router, but do not manage the Vast instance.",
+        }),
+        actions=actions,
+    )
+
+    assert plan["actions"] == ["restart_router"]
+    assert plan["ignored_actions"] == [
+        "rent",
+        "destroy",
+        "start",
+        "stop",
+        "vast_rent",
+        "vast_destroy",
+        "vast_start",
