+
+
+def test_build_manifest_includes_all_required_fields(tmp_path: Path) -> None:
+    target = tmp_path / "alpha.mid"
+    contents = _write_mthd_chunk(target, fmt=1, ntrks=3, division=240)
+    metadata = mod.read_mthd_header(target)
