+            "summary": "Read-only SSH process/log diagnostic completed.",
+            "command": {
+                "stdout": "tailscaled\nollama serve\nuvicorn app:app --host 0.0.0.0 --port 8000",
+                "stderr": "",
+                "exit_code": 0,
+            },
+        }
+
