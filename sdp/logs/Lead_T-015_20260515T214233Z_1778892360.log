+        return report_path
+
+    def fake_tailscale_status() -> dict[str, Any]:
+        calls.append("tailscale_status")
+        return {
+            "status": "ok",
+            "summary": "pal-cloud-a6000 is visible in local Tailscale status.",
+            "node_visible": True,
+        }
+
+    def fake_process_check() -> dict[str, Any]:
+        calls.append("ssh_process_check")
