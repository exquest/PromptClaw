class PALAgentClient(Protocol):
    base_url: str
    default_model: str

    def health(self) -> dict[str, Any]:
        ...

    def query(
        self,
        prompt: str,
        *,
        system: str | None = None,
        model: str | None = None,
        temperature: float | None = 0.7,
    ) -> PALQueryResult:
        ...


@dataclass(frozen=True)
class PALOpsTool:
    name: str
    description: str
    run: Callable[[], dict[str, Any]]


@dataclass(frozen=True)
class PALOpsAction:
