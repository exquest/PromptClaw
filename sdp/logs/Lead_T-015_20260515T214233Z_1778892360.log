+        "validation_status": validation_status,
+        "summary_path": state.final_summary_path,
+        "validation_path": _relative_path(project_root, validation_path),
+        "executed_tools": validation_tools,
+        "tool_count": len(validation_tools),
+        "mutating_actions": [],
+    }
