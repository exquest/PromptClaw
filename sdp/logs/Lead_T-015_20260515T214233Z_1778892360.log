+        "summary": (
+            f"PAL smoke suite {report.get('status', 'unknown')} with "
+            f"{summary.get('passed', 0)} passed and {summary.get('failed', 0)} failed checks."
+        ),
+        "report_path": str(report_path),
+        "report": report,
+    }
