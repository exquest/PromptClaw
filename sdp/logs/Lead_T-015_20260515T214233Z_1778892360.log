PAL_KNOWLEDGE_SNIPPET_MAX_CHARS = 240


def run_pal_ops_triage(
    project_root: Path,
    *,
    task: str = DEFAULT_TRIAGE_TASK,
    client: PALAgentClient | None = None,
    tool_registry: dict[str, PALOpsTool] | None = None,
