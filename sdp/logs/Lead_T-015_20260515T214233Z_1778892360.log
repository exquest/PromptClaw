+        calls.append("pal_smoke")
+        assert client is fake_client
+        return {
+            "status": "pass",
+            "started_at": "2026-05-15T20:00:00+00:00",
+            "summary": {"passed": 3, "failed": 0, "total_latency_s": 12.5},
+            "checks": [],
