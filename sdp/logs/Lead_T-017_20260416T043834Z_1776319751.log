{"type":"tool_use","timestamp":"2026-04-16T06:25:23.331Z","tool_name":"run_shell_command","tool_id":"run_shell_command_1776320723330_0","parameters":{"command":"cat << 'EOF' > rewrite_hook.py\nimport re\nfrom pathlib import Path\n\n# 1. Update score_tree.py\np = Path('my-claw/tools/senseweave/score_tree.py')\ntext = p.read_text()\ntext = re.sub(r'hook_type: str\\n\\s*contour: tuple\\[int, \\.\\.\\.\\]\\n\\s*rhythm_cell: tuple\\[float, \\.\\.\\.\\]',\n              r'hook_class: str\\n    contour: tuple[int, ...]\\n    rhythm: tuple[float, ...]', text)\ntext = re.sub(r'text_hook: str\\n', r'text_hook: str\\n    timbral_tags: tuple[str, ...]\\n', text)\np.write_text(text)\n\n# 2. Update hook_engine.py\np = Path('my-claw/tools/senseweave/hook_engine.py')\ntext = p.read_text()\ntext = text.replace('hook_type: str\\n    groove_family: str',\n                    'hook_class: str\\n    contour: tuple[int, ...]\\n    rhythm: tuple[float, ...]\\n    timbral_tags: tuple[str, ...]\\n    groove_family: str')\ntext = text.replace('hook_type', 'hook_class')\ntext = text.replace('hint_type = str(repertoire_hint.get(\"hook_class\", \"\") or \"\")',\n                    'hint_type = str(repertoire_hint.get(\"hook_class\", \"\") or repertoire_hint.get(\"hook_type\", \"\") or \"\")')\n\nhook_consts = \"\"\"\n_HOOK_CONTOURS = {\n    \"contour\": (1, 3, 5, 3),\n    \"rhythmic\": (1, 1, 5, 3),\n    \"lyric\": (1, 2, 3, 5),\n    \"interval\": (1, 5, 3, 6),\n}\n\n_RHYTHM_BY_GROOVE = {\n    \"lyric\": (1.0, 1.0, 1.0, 1.0),\n    \"rolling\": (0.75, 0.75, 1.0, 1.5),\n    \"suspended\": (2.0, 2.0, 4.0),\n    \"procession\": (1.5, 0.5, 1.0, 1.0),\n    \"study\": (0.5, 0.5, 1.0, 1.0, 1.0),\n}\n\n_TIMBRAL_TAGS = {\n    \"nocturne\": (\"dark\", \"soft\", \"glass\"),\n    \"ember\": (\"warm\", \"close\", \"wood\"),\n    \"drift\": (\"hollow\", \"wandering\", \"breath\"),\n    \"bloom\": (\"bright\", \"open\", \"bell\"),\n    \"pulse\": (\"kinetic\", \"electric\", \"wire\"),\n    \"forge\": (\"bent\", \"metallic\", \"edge\"),\n    \"default\": (\"clear\", \"steady\"),\n}\n\"\"\"\ntext = text.replace('_HOOK_ANCHORS: dict', hook_consts + '\\n_HOOK_ANCHORS: dict')\n\nbuild_hook_ret = \"\"\"    return HookProfile(\n        title=f\"{modifier} {noun}\",\n        text_hook=_normalize_hook_text(text_hook),\n        hook_class=hook_class,\n        contour=_HOOK_CONTOURS.get(hook_class, anchor),\n        rhythm=_RHYTHM_BY_GROOVE.get(_GROOVE_BY_FAMILY.get(family_key, \"lyric\"), (1.0, 1.0, 1.0, 1.0)),\n        anchor_degrees=anchor,\n        answer_degrees=answer,\n        timbral_tags=_TIMBRAL_TAGS.get(family_key, (\"clear\", \"steady\")),\n        groove_family=_GROOVE_BY_FAMILY.get(family_key, \"lyric\"),\n        section_intent=_SECTION_INTENT.get(cadence_key, \"open and answer\"),\n    )\"\"\"\ntext = re.sub(r'    return HookProfile\\([^)]+\\)', build_hook_ret, text)\np.write_text(text)\n\n# 3. Update recursive_composer.py\np = Path('my-claw/tools/senseweave/recursive_composer.py')\ntext = p.read_text()\n# Remove _HOOK_CONTOURS and _RHYTHM_BY_GROOVE\ntext = re.sub(r'_HOOK_CONTOURS = \\{[^}]+\\}\\n*', '', text)\ntext = re.sub(r'_RHYTHM_BY_GROOVE = \\{[^}]+\\}\\n*', '', text)\ntext = text.replace('hook_type=hook.hook_type,', 'hook_class=hook.hook_class,')\ntext = text.replace('contour=_HOOK_CONTOURS.get(hook.hook_type, hook.anchor_degrees),', 'contour=hook.contour,')\ntext = text.replace('rhythm_cell=_RHYTHM_BY_GROOVE.get(commission.groove_identity, (1.0, 1.0, 1.0, 1.0)),', 'rhythm=hook.rhythm,\\n        timbral_tags=hook.timbral_tags,')\ntext = text.replace('rhythm_cell=tuple(reversed(primary_motif.rhythm_cell)),', 'rhythm=tuple(reversed(primary_motif.rhythm)),\\n                timbral_tags=hook.timbral_tags,')\np.write_text(text)\n\n# 4. Update generative_scores.py\np = Path('my-claw/tools/senseweave/generative_scores.py')\ntext = p.read_text()\ntext = text.replace('hook_type=hook_profile.hook_type,', 'hook_class=hook_profile.hook_class,')\ntext = text.replace('contour=hook_profile.anchor_degrees,', 'contour=hook_profile.contour,')\ntext = text.replace('rhythm_cell=(1.0, 1.0, 1.0, 1.0),', 'rhythm=hook_profile.rhythm,\\n            timbral_tags=hook_profile.timbral_tags,')\np.write_text(text)\n\n# 5. Update repertoire_memory.py for \"recall a motif shape without exact self-copying\"\np = Path('my-claw/tools/senseweave/repertoire_memory.py')\ntext = p.read_text()\ntext = text.replace('\"hook_type\": hint.get(\"hook_type\", \"\"),', '\"hook_class\": hint.get(\"hook_class\", hint.get(\"hook_type\", \"\")),')\np.write_text(text)\nEOF\npython3 rewrite_hook.py\n"}}
