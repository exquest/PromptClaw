   228	def _extract_call_names(func: ast.FunctionDef) -> set[str]:
   229	    names: set[str] = set()
   230	    for node in ast.walk(func):
   231	        if isinstance(node, ast.Call):
   232	            if isinstance(node.func, ast.Name):
   233	                names.add(node.func.id)
   234	            elif isinstance(node.func, ast.Attribute):
   235	                names.add(node.func.attr)
   236	    return names
