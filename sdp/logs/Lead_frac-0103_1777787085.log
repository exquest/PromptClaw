+        "velocities": velocities,
+        "timing_deviations_ms": [0.0, 1.0, -1.0, 0.5] * 12,
+        "tempo_curve": [118.0 + (index * 0.25) for index in range(48)],
+        "section_gs": [0.971, 0.966, 0.982],
+        "phrase_worms": [
