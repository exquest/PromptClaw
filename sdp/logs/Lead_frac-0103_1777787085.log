+        assert failed_names == []
+        assert result_by_name["generated_content_dominance"].severity == "ok"
+        assert result_by_name["sampler_dominating"].severity == "ok"
+        assert result_by_name["sampler_silent_quintet_member"].severity == "ok"
+        assert len(results) == 9
