+def _result_by_name(
+    results: tuple[AntiPatternResult, ...],
+) -> dict[str, AntiPatternResult]:
+    by_name: dict[str, AntiPatternResult] = {}
+    for result in results:
+        by_name[result.name] = result
+    return by_name
