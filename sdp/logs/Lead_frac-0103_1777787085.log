+        assert "symmetric_arc_uncanny" not in actual_failed
+
+    def test_warning_detectors_keep_nonblocking_severity(self) -> None:
+        failures = failing_antipatterns(_mixed_antipattern_piece())
+        warning_names: set[str] = set()
