+            [(0.95, 0.1), (1.08, 1.0), (1.02, 1.3), (0.93, 0.3)],
+            [(0.98, 0.3), (1.02, 0.6), (1.0, 0.7), (0.97, 0.5)],
+            [(0.94, 0.2), (1.1, 1.2), (1.01, 1.5), (0.92, 0.2)],
