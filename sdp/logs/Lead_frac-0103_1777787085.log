+        wrapped = RenderEnvelope(_mixed_antipattern_piece())
+        direct_results = detect_antipatterns(wrapped.score)
+        wrapped_results = detect_antipatterns(wrapped)
+        for direct, via_wrapper in zip(direct_results, wrapped_results):
