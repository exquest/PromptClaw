+
+    assert "RenderAntipatternsEndToEndTests" in class_names
+    assert (
+        "test_full_antipattern_battery_reports_meaningful_json_safe_diagnostics"
+        in e2e_method_names
+    )
+    assert result.depth >= 2, result.reason

