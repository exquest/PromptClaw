+        assert failure_by_name.keys() == {
+            name for name, result in result_by_name.items() if result.failed
+        }
+        assert warning_names == {
+            "generated_content_dominance",
+            "sampler_dominating",
+        }
+        assert blocking_names == {
+            "quantization_ghosting",
+            "dynamic_compression",
+            "motif_ossification",
+            "dead_silence_failure",
