+    def test_score_wrapped_object_uses_same_detector_path(self) -> None:
+        class RenderEnvelope:
+            def __init__(self, score: dict[str, object]) -> None:
+                self.score = score
+
+        wrapped = RenderEnvelope(_mixed_antipattern_piece())
