import math, os, sys
sys.path.insert(0, os.path.join(os.getcwd(), 'my-claw', 'tools'))
from senseweave.mix_engine import build_mix_profile
SAMPLE_RATE=16000

def sine(freq, dur, amp):
    n=int(SAMPLE_RATE*dur)
    return [amp*math.sin(2*math.pi*freq*i/SAMPLE_RATE) for i in range(n)]

def sum_buffers(*buffers):
    length=max(map(len,buffers)); out=[0.0]*length
    for b in buffers:
        for i,v in enumerate(b): out[i]+=v
    return out
for patch in ['house_garden','house_procession']:
    p=build_mix_profile(cadence_state='occupied_day', patch_name=patch)
    voices=[]
    print(patch)
    for t in p.voice_targets:
        c=(t.lane.low_hz+t.lane.high_hz)/2
        a=10**(t.level_db/20)
        print(t.role, c, t.level_db, a)
        voices.append(sine(c,1,a))
    m=sum_buffers(*voices)
    peak=max(abs(x) for x in m)
    db=20*math.log10(peak)
    print('peak', peak, db)
