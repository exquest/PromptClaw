    71	class PhraseCaptureWriter:
    72	    """Buffer input across a phrase and write to ``<root>/<source>/`` on phrase_ended.
    73	
    74	    Parameters
    75	    ----------
    76	    source:
    77	        ``"keyboard"`` or ``"theramini"`` — selects the on-disk format and
    78	        the sub-directory under ``root``.
    79	    root:
    80	        Base directory (the ``samples/`` directory). Created on first write.
    81	    sample_rate:
    82	        Audio sample rate for ``"theramini"`` captures. Ignored for MIDI.
    83	    tracker:
    84	        Inject a custom :class:`PhraseTracker` (e.g., a non-default threshold
    85	        or a tracker shared with a listener). Defaults to a fresh tracker.
    86	    metadata:
    87	        Initial sidecar tags. Recognised keys: ``instrument``, ``song_id``,
    88	        ``key``, ``tempo``, ``source``. Unset keys are filled with defaults
    89	        (instrument=``source`` arg, source=``"human"``, others ``None``).
    90	        ``timestamp`` and ``duration`` are always derived per-phrase and
    91	        cannot be set here.
    92	    """
    93	
    94	    def __init__(
    95	        self,
    96	        source: CaptureSource,
