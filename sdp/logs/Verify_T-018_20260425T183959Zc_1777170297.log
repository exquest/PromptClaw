    53	def validate_sample_metadata(meta: Mapping[str, Any]) -> None:
    54	    """Raise ``ValueError`` if ``meta`` does not match :data:`SAMPLE_METADATA_SCHEMA`."""
    55	    missing = sorted(set(SAMPLE_METADATA_SCHEMA) - set(meta))
