   214	
   215	    def _write_sidecar(self, path: Path, now: float) -> None:
   216	        meta = self._compose_metadata(now)
   217	        sidecar = path.with_suffix(".json")
   218	        sidecar.write_text(json.dumps(meta, indent=2, sort_keys=True))
   219	
   220	
   221	def _encode_varlen(value: int) -> bytes:
   222	    if value < 0:
   223	        raise ValueError("varlen value must be non-negative")
   224	    out = bytearray([value & 0x7F])
   225	    value >>= 7
   226	    while value:
   227	        out.append((value & 0x7F) | 0x80)
   228	        value >>= 7
   229	    return bytes(reversed(out))
   230	
   231	
   232	def _write_smf0_midi(
   233	    path: Path,
   234	    events: Sequence[tuple[float, bytes]],
   235	) -> None:
   236	    """Write a Type-0 SMF with a leading tempo meta-event and the buffered events."""
   237	    header = b"MThd" + (6).to_bytes(4, "big") + (0).to_bytes(2, "big") + (1).to_bytes(2, "big") + _MIDI_PPQ.to_bytes(2, "big")
   238	
   239	    track = bytearray()
   240	    # Tempo meta event at tick 0 — anchors the tick→seconds mapping.
   241	    track.extend(b"\x00\xFF\x51\x03")
   242	    track.extend(_MIDI_TEMPO_USEC_PER_QUARTER.to_bytes(3, "big"))
   243	
   244	    prev_ticks = 0
   245	    for rel_t, midi_bytes in events:
   246	        absolute_ticks = int(round(rel_t * _MIDI_TICKS_PER_SECOND))
   247	        delta_ticks = max(0, absolute_ticks - prev_ticks)
   248	        prev_ticks = absolute_ticks
   249	        track.extend(_encode_varlen(delta_ticks))
   250	        track.extend(midi_bytes)
   251	
   252	    # End-of-track meta event.
   253	    track.extend(b"\x00\xFF\x2F\x00")
   254	
   255	    path.write_bytes(header + b"MTrk" + len(track).to_bytes(4, "big") + bytes(track))
   256	
   257	
   258	def _write_pcm16_wav(
   259	    path: Path,
   260	    chunks: Iterable[npt.NDArray[np.float32]],
   261	    sample_rate: int,
   262	) -> None:
   263	    arrays = [np.asarray(c, dtype=np.float32).reshape(-1) for c in chunks]
   264	    if arrays:
   265	        joined = np.concatenate(arrays)
   266	    else:
   267	        joined = np.zeros(0, dtype=np.float32)
   268	    clipped = np.clip(joined, -1.0, 1.0)
   269	    pcm = (clipped * 32767.0).astype("<i2").tobytes()
   270	    with wave.open(str(path), "wb") as handle:
   271	        handle.setnchannels(1)
   272	        handle.setsampwidth(2)
   273	        handle.setframerate(sample_rate)
   274	        handle.writeframes(pcm)

