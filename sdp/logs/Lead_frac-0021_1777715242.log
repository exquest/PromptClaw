         self_critique=_env_bool(source.get(SELF_CRITIQUE_ENV), default=True),
         long_form_suite=_env_bool(source.get(LONG_FORM_SUITE_ENV), default=True),
     )
+
+
+def flag_state(
+    name: str,
+    env_var: str,
+    raw_value: str | None,
