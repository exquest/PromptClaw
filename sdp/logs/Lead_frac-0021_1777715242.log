+def flag_state(
+    name: str,
+    env_var: str,
+    raw_value: str | None,
+    *,
+    default_enabled: bool = True,
+) -> RolloutFlagState:
+    """Resolve one rollout flag and preserve diagnostic source information."""
+    enabled = _env_bool(raw_value, default=default_enabled)
