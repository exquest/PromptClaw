    25	    mode_name: str | None,
    26	    *,
    27	    default: float = 0.25,
    28	    table: Mapping[str, float] = DEFAULT_SAMPLER_DENSITY_BY_MODE,
    29	) -> float:
    30	    """Return the canonical scheduler weight for ``mode_name``.
