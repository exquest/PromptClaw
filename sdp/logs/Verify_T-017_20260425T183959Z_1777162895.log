score.phrases)\n+    )\n+    sampler_rng = random.Random(\n+        hash((song_num, sampler_mode_name or \"\", sampler_total_phrases))\n+    )\n+    sampler_event_indices = plan_sampler_phrase_indices(\n+        sampler_density, sampler_total_phrases, sampler_rng\n+    )\n+    score.metadata[\"mode_sampler_density\"] = f\"{sampler_density:.3f}\"\n+    score.metadata[\"sampler_event_count\"] = str(len(sampler_event_indices))\n+    score.metadata[\"sampler_event_phrase_indices\"] = \",\".join(\n+        str(idx) for idx in sampler_event_indices\n+    )\n     next_key = harmony.next_key\n \n     print(f\"\\n=== SOLO TRACKER: {display_key_spec(key_name)} ===\", flush=True)\ndiff --git a/my-claw/tools/senseweave/sampler_scheduler.py b/my-claw/tools/senseweave/sampler_scheduler.py\nnew file mode 100644\nindex 0000000..d598ce1\n--- /dev/null\n+++ b/my-claw/tools/senseweave/sampler_scheduler.py\n@@ -0,0 +1,74 @@\n+\"\"\"Per-mode sampler density gates (CCS-023 / T-017).\n+\n+Computes how many sampler events the composer should fire in a piece and\n+which phrase indices receive them. The count formula is\n+\n+    floor(density * total_phrases) + Bernoulli(density)\n+\n+clamped to ``[0, total_phrases]``. The deterministic floor guarantees a\n+baseline density per mode while the Bernoulli term keeps neighbouring\n+pieces from being identical.\n+\"\"\"\n+from __future__ import annotations\n+\n+import math\n+import random\n+from collections.abc import Mapping\n+\n+from .render.antipatterns import DEFAULT_SAMPLER_DENSITY_BY_MODE\n+\n+\n+def density_for_mode(\n+    mode_name: str | None,\n+    *,\n+    default: float = 0.25,\n+    table: Mapping[str, float] = DEFAULT_SAMPLER_DENSITY_BY_MODE,\n+) -> float:\n+    \"\"\"Return the canonical sampler density for ``mode_name``.\"\"\"\n+    if not mode_name:\n+        return default\n+    return float(table.get(mode_name, default))\n+\n+\n+def count_sampler_events(\n+    density: float,\n+    total_phrases: int,\n+    rng: random.Random | None = None,\n+) -> int:\n+    \"\"\"Return how many sampler events to schedule this piece.\n+\n+    ``floor(density * total_phrases) + Bernoulli(density)``, clamped to\n+    ``[0, total_phrases]``. Density is clamped to ``[0.0, 1.0]`` first.\n+    \"\"\"\n+    if total_phrases <= 0:\n+        return 0\n+    d = max(0.0, min(1.0, float(density)))\n+    base = math.floor(d * total_phrases)\n+    rng = rng or random.Random()\n+    bonus = 1 if rng.random() < d else 0\n+    return max(0, min(total_phrases, base + bonus))\n+\n+\n+def plan_sampler_phrase_indices(\n+    density: float,\n+    total_phrases: int,\n+    rng: random.Random | None = None,\n+) -> list[int]:\n+    \"\"\"Pick the phrase indices that should fire a sampler event.\n+\n+    Indices are returned sorted so the composer can iterate the timeline\n+    in order. Selection within the phrase set is uniform-random.\n+    \"\"\"\n+    rng = rng or random.Random()\n+    count = count_sampler_events(density, total_phrases, rng)\n+    if count == 0:\n+        return []\n+    return sorted(rng.sample(range(total_phrases), count))\n+\n+\n+__all__ = (\n+    \"DEFAULT_SAMPLER_DENSITY_BY_MODE\",\n+    \"count_sampler_events\",\n+    \"density_for_mode\",\n+    \"plan_sampler_phrase_indices\",\n+)\ndiff --git a/progress.md b/progress.md\nindex dfdbd62..6a2ba36 100644\n--- a/progress.md\n+++ b/progress.md\n@@ -2,10 +2,10 @@\n \n Generated from SQLite state (`tasks`, `task_runs`, `escalations`). Do not edit manually.\n \n-ETC: ~3h 45m remaining (21 tasks, low confidence, calibrating)\n-Expected completion: 8:33 PM today.\n-Progress: [█████████████████████████████████░░░░░] 87%  145 / 166 tasks complete\n-  completed: 145, pending: 11, needs_split: 10, blocked: 0, skipped: 12\n+ETC: ~3h 1m remaining (19 tasks, low confidence, calibrating)\n+Expected completion: 8:09 PM today.\n+Progress: [██████████████████████████████████░░░░] 89%  147 / 166 tasks complete\n+  completed: 147, pending: 9, needs_split: 10, blocked: 0, sk