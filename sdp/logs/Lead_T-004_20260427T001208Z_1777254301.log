+"""Local Ada GPU generation client stub."""
+
+from __future__ import annotations
+
+from typing import TYPE_CHECKING, Any, Protocol, runtime_checkable
+
+
+@runtime_checkable
+class GenerationClient(Protocol):
+    """Structural protocol shared by generation backends."""
+
+    def generate(self, request: Any) -> Any:
+        """Generate output for a backend-specific request payload."""
+        ...
+
+
+class LocalAdaClient:
+    """Placeholder for the future local Ada GPU generation backend."""
+
+    def generate(self, request: Any) -> Any:
+        """Fail clearly until local GPU generation is installed."""
+        raise NotImplementedError(
+            "LocalAdaClient: GPU not yet installed; use Replicate or Modal"
+        )
+
+
+if TYPE_CHECKING:
+    _protocol_check: GenerationClient = LocalAdaClient()
+
+
+__all__ = ["GenerationClient", "LocalAdaClient"]
