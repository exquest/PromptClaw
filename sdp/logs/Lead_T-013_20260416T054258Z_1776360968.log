+    synthesis: str
+
+
+def _slug(value: str) -> str:
+    return value.lower().replace("_", "-").replace(" ", "-")
+
+
+def _concept(
+    chapter_id: str,
+    value: str,
+    title: str,
+    summary: str,
+) -> ProductionCourseConcept:
