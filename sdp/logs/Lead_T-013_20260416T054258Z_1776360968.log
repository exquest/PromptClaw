+    density: float
+    mutation_rate: float
+    transition_intent: str
+    dynamic: str
+    harmonic: str
+    rhythm: str
+    timbre: str
+    spatial: str
+    compression: float
+    senseweave: float
+    synthesis: str
+
+
+def _slug(value: str) -> str:
+    return value.lower().replace("_", "-").replace(" ", "-")
+
+
+def _concept(
+    chapter_id: str,
+    value: str,
+    title: str,
+    summary: str,
+) -> ProductionCourseConcept:
+    return ProductionCourseConcept(
+        stable_id=f"production-course.{chapter_id}.{_slug(value)}",
+        chapter_id=chapter_id,
+        value=value,
+        title=title,
+        summary=summary,
+    )
+
+
+def _chapter(
