+                "Double or ghost the motif.",
+            ),
+            _concept(
+                "counterpoint_relation",
+                "parallel_thirds",
+                "Parallel Thirds",
+                "Support with consonant parallel motion.",
+            ),
+            _concept(
+                "counterpoint_relation",
+                "contrary_motion",
+                "Contrary Motion",
+                "Answer by moving in opposition.",
+            ),
+            _concept(
+                "counterpoint_relation",
+                "oblique_pedal",
