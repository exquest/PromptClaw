+                "genre_strategy",
+                "ambient_drone",
+                "Ambient Drone",
+                "Sustain color and slow change.",
+            ),
+            _concept(
+                "genre_strategy",
+                "minimalist_process",
+                "Minimalist Process",
+                "Let repetition reveal form.",
