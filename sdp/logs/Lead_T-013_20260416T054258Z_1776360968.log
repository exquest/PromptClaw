+    "mode_scale": "modal",
+    "harmonic_function": "tonic",
+    "meter_groove": "pulse",
+    "counterpoint_relation": "parallel_thirds",
+    "synthesis_architecture": "subtractive",
+    "mix_role": "support",
+    "spatial_intent": "clear",
+    "genre_strategy": "minimalist_process",
+    "phase_profile": "Emergence",
+    "transition_type": "crossfade",
+}
