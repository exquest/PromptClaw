    assert "quintet" in lowered
    for voice in (
        "sw_bell_warm",
        "sw_bowed",
        "sw_breath",
        "sw_pad",
        "sw_sampler",
    ):
        assert voice in content

    for role_term in (
        "melody",
        "counter",
        "color",
        "foundation",
        "memory voice",
    ):
        assert role_term in lowered


def test_roadmap_records_landed_and_pending_quintet_status() -> None:
