+test("visualizer runtime composites MIDI foreground over audio features in display space", async () => {
+    const runtime = await loadRuntime();
+    const socket = runtime.webSockets[0];
+
+    runtime.eventSources[0].dispatch("features", {
+        data: JSON.stringify({
+            audio: {
+                rms: 0.38,
+                pitch_hz: 392,
+                spectral_centroid_hz: 2600,
+                onset_rate_hz: 4.5,
+            },
+            visual: {
+                brightness: 0.72,
+                motion: 0.48,
+                texture: 0.4,
+                density: 0.5,
+                salience: 0.52,
+            },
+            scene: { name: "Layer Test" },
+            tuning: { name: "ji" },
+        }),
+    });
+    runtime.setNow(220);
+    socket.dispatch("message", {
+        data: JSON.stringify({ status: 144, data1: 72, data2: 112, ts: 8 }),
+    });
+
+    const shape = runtime.window.cypherclawLiveMidiShapes[0];
+    const drawStart = runtime.drawCalls.length;
+    runtime.runNextFrame(340);
+    const frameCalls = runtime.drawCalls.slice(drawStart);
+
+    assert.equal(runtime.canvas.getAttribute("data-visualizer-layers"), "audio-features,midi-shapes");
+    assert.equal(runtime.canvas.getAttribute("data-midi-layer"), "foreground");
+    assert.equal(runtime.canvas.getAttribute("data-midi-blend-mode"), "lighter");
+
+    const backgroundIndex = frameCalls.findIndex((call) => call.op === "fillRect");
+    const audioPulseIndex = frameCalls.findIndex((call) => call.op === "arc" && call.args[2] > 80);
+    const blendIndex = frameCalls.findIndex(
+        (call) => call.op === "globalCompositeOperation" && call.value === "lighter",
+    );
+    const sourceOverIndex = frameCalls.findIndex(
+        (call, index) => index > blendIndex && call.op === "globalCompositeOperation" && call.value === "source-over",
+    );
+    assert.ok(backgroundIndex >= 0, "the frame clears the shared canvas before drawing layers");
+    assert.ok(audioPulseIndex > backgroundIndex, "the audio-feature layer draws after the background clear");
+    assert.ok(blendIndex > audioPulseIndex, "the MIDI blend mode starts after audio-feature drawing");
+
+    const age = 340 - shape.born_at_ms;
+    const life = 1 - Math.min(1, Math.max(0, age / shape.lifetime_ms));
+    const expectedRadius = Math.max(3, shape.radius_px * (0.72 + life * 0.28));
+    const expectedX = Math.max(expectedRadius, Math.min(640 - expectedRadius, shape.x_norm * 640));
+    const expectedY = Math.max(expectedRadius, Math.min(360 - expectedRadius, shape.y_norm * 360));
+    const midiCenterArcIndex = frameCalls.findIndex(
+        (call, index) =>
+            index > blendIndex &&
+            call.op === "arc" &&
+            Math.abs(call.args[0] - expectedX) < 0.001 &&
+            Math.abs(call.args[1] - expectedY) < 0.001 &&
+            Math.abs(call.args[2] - expectedRadius) < 0.001,
+    );
+    assert.ok(midiCenterArcIndex > blendIndex, "MIDI shapes draw after their foreground blend mode is active");
+    assert.ok(midiCenterArcIndex < sourceOverIndex, "normal compositing is restored after MIDI drawing");
+    assert.equal(runtime.context2d.globalCompositeOperation, "source-over");
+});
+
