test("visualizer runtime opens live MIDI WebSocket and queues normalized note events", async () => {
    const runtime = await loadRuntime();

    assert.equal(runtime.webSockets.length, 1);
    assert.equal(runtime.webSockets[0].url, "wss://cypherclaw.holdenu.com/api/cypherclaw/live-midi");

    runtime.webSockets[0].dispatch("open");
    assert.equal(runtime.canvas.getAttribute("data-midi-state"), "connected");

    runtime.webSockets[0].dispatch("message", {
        data: JSON.stringify({ status: 144, data1: 60, data2: 100, ts: 1779568086.25 }),
    });
    runtime.webSockets[0].dispatch("message", {
        data: JSON.stringify({ status: 145, data1: 64, data2: 0, ts: 1779568086.5 }),
    });
    runtime.webSockets[0].dispatch("message", {
        data: JSON.stringify({ status: 130, data1: 67, data2: 42, ts: 1779568086.75 }),
    });
    runtime.webSockets[0].dispatch("message", {
        data: JSON.stringify({ status: 176, data1: 74, data2: 99, ts: 1779568087 }),
    });
    runtime.webSockets[0].dispatch("message", { data: "{not-json" });
    runtime.webSockets[0].dispatch("message", {
        data: JSON.stringify({ status: 144, data1: 128, data2: 100, ts: 1779568088 }),
    });

    const events = runtime.window.cypherclawLiveMidiEvents;
    assert.equal(events.length, 3);
    assert.deepEqual(events.map((event) => event.type), ["note_on", "note_off", "note_off"]);
    assert.deepEqual(events.map((event) => event.note), [60, 64, 67]);
    assert.deepEqual(events.map((event) => event.velocity), [100, 0, 42]);
    assert.deepEqual(events.map((event) => event.channel), [1, 2, 3]);
    assert.equal(events[0].status, 144);
    assert.equal(events[0].ts, 1779568086.25);
    assert.equal(typeof events[0].received_at_ms, "number");
    assert.equal(runtime.window.cypherclawVisualizerState.midiEvents, events);
    assert.equal(runtime.canvas.getAttribute("data-midi-state"), "live");
    assert.equal(runtime.canvas.getAttribute("data-midi-events"), "3");

    runtime.webSockets[0].dispatch("close");
    assert.equal(runtime.canvas.getAttribute("data-midi-state"), "closed");
    assert.equal(runtime.window.cypherclawLiveMidiEvents.length, 3);
});

test("visualizer runtime keeps the live MIDI event queue bounded", async () => {
    const runtime = await loadRuntime();
    const socket = runtime.webSockets[0];

    for (let i = 0; i < 140; i += 1) {
        socket.dispatch("message", {
            data: JSON.stringify({ status: 144, data1: i % 128, data2: 64, ts: i }),
        });
    }

    const events = runtime.window.cypherclawLiveMidiEvents;
    assert.equal(events.length, 128);
    assert.equal(events[0].ts, 12);
    assert.equal(events[0].note, 12);
    assert.equal(events[127].ts, 139);
    assert.equal(events[127].note, 11);
    assert.equal(runtime.canvas.getAttribute("data-midi-events"), "128");
});

test("visualizer runtime maps live MIDI note-on events to decaying canvas shapes", async () => {
    const runtime = await loadRuntime();
    const socket = runtime.webSockets[0];

    runtime.setNow(120);
    socket.dispatch("message", {
        data: JSON.stringify({ status: 144, data1: 48, data2: 32, ts: 1 }),
    });
    runtime.setNow(160);
    socket.dispatch("message", {
        data: JSON.stringify({ status: 144, data1: 84, data2: 120, ts: 2 }),
    });
    socket.dispatch("message", {
        data: JSON.stringify({ status: 128, data1: 84, data2: 0, ts: 3 }),
    });

    const shapes = runtime.window.cypherclawLiveMidiShapes;
    assert.equal(shapes.length, 2);
    assert.equal(runtime.window.cypherclawVisualizerState.midiShapes, shapes);
    assert.deepEqual(shapes.map((shape) => shape.note), [48, 84]);
    assert.equal(shapes[0].pitch_axis, "y");
    assert.equal(shapes[0].size_source, "velocity");
    assert.ok(shapes[0].y_norm > shapes[1].y_norm, "higher MIDI notes render higher on the canvas");
    assert.ok(shapes[1].radius_px > shapes[0].radius_px, "higher velocity renders a larger shape");
    assert.equal(shapes[0].lifetime_ms, 1800);
    assert.equal(shapes[1].born_at_ms, 160);
    assert.equal(runtime.canvas.getAttribute("data-midi-shapes"), "2");
    assert.equal(runtime.canvas.getAttribute("data-midi-last-note"), "84");

    const drawStart = runtime.drawCalls.length;
    runtime.runNextFrame(300);
    const frameCalls = runtime.drawCalls.slice(drawStart);
    assert.ok(
        frameCalls.filter((call) => call.op === "arc").length >= 4,
        "the frame draws the audio feature arcs plus the MIDI note shapes",
    );
    assert.equal(runtime.window.cypherclawLiveMidiShapes.length, 2);

    runtime.runNextFrame(shapes[1].born_at_ms + shapes[1].lifetime_ms + 1);
    assert.equal(runtime.window.cypherclawLiveMidiShapes.length, 0);
    assert.equal(runtime.canvas.getAttribute("data-midi-shapes"), "0");
});

test("visualizer runtime accepts flat glyph payloads and keeps drawing after invalid SSE JSON", async () => {
    const runtime = await loadRuntime();

    runtime.eventSources[0].dispatch("message", {
        data: JSON.stringify({
            source: "glyph-audio-state",
            timestamp: 1779537600.123,
            rms: 0.18,
            pitch_hz: 261.6,
            spectral_centroid_hz: 1480,
            onset_rate_hz: 1.8,
            brightness: 0.41,
            motion: 0.33,
            texture: 0.62,
            density: 0.29,
            arc_phase: "Divination",
            tuning_system_name: "5-limit-ji",
        }),
    });
    runtime.runNextFrame(100);
    const firstRenderCount = Number(runtime.canvas.getAttribute("data-render-count"));

    assert.equal(runtime.window.cypherclawLiveFeatures.centroid_hz, 1480);
    assert.equal(runtime.window.cypherclawLiveFeatures.scene, "Divination");
    assert.equal(runtime.window.cypherclawLiveFeatures.tuning, "5-limit-ji");
    assert.equal(runtime.window.cypherclawLiveFeatures.event_count, 1);
    assert.ok(firstRenderCount >= 1);

    runtime.eventSources[0].dispatch("features", { data: "{not-json" });
    assert.equal(runtime.canvas.getAttribute("data-feed-state"), "bad-message");
    assert.equal(runtime.window.cypherclawLiveFeatures.scene, "Divination");

    runtime.runNextFrame(180);
    assert.ok(Number(runtime.canvas.getAttribute("data-render-count")) > firstRenderCount);
});

