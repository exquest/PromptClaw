function makeCanvasRuntime(script) {
    const drawCalls = [];
    const animationFrames = [];
    const eventSources = [];
    const webSockets = [];
    const fakeClock = { now: 1000 };
    const canvas = makeElement({
        "data-live-features-url": "/api/cypherclaw/live-features",
        "data-live-midi-url": "/api/cypherclaw/live-midi",
        "data-visualizer-state": "pending",
        "data-feed-state": "pending",
        "data-midi-state": "pending",
        "data-midi-events": "0",
        "data-midi-shapes": "0",
    });
    canvas.width = 1280;
    canvas.height = 720;
    canvas.getBoundingClientRect = () => ({ width: 640, height: 360 });

    const context2d = {
        set fillStyle(value) {
            drawCalls.push({ op: "fillStyle", value });
        },
        set strokeStyle(value) {
            drawCalls.push({ op: "strokeStyle", value });
        },
        set lineWidth(value) {
            drawCalls.push({ op: "lineWidth", value });
        },
        setTransform(...args) {
            drawCalls.push({ op: "setTransform", args });
        },
        fillRect(...args) {
            drawCalls.push({ op: "fillRect", args });
        },
        createRadialGradient(...args) {
            drawCalls.push({ op: "createRadialGradient", args });
            return {
                addColorStop(offset, color) {
                    drawCalls.push({ op: "addColorStop", offset, color });
                },
            };
        },
        beginPath() {
            drawCalls.push({ op: "beginPath" });
        },
        arc(...args) {
            drawCalls.push({ op: "arc", args });
        },
        fill() {
            drawCalls.push({ op: "fill" });
        },
        moveTo(...args) {
            drawCalls.push({ op: "moveTo", args });
        },
        lineTo(...args) {
            drawCalls.push({ op: "lineTo", args });
        },
        stroke() {
            drawCalls.push({ op: "stroke" });
        },
    };
    canvas.getContext = (kind) => {
        assert.equal(kind, "2d");
        return context2d;
    };

    const audio = makeElement({
        "data-stream-url": "/api/cypherclaw/live.m3u8",
        "data-playback-mode": "pending",
    });
    audio.canPlayType = () => "";

    class FakeEventSource {
        constructor(url) {
            this.url = url;
            this.closed = false;
            this.listeners = {};
            eventSources.push(this);

    runtime.setNow(120);
    socket.dispatch("message", {
        data: JSON.stringify({ status: 144, data1: 48, data2: 32, ts: 1 }),
    });
    runtime.setNow(160);
    socket.dispatch("message", {
        data: JSON.stringify({ status: 144, data1: 84, data2: 120, ts: 2 }),
    });
    socket.dispatch("message", {
        data: JSON.stringify({ status: 128, data1: 84, data2: 0, ts: 3 }),
    });

    const shapes = runtime.window.cypherclawLiveMidiShapes;
    assert.equal(shapes.length, 2);
    assert.equal(runtime.window.cypherclawVisualizerState.midiShapes, shapes);
    assert.deepEqual(shapes.map((shape) => shape.note), [48, 84]);
    assert.equal(shapes[0].pitch_axis, "y");
    assert.equal(shapes[0].size_source, "velocity");
    assert.ok(shapes[0].y_norm > shapes[1].y_norm, "higher MIDI notes render higher on the canvas");
    assert.ok(shapes[1].radius_px > shapes[0].radius_px, "higher velocity renders a larger shape");
    assert.equal(shapes[0].lifetime_ms, 1800);
    assert.equal(shapes[1].born_at_ms, 160);
    assert.equal(runtime.canvas.getAttribute("data-midi-shapes"), "2");
    assert.equal(runtime.canvas.getAttribute("data-midi-last-note"), "84");

    const drawStart = runtime.drawCalls.length;
    runtime.runNextFrame(300);
    const frameCalls = runtime.drawCalls.slice(drawStart);
    assert.ok(
        frameCalls.filter((call) => call.op === "arc").length >= 4,
        "the frame draws the audio feature arcs plus the MIDI note shapes",
    );
    assert.equal(runtime.window.cypherclawLiveMidiShapes.length, 2);

    runtime.runNextFrame(shapes[1].born_at_ms + shapes[1].lifetime_ms + 1);
    assert.equal(runtime.window.cypherclawLiveMidiShapes.length, 0);
    assert.equal(runtime.canvas.getAttribute("data-midi-shapes"), "0");
});

