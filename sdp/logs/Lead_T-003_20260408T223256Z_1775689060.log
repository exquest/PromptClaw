   370	def _split_message(text: str) -> list[str]:
   371	    if len(text) <= MAX_MESSAGE_LEN:
   372	        return [text]
   373	    chunks = []
   374	    while text:
   375	        if len(text) <= MAX_MESSAGE_LEN:
   376	            chunks.append(text)
   377	            break
   378	        split_at = text.rfind("\n", 0, MAX_MESSAGE_LEN)
   379	        if split_at == -1:
   380	            split_at = MAX_MESSAGE_LEN
   381	        chunks.append(text[:split_at])
   382	        text = text[split_at:].lstrip("\n")
   383	    return chunks
