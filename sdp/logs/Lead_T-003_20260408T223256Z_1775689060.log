   279	def tg_send(text: str) -> dict:
   280	    """Send a message. Auto-detects Markdown for code blocks."""
   281	    result = {}
   282	    for chunk in _split_message(text):
   283	        data: dict = {"chat_id": CHAT_ID, "text": chunk}
   284	        # Use Markdown parse mode if the message contains code blocks
   285	        if _has_code_block(chunk):
   286	            data["parse_mode"] = "Markdown"
   287	        result = tg_api("sendMessage", data)
   288	        # If Markdown fails (bad formatting), retry without parse_mode
   289	        if not result.get("ok") and "parse_mode" in data:
   290	            del data["parse_mode"]
   291	            result = tg_api("sendMessage", data)
   292	        time.sleep(0.2)
   293	    return result
