+def _empty_rollup() -> dict[str, int]:
+    return {
+        "total": 0,
+        "complete": 0,
+        "running": 0,
+        "pending": 0,
+        "needs_split": 0,
+        "blocked": 0,
+        "needs_attention": 0,
+        "skipped": 0,
+        "frozen": 0,
+    }
