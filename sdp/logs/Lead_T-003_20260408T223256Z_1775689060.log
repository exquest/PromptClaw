   389	
   390	class DaemonState:
   391	    def __init__(self):
   392	        self.last_update_id = 0
   393	        self.conversation: deque[dict] = deque(maxlen=CONVERSATION_WINDOW)
   394	        self.tasks: dict[str, dict] = {}  # task_id -> {status, agent, prompt, result, ...}
   395	        self.schedules: list[dict] = []   # [{name, interval_s, command, last_run, enabled}]
   396	        self.pending_confirm: dict | None = None
   397	        self._lock = threading.Lock()
   398	        self._load()
   399	
   400	    def _load(self):
   401	        try:
   402	            data = json.loads(STATE_FILE.read_text())
   403	            self.last_update_id = data.get("last_update_id", 0)
   404	            for msg in data.get("conversation", []):
   405	                self.conversation.append(msg)
   406	            self.tasks = data.get("tasks", {})
   407	            self.schedules = data.get("schedules", [])
   408	        except (FileNotFoundError, json.JSONDecodeError):
   409	            pass
   410	
   411	    def save(self):
   412	        with self._lock:
   413	            STATE_FILE.write_text(json.dumps({
   414	                "last_update_id": self.last_update_id,
   415	                "conversation": list(self.conversation),
   416	                "tasks": self.tasks,
   417	                "schedules": self.schedules,
   418	            }, default=str, indent=2))
   419	
   420	    def add_message(self, role: str, text: str):
   421	        self.conversation.append({
   422	            "role": role,
   423	            "text": text,
   424	            "time": datetime.now(timezone.utc).isoformat(),
   425	        })
   426	        self.save()
   427	
   428	    def conversation_context(self) -> str:
   429	        if not self.conversation:
   430	            return "(no prior conversation)"
   431	        lines = []
   432	        for msg in self.conversation:
   433	            prefix = "Anthony" if msg["role"] == "user" else "CypherClaw"
   434	            lines.append(f"[{msg.get('time', '')}] {prefix}: {msg['text']}")
   435	        return "\n".join(lines)
   436	
   437	    def create_task(self, task_id: str, agent: str, prompt: str) -> None:
   438	        self.tasks[task_id] = {
   439	            "status": "running",
   440	            "agent": agent,
   441	            "prompt": prompt[:200],
   442	            "created": datetime.now(timezone.utc).isoformat(),
   443	            "result": None,
   444	        }
   445	        self.save()
   446	
   447	    def complete_task(self, task_id: str, result: str) -> None:
   448	        if task_id in self.tasks:
   449	            self.tasks[task_id]["status"] = "done"
   450	            self.tasks[task_id]["result"] = result[:500]
   451	            self.tasks[task_id]["finished"] = datetime.now(timezone.utc).isoformat()
   452	            self.save()
   453	
   454	    def fail_task(self, task_id: str, error: str) -> None:
   455	        if task_id in self.tasks:
   456	            self.tasks[task_id]["status"] = "failed"
   457	            self.tasks[task_id]["result"] = error[:500]
   458	            self.save()
