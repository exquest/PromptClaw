   253	def tg_api(method: str, data: dict | None = None) -> dict:
   254	    url = f"{API_BASE}/{method}"
   255	    payload = json.dumps(data or {}).encode()
   256	    req = urllib.request.Request(url, data=payload)
   257	    req.add_header("Content-Type", "application/json")
   258	    try:
   259	        with urllib.request.urlopen(req, timeout=30) as resp:
   260	            return json.loads(resp.read())
   261	    except urllib.error.HTTPError as e:
   262	        body = ""
   263	        try:
   264	            body = e.read().decode()[:200]
   265	        except Exception:
   266	            pass
   267	        log.warning("Telegram HTTP %s: %s — %s", e.code, method, body)
   268	        return {"ok": False, "error": str(e)}
   269	    except urllib.error.URLError as e:
   270	        log.warning("Telegram API error: %s", e)
   271	        return {"ok": False, "error": str(e)}
