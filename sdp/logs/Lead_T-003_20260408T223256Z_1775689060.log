   325	def tg_send_file(filepath: str, caption: str = "") -> None:
   326	    """Send a file via Telegram. Uses sendPhoto for images, sendDocument for others.
   327	    Also records the file send in conversation memory so the daemon remembers."""
   328	    # Record in conversation memory
   329	    filename = os.path.basename(filepath)
   330	    state.add_message("assistant", f"[file sent] {filename}: {caption}")
   331	    import mimetypes
   332	    mime = mimetypes.guess_type(filepath)[0] or ""
   333	    method = "sendPhoto" if mime.startswith("image/") else "sendDocument"
   334	    field = "photo" if method == "sendPhoto" else "document"
   335	
   336	    try:
   337	        import urllib.request
   338	        boundary = "----CypherClawUpload"
   339	        filename = os.path.basename(filepath)
   340	        with open(filepath, "rb") as f:
   341	            file_data = f.read()
   342	
   343	        parts = []
   344	        # chat_id field
   345	        parts.append(f"--{boundary}\r\nContent-Disposition: form-data; name=\"chat_id\"\r\n\r\n{CHAT_ID}".encode())
   346	        # caption field
   347	        if caption:
   348	            parts.append(f"--{boundary}\r\nContent-Disposition: form-data; name=\"caption\"\r\n\r\n{caption[:1024]}".encode())
   349	        # file field
   350	        file_header = f"--{boundary}\r\nContent-Disposition: form-data; name=\"{field}\"; filename=\"{filename}\"\r\nContent-Type: {mime or 'application/octet-stream'}\r\n\r\n".encode()
   351	        parts.append(file_header + file_data)
   352	        # closing
   353	        body = b"\r\n".join(parts) + f"\r\n--{boundary}--\r\n".encode()
   354	
   355	        req = urllib.request.Request(f"{API_BASE}/{method}", data=body)
   356	        req.add_header("Content-Type", f"multipart/form-data; boundary={boundary}")
   357	        with urllib.request.urlopen(req, timeout=60) as resp:
   358	            result = json.loads(resp.read())
   359	            if not result.get("ok"):
   360	                log.warning("File send failed: %s", result)
   361	    except Exception as e:
   362	        log.warning("tg_send_file error: %s — falling back to telegram.py", e)
   363	        # Fallback to the old method
   364	        cmd = [sys.executable, str(TOOLS_DIR / "telegram.py"), "file", filepath]
   365	        if caption:
   366	            cmd.append(caption)
   367	        subprocess.run(cmd, capture_output=True, timeout=30)
