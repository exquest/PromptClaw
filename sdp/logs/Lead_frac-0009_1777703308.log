   308	# ---------------------------------------------------------------------------
   309	# Verification and Scoring
   310	# ---------------------------------------------------------------------------
   311	
   312	def verify_resolution(leader_notes: tuple[int, int], follower_notes: tuple[int, int]) -> bool:
   313	    """
   314	    Verify resolution-completion for a single interval transition.
   315	    If the first vertical interval is a sharp dissonance, both voices
   316	    must move stepwise (0, 1, or 2 semitones) to resolve it.
   317	    """
   318	    initial_interval = interval_between(leader_notes[0], follower_notes[0])
   319	    if initial_interval.consonance != "sharp_dissonance":
   320	        return True
   321	    
   322	    leader_motion = abs(leader_notes[1] - leader_notes[0])
   323	    follower_motion = abs(follower_notes[1] - follower_notes[0])
   324	    
   325	    return leader_motion <= 2 and follower_motion <= 2
   326	
   327	
   328	def voice_leading_smoothness(leader_notes: tuple[int, ...], follower_notes: tuple[int, ...]) -> float:
   329	    """
   330	    Calculate voice-leading smoothness scoring for a pair of voices.
   331	    Returns the average size of leaps (in semitones) across all melodic
   332	    intervals in both voices. A lower score means smoother voice-leading.
   333	    """
   334	    total_motion = 0
   335	    intervals = 0
   336	
   337	    if len(leader_notes) > 1:
   338	        total_motion += sum(abs(leader_notes[i] - leader_notes[i-1]) for i in range(1, len(leader_notes)))
   339	        intervals += len(leader_notes) - 1
   340	
   341	    if len(follower_notes) > 1:
   342	        total_motion += sum(abs(follower_notes[i] - follower_notes[i-1]) for i in range(1, len(follower_notes)))
   343	        intervals += len(follower_notes) - 1
   344	
   345	    if intervals == 0:
   346	        return 0.0
   347	
   348	    return float(total_motion) / intervals
   349	
