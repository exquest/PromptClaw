   367	@dataclass(frozen=True)
   368	class DissonanceReport:
   369	    """Analysis of dissonance and resolution across a voice-pair sequence."""
   370	
   371	    annotations: tuple[DissonanceAnnotation, ...]
   372	    sharp_dissonance_count: int
   373	    mild_dissonance_count: int
   374	    unresolved_count: int
   375	    resolution_rate: float
   376	
   377	
   378	def analyze_dissonance(
   379	    leader_notes: tuple[int, ...],
   380	    follower_notes: tuple[int, ...],
   381	) -> DissonanceReport:
   382	    """Annotate each vertical interval with consonance metadata from music_theory.py.
   383	
   384	    For sharp dissonances, checks whether the next beat resolves stepwise
   385	    (both voices move <=2 semitones) to a non-sharp-dissonance interval.
   386	    """
   387	    pair_count = min(len(leader_notes), len(follower_notes))
   388	    if pair_count == 0:
   389	        return DissonanceReport(
   390	            annotations=(),
   391	            sharp_dissonance_count=0,
   392	            mild_dissonance_count=0,
   393	            unresolved_count=0,
   394	            resolution_rate=1.0,
   395	        )
   396	
   397	    annotations: list[DissonanceAnnotation] = []
   398	    sharp_count = 0
   399	    mild_count = 0
   400	    unresolved = 0
   401	
   402	    for i in range(pair_count):
   403	        iv = interval_between(leader_notes[i], follower_notes[i])
   404	        consonance = iv.consonance
   405	        resolved: bool | None = None
   406	
   407	        if consonance == "sharp_dissonance":
   408	            sharp_count += 1
   409	            if i + 1 < pair_count:
   410	                leader_motion = abs(leader_notes[i + 1] - leader_notes[i])
   411	                follower_motion = abs(follower_notes[i + 1] - follower_notes[i])
   412	                next_iv = interval_between(leader_notes[i + 1], follower_notes[i + 1])
   413	                resolved = (
   414	                    leader_motion <= 2
   415	                    and follower_motion <= 2
   416	                    and next_iv.consonance != "sharp_dissonance"
   417	                )
   418	            else:
   419	                resolved = False
   420	            if not resolved:
   421	                unresolved += 1
   422	        elif consonance == "mild_dissonance":
   423	            mild_count += 1
   424	
   425	        annotations.append(DissonanceAnnotation(
   426	            beat_index=i,
   427	            leader_midi=leader_notes[i],
   428	            follower_midi=follower_notes[i],
   429	            interval=iv,
   430	            consonance=consonance,
   431	            resolved=resolved,
   432	        ))
   433	
   434	    rate = 1.0 if sharp_count == 0 else float(sharp_count - unresolved) / sharp_count
   435	
   436	    return DissonanceReport(
   437	        annotations=tuple(annotations),
   438	        sharp_dissonance_count=sharp_count,
   439	        mild_dissonance_count=mild_count,
   440	        unresolved_count=unresolved,
   441	        resolution_rate=rate,
   442	    )
   443	
   444	
   445	def verify_resolution_sequence(
   446	    leader_notes: tuple[int, ...],
   447	    follower_notes: tuple[int, ...],
   448	) -> bool:
   449	    """Return True only if every sharp dissonance in the sequence resolves properly."""
   450	    report = analyze_dissonance(leader_notes, follower_notes)
   451	    return report.unresolved_count == 0
   452	
   453	
   454	def resolution_completeness_score(
   455	    leader_notes: tuple[int, ...],
   456	    follower_notes: tuple[int, ...],
   457	) -> float:
   458	    """Return 0.0-1.0 measuring the proportion of resolved sharp dissonances."""
   459	    report = analyze_dissonance(leader_notes, follower_notes)
   460	    return report.resolution_rate
   461	
   462	
   463	def weighted_voice_leading_smoothness(
   464	    leader_notes: tuple[int, ...],
   465	    follower_notes: tuple[int, ...],
   466	    *,
   467	    dissonance_penalty: float = 2.0,
   468	) -> float:
   469	    """Voice-leading smoothness with a penalty for unresolved sharp dissonances.
   470	
   471	    Computes the base melodic motion average, then adds *dissonance_penalty*
   472	    semitones per unresolved sharp dissonance.  Lower is smoother.
   473	    """
   474	    base = voice_leading_smoothness(leader_notes, follower_notes)
   475	    report = analyze_dissonance(leader_notes, follower_notes)
   476	    return base + dissonance_penalty * report.unresolved_count
   477	

