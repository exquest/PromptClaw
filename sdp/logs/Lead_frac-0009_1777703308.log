   302	    source: str,
   303	    line_count: int,
   304	    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef],
   305	    matching_tests: list[Path],
   306	    test_boosted: bool = False,
   307	) -> bool:
   308	    """Return whether a depth-3 module qualifies as polished depth 4."""
   309	    if line_count <= 100:
   310	        return False
   311	    if _DEPTH_FOUR_MARKER_RE.search(source):
   312	        return False
   313	    if _docstring_coverage(public_function_nodes) <= _DEPTH_FOUR_DOCSTRING_THRESHOLD:
   314	        return False
   315	    if test_boosted:
   316	        return True
   317	    return _test_line_ratio(line_count, matching_tests) >= _DEPTH_FOUR_TEST_RATIO_THRESHOLD
   318	
   319	
   320	def _docstring_coverage(
   321	    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef],
   322	) -> float:
   323	    """Return the fraction of public functions with docstrings."""
   324	    if not public_function_nodes:
   325	        return 0.0
   326	
   327	    documented = sum(1 for node in public_function_nodes if ast.get_docstring(node) is not None)
   328	    return documented / len(public_function_nodes)
   329	
   330	
   331	def _test_line_ratio(source_line_count: int, matching_tests: list[Path]) -> float:
   332	    """Return the total test-to-source line ratio for matching tests."""
   333	    if source_line_count <= 0:
   334	        return 0.0
   335	
   336	    test_line_count = 0
   337	    for test_path in matching_tests:
   338	        try:
   339	            test_line_count += len(test_path.read_text().splitlines())
   340	        except OSError:
   341	            continue
   342	    return test_line_count / source_line_count
   343	
   344	
   345	def _compute_test_coverage(
   346	    module_name: str,
   347	    public_functions: list[str],
   348	    matching_tests: list[Path],
   349	) -> tuple[float, float]:
   350	    """Return (total_coverage, max_single_file_coverage) of public functions."""
   351	    if not public_functions:
   352	        return 0.0, 0.0
   353	
   354	    total_imported_funcs: set[str] = set()
   355	    max_single_file_coverage = 0.0
   356	
   357	    for test_path in matching_tests:
   358	        try:
   359	            tree = ast.parse(test_path.read_text())
   360	        except (SyntaxError, OSError):
   361	            continue
   362	
   363	        file_imported_funcs: set[str] = set()
   364	        for node in ast.walk(tree):
   365	            if isinstance(node, ast.ImportFrom) and node.module and node.module.endswith(
   366	                module_name
   367	            ):
   368	                for alias in node.names:
   369	                    if alias.name in public_functions:
   370	                        file_imported_funcs.add(alias.name)
   371	                        total_imported_funcs.add(alias.name)
   372	        
   373	        file_coverage = len(file_imported_funcs) / len(public_functions)
   374	        if file_coverage > max_single_file_coverage:
   375	            max_single_file_coverage = file_coverage
   376	
   377	    total_coverage = len(total_imported_funcs) / len(public_functions)
   378	    return total_coverage, max_single_file_coverage
   379	
   380	
   381	def _find_matching_test_files(source_path: Path) -> list[Path]:
   382	    """Locate matching test files under the nearest tests directory.
   383	
   384	    Python convention: ``test_<module>.py``
   385	    JS/TS convention: ``<module>.test.{js,ts,tsx}``, ``<module>.spec.{js,ts,tsx}``,
   386	    and ``__tests__/<module>.{js,ts,tsx}``
   387	    """
   388	    stem = source_path.stem
   389	    results: list[Path] = []
   390	
   391	    if source_path.suffix == ".py":
   392	        pattern = f"test_{stem}.py"
   393	        for parent in source_path.parents:
   394	            tests_dir = parent / "tests"
   395	            if tests_dir.is_dir():
   396	                results.extend(tests_dir.rglob(pattern))
   397	                break
   398	    elif source_path.suffix in _JS_TS_EXTENSIONS:
   399	        js_patterns = [
   400	            f"{stem}.test.js", f"{stem}.test.ts", f"{stem}.test.tsx",
   401	            f"{stem}.spec.js", f"{stem}.spec.ts", f"{stem}.spec.tsx",
   402	        ]
   403	        for parent in source_path.parents:
   404	            # Search tests/ directory
   405	            tests_dir = parent / "tests"
   406	            if tests_dir.is_dir():
   407	                for pat in js_patterns:
   408	                    results.extend(tests_dir.rglob(pat))
   409	            # Search __tests__/ directory
   410	            dunder_tests = parent / "__tests__"
   411	            if dunder_tests.is_dir():
   412	                for ext in (".js", ".ts", ".tsx"):
   413	                    match_path = dunder_tests / f"{stem}{ext}"
   414	                    if match_path.exists():
   415	                        results.append(match_path)
   416	            if results:
   417	                break
   418	
   419	    return sorted(set(results))
   420	

