+) -> MotionProfile:
+    """Classify parallel, contrary, oblique, and static motion between voices."""
+    pair_count = min(len(leader_notes), len(follower_notes))
+    transitions = max(pair_count - 1, 0)
+    if transitions == 0:
+        return MotionProfile(
+            transitions=0,
+            parallel_count=0,
+            contrary_count=0,
