        route_input = route_prompt
    else:
        route_cmd = ["claude", "--dangerously-skip-permissions", "--print", "--effort", "low", "-p", "-"]
        route_input = route_prompt
    return subprocess.run(
        route_cmd,
        input=route_input,
        capture_output=True,

