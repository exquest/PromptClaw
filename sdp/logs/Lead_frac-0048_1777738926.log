"""Fractal development — progressive depth refinement for SDP tasks.

Adds depth-aware task generation to the SDP pipeline. Instead of building
modules from scratch, the fractal system:

1. Generates a complete skeleton at depth 0 (interfaces only)
2. Each pass deepens all modules by one level
3. Every depth level goes through lead/verify pipeline
4. The project becomes sharper at every scale simultaneously

Depths:
  0 — Skeleton: signatures + NotImplementedError, interface tests pass
  1 — Stub: trivial returns (correct types, wrong values), basic tests pass
  2 — Simple: one-path implementation, end-to-end works
  3 — Full: edge cases, error handling, integration
  4 — Polished: optimized, documented, battle-tested

Commands:
  sdp fractal init <prd.md>     Generate depth-0 skeleton from PRD
  sdp fractal scan [path]       Analyze modules and report current depth
  sdp fractal deepen [--target] Generate tasks for next depth, load into queue
  sdp fractal status            Show resolution map across the project
"""

from __future__ import annotations

import ast
import json
import re
from collections.abc import Callable, Mapping
from dataclasses import dataclass, field
from pathlib import Path
from typing import TYPE_CHECKING, Any

from jinja2 import TemplateNotFound

from sdp.pipeline.alternator import AgentAlternator
from sdp.prompts.builder import PromptBuilder

if TYPE_CHECKING:
    from sdp.agents.base import AgentAdapter, AgentResult
    from sdp.config.settings import SDPSettings

_DEPTH_FOUR_DOCSTRING_THRESHOLD = 0.9
_DEPTH_FOUR_TEST_RATIO_THRESHOLD = 0.5
_DEPTH_FOUR_MARKER_RE = re.compile(r"\b(?:TODO|FIXME|HACK)\b", re.IGNORECASE)

_JS_TS_EXTENSIONS = {".js", ".ts", ".tsx"}

# JS/TS regex heuristics
_JS_NOT_IMPLEMENTED_RE = re.compile(
    r"throw\s+new\s+Error\(\s*['\"]not\s+implemented['\"]", re.IGNORECASE
)
_JS_TRIVIAL_ARROW_RE = re.compile(
    r"=>\s*(?:null|undefined|0|true|false|'[^']*'|\"[^\"]*\"|\[\s*\]|\(\s*\{?\s*\}?\s*\))\s*[;,\n]"
)
_JS_TRIVIAL_RETURN_RE = re.compile(
    r"^\s*return\s+(?:null|undefined|0|true|false|'[^']*'|\"[^\"]*\"|\[\s*\]|\{\s*\})\s*;",
    re.MULTILINE,
)
_JS_LOGIC_BLOCK_RE = re.compile(r"\b(?:if|for|while|switch|try)\s*\(")
_JS_FUNCTION_RE = re.compile(
    r"(?:export\s+)?(?:async\s+)?function\s+(\w+)"
)
_JS_ARROW_FUNC_RE = re.compile(
    r"(?:export\s+)?(?:const|let|var)\s+(\w+)\s*=\s*(?:async\s+)?\("
)
_JS_CLASS_RE = re.compile(r"(?:export\s+)?class\s+(\w+)")
_PYTHON_MODULE_PATH_RE = re.compile(r"^[A-Za-z0-9_./-]+\.py$")
_PYTHON_IDENTIFIER_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")


@dataclass(frozen=True)
class SkeletonCallableSpec:
    """Structured callable definition returned from the skeleton planner."""

    name: str
    signature: str
    docstring: str = ""


@dataclass(frozen=True)
class SkeletonClassSpec:
    """Structured class definition returned from the skeleton planner."""

    name: str
    docstring: str = ""
    methods: tuple[SkeletonCallableSpec, ...] = ()


@dataclass(frozen=True)
class SkeletonModuleSpec:
    """Structured module definition returned from the skeleton planner."""

    path: str
    docstring: str = ""
    classes: tuple[SkeletonClassSpec, ...] = ()
    functions: tuple[SkeletonCallableSpec, ...] = ()


# ── Depth Classification ──────────────────────────────────────

@dataclass
class ModuleDepth:
    """Analysis result for a single module."""
    path: str
    module_name: str
    depth: int  # 0-4
    reason: str
    classes: list[str] = field(default_factory=list)
    functions: list[str] = field(default_factory=list)
    not_implemented_count: int = 0
    trivial_return_count: int = 0
    real_logic_count: int = 0
    test_count: int = 0
    test_files: list[str] = field(default_factory=list)
    test_coverage: float = 0.0
    test_boosted: bool = False
    line_count: int = 0


def classify_depth(source_path: str | Path) -> ModuleDepth:
    """Classify a module's implementation depth.

    Dispatches to language-specific classifiers based on file extension.
    """
    path = Path(source_path)
    if not path.exists():
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="file does not exist",
        )

    if path.suffix in _JS_TS_EXTENSIONS:
        return classify_depth_js(path)
    if path.suffix == ".py":
        return _classify_depth_python(path)

    return ModuleDepth(
        path=str(path),
        module_name=path.stem,
        depth=-1,
        reason=f"unsupported file type: {path.suffix}",
    )


def _classify_depth_python(path: Path) -> ModuleDepth:
    """Classify a Python module's implementation depth via AST analysis."""
    try:
        source = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        # Source file is not UTF-8 (e.g., vendored Big5 / GBK / latin-1 test
        # fixtures). Fall back to permissive decode so we still report depth=0.
        try:
            source = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return ModuleDepth(
                path=str(path),
                module_name=path.stem,
                depth=-1,
                reason="unreadable file",
            )
    except OSError:
        return ModuleDepth(
            path=str(path),
            module_name=path.stem,
            depth=-1,
            reason="unreadable file",
        )
    lines = source.splitlines()
    line_count = len(lines)

    try:
        tree = ast.parse(source)
    except SyntaxError as e:
        return ModuleDepth(
            path=str(path), module_name=path.stem,
            depth=-1, reason=f"syntax error: {e}",
            line_count=line_count,
        )

    classes = []
    functions = []
    not_implemented = 0
    trivial_returns = 0
    real_logic = 0
    public_function_nodes: list[ast.FunctionDef | ast.AsyncFunctionDef] = []

    for node in ast.walk(tree):
        if isinstance(node, ast.ClassDef):
            classes.append(node.name)
        elif isinstance(node, ast.FunctionDef | ast.AsyncFunctionDef):
            if _is_public_function(node):
                functions.append(node.name)
                public_function_nodes.append(node)

            # Analyze function body
            body = node.body
            # Skip docstrings
