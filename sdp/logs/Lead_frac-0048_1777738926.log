+        "required_prompt_paths": list(report.required_prompt_paths),
+        "missing_required_prompt_paths": list(report.missing_required_prompt_paths),
+        "entries": entries,
+    }
+
+
+def project_scaffold(project_name: str) -> dict[str, str]:
