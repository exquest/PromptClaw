+    entry_paths: set[str] = set()
+    total_size_bytes = 0
+    for entry in entries:
+        category_counts[entry.category] = category_counts.get(entry.category, 0) + 1
+        entry_paths.add(entry.path)
+        total_size_bytes += entry.size_bytes
+
