def _scale_phrase_durations(phrase: Phrase, factor: float) -> Phrase:
    return _replace_phrase(
        phrase,
        notes=[
            Note(
                scale_degree=note.scale_degree,
                duration_beats=round(max(0.25, note.duration_beats * factor), 2),
                accent=note.accent,
            )
            for note in phrase.notes
        ],
    )

