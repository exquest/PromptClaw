    return targets.get(role)


def _guide_tone_degree(role: str, root_degree: int) -> int:
    root = int(_clamp(root_degree, 1, 7))
    if role == "bass":
        return root
    if role == "counter":
        return _shift_scale_degree(root, 2)
    if role == "color":
        return _shift_scale_degree(root, 4)
    return _shift_scale_degree(root, 2)


