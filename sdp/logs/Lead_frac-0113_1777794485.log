+    def test_sampler_effects_source_and_runtime_harness_round_trip_json_diagnostic(
+        self, scd_source: str
+    ) -> None:
+        arg_block = _arg_block(scd_source)
+        defaults = {
+            name: _arg_default(arg_block, name)
+            for name in (
+                "in_bus",
+                "out_bus",
+                "delay_time",
+                "tempo_bpm",
+                "delay_feedback",
+                "verb_mix",
+                "room_size",
+                "freeze_amount",
+                "comb_b_amount",
+                "comb_b_freq",
+                "comb_decay",
+                "comb_damping",
+            )
+        }
