+            },
+            "defaults": defaults,
+            "fx_chain": [label for label, _ in stage_patterns],
+            "stage_positions": stage_positions,
+        }
+        round_tripped = json.loads(json.dumps(diagnostic, sort_keys=True))
+
+        assert round_tripped == diagnostic
