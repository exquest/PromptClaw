+    ):
+        issues.append(
+            MixProfileIssue(
+                "mastering.target_lufs_range",
+                f"unsafe LUFS target/range ({policy.target_lufs}, {policy.target_lufs_range})",
+            )
+        )
+
+    if min_peak > max_peak or min_peak < -8.0 or max_peak > -1.0:
+        issues.append(
