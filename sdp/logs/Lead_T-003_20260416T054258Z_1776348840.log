+
+    if not 8.0 <= policy.dynamic_contrast_db <= 24.0:
+        issues.append(
+            MixProfileIssue(
+                "mastering.dynamic_contrast_db",
+                f"dynamic contrast outside phase-safe range ({policy.dynamic_contrast_db} dB)",
+            )
+        )
+
+    return issues
