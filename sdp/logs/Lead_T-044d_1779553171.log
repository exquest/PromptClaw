### my-claw/tools/senseweave/synthesis/voices/sw_bowed.scd
// sw_bowed.scd — Source stub for the `sw_bowed` voice SynthDef.
//
// CypherClaw v2 §4 voice: damp-cave-wall bowed-string tone.
// Routes the dry signal to `out_bus` and a parallel send to the matching
// per-voice FX return bus `fx_bus_id` (default 21, paired with the
// `cc_space_damp_cave_wall` reverb synth). This `fx_bus_id` control is
// the per-voice routing contract that
// `cypherclaw.space_reverb.build_voice_s_new_args` writes via OSC.
//
// Voice: bowed
// Space: damp_cave_wall
// FX bus: 21
//
// Compile to synthesis/synthdefs/sw_bowed.scsyndef via `.writeDefFile`.

(
SynthDef(\sw_bowed, {
    | freq = 220.0,
      amp = 0.05,
      attack = 0.25,
      release = 1.6,
      bow_pressure = 0.55,
      out_bus = 0,
      fx_bus_id = 21,
      fx_send = 0.6 |

    var env, exciter, body, sig;

    env = EnvGen.kr(
        Env.asr(attack.clip(0.02, 4.0), 1.0, release.clip(0.1, 6.0)),
        doneAction: 2
    );

    // Bowed-string excitation: pink noise filtered into resonator.
    exciter = PinkNoise.ar(bow_pressure.clip(0.0, 1.0));
    body = Resonz.ar(exciter, freq, 0.04, mul: 8.0);
    body = body + (SinOsc.ar(freq) * 0.2);

    sig = body * env * amp;
    sig = Pan2.ar(sig, 0.0);

    Out.ar(out_bus, sig);
    Out.ar(fx_bus_id, sig * fx_send.clip(0.0, 1.0));
}).writeDefFile("../synthdefs/");
)

### my-claw/tools/senseweave/synthesis/voices/sw_breath.scd
// sw_breath.scd — Source stub for the `sw_breath` voice SynthDef.
//
// CypherClaw v2 §4 voice: glass-bell-jar breath tone.
// Routes the dry signal to `out_bus` and a parallel send to the matching
// per-voice FX return bus `fx_bus_id` (default 17, paired with the
// `cc_space_glass_bell_jar` reverb synth). This `fx_bus_id` control is
// the per-voice routing contract that
// `cypherclaw.space_reverb.build_voice_s_new_args` writes via OSC.
//
// Voice: breath
// Space: glass_bell_jar
// FX bus: 17
//
// Compile to synthesis/synthdefs/sw_breath.scsyndef via `.writeDefFile`.

(
SynthDef(\sw_breath, {
    | freq = 220.0,
      amp = 0.06,
      attack = 0.4,
      release = 1.4,
      breathiness = 0.65,
      formant_shift = 1.0,
      out_bus = 0,
      fx_bus_id = 17,
      fx_send = 0.6 |

    var env, tone, noise, sig, send;

    env = EnvGen.kr(
        Env.linen(
            attackTime: attack.clip(0.01, 4.0),
            sustainTime: 0.05,
            releaseTime: release.clip(0.05, 6.0)
        ),
        doneAction: 2
    );

    tone  = SinOsc.ar(freq * formant_shift.clip(0.5, 2.0)) * (1.0 - breathiness);
    noise = BPF.ar(WhiteNoise.ar(1.0), freq * 2.0, 0.3) * breathiness;

    sig = (tone + noise) * env * amp;
    sig = Pan2.ar(sig, 0.0);

    Out.ar(out_bus, sig);
    Out.ar(fx_bus_id, sig * fx_send.clip(0.0, 1.0));
}).writeDefFile("../synthdefs/");
)

### my-claw/tools/senseweave/synthesis/voices/sw_choir.scd
// sw_choir.scd — Source stub for the `sw_choir` voice SynthDef.
//
// CypherClaw v2 §4 voice: stone-cathedral choir tone.
// Routes the dry signal to `out_bus` and a parallel send to the matching
// per-voice FX return bus `fx_bus_id` (default 18, paired with the
// `cc_space_stone_cathedral` reverb synth). This `fx_bus_id` control is
// the per-voice routing contract that
// `cypherclaw.space_reverb.build_voice_s_new_args` writes via OSC.
//
// Voice: choir
// Space: stone_cathedral
// FX bus: 18
//
// Compile to synthesis/synthdefs/sw_choir.scsyndef via `.writeDefFile`.

(
SynthDef(\sw_choir, {
    | freq = 220.0,
      amp = 0.06,
      attack = 0.6,
      release = 2.5,
      formant = 0.5,
      out_bus = 0,
      fx_bus_id = 18,
      fx_send = 0.7 |

    var env, voices, sig;

    env = EnvGen.kr(
        Env.asr(attack.clip(0.05, 6.0), 1.0, release.clip(0.1, 8.0)),
        doneAction: 2
    );

    // Detuned saw stack approximates a stacked choral ensemble.
    voices = Mix.fill(5, { |i|
        SinOsc.ar(freq * (1.0 + ((i - 2) * 0.004)), mul: 0.2)
        + Saw.ar(freq * (1.0 + ((i - 2) * 0.004)), mul: 0.05)
    });
    voices = BPF.ar(voices, freq * (1.0 + formant.clip(0.0, 2.0)), 0.4);

    sig = voices * env * amp;
    sig = Pan2.ar(sig, 0.0);

    Out.ar(out_bus, sig);
    Out.ar(fx_bus_id, sig * fx_send.clip(0.0, 1.0));
}).writeDefFile("../synthdefs/");
)

