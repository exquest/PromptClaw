+
+_FRACTAL_PATH = Path(__file__).resolve().parent.parent / "sdp" / "fractal.py"
+_FRACTAL_SPEC = importlib.util.spec_from_file_location(
+    "_promptclaw_local_functional_harmony_fractal", _FRACTAL_PATH
