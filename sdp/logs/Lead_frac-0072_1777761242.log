_ROOT_INDEX = {
    "C": 0,
    "C#": 1,
    "D": 2,
    "D#": 3,
    "E": 4,
    "F": 5,
    "F#": 6,
    "G": 7,
    "G#": 8,
    "A": 9,
    "Bb": 10,
    "B": 11,
}


def _root_distance(left: str, right: str) -> int:
    raw = abs(_ROOT_INDEX[left] - _ROOT_INDEX[right])
    return min(raw, 12 - raw)


