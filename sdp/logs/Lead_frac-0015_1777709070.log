+
+    def test_build_ablation_cases_accepts_custom_pairs(self) -> None:
+        rules = (
+            DummyRule("metric_accent"),
+            DummyRule("phrase_arch"),
+            DummyRule("agogic"),
+            DummyRule("duration_contrast"),
+        )
+
+        cases = build_ablation_cases(
+            rules,
+            disabled_rule_sets=(
+                ("phrase_arch", "duration_contrast"),
+                ("metric_accent",),
+            ),
+        )
+
+        assert cases == (
+            AblationCase(
