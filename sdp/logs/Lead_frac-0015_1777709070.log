+def _dedupe_rule_ids(rule_ids: Iterable[str]) -> tuple[str, ...]:
+    deduped: list[str] = []
+    seen: set[str] = set()
+    for rule_id in rule_ids:
+        if rule_id in seen:
+            continue
+        seen.add(rule_id)
+        deduped.append(rule_id)
