+def _format_ablation_summary(case: AblationCase, changed: bool) -> str:
+    disabled = ",".join(case.disabled_rules) if case.disabled_rules else "none"
+    remaining = (
+        ",".join(case.remaining_rule_ids) if case.remaining_rule_ids else "baseline"
+    )
