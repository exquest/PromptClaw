+                remaining_rule_ids=case.remaining_rule_ids,
+                removed_rule_ids=case.removed_rule_ids,
+                rendered=rendered,
+                changed=changed,
+                summary=_format_ablation_summary(case, changed),
+            )
+        )
+    return AblationSuite(
+        rule_ids=rule_ids,
+        baseline=baseline,
+        results=tuple(results),
+    )
+
