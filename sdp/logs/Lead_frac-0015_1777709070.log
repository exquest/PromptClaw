            "novelty_peaks": 2,
            "silence_ms": 220.0,
            "rests_ms": [80.0, 240.0, 120.0],
            "section_gs": [0.82, 0.91, 0.94],
            "role": "melody",
        },
        applied_rules=("R1", "R2", "R3"),
        quantities={},
    )


