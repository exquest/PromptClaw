+                remaining_rule_ids=tuple(
+                    rule_id for rule_id in rule_ids if rule_id not in disabled_set
+                ),
+                removed_rule_ids=tuple(
+                    rule_id for rule_id in rule_ids if rule_id in disabled_set
+                ),
