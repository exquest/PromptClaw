-            ("Release", "coda", "Theme", "strong", "authentic"),
-            ("Resolution", "coda", "Release", "moderate", "authentic"),
-            ("Afterglow", "residue", "Resolution", "light", "plagal"),
-        ],
+        glow = next((section for section in reversed(selected) if section[1] == "afterglow"), selected[-1])
