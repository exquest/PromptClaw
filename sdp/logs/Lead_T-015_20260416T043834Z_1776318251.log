+def _base_sections(
+    form_class: str,
+    mode: str,
+    brief: PieceBrief,
+    *,
+    family: str,
+    ending_family: str,
+    repertoire_entries: Sequence[Mapping[str, object]],
+    form_family_hint: str,
+) -> tuple[str, tuple[SectionSpec, ...]]:
