+            ("Bridge", "bridge", None, "strong", "borrowed"),
+            ("Recap", "recap", selected[2][0], "moderate", "authentic"),
+            selected[-1],
+        ]
+
+    if ending_family == "afterglow" and selected[-1][1] != "afterglow":
