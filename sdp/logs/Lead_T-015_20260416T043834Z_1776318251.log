+def _candidate_family_names(
+    *,
+    form_class: str,
+    mode: str,
+    brief: PieceBrief,
+    form_family_hint: str,
+) -> tuple[str, ...]:
+    if form_family_hint in _FORM_LIBRARY:
+        return (form_family_hint,)
+    if brief.through_composed_pressure >= 0.82:
