+    score = 0
+    for age, recent_signature in enumerate(reversed(recent_signatures), start=1):
+        weight = max(1, 9 - age)
+        if signature == recent_signature:
+            score += 8 * weight
+        elif signature[:3] == recent_signature[:3]:
