+def test_form_selection_avoids_recent_repertoire_fatigue() -> None:
+    commission, brief = _brief_for(cadence_state="occupied_day", hour=14)
+    first_plan = plan_form(commission=commission, brief=brief, family="bloom")
+    recent_repertoire = [
+        {
