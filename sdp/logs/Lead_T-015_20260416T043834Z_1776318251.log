+        ]
+    elif form_class == "suite" and len(selected) < 8:
+        selected = selected[:-1] + [
+            ("Development", "development", selected[1][0], "moderate", "predominant"),
+            ("Bridge", "bridge", None, "strong", "borrowed"),
+            ("Recap", "recap", selected[2][0], "moderate", "authentic"),
+            selected[-1],
+        ]
