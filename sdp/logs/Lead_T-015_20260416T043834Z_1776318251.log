+def _deform_sections_for_class(
+    sections: Sequence[SectionSpec],
+    *,
+    form_class: str,
+    ending_family: str,
+) -> tuple[SectionSpec, ...]:
+    selected = list(sections)
+    if form_class == "micro" and len(selected) > 3:
+        first = selected[0]
+        core = next(
+            (
+                section
+                for section in selected[1:]
+                if section[1] in {"arrival", "drop", "return", "chorus", "afterglow"}
