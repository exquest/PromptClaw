+        "rondo_return",
+        "bridge",
+        "afterglow",
+        "through_composed",
+    ):
+        plan = plan_form(commission=commission, brief=brief, family="bloom", form_family_hint=form_family)
+        seen_functions.update(plan.section_functions)
+
+    assert expected_functions <= seen_functions
