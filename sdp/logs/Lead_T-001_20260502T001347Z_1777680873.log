+"""CypherClaw narrative-engine HTTP API."""
+from __future__ import annotations
+
+from .app import create_app
+from .schemas import MemorySearchRequest, MemorySearchResponse, MemorySearchResult
+
+__all__ = [
+    "MemorySearchRequest",
+    "MemorySearchResponse",
+    "MemorySearchResult",
+    "create_app",
+]
diff --git a/src/cypherclaw/narrative_api/app.py b/src/cypherclaw/narrative_api/app.py
new file mode 100644
index 0000000000000000000000000000000000000000..37889119d18bd6f2723c7aaecd5fdb1fe89dd8b2
--- /dev/null
+++ b/src/cypherclaw/narrative_api/app.py
@@ -0,0 +1,72 @@
+"""FastAPI app exposing the CypherClaw narrative API."""
+from __future__ import annotations
+
+import logging
+from typing import Any, Callable
+
+from fastapi import FastAPI, HTTPException, status
+
+from .memory import (
+    MemoryUnavailableError,
+    build_default_memory,
+    search_narrative_memory,
+)
+from .schemas import MemorySearchRequest, MemorySearchResponse
+
+logger = logging.getLogger(__name__)
+
+MemoryFactory = Callable[[], Any]
+
+
+def create_app(
+    *,
+    memory: Any | None = None,
+    memory_factory: MemoryFactory | None = None,
+) -> FastAPI:
+    """Create the narrative API app.
+
+    Tests inject ``memory`` directly. Production leaves it unset so the request
+    path lazily imports the deploy-side ``NarrativeMemory`` implementation.
+    """
+
+    app = FastAPI(title="cypherclaw-narrative-api", version="0.1.0")
+
+    def get_memory() -> Any:
+        if memory is not None:
+            return memory
+        if memory_factory is not None:
+            return memory_factory()
+        return build_default_memory()
+
+    @app.post("/memory/search", response_model=MemorySearchResponse)
+    def memory_search(payload: MemorySearchRequest) -> MemorySearchResponse:
+        try:
+            searcher = get_memory()
+        except MemoryUnavailableError as exc:
+            raise HTTPException(
+                status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
+                detail=str(exc),
+            ) from exc
+        except Exception as exc:  # noqa: BLE001
+            raise HTTPException(
+                status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
+                detail=f"memory searcher unavailable: {exc}",
+            ) from exc
+
+        try:
+            results = search_narrative_memory(
+                searcher,
+                query=payload.query,
+                k=payload.k,
+                domain_filter=payload.domain_filter,
+            )
+        except Exception as exc:  # noqa: BLE001
+            logger.exception("NarrativeMemory search failed")
+            raise HTTPException(
+                status_code=status.HTTP_502_BAD_GATEWAY,
+                detail=f"memory search failed: {exc}",
+            ) from exc
+
+        return MemorySearchResponse(results=results)
+
+    return app
