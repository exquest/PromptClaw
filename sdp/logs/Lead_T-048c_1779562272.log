+        pytest.param(
+            {
+                "source_voice": "pluck",
+                "target_voice": "bowed",
+                "morph_curve_type": "linear",
+                "phrase_curve": "linear",
+                "phrase_frame_count": 1,
+            },
+            "phrase_frame_count",
+            id="too-few-frames",
+        ),
+    ],
+)
