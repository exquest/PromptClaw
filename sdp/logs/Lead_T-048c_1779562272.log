+                "source_voice": "pluck",
+                "target_voice": "bowed",
+                "morph_curve_type": "linear",
+                "phrase_curve": "linear",
+                "phrase_frame_count": 1,
+            },
+            "phrase_frame_count",
+            id="too-few-frames",
+        ),
+    ],
+)
+def test_morph_phrase_endpoint_rejects_invalid_phrase_generation_fields(
+    payload: dict[str, object],
+    expected_detail: str,
+) -> None:
