+            )
+            entry = self._entries.pop(request_hash)
+            _unlink_quietly(self.root / entry.filename)
+
+    def _over_limits(self) -> bool:
+        return (
+            len(self._entries) > self.max_entries
+            or sum(entry.size_bytes for entry in self._entries.values())
+            > self.max_size_bytes
+        )
+
