diff --git a/my-claw/tools/senseweave/generation/request.py b/my-claw/tools/senseweave/generation/request.py
index 0c67e66737ef3b01ed56fa5103d0377d44c12472..d35a024531281dae4c86ef3bd63fe147aad7f0c9
--- a/my-claw/tools/senseweave/generation/request.py
+++ b/my-claw/tools/senseweave/generation/request.py
@@ -2,6 +2,8 @@
 
 from __future__ import annotations
 
+import hashlib
+import struct
 from dataclasses import dataclass, field
 from typing import Literal, get_args
 
@@ -61,6 +63,18 @@
                 f"model must be one of {sorted(_VALID_MODELS)}, got {self.model!r}"
             )
 
+    def hash(self) -> str:
+        """Return the backend-independent content hash for generation caching."""
+        digest = hashlib.sha256()
+        digest.update(b"GenerationRequest:v1")
+        digest.update(self.prompt.encode("utf-8"))
+        digest.update(self.clap_centroid.astype("<f4", copy=False).tobytes(order="C"))
+        digest.update(struct.pack(">d", float(self.duration_sec)))
+        digest.update(struct.pack(">q", int(self.seed)))
+        digest.update(self.model.encode("utf-8"))
+        digest.update(struct.pack(">d", float(self.bpm_target)))
+        return digest.hexdigest()
+
 
