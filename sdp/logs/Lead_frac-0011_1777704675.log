+    """Local deterministic preview backend for offline generation tests."""
 
+    def __init__(
+        self,
+        output_dir: str | Path | None = None,
+        sample_rate: int = DEFAULT_SAMPLE_RATE,
+        *,
+        clock: Callable[[], float] = time.monotonic,
