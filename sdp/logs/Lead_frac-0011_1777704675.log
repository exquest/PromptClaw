+    latency_ms: int,
+) -> GenerationResult:
+    request_id = local_request_id(request)
+    duration_sec = _request_duration_sec(request)
+    prompt = _request_prompt(request)
+    seed = _request_seed(request)
+    audio_path = output_dir / f"{request_id}.wav"
