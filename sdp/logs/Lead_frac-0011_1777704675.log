self) -> bool:\n+        return self.status_code is not None and 200 <= self.status_code < 300\n+\n+\n+def request_endpoint(\n+    base_url: str,\n+    method: str,\n+    path: str,\n+    token: str | None,\n+    *,\n+    payload: dict[str, Any] | None = None,\n+    verbose: bool = False,\n+) -> SmokeResult:\n     url = base_url.rstrip(\"/\") + path\n-    request = urllib.request.Request(url, method=\"GET\")\n+    data = None\n+    headers = {\"Accept\": \"application/json\"}\n+    if payload is not None:\n+        data = json.dumps(payload, separators=(\",\", \":\")).encode(\"utf-8\")\n+        headers[\"Content-Type\"] = \"application/json\"\n+    request = urllib.request.Request(url, data=data, headers=headers, method=method)\n     if token:\n+        request.add_header(\"X-Narrative-Auth\", token)\n         request.add_header(\"Authorization\", f\"Bearer {token}\")\n \n     try:\n@@ -38,19 +67,47 @@ def check_endpoint(base_url: str, path: str, token: str | None) -> bool:\n             request, timeout=REQUEST_TIMEOUT_SECONDS\n         ) as response:\n             status_code = response.getcode()\n-            body = response.read(BODY_PREVIEW_CHARS + 1)\n+            body = response.read()\n     except urllib.error.HTTPError as exc:\n         status_code = exc.code\n-        body = exc.read(BODY_PREVIEW_CHARS + 1) if exc.fp is not None else b\"\"\n+        body = exc.read() if exc.fp is not None else b\"\"\n     except (urllib.error.URLError, TimeoutError, OSError) as exc:\n-        print(f\"{path}: ERROR {exc}\")\n-        return False\n+        print(f\"{method} {path} -> ERROR {exc}\")\n+        return SmokeResult(method=method, path=path, status_code=None, error=str(exc))\n \n     body_text = body.decode(\"utf-8\", errors=\"replace\")\n-    truncated = len(body_text) > BODY_PREVIEW_CHARS\n-    preview = body_text[:BODY_PREVIEW_CHARS] + (\"...\" if truncated else \"\")\n-    print(f\"{path}: {status_code} {preview}\".rstrip())\n-    return 200 <= status_code < 300\n+    line = f\"{method} {path} -> {status_code}\"\n+    if verbose and body_text:\n+        preview = body_text[:BODY_PREVIEW_CHARS]\n+        if len(body_text) > BODY_PREVIEW_CHARS:\n+            preview += \"...\"\n+        one_line_preview = preview.replace(\"\\n\", r\"\\n\")\n+        line += f\" body={one_line_preview}\"\n+    print(line)\n+    return SmokeResult(method=method, path=path, status_code=status_code, body=body_text)\n+\n+\n+def first_entity_id(body: str) -> str | None:\n+    try:\n+        data = json.loads(body)\n+    except json.JSONDecodeError:\n+        return None\n+\n+    if not isinstance(data, dict):\n+        return None\n+    entities = data.get(\"entities\")\n+    if not isinstance(entities, list) or not entities:\n+        return None\n+    first_entity = entities[0]\n+    if not isinstance(first_entity, dict):\n+        return None\n+    entity_id = first_entity.get(\"id\")\n+    return entity_id if isinstance(entity_id, str) and entity_id else None\n+\n+\n+def entity_get_path(entity_id: str) -> str:\n+    quoted_id = urllib.parse.quote(entity_id, safe=\"\")\n+    return f\"/world/entities/{quoted_id}\"\n \n \n def main(argv: list[str] | None = None) -> int:\n@@ -63,15 +120,58 @@ def main(argv: list[str] | None = None) -> int:\n     parser.add_argument(\n         \"--token\",\n         default=None,\n-        help=\"Optional bearer token sent as the Authorization header.\",\n+        help=\"Optional token sent as X-Narrative-Auth and Authorization.\",\n+    )\n+    parser.add_argument(\n+        \"--entity-id\",\n+        default=os.environ.get(\"NARRATIVE_ENTITY_ID\"),\n+        help=(\n+            \"Optional known-safe entity ID for GET /world/entities/{entity_id} \"\n+            \"(env: NARRATIVE_ENTITY_ID). Defaults to the first listed entity.\"\n+        ),\n+    )\n+    parser.add_argument(\n+        \"--verbose\",\n+        action=\"store_true\",\n+        help=\"Also print the first 200 chars of each response body.\",\n     )\n     args = parser.parse_args(argv)\n \n     print(f\"smoke_narrative: base_url={args.base_url}\")\n     ok = True\n-    for path in ENDPOINTS:\n-        if not check_endpoint(args.base_url, path, args.token):\n+\n+    def run(\n+        method: str,\n+        path: str,\n+        payload: dict[str, Any] | None = None,\n+    ) -> SmokeResult:\n+        result = request_endpoint(\n+            args.base_url,\n+            method,\n+            path,\n+            args.token,\n+            payload=payload,\n+            verbose=args.verbose,\n+        )\n+        nonlocal ok\n+        if not result.ok:\n             ok = False\n+        return result\n+\n+    run(\"GET\", \"/health\")\n+    run(\n+        \"POST\",\n+        \"/memory/search\",\n+        {\"query\": \"smoke\", \"k\": 1, \"domain_filter\": \"shared\"},\n+    )\n+    run(\"POST\", \"/beats/next\", {\"cycle_number\": 0, \"domain_filter\": \"shared\"})\n+    entities = run(\"GET\", \"/world/entities?limit=1\")\n+    entity_id = args.entity_id or first_entity_id(entities.body)\n+    if entity_id:\n+        run(\"GET\", entity_get_path(entity_id))\n+    else:\n+        print(\"GET /world/entities/{entity_id} -> SKIP no entity id returned\")\n+    run(\"GET\", \"/events?limit=1\")\n     return 0 if ok else 1\n \n \n\ncommit b27fba5baa54bf83d5075c37dbe4bfff0ca304b7\nAuthor: Anthony Ainsworth <anthony@cascadiantech.com>\nDate:   Fri May 1 21:47:18 2026 -0700\n\n    fix(scripts): use /healthz+/readyz and bearer auth in narrative smoke CLI [T-016@20260502T001347Za]\n    \n    Align scripts/smoke_narrative.py with the task spec: probe both /healthz and\n    /readyz, send the optional --token as an Authorization: Bearer header rather\n    than X-Narrative-Auth, and update regression tests to assert both endpoints\n    are exercised and the bearer header format is correct.\n    \n    Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>\n\ndiff --git a/scripts/smoke_narrative.py b/scripts/smoke_narrative.py\nindex f4042d8..b2bd4e0 100755\n--- a/scripts/smoke_narrative.py\n+++ b/scripts/smoke_narrative.py\n@@ -1,5 +1,5 @@\n #!/usr/bin/env python3\n-\"\"\"Smoke-test the cypherclaw narrative API health endpoint.\n+\"\"\"Smoke-test the cypherclaw narrative API health endpoints.\n \n Reachable from either the cypherclaw machine (via localhost) or the Deniable\n operator's Mac after a Tailscale connection. Stdlib-only so it can be copied\n@@ -9,8 +9,7 @@ Usage:\n     NARRATIVE_BASE_URL=http://cypherclaw:8765 python3 scripts/smoke_narrative.py\n     python3 scripts/smoke_narrative.py --base-url http://100.x.y.z:8765 --token <secret>\n \n-The --token value is sent as the ``X-Narrative-Auth`` shared-secret header that\n-``cypherclaw.narrative_api`` enforces when ``NARRATIVE_AUTH_TOKEN`` is set.\n+The --token value is sent as an ``Authorization: Bearer <token>`` header.\n \n Exit code: 0 if every endpoint returns 2xx, 1 otherwise.\n \"\"\"\n@@ -23,7 +22,7 @@ import urllib.error\n import urllib.request\n \n DEFAULT_BASE_URL = \"http://cypherclaw:8765\"\n-ENDPOINTS = (\"/health\",)\n+ENDPOINTS = (\"/healthz\", \"/readyz\")\n BODY_PREVIEW_CHARS = 200\n REQUEST_TIMEOUT_SECONDS = 5.0\n \n@@ -32,7 +31,7 @@ def check_endpoint(base_url: str, path: str, token: str | None) -> bool:\n     url = base_url.rstrip(\"/\") + path\n     request = urllib.request.Request(url, method=\"GET\")\n     if token:\n-        request.add_header(\"X-Narrative-Auth\", token)\n+        request.add_header(\"Authorization\", f\"Bearer {token}\")\n \n     try:\n         with urllib.request.urlopen(  # noqa: S310 - operator-supplied URL\n@@ -64,7 +63,7 @@ def main(argv: list[str] | None = None) -> int:\n     parser.add_argument(\n         \"--token\",\n         default=None,\n-        help=\"Optional shared secret sent as the X-Narrative-Auth header.\",\n+        help=\"Optional bearer token sent as the Authorization header.\",\n     )\n     args = parser.parse_args(argv)\n \n\ncommit a76dfd1ccd99bffd1c56dcf764adc7656c86f61d\nAuthor: Anthony Ainsworth <anthony@cascadiantech.com>\nDate:   Fri May 1 21:43:59 2026 -0700\n\n    fix(scripts): align narrative smoke CLI with /health + X-Narrative-Auth [T-016@20260502T001347Za]\n    \n    Update scripts/smoke_narrative.py to probe the actual narrative_api\n    endpoint (/health) and send the operator token through the\n    X-Narrative-Auth header that cypherclaw.narrative_api enforces. The\n    prior /healthz + /readyz + Authorization: Bearer shape did not exist on\n    the target service, so the smoke run could never succeed against a\n    live API.\n    \n    Document the script in README.md and add a CHANGELOG entry so the\n    Deniable operator can validate from their Mac. Tests in\n    tests/test_smoke_narrative_script.py now pin the /health endpoint and\n    the X-Narrative-Auth header propagation.\n\ndiff --git a/scripts/smoke_narrative.py b/scripts/smoke_narrative.py\nindex b9ffe9a..f4042d8 100755\n--- a/scripts/smoke_narrative.py\n+++ b/scripts/smoke_narrative.py\n@@ -1,5 +1,5 @@\n #!/usr/bin/env python3\n-\"\"\"Smoke-test the cypherclaw narrative API liveness/readiness endpoints.\n+\"\"\"Smoke-test the cypherclaw narrative API health endpoint.\n \n Reachable from either the cypherclaw machine (via localhost) or the Deniable\n operator's Mac after a Tailscale connection. Stdlib-only so it can be copied\n@@ -7,7 +7,10 @@ out without a virtualenv.\n \n Usage:\n     NARRATIVE_BASE_URL=http://cypherclaw:8765 python3 scripts/smoke_narrative.py\n-    python3 scripts/smoke_narrative.py --base-url http://100.x.y.z:8765 --token <bearer>\n+    python3 scripts/smoke_narrative.py --base-url http://100.x.y.z:8765 --token <secret>\n+\n+The --token value is sent as the ``X-Narrative-Auth`` shared-secret header that\n+``cypherclaw.narrative_api`` enforces when ``NARRATIVE_AUTH_TOKEN`` is set.\n \n Exit code: 0 if every endpoint returns 2xx, 1 otherwise.\n \"\"\"\n@@ -20,7 +23,7 @@ import urllib.error\n import urllib.request\n \n DEFAULT_BASE_URL = \"http://cypherclaw:8765\"\n-ENDPOINTS = (\"/healthz\", \"/readyz\")\n+ENDPOINTS = (\"/health\",)\n BODY_PREVIEW_CHARS = 200\n REQUEST_TIMEOUT_SECONDS = 5.0\n \n@@ -29,7 +32,7 @@ def check_endpoint(base_url: str, path: str, token: str | None) -> bool:\n     url = base_url.rstrip(\"/\") + path\n     request = urllib.request.Request(url, method=\"GET\")\n     if token:\n-        request.add_header(\"Authorization\", f\"Bearer {token}\")\n+        request.add_header(\"X-Narrative-Auth\", token)\n \n     try:\n         with urllib.request.urlopen(  # noqa: S310 - operator-supplied URL\n@@ -61,7 +64,7 @@ def main(argv: list[str] | None = None) -> int:\n     parser.add_argument(\n         \"--token\",\n         default=None,\n-        help=\"Optional bearer token sent as Authorization: Bearer <token>.\",\n+        help=\"Optional shared secret sent as the X-Narrative-Auth header.\",\n     )\n     args = parser.parse_args(argv)\n \n\ncommit a6675c1b4e26e297ccff0dccc00d7d4dbf938679\nAuthor: Anthony Ainsworth <anthony@cascadiantech.com>\nDate:   Fri May 1 21:35:30 2026 -0700\n\n    feat(scripts): add narrative API smoke CLI [T-016@20260502T001347Za]\n    \n    Stdlib-only script that probes /healthz and /readyz against a configurable\n    base URL, prints status + short body, and exits non-zero on any non-2xx\n    or unreachable endpoint. Lets the Deniable operator validate the\n    narrative API from their Mac over Tailscale.\n\ndiff --git a/scripts/smoke_narrative.py b/scripts/smoke_narrative.py\nnew file mode 100755\nindex 0000000..b9ffe9a\n--- /dev/null\n+++ b/scripts/smoke_narrative.py\n@@ -0,0 +1,77 @@\n+#!/usr/bin/env python3\n+\"\"\"Smoke-test the cypherclaw narrative API liveness/readiness endpoints.\n+\n+Reachable from either the cypherclaw machine (via localhost) or the Deniable\n+operator's Mac after a Tailscale connection. Stdlib-only so it can be copied\n+out without a virtualenv.\n+\n+Usage:\n+    NARRATIVE_BASE_URL=http://cypherclaw:8765 python3 scripts/smoke_narrative.py\n+    python3 scripts/smoke_narrative.py --base-url http://100.x.y.z:8765 --token <bearer>\n+\n+Exit code: 0 if every endpoint returns 2xx, 1 otherwise.\n+\"\"\"\n+from __future__ import annotations\n+\n+import argparse\n+import os\n+import sys\n+import urllib.error\n+import urllib.request\n+\n+DEFAULT_BASE_URL = \"http://cypherclaw:8765\"\n+ENDPOINTS = (\"/healthz\", \"/readyz\")\n+BODY_PREVIEW_CHARS = 200\n+REQUEST_TIMEOUT_SECONDS = 5.0\n+\n+\n+def check_endpoint(base_url: str, path: str, token: str | None) -> bool:\n+    url = base_url.rstrip(\"/\") + path\n+    request = urllib.request.Request(url, method=\"GET\")\n+    if token:\n+        request.add_header(\"Authorization\", f\"Bearer {token}\")\n+\n+    try:\n+        with urllib.request.urlopen(  # noqa: S310 - operator-supplied URL\n+            request, timeout=REQUEST_TIMEOUT_SECONDS\n+        ) as response:\n+            status_code = response.getcode()\n+            body = response.read(BODY_PREVIEW_CHARS + 1)\n+    except urllib.error.HTTPError as exc:\n+        status_code = exc.code\n+        body = exc.read(BODY_PREVIEW_CHARS + 1) if exc.fp is not None else b\"\"\n+    except (urllib.error.URLError, TimeoutError, OSError) as exc:\n+        print(f\"{path}: ERROR {exc}\")\n+        return False\n+\n+    body_text = body.decode(\"utf-8\", errors=\"replace\")\n+    truncated = len(body_text) > BODY_PREVIEW_CHARS\n+    preview = body_text[:BODY_PREVIEW_CHARS] + (\"...\" if truncated else \"\")\n+    print(f\"{path}: {status_code} {preview}\".rstrip())\n+    return 200 <= status_code < 300\n+\n+\n+def main(argv: list[str] | None = None) -> int:\n+    parser = argparse.ArgumentParser(description=__doc__)\n+    parser.add_argument(\n+        \"--base-url\",\n+        default=os.environ.get(\"NARRATIVE_BASE_URL\", DEFAULT_BASE_URL),\n+        help=\"Narrative API base URL (env: NARRATIVE_BASE_URL).\",\n+    )\n+    parser.add_argument(\n+        \"--token\",\n+        default=None,\n+        help=\"Optional bearer token sent as Authorization: Bearer <token>.\",\n+    )\n+    args = parser.parse_args(argv)\n+\n+    print(f\"smoke_narrative: base_url={args.base_url}\")\n+    ok = True\n+    for path in ENDPOINTS:\n+        if not check_endpoint(args.base_url, path, args.token):\n+            ok = False\n+    return 0 if ok else 1\n+\n+\n+if __name__ == \"__main__\":\n+    sys.exit(main())"}
