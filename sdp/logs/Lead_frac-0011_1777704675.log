+        result = replace(result, latency_ms=latency_ms)
+        if isinstance(request, GenerationRequest):
+            return result
+        return _legacy_payload(result)
+
+
+def local_request_id(request: Any) -> str:
+    """Return the stable local generation id for ``request``."""
