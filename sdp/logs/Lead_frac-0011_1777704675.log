+DEFAULT_MODEL = "local-ada-preview"
+_MIN_FREQUENCY_HZ = 160.0
+_FREQUENCY_RANGE_HZ = 720
+_AMPLITUDE = 0.18
+_SAMPLE_WIDTH_BYTES = 2
+_CHANNELS = 1
