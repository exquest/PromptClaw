+        "duration_sec": _request_duration_sec(request),
+        "seed": _request_seed(request),
+        "model": _request_model(request),
+    }
+    encoded = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode()
+    return hashlib.sha256(encoded).hexdigest()[:16]
+
