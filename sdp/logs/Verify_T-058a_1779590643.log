ty_release = \"2.0.0\"\n            mock_args.identity_parent_id = None\n            mock_args.dry_run = True  # Exit early after bootstrap\n            mock_parse.return_value = mock_args\n\n            with patch(\"my_claw.tools.session_archiver._config_from_args\"):\n                with patch(\"my_claw.tools.session_archiver._dry_run\") as mock_dry:\n                    mock_dry.return_value = 0\n                    \n                    run_archiver([\"--dry-run\"])\n\n                    mock_bootstrap.assert_called_once_with(\n                        mode=\"federated\",\n                        release=\"2.0.0\",\n                        parent_id=None,\n                    )\n","file_path":"tests/test_t058a_hardening.py"}}
