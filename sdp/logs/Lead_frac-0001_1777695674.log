+            if not exercise.expected_features:
+                errors.append(f"{key} has no expected features")
+            if not exercise.title:
+                errors.append(f"{key} has empty title")
+            if not exercise.objective:
+                errors.append(f"{key} has empty objective")
+
+    return tuple(errors)
