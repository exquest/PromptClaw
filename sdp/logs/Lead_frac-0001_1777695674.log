+        template={},
+        verifier="manual",
+        expected_features=(),
+    )
+    duplicate_exercise = ExerciseSpec(
+        id="ex01",
+        title="Duplicate Exercise",
+        objective="Duplicate exercise id.",
+        template={"ok": True},
+        verifier="structural",
