+
+def catalog_summary(
+    courses: tuple[Course, ...] | None = None,
+) -> dict[str, object]:
+    """Return compact aggregate statistics for the curriculum catalog."""
+    if courses is None:
+        courses = COURSE_CATALOG
+
+    category_counts: dict[str, int] = {}
+    semesters: set[int] = set()
+    exercise_count = 0
+    credit_count = 0
+
+    for course in courses:
