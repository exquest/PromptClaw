+def courses_by_category(
+    category: str | None = None,
+    courses: tuple[Course, ...] | None = None,
+) -> dict[str, tuple[Course, ...]] | tuple[Course, ...]:
+    """Group courses by category, or return one category when requested."""
+    if courses is None:
+        courses = COURSE_CATALOG
+
