 """Tests for arrangement_engine.py -- section arrangement plans."""
 from __future__ import annotations
 
+import json
 import os
 import sys
+from dataclasses import asdict
 
 sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "my-claw", "tools"))
