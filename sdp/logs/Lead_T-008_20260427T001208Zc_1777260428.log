+
+def test_dequeue_concurrent_workers_do_not_double_claim(tmp_path: Path) -> None:
+    queue = GenerationQueue(tmp_path / "queue.sqlite")
+    row_id = queue.enqueue({"prompt": "bells"}, "request-1")
