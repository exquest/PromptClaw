+        now = self._clock()
+        with connect_generation_queue_db(self.db_path) as conn:
+            conn.execute("BEGIN IMMEDIATE")
+            try:
+                row = conn.execute(
+                    """UPDATE queue_items
+                       SET status = ?,
+                           attempts = attempts + 1,
+                           updated_at = ?
+                       WHERE id = (
+                           SELECT id
+                           FROM queue_items
+                           WHERE status = ?
+                           ORDER BY id ASC
+                           LIMIT 1
+                       )
+                       RETURNING *""",
+                    (RUNNING, now, QUEUED),
+                ).fetchone()
+                conn.execute("COMMIT")
+            except Exception:
+                conn.execute("ROLLBACK")
+                raise
+
+        if row is None:
+            return None
+        return _row_to_queue_item(row)
+
+    def mark_done(self, item_id: int) -> bool:
+        """Mark a running item as done."""
+        return self._mark_running_item(item_id, DONE)
+
+    def mark_failed(self, item_id: int) -> bool:
+        """Mark a running item failed, requeueing while retry attempts remain."""
+        now = self._clock()
+        with connect_generation_queue_db(self.db_path) as conn:
+            cursor = conn.execute(
+                """UPDATE queue_items
+                   SET status = CASE
+                           WHEN attempts >= ? THEN ?
+                           ELSE ?
+                       END,
+                       updated_at = ?
+                   WHERE id = ? AND status = ?""",
+                (self.max_attempts, FAILED, QUEUED, now, item_id, RUNNING),
+            )
+        return cursor.rowcount == 1
+
+    def _mark_running_item(self, item_id: int, status: str) -> bool:
+        now = self._clock()
+        with connect_generation_queue_db(self.db_path) as conn:
+            cursor = conn.execute(
+                """UPDATE queue_items
+                   SET status = ?, updated_at = ?
+                   WHERE id = ? AND status = ?""",
+                (status, now, item_id, RUNNING),
+            )
+        return cursor.rowcount == 1
+
+
+def _row_to_queue_item(row: sqlite3.Row) -> QueueItem:
+    return QueueItem(
+        id=int(row["id"]),
+        idempotency_key=str(row["idempotency_key"]),
+        payload=json.loads(str(row["payload"])),
+        status=str(row["status"]),
+        attempts=int(row["attempts"]),
+        created_at=float(row["created_at"]),
+        updated_at=float(row["updated_at"]),
+    )
