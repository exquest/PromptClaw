diff --git a/specs/t-008@20260427t001208zc-spec.md b/specs/t-008@20260427t001208zc-spec.md
new file mode 100644
index 0000000000000000000000000000000000000000..b5296db21b0dee623b2c0647d46711a4f6c700ac
--- /dev/null
+++ b/specs/t-008@20260427t001208zc-spec.md
@@ -0,0 +1,63 @@
+# Task T-008@20260427T001208Zc: Generation Queue Claim Transitions
+
+## Problem Statement
+
+The generation queue currently creates the SQLite `queue_items` table and
+supports idempotent `enqueue(payload, idempotency_key)`, but workers have no
+safe way to claim queued work or return it to the queue after transient
+failure. This leaves the future generation worker unable to process items
+oldest-first, retry failed attempts, or prevent two workers from claiming the
+same row.
+
+## Technical Approach
+
+- Extend `my-claw/tools/senseweave/generation/queue.py` in place.
+- Preserve the existing schema and status spelling from T-008a/b:
+  `status = "queued"` is the current pending state.
+- Add a small typed row model for claimed queue items.
+- Implement `GenerationQueue.dequeue()` as one SQLite transaction that:
+  - selects the oldest `queued` row by `id`;
+  - atomically marks it `running`;
+  - increments `attempts`;
+  - refreshes `updated_at`;
+  - returns the claimed row, or `None` when no work is queued.
+- Implement `mark_done(item_id)` for `running -> done`, refreshing
+  `updated_at`.
+- Implement `mark_failed(item_id)` for `running -> queued` while attempts are
+  below `max_attempts`, and `running -> failed` once the retry budget is
+  exhausted. Attempts are incremented only when work is claimed by
+  `dequeue()`.
+- Keep the implementation stdlib-only; no migrations or new dependencies are
+  required because the current table already includes `status`, `attempts`, and
+  timestamp columns.
+
+## Edge Cases
+
+- Empty queue: `dequeue()` returns `None` without mutating the database.
+- FIFO: when multiple rows are queued, the lowest `id` is claimed first.
+- Retry: a failed first attempt returns to `queued`, and a subsequent dequeue
+  increments attempts again.
+- Retry exhaustion: an item whose attempt count has reached `max_attempts`
+  transitions to `failed` instead of requeueing.
+- No double claim: concurrent `dequeue()` calls against one queued item cannot
+  both receive that row.
+- Terminal rows: `done` and `failed` rows are never claimed by `dequeue()`.
+- Timestamp refresh: `dequeue()`, `mark_done()`, and `mark_failed()` all update
+  `updated_at`.
+
+## Acceptance Criteria
+
+1. `dequeue()` claims queued rows oldest-first, marks them running, increments
+   attempts, and refreshes `updated_at`.
+   - **VERIFY:** `pytest tests/test_generation_queue.py::test_dequeue_claims_oldest_queued_item_fifo -q`
+2. `mark_done()` transitions a running item to done and refreshes `updated_at`.
+   - **VERIFY:** `pytest tests/test_generation_queue.py::test_mark_done_completes_running_item_and_refreshes_updated_at -q`
+3. `mark_failed()` requeues failed attempts below the retry budget, and a later
+   `dequeue()` increments attempts again.
+   - **VERIFY:** `pytest tests/test_generation_queue.py::test_mark_failed_requeues_for_retry_until_max_attempts -q`
+4. Concurrent claims cannot double-claim one queued row.
+   - **VERIFY:** `pytest tests/test_generation_queue.py::test_dequeue_concurrent_workers_do_not_double_claim -q`
+5. Existing enqueue/schema behavior remains intact.
+   - **VERIFY:** `pytest tests/test_generation_queue.py -q`
+6. Full repository checks pass after implementation.
+   - **VERIFY:** `pip install -e '.[dev]' && pytest tests/ -x && ruff check src/ tests/ && mypy src/`
diff --git a/tests/test_generation_queue.py b/tests/test_generation_queue.py
index 0d4ccd112763d1dbbc16edd401ac543f99076f43..c1396202d3bcbf266e6293b8a1f53ca18e35c068
--- a/tests/test_generation_queue.py
+++ b/tests/test_generation_queue.py
@@ -16,6 +16,27 @@
 )
 
 
+class TickClock:
+    def __init__(self, start: float = 1000.0) -> None:
+        self.value = start
+
+    def __call__(self) -> float:
+        current = self.value
+        self.value += 1.0
+        return current
+
+
+def _queue_row(queue: GenerationQueue, row_id: int) -> sqlite3.Row:
+    with sqlite3.connect(queue.db_path) as conn:
+        conn.row_factory = sqlite3.Row
+        row = conn.execute(
+            "SELECT * FROM queue_items WHERE id = ?",
+            (row_id,),
+        ).fetchone()
+    assert row is not None
+    return row
+
+
 def test_generation_queue_constructor_creates_queue_items_schema(
     tmp_path: Path,
 ) -> None:
@@ -136,3 +157,102 @@
             ("request-1",),
         ).fetchone()[0]
     assert count == 1
+
+
+def test_dequeue_claims_oldest_queued_item_fifo(tmp_path: Path) -> None:
+    clock = TickClock()
+    queue = GenerationQueue(tmp_path / "queue.sqlite", clock=clock)
+    first_id = queue.enqueue({"prompt": "first"}, "request-1")
+    second_id = queue.enqueue({"prompt": "second"}, "request-2")
+
+    first_claim = queue.dequeue()
+    assert first_claim is not None
+    assert first_claim.id == first_id
+    assert first_claim.idempotency_key == "request-1"
+    assert first_claim.payload == {"prompt": "first"}
+    assert first_claim.status == "running"
+    assert first_claim.attempts == 1
+
+    first_row = _queue_row(queue, first_id)
+    second_row = _queue_row(queue, second_id)
+    assert first_row["status"] == "running"
+    assert first_row["attempts"] == 1
+    assert first_row["updated_at"] > first_row["created_at"]
+    assert second_row["status"] == "queued"
+    assert second_row["attempts"] == 0
+
+    second_claim = queue.dequeue()
+    assert second_claim is not None
+    assert second_claim.id == second_id
+    assert second_claim.payload == {"prompt": "second"}
+    assert second_claim.attempts == 1
+
+
+def test_mark_done_completes_running_item_and_refreshes_updated_at(
+    tmp_path: Path,
+) -> None:
+    clock = TickClock()
+    queue = GenerationQueue(tmp_path / "queue.sqlite", clock=clock)
+    row_id = queue.enqueue({"prompt": "bells"}, "request-1")
+    claimed = queue.dequeue()
+    assert claimed is not None
+    running_updated_at = _queue_row(queue, row_id)["updated_at"]
+
+    assert queue.mark_done(row_id) is True
+
+    row = _queue_row(queue, row_id)
+    assert row["status"] == "done"
+    assert row["attempts"] == 1
+    assert row["updated_at"] > running_updated_at
+    assert queue.dequeue() is None
+
+
+def test_mark_failed_requeues_for_retry_until_max_attempts(tmp_path: Path) -> None:
+    clock = TickClock()
+    queue = GenerationQueue(tmp_path / "queue.sqlite", max_attempts=2, clock=clock)
+    row_id = queue.enqueue({"prompt": "bells"}, "request-1")
+    first_claim = queue.dequeue()
+    assert first_claim is not None
+    first_running_updated_at = _queue_row(queue, row_id)["updated_at"]
+
+    assert queue.mark_failed(row_id) is True
+
+    retry_row = _queue_row(queue, row_id)
+    assert retry_row["status"] == "queued"
+    assert retry_row["attempts"] == 1
+    assert retry_row["updated_at"] > first_running_updated_at
+
+    second_claim = queue.dequeue()
+    assert second_claim is not None
+    assert second_claim.id == row_id
+    assert second_claim.attempts == 2
+
+    assert queue.mark_failed(row_id) is True
+
+    failed_row = _queue_row(queue, row_id)
+    assert failed_row["status"] == "failed"
+    assert failed_row["attempts"] == 2
+    assert queue.dequeue() is None
+
+
+def test_dequeue_concurrent_workers_do_not_double_claim(tmp_path: Path) -> None:
+    queue = GenerationQueue(tmp_path / "queue.sqlite")
+    row_id = queue.enqueue({"prompt": "bells"}, "request-1")
+    worker_count = 2
+    barrier = Barrier(worker_count)
+
+    def worker(_: int):
+        barrier.wait()
+        return queue.dequeue()
+
+    with ThreadPoolExecutor(max_workers=worker_count) as pool:
+        claims = list(pool.map(worker, range(worker_count)))
+
+    claimed = [item for item in claims if item is not None]
+    assert len(claimed) == 1
+    assert claimed[0].id == row_id
+    assert sum(item is None for item in claims) == 1
+
+    row = _queue_row(queue, row_id)
+    assert row["status"] == "running"
+    assert row["attempts"] == 1

