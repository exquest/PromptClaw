+def _with_revoicing(item: Any) -> Any:
+    octave_shift = getattr(item, "octave_shift", None)
+    if octave_shift is not None:
+        return _replace_or_set(item, octave_shift=int(octave_shift) + 1)
+    return _with_pitch_delta(item, 12.0)
