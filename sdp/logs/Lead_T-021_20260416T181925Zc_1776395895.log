+    updates: dict[str, object] = {}
+    for attr in ("nominal_dur_sec", "nominal_sec", "duration_sec", "dur_sec", "length_rows"):
+        value = getattr(item, attr, None)
+        if value is None:
+            continue
+        scaled = float(value) * factor
+        if isinstance(value, int):
