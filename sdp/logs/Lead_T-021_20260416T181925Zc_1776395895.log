+        if variation == "inversion":
+            pivot = _numeric_attr(items[0], ("pitch", "midi_pitch", "pitch_midi", "scale_degree"))
+            return [_with_pitch_value(item, (2.0 * pivot) - _numeric_attr(
+                item,
+                ("pitch", "midi_pitch", "pitch_midi", "scale_degree"),
+            )) for item in items]
