+def _contiguous_groups(steps: Sequence[Any]) -> list[list[Any]]:
+    groups: list[list[Any]] = []
+    current_key: str | None = None
+    current_group: list[Any] = []
+    for step in steps:
+        key = _phrase_group_key(step)
+        if current_group and key != current_key:
