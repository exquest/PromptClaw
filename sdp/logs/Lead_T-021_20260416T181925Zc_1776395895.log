+def _phrase_group_key(step: Any) -> str:
+    metadata = getattr(step, "metadata", None)
+    if not isinstance(metadata, Mapping):
+        return "lane"
+    for key in ("motif_id", "phrase_id", "phrase_index", "repeat_cycle"):
+        value = metadata.get(key)
+        if value:
+            return f"{key}:{value}"
+    return "lane"
