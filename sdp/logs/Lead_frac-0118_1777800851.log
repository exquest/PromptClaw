+            "fm",
+            "additive",
+            "physical_model",
+        ]
+        assert "spectral" in round_tripped["course_values"]
+        assert (
+            round_tripped["profile_diagnostics"]["granular"]["fallback_chain"][0]
+            == "granular"
+        )
