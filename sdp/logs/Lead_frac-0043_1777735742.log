+    def _file_status(self, name: str, path: Path) -> ArtifactFileStatus:
+        if path.exists():
+            size_bytes = path.stat().st_size
+            return ArtifactFileStatus(
+                name=name,
+                path=path,
+                exists=True,
+                size_bytes=size_bytes,
+            )
+        return ArtifactFileStatus(
+            name=name,
+            path=path,
+            exists=False,
+            size_bytes=0,
