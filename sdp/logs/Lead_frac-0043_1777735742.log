+        if events:
+            latest_event_type = events[-1].event_type
+        return ArtifactRunReport(
+            run_id=self.run_id,
+            root=layout.root,
+            files=tuple(file_statuses),
+            event_count=len(events),
+            latest_event_type=latest_event_type,
+        )
