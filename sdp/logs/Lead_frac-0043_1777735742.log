+        layout = self.paths.run_layout(self.run_id)
+        file_statuses: list[ArtifactFileStatus] = []
+        for name, path in layout.files:
+            file_statuses.append(self._file_status(name, path))
+        events = self.read_events()
+        latest_event_type = ""
+        if events:
