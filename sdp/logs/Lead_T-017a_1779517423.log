   255	
   256	def process_midi_file(
   257	    path: Path | str,
   258	    *,
   259	    processed_dir: Path | str | None = None,
   260	    rejected_dir: Path | str | None = None,
   261	    faithful_transmission: bool = False,
   262	) -> dict[str, object]:
   263	    """Validate ``path``, move it to ``processed/`` or ``rejected/``, emit event.
   264	
   265	    For valid MIDI files moved to the ``processed/`` directory, a JSON sidecar
   266	    manifest is written next to the destination path (using a ``.json``
   267	    suffix).
   268	
   269	    Returns the JSON event record describing the outcome. The record contains
   270	    the original path, file size, sha256, ISO8601 UTC timestamp, status
   271	    (``processed`` or ``rejected``), and the destination path. The same
   272	    record is emitted to :data:`LOGGER` as a JSON line prefixed with
   273	    ``midi_intake_event ``.
   274	    """
   275	
   276	    src = Path(path)
   277	    parent = src.parent
   278	    processed = Path(processed_dir) if processed_dir else parent / PROCESSED_SUBDIR
   279	    rejected = Path(rejected_dir) if rejected_dir else parent / REJECTED_SUBDIR
   280	
   281	    size = src.stat().st_size
   282	    sha256 = _sha256_of(src)
   283	    valid = validate_midi_header(src)
   284	    header_info = read_mthd_header(src)
   285	    metadata: dict[str, object] = dict(header_info or {})
   286	    if valid:
   287	        if faithful_transmission:
   288	            metadata["mode"] = "faithful_transmission"
   289	            metadata["faithful_events"] = [
   290	                event.to_dict() for event in load_faithful_midi_events(src)
   291	            ]
   292	            metadata["fragments"] = empty_midi_fragments()
   293	        else:
   294	            metadata["mode"] = "fragment_extraction"
   295	            try:
   296	                metadata["fragments"] = extract_midi_fragments(src)
   297	            except ValueError as exc:
   298	                LOGGER.warning("midi_fragment_extraction_failed path=%s error=%s", src, exc)
   299	                metadata["fragments"] = empty_midi_fragments()
   300	    target_dir = processed if valid else rejected
   301	    target_dir.mkdir(parents=True, exist_ok=True)
   302	    destination = _unique_destination(target_dir, src.name)
   303	    shutil.move(str(src), str(destination))
   304	
   305	    if valid:
   306	        manifest = build_manifest(destination, extracted_metadata=metadata)
   307	        manifest_path = destination.with_suffix(destination.suffix + ".json")
   308	        manifest_path.write_text(
   309	            json.dumps(manifest, indent=2, sort_keys=True), encoding="utf-8"
   310	        )
   490	    )
   491	    parser.add_argument(
   492	        "--poll",
   493	        action="store_true",
   494	        help="Force poll-based watching even if watchdog is available.",
   495	    )
   496	    parser.add_argument(
   497	        "--poll-interval",
   498	        type=float,
   499	        default=1.0,
   500	        help="Seconds between scans in poll mode (default: 1.0).",
   501	    )
   502	    parser.add_argument(
   503	        "--faithful-transmission",
   504	        action="store_true",
   505	        help=(
   506	            "Load imported MIDI into ordered pitch/duration/velocity events "
   507	            "and bypass fragment extraction."
   508	        ),
   509	    )
   510	    return parser.parse_args(list(argv) if argv is not None else None)
   511	
