   528	        cleanup_processed(processed_dir)
   529	
   530	    if stop_event is None:
   531	        stop_event = threading.Event()
   532	        install_signal_handlers(stop_event)
   533	
   534	    LOGGER.info("midi_intake_daemon_started watch_dir=%s", args.watch_dir)
   535	
