+def _varlen(value: int) -> bytes:
+    if value < 0:
+        raise ValueError("varlen value must be non-negative")
+    parts = [value & 0x7F]
+    value >>= 7
+    while value:
+        parts.insert(0, 0x80 | (value & 0x7F))
+        value >>= 7
+    return bytes(parts)
+
+
