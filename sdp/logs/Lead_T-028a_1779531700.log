const test = require("node:test");
const assert = require("node:assert/strict");

const worker = require("../.tmp/test-build/index.js").default;

function makeEnv() {
    return {
        DB: {},
        MEDIA: {},
        ADMIN_TOKEN: "segment-token",
        STRIPE_SECRET_KEY: "sk_test_unused",
        STRIPE_WEBHOOK_SECRET: "whsec_unused",
        RESEND_API_KEY: "re_unused",
        PUBLIC_SITE_ORIGIN: "https://holdenu.com",
        ENVIRONMENT: "test",
    };
}

test("GET / on cypherclaw.holdenu.com returns a 200 HTML landing page", async () => {
    const env = makeEnv();
    const request = new Request("https://cypherclaw.holdenu.com/", { method: "GET" });
    const response = await worker.fetch(request, env, { waitUntil() {} });
    const body = await response.text();

    assert.equal(response.status, 200);
    assert.match(response.headers.get("Content-Type") || "", /text\/html/);
    assert.match(body, /<title>CypherClaw — live<\/title>/);
});

test("GET / on the explorer host still 404s (no accidental wildcard landing)", async () => {
    const env = makeEnv();
    const request = new Request("https://explorer.holdenu.com/", { method: "GET" });
    const response = await worker.fetch(request, env, { waitUntil() {} });
    assert.equal(response.status, 404);
});

test("HEAD / on cypherclaw.holdenu.com returns 200 with no body (T-027 acceptance: curl -I)", async () => {
    const env = makeEnv();
    const request = new Request("https://cypherclaw.holdenu.com/", { method: "HEAD" });
    const response = await worker.fetch(request, env, { waitUntil() {} });
    assert.equal(response.status, 200);
    assert.match(response.headers.get("Content-Type") || "", /text\/html/);
    const body = await response.text();
    assert.equal(body, "");
});

