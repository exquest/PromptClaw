/**
 * holdenu API — Cloudflare Worker
 *
 * Routes:
 *   GET  /api/releases               — public; list visible releases + their tracks
 *   GET  /api/public-annotations     — public; sanitized annotations
 *   GET  /api/stream/:trackId        — public; byte-range proxy to R2 audio
 *   POST /api/cypherclaw/segment     — admin; ingest live CypherClaw segment
 *   GET  /api/cypherclaw/live.m3u8   — public; rolling HLS playlist of recent segments
 *   GET  /api/cypherclaw/segment/... — public; serve a stored CypherClaw segment
 *   POST /api/checkout               — public; Stripe Checkout Session
 *   POST /api/webhook/stripe         — webhook; signature-verified
 *   GET  /download/:token            — public; serve paid downloads
 *   POST /api/release                — admin; create/update release event
 *   POST /api/upload-url             — admin; mint upload token
 *   POST /api/upload/:token          — admin; receive file body, write to R2
 *   POST /api/sync                   — admin; mirror workspace annotations
 */

export interface Env {
    DB: D1Database;
    MEDIA: R2Bucket;
    ADMIN_TOKEN: string;
    STRIPE_SECRET_KEY: string;
    STRIPE_WEBHOOK_SECRET: string;
    RESEND_API_KEY: string;
    PUBLIC_SITE_ORIGIN: string;
    ENVIRONMENT: string;
}

const CORS_BASE = {
    'Access-Control-Allow-Methods': 'GET, POST, PUT, OPTIONS',
    'Access-Control-Allow-Headers': 'Authorization, Content-Type, Range, If-Range, X-CypherClaw-Sequence, X-CypherClaw-Captured-At, X-CypherClaw-Duration, X-CypherClaw-Scene, X-CypherClaw-Tuning',
    'Access-Control-Expose-Headers': 'Content-Length, Content-Range, Accept-Ranges',
    'Access-Control-Max-Age': '86400',
};
const CYPHERCLAW_SEGMENT_PATH = '/api/cypherclaw/segment';
const CYPHERCLAW_SEGMENT_PREFIX = '/api/cypherclaw/segment/';
const CYPHERCLAW_PLAYLIST_PATH = '/api/cypherclaw/live.m3u8';
const CYPHERCLAW_SEGMENT_CONTENT_TYPE = 'audio/ogg; codecs=opus';
const CYPHERCLAW_LIVE_PLAYLIST_WINDOW = 10;
const CYPHERCLAW_LIVE_TARGET_DURATION = 6;
const CYPHERCLAW_LIVE_HOST = 'cypherclaw.holdenu.com';

function corsHeaders(_env: Env, _req?: Request): Record<string, string> {
    // Always allow any origin. CORS is a browser-side mechanism and
    // does not provide auth. Our admin write endpoints are protected
    // by Authorization: Bearer regardless. The public read endpoints
    // are intentionally open. Real origin restriction (if ever needed)
    // belongs at the Cloudflare WAF / firewall layer, not here.
    return {
        ...CORS_BASE,
        'Access-Control-Allow-Origin': '*',
    };
}

function jsonResponse(body: unknown, env: Env, init: ResponseInit = {}, req?: Request): Response {
    return new Response(JSON.stringify(body), {
        ...init,
        headers: {
            'Content-Type': 'application/json',
            ...corsHeaders(env, req),
            ...(init.headers || {}),
        },
    });
}
function errorResponse(status: number, message: string, env: Env, req?: Request): Response {
    return jsonResponse({ error: message }, env, { status }, req);
}
function requireAdmin(req: Request, env: Env): Response | null {
    const auth = req.headers.get('Authorization') || '';
    const token = auth.startsWith('Bearer ') ? auth.slice(7) : '';
    if (!token || token !== env.ADMIN_TOKEN) {
        return errorResponse(401, 'admin auth required', env, req);
    }
    return null;
}

export default {
    async fetch(req: Request, env: Env, ctx: ExecutionContext): Promise<Response> {
        const url = new URL(req.url);
        const pathname = url.pathname;

        if (req.method === 'OPTIONS') {
            return new Response(null, { headers: corsHeaders(env, req) });
        }

        try {
            // CypherClaw live presence (PRD CC-023): on the cypherclaw.holdenu.com
            // custom-domain binding, serve a minimal placeholder at the site root so
            // the DNS + Worker + TLS plumbing has a 200 response to verify against.
            // The richer landing page (live stream, GlyphWeave backdrop, visualizer)
            // ships in CC-024 / T-028.
            if (url.hostname === CYPHERCLAW_LIVE_HOST && pathname === '/' && (req.method === 'GET' || req.method === 'HEAD')) {
                return serveCypherClawLanding(env, req, req.method === 'HEAD');
            }

            // Public reads
            if (pathname === '/api/releases' && req.method === 'GET')           return await listReleases(req, env);
            if (pathname === '/api/public-annotations' && req.method === 'GET') return await listPublicAnnotations(req, env);
            if (pathname.startsWith('/api/stream/') && req.method === 'GET')    return await streamTrack(req, env, decodeURIComponent(pathname.slice('/api/stream/'.length)));
            if (pathname === CYPHERCLAW_PLAYLIST_PATH && req.method === 'GET')  return await serveCypherClawPlaylist(req, env);
            if (pathname.startsWith(CYPHERCLAW_SEGMENT_PREFIX) && req.method === 'GET') return await serveCypherClawSegment(req, env, decodeURIComponent(pathname.slice(CYPHERCLAW_SEGMENT_PREFIX.length)));
            if (pathname.startsWith('/api/artwork/') && req.method === 'GET')   return await serveArtwork(req, env, decodeURIComponent(pathname.slice('/api/artwork/'.length)));
            if (pathname.startsWith('/download/') && req.method === 'GET')      return await serveDownload(req, env, decodeURIComponent(pathname.slice('/download/'.length)));

            // Discoverability — pretty URLs for crawlers + sharing
            if (pathname === '/sitemap.xml' && req.method === 'GET')            return await serveSitemap(env);
            if (pathname === '/robots.txt' && req.method === 'GET')             return serveRobots(env);
            if (pathname.startsWith('/release/') && req.method === 'GET')       return await serveReleasePage(req, env, decodeURIComponent(pathname.slice('/release/'.length)));
            if (pathname.startsWith('/album/') && req.method === 'GET')         return await serveReleasePage(req, env, decodeURIComponent(pathname.slice('/album/'.length)));
            if (pathname.startsWith('/track/') && req.method === 'GET')         return await serveTrackPage(req, env, decodeURIComponent(pathname.slice('/track/'.length)));

            // Public commerce
            if (pathname === '/api/checkout' && req.method === 'POST')          return await createCheckout(req, env);
            if (pathname === '/api/webhook/stripe' && req.method === 'POST')    return await handleStripeWebhook(req, env, ctx);

            // Admin reads (workspace mirror)
            if (pathname === '/api/workspace-state' && req.method === 'GET') {
                const unauth = requireAdmin(req, env);
                if (unauth) return unauth;
                return await getWorkspaceState(req, env);
            }

            // Admin writes
            const adminPaths = ['/api/release', '/api/upload-url', '/api/sync', '/api/workspace-sync'];
            const isUploadDirect = pathname.startsWith('/api/upload/');
            if ((adminPaths.includes(pathname) || isUploadDirect || pathname === CYPHERCLAW_SEGMENT_PATH) && req.method === 'POST') {
                const unauth = requireAdmin(req, env);
                if (unauth) return unauth;
                if (pathname === CYPHERCLAW_SEGMENT_PATH) return await receiveCypherClawSegment(req, env);
                if (pathname === '/api/release')         return await createRelease(req, env);
                if (pathname === '/api/upload-url')      return await signUploadUrl(req, env);
                if (pathname === '/api/sync')            return await syncAnnotations(req, env);
                if (pathname === '/api/workspace-sync')  return await syncWorkspace(req, env);
                if (isUploadDirect)                      return await receiveUpload(req, env, pathname.slice('/api/upload/'.length));
            }

            return errorResponse(404, `not found: ${req.method} ${pathname}`, env, req);
        } catch (err) {
            console.error('Worker error:', err);
            return errorResponse(500, (err as Error).message || 'internal error', env, req);
        }
    },
} satisfies ExportedHandler<Env>;

// =================================================================
// Public: CypherClaw live presence landing (PRD CC-023)
// =================================================================

function serveCypherClawLanding(env: Env, req: Request, headOnly = false): Response {
    const body = `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>CypherClaw — live</title>
<style>
  html, body { margin: 0; padding: 0; background: #0b0b10; color: #d8d4c8; font-family: system-ui, -apple-system, "Segoe UI", sans-serif; }
  main { min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1.5rem; padding: 2rem; }
  h1 { font-weight: 400; letter-spacing: 0.25em; text-transform: uppercase; margin: 0; font-size: clamp(1.4rem, 4vw, 2.4rem); }
  p { max-width: 36rem; line-height: 1.5; text-align: center; opacity: 0.75; }
  a { color: #d8d4c8; }
</style>
</head>
<body>
<main>
  <h1>CypherClaw</h1>
  <p>A continuous, self-listening generative ensemble. The live stream and visualizer page is being prepared at this address.</p>
  <p><a href="/api/cypherclaw/live.m3u8">live playlist (m3u8)</a></p>
</main>
</body>
</html>`;
    const bytes = new TextEncoder().encode(body);
    return new Response(headOnly ? null : bytes, {
        status: 200,
        headers: {
            'Content-Type': 'text/html; charset=utf-8',
            'Content-Length': String(bytes.byteLength),
            'Cache-Control': 'public, max-age=60',
            ...corsHeaders(env, req),
        },
    });
}

// =================================================================
// Admin: CypherClaw live segment ingest
// =================================================================

async function receiveCypherClawSegment(req: Request, env: Env): Promise<Response> {
    if (!req.body) return errorResponse(400, 'request body required', env, req);

    const sequenceHeader = req.headers.get('X-CypherClaw-Sequence') || '';
    if (!/^\d+$/.test(sequenceHeader)) {
        return errorResponse(400, 'X-CypherClaw-Sequence must be a non-negative integer', env, req);
    }
    const sequence = Number(sequenceHeader);
    if (!Number.isSafeInteger(sequence)) {
        return errorResponse(400, 'X-CypherClaw-Sequence is outside the safe integer range', env, req);
    }

    const capturedAtHeader = req.headers.get('X-CypherClaw-Captured-At');
    const capturedAt = capturedAtHeader ? new Date(capturedAtHeader) : new Date();
    if (Number.isNaN(capturedAt.getTime())) {
        return errorResponse(400, 'X-CypherClaw-Captured-At must be a valid ISO timestamp', env, req);
    }

    const dateKey = capturedAt.toISOString().slice(0, 10);
    const key = `cypherclaw/live/${dateKey}/seg-${sequence}.opus`;
    const contentType = req.headers.get('Content-Type') || CYPHERCLAW_SEGMENT_CONTENT_TYPE;
    const customMetadata: Record<string, string> = {
        sequence: String(sequence),
        captured_at: capturedAt.toISOString(),
    };

    const duration = req.headers.get('X-CypherClaw-Duration');
    const scene = req.headers.get('X-CypherClaw-Scene');
    const tuning = req.headers.get('X-CypherClaw-Tuning');
    if (duration) customMetadata.duration = duration;
    if (scene) customMetadata.scene = scene;
    if (tuning) customMetadata.tuning = tuning;

    const obj = await env.MEDIA.put(key, req.body, {
        httpMetadata: { contentType },
        customMetadata,
    });

    return jsonResponse({
        ok: true,
        key,

