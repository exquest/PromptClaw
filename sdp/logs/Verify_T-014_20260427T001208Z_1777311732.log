{"type":"tool_result","timestamp":"2026-04-27T17:42:23.841Z","tool_id":"run_shell_command_1777311743682_0","status":"success","output":"commit b854f62d3258b2da9337388cc10e73d281ce08a0 (HEAD -> feat/graceful-degradation)\nAuthor: Anthony Ainsworth <anthony@cascadiantech.com>\nDate:   Mon Apr 27 10:41:29 2026 -0700\n\n    feat(generation): enforce rate gate in _should_queue_now via learning state [T-014@20260427T001208Z]\n    \n    Previously the runtime call _should_queue_now(mode, mood, learning) bypassed\n    the 30-minute throttle because last_enqueued_at was never threaded through.\n    Have the heuristic fall back to learning[\"last_generation_enqueued_at\"], and\n    inject the module-level _generation_last_enqueued_at into learning at the\n    composer call site.\n    \n    Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>\n\ndiff --git a/my-claw/tools/duet_composer.py b/my-claw/tools/duet_composer.py\nindex 53caa0c..7cd55ea 100644\n--- a/my-claw/tools/duet_composer.py\n+++ b/my-claw/tools/duet_composer.py\n@@ -294,6 +294,12 @@ def _post_song_generation_hook(\n         if queue is None:\n             return None\n \n+        if isinstance(learning, dict) and _generation_last_enqueued_at is not None:\n+            learning.setdefault(\n+                \"last_generation_enqueued_at\",\n+                _generation_last_enqueued_at,\n+            )\n+\n         if not _should_queue_now(mode, mood, learning):\n             return None\n \ndiff --git a/my-claw/tools/senseweave/generation/composer_hook.py b/my-claw/tools/senseweave/generation/composer_hook.py\nindex 082a5ac..6c68664 100644\n--- a/my-claw/tools/senseweave/generation/composer_hook.py\n+++ b/my-claw/tools/senseweave/generation/composer_hook.py\n@@ -81,6 +81,8 @@ def _should_queue_now(\n     if remaining <= MIN_DAILY_BUDGET_REMAINING_USD:\n         return False\n \n+    if last_enqueued_at is None:\n+        last_enqueued_at = _last_enqueued_from_learning(learning)\n     if last_enqueued_at is None:\n         return True\n \n@@ -88,6 +90,20 @@ def _should_queue_now(\n     return (current - last_enqueued_at) >= MIN_GENERATION_INTERVAL_SECONDS\n \n \n+def _last_enqueued_from_learning(learning: Any) -> float | None:\n+    raw = _mapping_value(\n+        learning,\n+        \"last_generation_enqueued_at\",\n+        \"last_enqueued_at\",\n+    )\n+    if raw is None:\n+        return None\n+    try:\n+        return float(raw)\n+    except (TypeError, ValueError):\n+        return None\n+\n+\n def build_generation_request(\n     *,\n     mode: Any,\ndiff --git a/tests/test_generation_composer_hook.py b/tests/test_generation_composer_hook.py\nindex 6f6e986..6a78df6 100644\n--- a/tests/test_generation_composer_hook.py\n+++ b/tests/test_generation_composer_hook.py\n@@ -47,6 +47,29 @@ def test_should_queue_now_enforces_rate_budget_and_working_gate() -> None:\n     )\n \n \n+def test_should_queue_now_rate_gate_reads_last_enqueued_from_learning() -> None:\n+    base = {\n+        \"arc_payoff_score\": 0.7,\n+        \"daily_budget_remaining_usd\": 1.0,\n+    }\n+\n+    too_soon = dict(base, last_generation_enqueued_at=900.0)\n+    assert not _should_queue_now(\n+        \"evening_reflection\",\n+        {\"energy\": 0.6},\n+        too_soon,\n+        now=1000.0,\n+    )\n+\n+    cooled_off = dict(base, last_generation_enqueued_at=900.0)\n+    assert _should_queue_now(\n+        \"evening_reflection\",\n+        {\"energy\": 0.6},\n+        cooled_off,\n+        now=900.0 + 30 * 60,\n+    )\n+\n+\n def test_should_queue_now_blocks_sampler_dominating_antipattern() -> None:\n     assert not _should_queue_now(\n         \"solitary\","}
