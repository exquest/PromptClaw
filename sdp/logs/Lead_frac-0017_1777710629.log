+    strongest_row: int | None
+    applies: bool
+
+
+@dataclass(frozen=True)
+class MetricAccentReport:
+    """Aggregate metric-accent outcome for one score."""
+
+    score_kind: str
+    total_shaped_steps: int
+    lane_stats: tuple[LaneMetricAccentStat, ...]
+
+
 def _apply_to_step(
