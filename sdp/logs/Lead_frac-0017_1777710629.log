+                "lane_name": "ostinato",
+                "role": "ostinato",
+                "meter": "4/4",
+                "step_count": 16,
+                "shaped_step_count": 0,
+                "mean_multiplier": 1.0,
+                "strongest_row": 0,
+                "applies": False,
+            },
+        ],
+    }
+
+
+def test_metric_accent_reaches_depth_two() -> None:
