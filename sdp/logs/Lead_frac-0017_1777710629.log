headers``. Used by the live submission path and by\\n    tests that mock httpx ``Response`` objects.\\n    \\\"\\\"\\\"\"}\n{\"type\":\"message\",\"timestamp\":\"2026-04-27T02:20:50.516Z\",\"role\":\"assistant\",\"content\":\"I will re-examine the `_http_failure_info` function to confirm how it utilizes\",\"delta\":true}\n{\"type\":\"message\",\"timestamp\":\"2026-04-27T02:20:50.521Z\",\"role\":\"assistant\",\"content\":\" `_retry_after_seconds` for parsing the `Retry-After` header.\",\"delta\":true}\n{\"type\":\"tool_use\",\"timestamp\":\"2026-04-27T02:20:50.569Z\",\"tool_name\":\"run_shell_command\",\"tool_id\":\"run_shell_command_1777256450568_0\",\"parameters\":{\"command\":\"grep -B 5 -A 15 \\\"def _http_failure_info\\\" my-claw/tools/senseweave/generation/client_replicate.py\",\"description\":\"Examine _http_failure_info implementation.\"}}\n{\"type\":\"tool_result\",\"timestamp\":\"2026-04-27T02:20:50.871Z\",\"tool_id\":\"run_shell_command_1777256450568_0\",\"status\":\"success\",\"output\":\"    if isinstance(request, Mapping):\\n        return {k: v for k, v in request.items() if k not in _ROUTING_KEYS}\\n    return {}\\n\\n\\ndef _http_failure_info(exc: BaseException) -> tuple[int | None, float | None]:\\n    \\\"\\\"\\\"Pull a status code + Retry-After hint off an HTTP-style exception.\\n\\n    Recognizes both httpx-style (``exc.response.status_code``) and\\n    replicate-SDK-style (``exc.status``) failure objects.\\n    \\\"\\\"\\\"\\n    response = getattr(exc, \\\"response\\\", None)\\n    headers = getattr(response, \\\"headers\\\", None) if response is not None else None\\n    status_code = getattr(response, \\\"status_code\\\", None) if response is not None else None\\n    if not isinstance(status_code, int):\\n        candidate = getattr(exc, \\\"status\\\", None)\\n        status_code = candidate if isinstance(candidate, int) else None\\n    if status_code is None:\\n        return None, None\\n    return status_code, _retry_after_seconds(headers)\"}\n{\"type\":\"message\",\"timestamp\":\"2026-04-27T02:20:55.176Z\",\"role\":\"assistant\",\"content\":\"I will search\",\"delta\":true}\n{\"type\":\"message\",\"timestamp\":\"2026-04-27T02:20:55.190Z\",\"role\":\"assistant\",\"content\":\" for `replicate` in other files to see if there are other examples of Replicate error handling in the codebase.\",\"delta\":true}\n{\"type\":\"tool_use\",\"timestamp\":\"2026-04-27T02:20:55.223Z\",\"tool_name\":\"run_shell_command\",\"tool_id\":\"run_shell_command_1777256455223_0\",\"parameters\":{\"command\":\"grep -r \\\"replicate\\\" . --exclude-dir=.git --exclude-dir=.sdp --exclude-dir=.venv | grep -v \\\"client_replicate.py\\\" | head -n 20\",\"description\":\"Search for replicate usage in other files.\"}}\n{\"type\":\"tool_result\",\"timestamp\":\"2026-04-27T02:21:20.701Z\",\"tool_id\":\"run_shell_command_1777256455223_0\",\"status\":\"success\",\"output\":\"./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_live_replicate.py::test_replicate_client_live_generation\\\",\\n./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_replicate_retry.py::test_generate_uses_retry_loop\\\",\\n./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_replicate_retry.py::test_non_429_4xx_does_not_retry[400]\\\",\\n./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_replicate_retry.py::test_non_429_4xx_does_not_retry[401]\\\",\\n./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_replicate_retry.py::test_non_429_4xx_does_not_retry[403]\\\",\\n./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_replicate_retry.py::test_non_429_4xx_does_not_retry[404]\\\",\\n./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_replicate_retry.py::test_non_429_4xx_does_not_retry[422]\\\",\\n./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_replicate_retry.py::test_non_replicate_exception_propagates_without_retry\\\",\\n./.pytest_cache/v/cache/nodeids:  \\\"tests/test_generation_replicate_retry.py::tes