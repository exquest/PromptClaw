            patch_name="house_garden",
            family_name="bloom",
            cadence_state="occupied_day",
            progression_profile="open_day",
            form_templates=form,
        )
        for name, scene in plan.scenes.items():
            assert scene.timeline is not None, f"Scene {name} missing timeline"

