+        except Exception as exc:  # pragma: no cover - defensive daemon guard
+            print(f"[sensory_journal_daemon] cycle failed: {exc}", file=sys.stderr)
+
+        iteration += 1
+        if max_iterations > 0 and iteration >= max_iterations:
