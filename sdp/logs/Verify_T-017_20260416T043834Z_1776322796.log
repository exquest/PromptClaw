 # Track last seen update to avoid re-reading old messages
 STATE_FILE = os.path.join(os.path.dirname(__file__), ".telegram_state.json")
+_ALLOW_LIVE_ENV = "PROMPTCLAW_ALLOW_LIVE_TELEGRAM"
+_POLICY_ENV = "PROMPTCLAW_TELEGRAM_POLICY"
+_TMP_WORKDIR_MARKER = "/run/cypherclaw-tmp/workdir/"
+
+
+def _truthy(value: str | None) -> bool:
+    return (value or "").strip().lower() in {"1", "true", "yes", "on"}
+
+
+def _send_policy() -> str:
+    policy = os.environ.get(_POLICY_ENV, "auto").strip().lower()
+    if policy in {"live", "suppress", "auto"}:
+        return policy
+    return "auto"
+
+
+def _suppress_reason() -> str | None:
+    if _truthy(os.environ.get(_ALLOW_LIVE_ENV)):
+        return None
+
+    policy = _send_policy()
+    if policy == "live":
+        return None
+    if policy == "suppress":
+        return "suppressed by PROMPTCLAW_TELEGRAM_POLICY=suppress"
+
+    if os.environ.get("PYTEST_CURRENT_TEST"):
+        return "suppressed during pytest execution"
+    if _truthy(os.environ.get("PROMPTCLAW_TEST_MODE")):
+        return "suppressed during PromptClaw test mode"
+
+    cwd = Path.cwd()
+    script_path = Path(__file__).resolve()
+    for candidate in (cwd, script_path):
+        candidate_text = str(candidate)
+        if "pytest-of-" in candidate_text:
+            return f"suppressed from pytest temp workdir {candidate}"
+        if _TMP_WORKDIR_MARKER in candidate_text:
+            return f"suppressed from task-run workdir {candidate}"
