+        except urllib.error.URLError as exc:
+            last_error = RuntimeError(f"URL Error: {exc.reason}")
+            if index < len(urls) - 1:
+                continue
+            raise last_error from exc
+        except OSError as exc:
+            last_error = RuntimeError(str(exc))
+            if index < len(urls) - 1:
