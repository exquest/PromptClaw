+
+def test_runner_launcher_discovers_project_root_from_script_location(tmp_path: Path) -> None:
+    project_root, tmp_root = _healthy_project(tmp_path)
+    tools_dir = _install_tool_stack(
+        project_root,
+        "init_workdir.sh",
