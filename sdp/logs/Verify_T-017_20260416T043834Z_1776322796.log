+        midi_state.note_off(note)
+        active_notes.pop(note, None)
+        return last_activity
+    if msg_type == 0xB0:
+        cc, value = data1, data2
+        previous_sustain = midi_state.sustain_pedal
+        midi_state.control_change(cc, value)
