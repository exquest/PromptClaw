+    def _make_state(self, **overrides):
+        base = {
+            "timestamp": time.time(),
+            "is_playing": True,
+            "pitch_hz": 440.0,
+            "pitch_note": "A4",
+            "pitch_confidence": 0.8,
+            "rms": 0.05,
+            "state": "sustain",
+            "suggested_key": "A",
+            "consecutive_silence_ms": 0,
+            "onset_rate": 1.0,
+        }
