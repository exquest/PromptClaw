+            reason="human_gesture_active",
+        )
+
+    if should_exit_duet(state, silence_threshold_ms=inactivity_ms):
+        return ConversationDecision(
+            phase="solo",
+            policy="solo",
+            speaker="none",
+            may_play=False,
