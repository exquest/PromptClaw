+
+    return {
+        "raw": raw,
+        "mod_wheel": named.get("mod_wheel", 0),
+        "breath": named.get("breath", 127),
+        "volume": named.get("volume", 100),
+        "expression": named.get("expression", 100),
+        "sustain": bool(named.get("sustain", False)),
+    }
+
