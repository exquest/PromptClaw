+    state["midi_cc"] = midi_cc
+    state["human_gesture_active"] = human_active
+    state["listening"] = is_listening
+    state["speaking"] = is_speaking
+    state["silence_request"] = silence_request
+    state["conversation"] = decision.to_dict()
+    return state
