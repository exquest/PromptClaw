+    duet_active: bool
+    wait_beats: int = 0
+    reason: str = ""
+
+    def to_dict(self) -> dict[str, object]:
+        """Return a JSON-serializable representation for state files."""
+        return {
+            "phase": self.phase,
+            "policy": self.policy,
+            "speaker": self.speaker,
+            "may_play": self.may_play,
+            "duet_active": self.duet_active,
