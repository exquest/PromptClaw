+            speaker="none",
+            may_play=False,
+            duet_active=False,
+            wait_beats=0,
+            reason="inactive",
+        )
+
+    if silence_ms < response_delay_ms:
+        return ConversationDecision(
+            phase="listening",
+            policy="turn_taking",
+            speaker="none",
+            may_play=False,
+            duet_active=True,
+            wait_beats=calculate_wait_beats(silence_ms, 0.5),
+            reason="waiting_for_turn",
+        )
+
+    return ConversationDecision(
+        phase="speaking",
+        policy=_requested_response_policy(state),
+        speaker="cypherclaw",
+        may_play=True,
+        duet_active=True,
+        wait_beats=0,
+        reason="response_window",
+    )
