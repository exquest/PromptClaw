+_RESPONSE_POLICIES = {"imitation", "counterpoint", "accompaniment"}
+_RESPONSE_DELAY_MS = 1200
+_SOLO_INACTIVITY_MS = 5000
+_SILENCE_CC_THRESHOLD = 3
+
+_CC_NAMES: dict[int, str] = {
+    1: "mod_wheel",
+    2: "breath",
+    7: "volume",
+    11: "expression",
+    64: "sustain",
+}
