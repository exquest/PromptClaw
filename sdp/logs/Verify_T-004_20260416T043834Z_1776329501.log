+            bandwidth="medium",
+        ),
+        quarantined=True,
+        quarantine_reason="node leak: doneAction:2 unreliable on long resonant tails",
+        safe_substitute="bowed",
+    ),
+
+    # -- Wavetable / waveshaping ----------------------------------------------
+    SynthDefEntry(
+        voice_name="pad",
