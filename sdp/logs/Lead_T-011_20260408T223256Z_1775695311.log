+        [{"type": "agent", "agent": "claude", "prompt": "Apply the fix.", "label": "local only step"}]
+    )
+
+    assert ollama_calls == [
+        {
+            "prompt": "Apply the fix.",
+            "timeout": cypherclaw_daemon.MAX_AGENT_TIMEOUT,
+            "task_category": None,
+            "task_label": "local only step",
