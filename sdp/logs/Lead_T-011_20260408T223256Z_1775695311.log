        _agent_semaphore = threading.Semaphore(1)
        _agent_semaphore_limit = 1
        observatory.record(
            "semaphore_reverted",
            {
                "from": previous_limit,
                "to": _agent_semaphore_limit,
                "trigger_count": _io_guard_trigger_count,
            },
        )


