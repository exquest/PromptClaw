def _notify_watchdog():
    """Notify systemd watchdog that we are alive."""
    try:
        import socket
        addr = os.environ.get("NOTIFY_SOCKET")
        if not addr:
            return
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
        if addr[0] == "@":
            addr = "\0" + addr[1:]
        sock.sendto(b"WATCHDOG=1", addr)
        sock.close()
    except Exception:
        pass


