            reason = f"ollama healthy on ports {ports_label}"
        else:
            status = "error"
            reason = f"ollama unhealthy on ports {ports_label}"

        self._apply_status(
            provider,
            status=status,
            headroom=headroom,
            confidence=confidence,
            reason=reason,
        )
        return healthy

