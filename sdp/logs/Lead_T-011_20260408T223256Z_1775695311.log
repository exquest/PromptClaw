+    assert pet_manager.calls[0] == ("start", "ollama")
+    assert pet_manager.calls[1][:3] == ("end", "ollama", True)
+    assert pet_manager.calls[2] == ("idle", "ollama")
+    assert any("ollama handled explicit cloud step" in message for message in sent)
+
