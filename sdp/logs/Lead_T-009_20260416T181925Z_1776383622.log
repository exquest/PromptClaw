+def _first_attr(source: object, names: tuple[str, ...]) -> object | None:
+    for name in names:
+        value = getattr(source, name, None)
+        if value is not None:
+            return value
+    return None
+
+
+def _coerce_optional_float(value: object | None) -> float | None:
+    if value is None:
+        return None
+    return float(cast(Any, value))
