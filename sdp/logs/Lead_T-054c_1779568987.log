index 0000000000000000000000000000000000000000..eec0473e3186ea3436d5f16c7969138d0abaa8cc
--- /dev/null
+++ b//Users/anthony/Programming/catalog-explorer/worker/tests/cypherclaw-live-midi-config.test.js
@@ -0,0 +1,106 @@
+const test = require("node:test");
+const assert = require("node:assert/strict");
+const fs = require("node:fs");
+const path = require("node:path");
+
+const WORKER_ROOT = path.join(__dirname, "..");
+const wranglerToml = fs.readFileSync(path.join(WORKER_ROOT, "wrangler.toml"), "utf8");
+const workerSource = fs.readFileSync(path.join(WORKER_ROOT, "src", "index.ts"), "utf8");
+
+function tableBodies(toml, tableName) {
+    const target = `[[${tableName}]]`;
+    const bodies = [];
+    let current = null;
+
+    for (const line of toml.split(/\r?\n/)) {
+        const trimmed = line.trim();
+        if (trimmed.startsWith("[") && trimmed.endsWith("]")) {
+            if (current !== null) {
+                bodies.push(current.join("\n"));
+            }
+            current = trimmed === target ? [] : null;
+            continue;
+        }
+
+        if (current !== null) {
+            current.push(line);
+        }
+    }
+
+    if (current !== null) {
+        bodies.push(current.join("\n"));
+    }
+
+    return bodies;
+}
+
+function hasTableMatching(toml, tableName, patterns) {
+    return tableBodies(toml, tableName).some((body) => (
+        patterns.every((pattern) => pattern.test(body))
+    ));
+}
+
+test("wrangler config binds and migrates LiveMidiRoom at top-level and in env.dev", () => {
+    const bindingPatterns = [
+        /^name\s*=\s*"LIVE_MIDI_ROOM"/m,
+        /^class_name\s*=\s*"LiveMidiRoom"/m,
+    ];
+    const migrationPatterns = [
+        /^tag\s*=\s*"v1"/m,
+        /^new_sqlite_classes\s*=\s*\[\s*"LiveMidiRoom"\s*\]/m,
+    ];
+
+    assert.equal(
+        hasTableMatching(wranglerToml, "durable_objects.bindings", bindingPatterns),
+        true,
+        "top-level wrangler config must bind LIVE_MIDI_ROOM to LiveMidiRoom",
+    );
+    assert.equal(
+        hasTableMatching(wranglerToml, "migrations", migrationPatterns),
+        true,
+        "top-level wrangler config must migrate LiveMidiRoom",
+    );
+    assert.equal(
+        hasTableMatching(wranglerToml, "env.dev.durable_objects.bindings", bindingPatterns),
+        true,
+        "env.dev wrangler config must bind LIVE_MIDI_ROOM to LiveMidiRoom",
+    );
+    assert.equal(
+        hasTableMatching(wranglerToml, "env.dev.migrations", migrationPatterns),
+        true,
+        "env.dev wrangler config must migrate LiveMidiRoom",
+    );
+});
+
+test("worker source exposes live-midi route, Env binding, and websocket guard", () => {
+    assert.match(
+        workerSource,
+        /LIVE_MIDI_ROOM:\s*DurableObjectNamespace;/,
+        "Env must expose LIVE_MIDI_ROOM as a DurableObjectNamespace",
+    );
+    assert.match(
+        workerSource,
+        /const CYPHERCLAW_LIVE_MIDI_PATH\s*=\s*'\/api\/cypherclaw\/live-midi';/,
+        "route path constant must pin /api/cypherclaw/live-midi",
+    );
+    assert.match(
+        workerSource,
+        /pathname === CYPHERCLAW_LIVE_MIDI_PATH && req\.method === 'GET'\) return await serveCypherClawLiveMidi\(req, env\);/,
+        "GET live-midi route must dispatch through the Worker route table",
+    );
+    assert.match(
+        workerSource,
+        /function isWebSocketUpgrade\(req: Request\): boolean \{\s*return \(req\.headers\.get\('Upgrade'\) \|\| ''\)\.toLowerCase\(\) === 'websocket';\s*\}/,
+        "websocket guard must only accept Upgrade: websocket",
+    );
+    assert.match(
+        workerSource,
+        /headers\.set\('Upgrade', 'websocket'\);\s*return new Response\('Expected Upgrade: websocket', \{ status: 426, headers \}\);/,
+        "non-websocket requests must return 426 with Upgrade: websocket",
+    );
+    assert.match(
+        workerSource,
+        /env\.LIVE_MIDI_ROOM\.idFromName\('global'\);[\s\S]*env\.LIVE_MIDI_ROOM\.get\(id\);[\s\S]*return await room\.fetch\(req\);/,
+        "websocket route must forward to the global LiveMidiRoom Durable Object",
+    );
+});
