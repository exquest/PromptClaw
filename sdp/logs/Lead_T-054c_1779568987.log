        texture: 0.35,
        density: 0.18,
        salience: 0.07,
        scene: 'awaiting-live-features',
        arc_phase: '',
        tuning: 'unknown',
        dsp_blocks: [],
        artistic_identity: '',
    };
    const lines = [
        ': cypherclaw live features bootstrap',
        'retry: 5000',
        'event: features',
        `data: ${JSON.stringify(payload)}`,
        '',
        '',
    ];
    const headers = new Headers(corsHeaders(env, req));
    headers.set('Content-Type', 'text/event-stream; charset=utf-8');
    headers.set('Cache-Control', 'no-cache');
    headers.set('X-Accel-Buffering', 'no');
    return new Response(lines.join('\n'), { status: 200, headers });
}

// =================================================================
// Public: CypherClaw live MIDI WebSocket room
// =================================================================

function isWebSocketUpgrade(req: Request): boolean {
    return (req.headers.get('Upgrade') || '').toLowerCase() === 'websocket';
}

function webSocketUpgradeRequiredResponse(env: Env, req: Request): Response {
    const headers = new Headers(corsHeaders(env, req));
    headers.set('Upgrade', 'websocket');
    return new Response('Expected Upgrade: websocket', { status: 426, headers });
}

interface LiveMidiEvent {
    status: number;
    data1: number;
    data2: number;
    ts: number;
}

const LIVE_MIDI_EVENT_KEYS = new Set(['status', 'data1', 'data2', 'ts']);

function parseLiveMidiEventMessage(data: unknown): string | null {
    if (typeof data !== 'string') {
        return null;
    }

    let parsed: unknown;
    try {
        parsed = JSON.parse(data);
    } catch (_error) {
        return null;
    }

    return isLiveMidiEvent(parsed) ? data : null;
}

function isLiveMidiEvent(value: unknown): value is LiveMidiEvent {
    if (value === null || typeof value !== 'object' || Array.isArray(value)) {
        return false;
    }

    const record = value as Record<string, unknown>;
    const keys = Object.keys(record);
    if (keys.length !== LIVE_MIDI_EVENT_KEYS.size) {
        return false;
    }
    if (!keys.every((key) => LIVE_MIDI_EVENT_KEYS.has(key))) {
        return false;
    }

    return (
        isMidiByte(record.status) &&
        isMidiByte(record.data1) &&
        isMidiByte(record.data2) &&
        typeof record.ts === 'number' &&
        Number.isFinite(record.ts)
    );
}

function isMidiByte(value: unknown): value is number {
    return (
        typeof value === 'number' &&
        Number.isInteger(value) &&
        value >= 0 &&
        value <= 255
    );
}

async function serveCypherClawLiveMidi(req: Request, env: Env): Promise<Response> {
    if (!isWebSocketUpgrade(req)) {
        return webSocketUpgradeRequiredResponse(env, req);
    }
    const id = env.LIVE_MIDI_ROOM.idFromName('global');
    const room = env.LIVE_MIDI_ROOM.get(id);
    return await room.fetch(req);
}

export class LiveMidiRoom implements DurableObject {
    private readonly env: Env;
    private readonly clients: Set<WebSocket>;

    constructor(_state: DurableObjectState, env: Env) {
        this.env = env;
        this.clients = new Set<WebSocket>();
    }

    async fetch(req: Request): Promise<Response> {
        if (!isWebSocketUpgrade(req)) {
            return webSocketUpgradeRequiredResponse(this.env, req);
        }

        const pair = new WebSocketPair();
        const client = pair[0];
        const server = pair[1];
        server.accept();
        this.clients.add(server);

        const removeClient = (_event: Event): void => {
            this.clients.delete(server);
        };
        const relayMidiEvent = (event: MessageEvent): void => {
            const message = parseLiveMidiEventMessage(event.data);
            if (message === null) {
                return;
            }
            this.broadcastMidiEvent(server, message);
        };
        server.addEventListener('close', removeClient);
        server.addEventListener('error', removeClient);
        server.addEventListener('message', relayMidiEvent);

        return new Response(null, {
            status: 101,
            webSocket: client,
        });
    }

    clientCount(): number {
        return this.clients.size;
    }

    private broadcastMidiEvent(sender: WebSocket, message: string): void {
        const deadClients: WebSocket[] = [];
        for (const client of this.clients) {
