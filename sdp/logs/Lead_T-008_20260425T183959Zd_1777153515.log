+SAMPLE_CAPTURE_ROOT = Path("/home/user/cypherclaw-data/samples")
+SAMPLE_INDEX_FILENAME = "index.sqlite"
+CAPTURE_CONTEXT_PATHS: dict[str, Path] = {
+    "organism": Path("/tmp/organism_state.json"),
