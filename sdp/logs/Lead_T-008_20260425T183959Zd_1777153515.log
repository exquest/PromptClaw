+@dataclass(frozen=True)
+class SavedCapture:
+    """A persisted sample capture plus the tag record emitted at write time."""
+
+    sample_id: str
+    source: str
+    path: Path
+    tags: SampleTags
+    sample_rate: int
+    frame_count: int
