+from __future__ import annotations
+
+import os
+import sys
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "my-claw", "tools"))
+
+from senseweave.music_tracker import (
+    SceneConstraint,
+    TrackerLane,
+    TrackerPattern,
+    TrackerScene,
