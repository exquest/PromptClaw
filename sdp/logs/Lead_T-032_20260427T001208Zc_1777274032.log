+def test_render_cap_summary_links_cost_model_and_lists_breaches() -> None:
+    rows = [
+        sdp_cost.DailyCostRow(
+            date="2026-04-26",
+            runs=1,
+            input_tokens=0,
+            output_tokens=0,
+            cache_creation_tokens=0,
