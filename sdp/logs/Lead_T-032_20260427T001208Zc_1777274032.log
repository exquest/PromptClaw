 False\\\\\\\\\\\\\\\\n++    age = now - float(timestamp)\\\\\\\\\\\\\\\\n++    return 0.0 <= age <= max_age_s\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def fallback_mood_for_hour(hour: int) -> dict[str, float]:\\\\\\\\\\\\\\\\n++    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Return a time-of-day fallback mood when live fusion data is unavailable.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    hour = hour % 24\\\\\\\\\\\\\\\\n++    if 0 <= hour < 5:\\\\\\\\\\\\\\\\n++        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.16, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"valence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.3, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arousal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.14}\\\\\\\\\\\\\\\\n++    if 5 <= hour < 8:\\\\\\\\\\\\\\\\n++        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.28, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"valence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.48, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arousal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.25}\\\\\\\\\\\\\\\\n++    if 8 <= hour < 12:\\\\\\\\\\\\\\\\n++        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.46, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"valence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.58, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arousal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.42}\\\\\\\\\\\\\\\\n++    if 12 <= hour < 17:\\\\\\\\\\\\\\\\n++        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.64, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"valence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.62, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arousal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.58}\\\\\\\\\\\\\\\\n++    if 17 <= hour < 21:\\\\\\\\\\\\\\\\n++        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.4, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"valence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.54, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arousal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.34}\\\\\\\\\\\\\\\\n++    return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.22, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"valence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.38, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"arousal\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0.2}\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def resolve_tracker_mood(\\\\\\\\\\\\\\\\n++    *,\\\\\\\\\\\\\\\\n++    organism_state: Mapping[str, object] | None,\\\\\\\\\\\\\\\\n++    room_state: Mapping[str, object] | None,\\\\\\\\\\\\\\\\n++    outdoor_state: Mapping[str, object] | None,\\\\\\\\\\\\\\\\n++    inner_state: Mapping[str, object] | None,\\\\\\\\\\\\\\\\n++    now: float | None = None,\\\\\\\\\\\\\\\\n++    hour: int | None = None,\\\\\\\\\\\\\\\\n++) -> TrackerMoodState:\\\\\\\\\\\\\\\\n++    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Resolve the current tracker mood with stale-state protection.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    now = time.time() if now is None else now\\\\\\\\\\\\\\\\n++    hour = time.localtime(now).tm_hour if hour is None else hour\\\\\\\\\\\\\\\\n++    mood = fallback_mood_for_hour(hour)\\\\\\\\\\\\\\\\n++    source = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fallback\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    source_fresh = False\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    organism_mood: Mapping[str, object] | None = None\\\\\\\\\\\\\\\\n++    if organism_state is not None and _timestamp_is_fresh(organism_state.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"timestamp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"), now=now):\\\\\\\\\\\\\\\\n++        candidate = organism_state.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"organism_mood\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++        if isinstance(candidate, Ma