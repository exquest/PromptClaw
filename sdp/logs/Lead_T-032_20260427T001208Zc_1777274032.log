+
+    @property
+    def breach_count(self) -> int:
+        return len(self.breaches)
+
+    @property
+    def missing_days(self) -> int:
+        return max(0, self.min_days - self.days_checked)
+
+    @property
+    def result(self) -> str:
+        if self.missing_days or self.breach_count:
