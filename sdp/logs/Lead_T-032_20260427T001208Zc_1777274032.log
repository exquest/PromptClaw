+    assert str(out) in result.stdout
+    assert str(summary_out) in result.stdout
+    text = summary_out.read_text(encoding="utf-8")
+    assert "**Result:** FAIL" in text
+    assert "| 2026-04-25 | $0.5670 | $0.05 | BREACH (+$0.5170) |" in text
+
+
