_state(ROOM_ACTIVITY_STATE)\\\\\\\\\\\\\\\\n++    room_speech = read_state(ROOM_SPEECH_STATE)\\\\\\\\\\\\\\\\n++    theramini = read_state(THERAMINI_STATE)\\\\\\\\\\\\\\\\n++    midi = read_state(MIDI_STATE)\\\\\\\\\\\\\\\\n++    input_levels = read_state(INPUT_LEVELS_STATE)\\\\\\\\\\\\\\\\n++    return {\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"room_presence\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {**room_presence, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"_fresh\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(room_presence)},\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"observer\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {**observer, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"_fresh\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(observer)},\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"room_activity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {**room_activity, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"_fresh\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(room_activity)},\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"room_speech\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {**room_speech, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"_fresh\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(room_speech)},\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"theramini\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {**theramini, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"_fresh\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(theramini)},\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"midi\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {**midi, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"_fresh\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(midi)},\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"input_levels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {**input_levels, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"_fresh\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(input_levels)},\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"direct_interaction\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {},\\\\\\\\\\\\\\\\n++    }\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def _clamp(value: float, lo: float = 0.0, h