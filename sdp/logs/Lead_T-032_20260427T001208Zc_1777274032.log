al\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 0.5))\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    if energy < 0.22 and arousal < 0.22:\\\\\\\\\\\\\\\\n++        return 4\\\\\\\\\\\\\\\\n++    if energy < 0.45:\\\\\\\\\\\\\\\\n++        choices = (4, 5)\\\\\\\\\\\\\\\\n++    elif energy < 0.7:\\\\\\\\\\\\\\\\n++        choices = (3, 4, 5)\\\\\\\\\\\\\\\\n++    else:\\\\\\\\\\\\\\\\n++        choices = (4, 5, 6)\\\\\\\\\\\\\\\\n++    return choices[song_num % len(choices)]\\\\\\\\\\\\\\\\n+diff --git a/my-claw/tools/senseweave/voice_aliases.py b/my-claw/tools/senseweave/voice_aliases.py\\\\\\\\\\\\\\\\n+new file mode 100644\\\\\\\\\\\\\\\\n+index 0000000..21e10b2\\\\\\\\\\\\\\\\n+--- /dev/null\\\\\\\\\\\\\\\\n++++ b/my-claw/tools/senseweave/voice_aliases.py\\\\\\\\\\\\\\\\n+@@ -0,0 +1,27 @@\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Runtime-safe voice aliases for CypherClaw playback.\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++This keeps the musical role metadata intact while allowing the live runtime\\\\\\\\\\\\\\\\n++to substitute safer or available voices when a SynthDef is known to leak or\\\\\\\\\\\\\\\\n++is missing from the deployed bundle.\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++from __future__ import annotations\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++RUNTIME_VOICE_ALIAS: dict[str, str] = {\\\\\\\\\\\\\\\\n++    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"gong\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bowed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sw_gong\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sw_bowed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bell\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bowed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++    \\\\\\\\\\\\\\\\\\\\\\\\\