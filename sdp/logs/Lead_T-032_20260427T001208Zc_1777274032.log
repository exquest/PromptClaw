+            total_cost_usd=row.total_cost_usd,
+            cap_usd=float(daily_cap_usd),
+            over_by_usd=max(0.0, row.total_cost_usd - float(daily_cap_usd)),
+        )
+        for row in rows
+    ]
+
+
+def summarize_daily_cap(
