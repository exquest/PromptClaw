family=family)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    biases = {\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"nocturne\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (-0.18, -0.02, -0.18),\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ember\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (0.04, 0.05, 0.04),\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"drift\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (-0.03, 0.02, -0.02),\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bloom\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (0.1, 0.08, 0.06),\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (0.18, 0.04, 0.2),\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"forge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (0.24, -0.02, 0.28),\\\\\\\\\\\\\\\\n++    }[family]\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    return TrackerPlan(\\\\\\\\\\\\\\\\n++        occupancy_state=occupancy,\\\\\\\\\\\\\\\\n++        cadence_state=cadence,\\\\\\\\\\\\\\\\n++        family=family,\\\\\\\\\\\\\\\\n++        progression_profile=progression_profile,\\\\\\\\\\\\\\\\n++        source=source,\\\\\\\\\\\\\\\\n++        energy_bias=biases[0],\\\\\\\\\\\\\\\\n++        valence_bias=biases[1],\\\\\\\\\\\\\\\\n++        arousal_bias=biases[2],\\\\\\\\\\\\\\\\n++    )\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def apply_tracker_plan_to_mood(\\\\\\\\\\\\\\\\n++    mood: dict[str, float],\\\\\\\\\\\\\\\\n++    plan: TrackerPlan,\\\\\\\\\\\\\\\\n++) -> dict[str, float]:\\\\\\\\\\\\\\\\n++    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Bias a resolved mood into the chosen cadence family.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    return {\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": round(_clamp(mood.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"energy\\\\\\\\\\\\\\\\