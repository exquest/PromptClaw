bpm * 0.84\\\\\\\\\\\\\\\\n++    elif family == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ember\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n++        shaped = [\\\\\\\\\\\\\\\\n++            _copy_phrase(\\\\\\\\\\\\\\\\n++                phrase,\\\\\\\\\\\\\\\\n++                duration_scale=1.1 if phrase.role != \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"counter\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" else 0.95,\\\\\\\\\\\\\\\\n++                accent_mode=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"head\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                dynamic_shift=-1,\\\\\\\\\\\\\\\\n++            )\\\\\\\\\\\\\\\\n++            for phrase in phrases\\\\\\\\\\\\\\\\n++        ]\\\\\\\\\\\\\\\\n++        if not any(phrase.role == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" for phrase in shaped):\\\\\\\\\\\\\\\\n++            shaped.append(_ensure_color_phrase(score, long=False))\\\\\\\\\\\\\\\\n++        tempo = score.tempo_bpm * (0.94 if cadence_state == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"wake_ramp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" else 0.98)\\\\\\\\\\\\\\\\n++    elif family == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bloom\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n++        shaped = [\\\\\\\\\\\\\\\\n++            _copy_phrase(\\\\\\\\\\\\\\\\n++                phrase,\\\\\\\\\\\\\\\\n++                duration_scale=0.95 if phrase.role == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" else 1.0,\\\\\\\\\\\\\\\\n++                accent_mode=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"keep\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++                dynamic_shift=1 if phrase.role == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"melody\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" else 0,\\\\\\\\\\\\\\\\n++            )\\\\\\\\\\\\\\\\n++            for phrase in phrases\\\\\\\\\\\\\\\\n++        ]\\\\\\\\\\\\\\\\n++        if not any(phrase.role == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" for phrase in shaped):\\\\\\\\\\\\\\\\n++         