+        f"**Daily cap:** ${summary.cap_usd:.2f}",
+        f"**Days checked:** {summary.days_checked} / {summary.min_days}",
+        f"**Breaches:** {summary.breach_count}",
+    ]
+    if summary.missing_days:
+        lines.append(f"Minimum days missing: {summary.missing_days}")
+    lines.extend(
