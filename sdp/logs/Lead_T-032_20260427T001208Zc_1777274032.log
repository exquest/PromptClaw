+
+    assert [(c.date, c.status, c.over_by_usd) for c in checks] == [
+        ("2026-04-25", "OK", 0.0),
+        ("2026-04-26", "OK", 0.0),
+        ("2026-04-27", "BREACH", pytest.approx(0.5)),
+    ]
+    assert checks[0].breached is False
+    assert checks[1].breached is False
+    assert checks[2].breached is True
