\\\\\\\\\\\\\\\\\\\\\\\\\\\"PALETTE_WATER\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": PALETTE_WATER,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"PALETTE_SPACE\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": PALETTE_SPACE,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"PALETTE_CUTE\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": PALETTE_CUTE,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"PALETTE_DRAGON\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": PALETTE_DRAGON,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"PALETTE_NIGHT\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": PALETTE_NIGHT,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"PALETTE_UI\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": PALETTE_UI,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ACTIVE_PALETTE\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": palette,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"width\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": width,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"height\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": height,\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"canvas\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": Canvas(width, height),\\\\\\\\\\\\\\\\n++    }\\\\\\\\\\\\\\\\n++    code = compile(path.read_text(), str(path), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"exec\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++    exec(code, namespace, namespace)\\\\\\\\\\\\\\\\n++    builder = namespace.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"build\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++    renderer = namespace.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"render\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++    if callable(builder):\\\\\\\\\\\\\\\\n++        return builder(width, height, palette)  # type: ignore[misc]\\\\\\\\\\\\\\\\n++    if callable(renderer):\\\\\\\\\\\\\\\\n++        return renderer(width, height, palette)  # type: ignore[misc]\\\\\\\\\\\\\\\\n++    for key in (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"canvas\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"result\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"animation\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"):\\\\\\\\\\\\\\\\n++        value = namespace.get(key)\\\\\\\\\\\\\\\\n++        if isinstance(value, (Canvas, Animation, str)):\\\\\\\\\\\\\\\\n++            return value\\\\\\\\\\\\\\\\n++    raise ValueError(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"DSL file {path} did not produce a canvas, animation, or string result\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def _preview_text(renderable: Canvas | Animation | str) -> str:\\\\\\\\\\\\\\\\n++    if isinstance(renderable, Canvas):\\\\\\\\\\\\\\\\n++        return renderable.to_string()\\\\\\\\\\\\\\\\n++    if isinstance(renderable, Animation):\\\\\\\\\\\\\\\\n++        if renderable.frames:\\\\\\\\\\\\\\\\n++            return renderable.frames[0].to_string()\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    return renderable\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def _png_chunk(chunk_type: bytes, data: bytes) -> bytes:\\\\\\\\\\\\\\\\n++    return struct.pack(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\">I\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", len(data)) + chunk_type + data + struct.pack(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\">I\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", zlib.crc32(chunk_type + data) & 0xFFFFFFFF)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def _write_block_png(text: str, output_path: Path) -> None:\\\\\\\\\\\\\\\\n++    lines = text.splitlines() or [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n++    cell_w = 10\\\\\\\\\\\\\\\\n++    cell_h = 16\\\\\\\\\\\\\\\\n++    padding = 8\\\\\\\\\\\\\\\\n++    token_lines: list[list[tuple[str, int]]] = []\\\\\\\\\\\\\\\\n++    max_width = 0\\\\\\\\\\\\\\\\n++    for line in lines:\\\\\\\\\\\\\\\\n++        row: list[tuple[str, int]] = []\\\\\\\\\\\\\\\\n++        width = 0\\\\\\\\\\\\\\\\n++        for token in _split_graphemes(line):\\\\\\\\\\\\\\\\n++            token_width = max(1, _display_width(token))\\\\\\\\\\\\\\\\n++            row.append((token, token_width))\\\\\\\\\\\\\\\\n++            width += token_width\\\\\\\\\\\\\\\\n++        token_lines.append(row)\\\\\\\\\\\\\\\\n++        max_width = max(max_width, width)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    img_w = max(1, max_width * cell_w + padding * 2)\\\\\\\\\\\\\\\\n++    img_h = max(1, len(token_lines) * cell_h + padding * 2)\\\\\\\\\\\\\\\\n++    pixels = bytearray([18, 18, 24, 255] * img_w * img_h)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    def fill_rect(x0: int, y0: int, w: int, h: int, rgba: tuple[int, int, int, int]) -> None:\\\\\\\\\\\\\\\\n++        r, g, b, a = rgba\\\\\\\\\\\\\\\\n++        for y in range(max(0, y0), min(img_h, y0 + h)):\\\\\\\\\\\\\\\\n++            offset = (y * img_w + max(0, x0)) * 4\\\\\\\\\\\\\\\\n++            for _ in range(max(0, x0), min(img_w, x0 + w)):\\\\\\\\\\\\\\\\n++                pixels[offset:offset + 4] = bytes((r, g, b, a))\\\\\\\\\\\\\\\\n++                offset += 4\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    for row_index, row in enumerate(token_lines):\\\\\\\\\\\\\\\\n++        cursor = padding\\\\\\\\\\\\\\\\n++        for token, token_width in row:\\\\\\\\\\\\\\\\n++            if token.strip():\\\\\\\\\\\\\\\\n++                color_seed = sum(ord(ch) for ch in token)\\\\\\\\\\\\\\\\n++                rgba = (\\\\\\\\\\\\\\\\n++                    80 + color_seed % 120,\\\\\\\\\\\\\\\\n++                    70 + (color_seed // 3) % 120,\\\\\\\\\\\\\\\\n++                    110 + (color_seed // 7) % 110,\\\\\\\\\\\\\\\\n++                    255,\\\\\\\\\\\\\\\\n++                )\\\\\\\\\\\\\\\\n++                fill_rect(cursor, padding + row_index * cell_h, token_width * cell_w - 1, cell_h - 2, rgba)\\\\\\\\\\\\\\\\n++            cursor += token_width * cell_w\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    raw = bytearray()\\\\\\\\\\\\\\\\n++    stride = img_w * 4\\\\\\\\