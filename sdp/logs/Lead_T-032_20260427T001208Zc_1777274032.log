\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"settling\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if cadence == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"away_practice\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"experiment\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if weekly_phase == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"friday_lift\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and day_phase in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"late_afternoon\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"evening_settling\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lift\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if weekly_phase == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sunday_settle\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and day_phase in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"afternoon_dip\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"evening_settling\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pre_sleep\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"settling\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if day_phase in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pre_dawn\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"morning_activation\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"awakening\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if day_phase in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mid_morning\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"midday\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"open_day\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if day_phase == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"late_afternoon\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lift\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if day_phase in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"afternoon_dip\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"evening_settling\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shadow_play\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    return {\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"nocturne\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"stillness\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"ember\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"awakening\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"drift\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shadow_play\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"bloom\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"open_day\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"procession\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"forge\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"experiment\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n++    }.get(family, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"open_day\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def _occupancy_state(world: WorldModel, hour: int) -> str:\\\\\\\\\\\\\\\\n++    if getattr(world, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"occupancy_state\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") not in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"uncertain\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}:\\\\\\\\\\\\\\\\n++        return world.occupancy_state\\\\\\\\\\\\\\\\n++    interaction = world.theramini_playing or world.midi_active\\\\\\\\\\\\\\\\n++    activity = world.room_activity in {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"moderate\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"active\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"} or world.recent_transient\\\\\\\\\\\\\\\\n++    fresh = _presence_sources_fresh(world)\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    if interaction or (world.someone_here and activity):\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"occupied_active\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if world.someone_here:\\\\\\\\\\\\\\\\n++        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"occupied_quiet\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    if fresh and not world.someone_here and not activity:\\\\\\\\\\\\\\\\n++        if 0 <= hour < 6:\\\\\\\\\\\\\\\\n++            return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"likely_asleep\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++        if 8 <= hour < 22:\\\\\\\\\\\\\\\\n++            return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"likely_away\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++    return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"uncertain\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++def resolve_tracker_plan(\\\\\\\\\\\\\\\\n++    world: WorldModel,\\\\\\\\\\\\\\\\n++    *,\\\\\\\\\\\\\\\\n++    song_num: int,\\\\\\\\\\\\\\\\n++    hour: int,\\\\\\\\\\\\\\\\n++) -> TrackerPlan:\\\\\\\\\\\\\\\\n++    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Resolve occupancy, cadence, and family from the current world.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n++\\\\\\\\\\\\\\\\n++    occupancy = _occupancy_state(world, hour)\\\\\\\\\\\\\\\\n++    interaction = world.theramini_playing or world.midi_active\\\\\\\\\\\\\\\\n++    activity = world.room_activit