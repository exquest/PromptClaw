+def grain_density_band(density: float) -> str:
+    """Return an operator-readable band for grain density in grains/sec."""
+    value = float(density)
+    if value <= 8.0:
+        return "sparse"
+    if value <= 16.0:
+        return "moderate"
+    if value <= 28.0:
+        return "dense"
+    return "saturated"
+
