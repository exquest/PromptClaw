+def grain_density_band(density: float) -> str:
+    """Return an operator-readable band for grain density in grains/sec."""
+    value = float(density)
+    if value <= 8.0:
+        return "sparse"
+    if value <= 16.0:
+        return "moderate"
+    if value <= 28.0:
+        return "dense"
+    return "saturated"
+
+
+def sampler_synth_arg_pairs(
+    *,
+    buffer_id: int | None,
+    effective_amp: float,
+    grain_size_ms: float,
+    density: float,
+    position: float,
+    position_rate: float,
+    pitch_transpose: float,
+    fx_send: float,
+) -> tuple[tuple[str, Any], ...]:
+    """Return canonical ordered key/value pairs for `sw_sampler` controls."""
+    values: dict[str, Any] = {
+        "bufnum": buffer_id,
+        "amp": effective_amp,
+        "grain_size_ms": grain_size_ms,
+        "density": density,
+        "position": position,
+        "position_rate": position_rate,
+        "pitch_transpose_semitones": pitch_transpose,
+        "fx_send": fx_send,
+    }
+    pairs: list[tuple[str, Any]] = []
+    for key in _SYNTH_ARG_KEYS:
+        pairs.append((key, values[key]))
+    return tuple(pairs)
+
+
+def build_s_new_args(
+    *,
+    node_id: int,
+    buffer_id: int | None,
