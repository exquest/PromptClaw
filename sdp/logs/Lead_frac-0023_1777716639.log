+    *,
+    buffer_id: int | None,
+    effective_amp: float,
+    grain_size_ms: float,
+    density: float,
+    position: float,
+    position_rate: float,
+    pitch_transpose: float,
+    fx_send: float,
+) -> tuple[tuple[str, Any], ...]:
+    """Return canonical ordered key/value pairs for `sw_sampler` controls."""
+    values: dict[str, Any] = {
+        "bufnum": buffer_id,
+        "amp": effective_amp,
+        "grain_size_ms": grain_size_ms,
+        "density": density,
+        "position": position,
+        "position_rate": position_rate,
+        "pitch_transpose_semitones": pitch_transpose,
+        "fx_send": fx_send,
+    }
+    pairs: list[tuple[str, Any]] = []
+    for key in _SYNTH_ARG_KEYS:
