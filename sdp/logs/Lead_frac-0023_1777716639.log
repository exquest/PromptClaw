+        "grain_size_ms": grain_size_ms,
+        "density": density,
+        "position": position,
+        "position_rate": position_rate,
+        "pitch_transpose_semitones": pitch_transpose,
+        "fx_send": fx_send,
+    }
+    pairs: list[tuple[str, Any]] = []
