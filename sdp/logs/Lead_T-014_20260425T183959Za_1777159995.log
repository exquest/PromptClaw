diff --git a/my-claw/systemd/cypherclaw-sample-capture.service b/my-claw/systemd/cypherclaw-sample-capture.service
new file mode 100644
index 0000000000000000000000000000000000000000..a5ab102b2e38f9d12759829c0181b6817bf55ff2
--- /dev/null
+++ b/my-claw/systemd/cypherclaw-sample-capture.service
@@ -0,0 +1,23 @@
+[Unit]
+Description=CypherClaw Sample Capture
+After=cypherclaw-jack.service
+Requires=cypherclaw-jack.service
+ConditionPathExists=/home/user/cypherclaw
+
+[Service]
+Type=simple
+User=user
+Group=user
+WorkingDirectory=/home/user/cypherclaw
+Environment=HOME=/home/user
+Environment=PYTHONUNBUFFERED=1
+ExecStart=/home/user/cypherclaw/.venv/bin/python3 /home/user/cypherclaw/tools/sample_capture_daemon.py
+Restart=always
+RestartSec=5
+LimitMEMLOCK=infinity
+StandardOutput=journal
+StandardError=journal
+SyslogIdentifier=cypherclaw-sample-capture
+
+[Install]
+WantedBy=multi-user.target
