sion text must confirm people.\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"someone_here\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(motion and brightness > 0.08),\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rgb_avg\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [int(r_avg), int(g_avg), int(b_avg)],\\\\\\\\\\\\\\\\n+    }\\\\\\\\\\\\\\\\n+    return result, pixels\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def description_suggests_person(description: str) -> bool:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Infer whether the slow vision model likely saw a person.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    text = description.lower()\\\\\\\\\\\\\\\\n+    return any(token in text for token in PERSON_TOKENS)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def is_ollama_busy_error(error: str) -> bool:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Return whether an error string indicates Ollama queue saturation.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    text = error.lower()\\\\\\\\\\\\\\\\n+    return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"503\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in text and (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"server busy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in text or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pending requests exceeded\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" in text)\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def local_scene_description(\\\\\\\\\\\\\\\\n+    fast_state: dict[str, Any],\\\\\\\\\\\\\\\\n+    *,\\\\\\\\\\\\\\\\n+    visual_person_cue: bool = False,\\\\\\\\\\\\\\\\n+) -> str:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Create a compact local summary when slow multimodal vision is unavailable.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    lighting = str(fast_state.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lighting\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"unknown\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")).strip() or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"unknown\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    dominant = str(fast_state.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"dominant_color\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"neutral\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")).strip() or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"neutral\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    motion = bool(fast_state.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"motion\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    if visual_person_cue:\\\\\\\\\\\\\\\\n+        presence = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"possible person in view\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    elif motion:\\\\\\\\\\\\\\\\n+        presence = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"movement in the room\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    else:\\\\\\\\\\\\\\\\n+        presence = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"no clear people\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    return f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{lighting} {dominant} room, {presence}.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def error_text(exc: Exception) -> str:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Normalize error text for state files without hiding the actual cause.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    return str(exc).strip()[:MAX_ERROR_CHARS]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def normalize_vision_description(text: str) -> str:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Trim low-signal model chatter from scene descriptions.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cleaned = text.replace(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\r\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").strip()\\\\\\\\\\\\\\\\n+    for prefix in (\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Okay, processing…\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Okay, processing...\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Okay, processing\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Processing…\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Processing...\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    ):\\\\\\\\\\\\\\\\n+        if cleaned.startswith(prefix):\\\\\\\\\\\\\\\\n+            cleaned = cleaned[len(prefix):].lstrip()\\\\\\\\\\\\\\\\n+    return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\".join(part.strip() for part in cleaned.splitlines() if part.strip())\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def parse_http_error(exc: urllib.error.HTTPError) -> RuntimeError:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Preserve useful Ollama error details from an HTTP response.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    detail = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n     try:\\\\\\\\\\\\\\\\n-        if capture():\\\\\\\\\\\\\\\\n-            result = fast_analyze(FRAME)\\\\\\\\\\\\\\\\n-            now = time.time()\\\\\\\\\\\\\\\\n-            # Vision analysis on slower cadence\\\\\\\\\\\\\\\\n-            if now - last_vision > VISION_INTERVAL:\\\\\\\\\\\\\\\\n-                try:\\\\\\\\\\\\\\\\n-                    last_description = vision_analyze(FRAME)\\\\\\\\\\\\\\\\n-                    last_vision = now\\\\\\\\\\\\\\\\n+        raw = exc.read().decode()\\\\\\\\\\\\\\\\n+        parsed = json.loads(raw)\\\\\\\\\\\\\\\\n+        if isinstance(parsed, dict):\\\\\\\\\\\\\\\\n+            detail = str(parsed.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"error\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")).strip()\\\\\\\\\\\\\\\\n+        if not detail:\\\\\\\\\\\\\\\\n+            detail = raw.strip()\\\\\\\\\\\\\\\\n+    except Exception:\\\\\\\\\\\\\\\\n+        detail = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    suffix = f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" {detail}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if detail else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    return RuntimeError(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"HTTP Error {exc.code}: {exc.reason}{suffix}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _load_cv2():\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Load cv2 lazily so local development without OpenCV still works.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    try:\\\\\\\\\\\\\\\\n+        return importlib.import_module(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"cv2\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+    except Exception:\\\\\\\\\\\\\\\\n+        return None\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def detect_visual_person_cue(frame_path: str, cv2_module=None) -> dict[str, Any]:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Detect explicit face/person cues with OpenCV when available.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cv2_module = _load_cv2() if cv2_module is None else cv2_module\\\\\\\\\\\\\\\\n+    if cv2_module is None:\\\\\\\\\\\\\\\\n+        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    try:\\\\\\\\\\\\\\\\n+        image = cv2_module.imread(frame_path)\\\\\\\\\\\\\\\\n+        if image is None:\\\\\\\\\\\\\\\\n+            return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0}\\\\\\\\\\\\\\\\n+        gray = cv2_module.cvtColor(image, cv2_module.COLOR_BGR2GRAY)\\\\\\\\\\\\\\\\n+        cascade = cv2_module.CascadeClassifier(\\\\\\\\\\\\\\\\n+            os.path.join(cv2_module.data.haarcascades, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"haarcascade_frontalface_default.xml\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+        )\\\\\\\\\\\\\\\\n+        empty_method = getattr(cascade, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"empty\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", None)\\\\\\\\\\\\\\\\n+        if callable(empty_method) and empty_method():\\\\\\\\\\\\\\\\n+            return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0}\\\\\\\\\\\\\\\\n+        faces = cascade.detectMultiScale(gray, scaleFactor=1.1, minNeighbors=4, minSize=(24, 24))\\\\\\\\\\\\\\\\n+        face_count = len(faces)\\\\\\\\\\\\\\\\n+        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": face_count > 0, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": face_count}\\\\\\\\\\\\\\\\n+    except Exception:\\\\\\\\\\\\\\\\n+        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def vision_analyze(frame_path: str, urls: tuple[str, ...] | None = None) -> str:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Run the slow multimodal scene description.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    with open(frame_path, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"rb\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") as handle:\\\\\\\\\\\\\\\\n+        img_b64 = base64.b64encode(handle.read()).decode()\\\\\\\\\\\\\\\\n+    payload = json.dumps(\\\\\\\\\\\\\\\\n+        {\\\\\\\\\\\\\\\\n+            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"model\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": VISION_MODEL,\\\\\\\\\\\\\\\\n+            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"messages\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"user\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"content\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": PROMPT, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"images\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": [img_b64]}],\\\\\\\\\\\\\\\\n+            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"stream\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False,\\\\\\\\\\\\\\\\n+            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"options\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"num_predict\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 60},\\\\\\\\\\\\\\\\n+        }\\\\\\\\\\\\\\\\n+    ).encode()\\\\\\\\\\\\\\\\n+    urls = OLLAMA_URLS if urls is None else urls\\\\\\\\\\\\\\\\n+    last_error: RuntimeError | None = None\\\\\\\\\\\\\\\\n+    for index, url in enumerate(urls):\\\\\\\\\\\\\\\\n+        req = urllib.request.Request(url, data=payload, headers={\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Content-Type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"application/json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"})\\\\\\\\\\\\\\\\n+        try:\\\\\\\\\\\\\\\\n+            resp = urllib.request.urlopen(req, timeout=90)\\\\\\\\\\\\\\\\n+        except urllib.error.HTTPError as exc:\\\\\\\\\\\\\\\\n+            parsed = parse_http_error(exc)\\\\\\\\\\\\\\\\n+            if is_ollama_busy_error(str(parsed)) and index < len(urls) - 1:\\\\\\\\\\\\\\\\n+                last_error = parsed\\\\\\\\\\\\\\\\n+                continue\\\\\\\\\\\\\\\\n+            raise parsed from exc\\\\\\\\\\\\\\\\n+        except urllib.error.URLError as exc:\\\\\\\\\\\\\\\\n+            last_error = RuntimeError(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"URL Error: {exc.reason}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+            if index < len(urls) - 1:\\\\\\\\\\\\\\\\n+                continue\\\\\\\\\\\\\\\\n+            raise last_error from exc\\\\\\\\\\\\\\\\n+        except OSError as exc:\\\\\\\\\\\\\\\\n+            last_error = RuntimeError(str(exc))\\\\\\\\\\\\\\\\n+            if index < len(urls) - 1:\\\\\\\\\\\\\\\\n+                continue\\\\\\\\\\\\\\\\n+            raise last_error from exc\\\\\\\\\\\\\\\\n+        text = json.loads(resp.read()).get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"message\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", {}).get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"content\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").strip()\\\\\\\\\\\\\\\\n+        return normalize_vision_description(text)\\\\\\\\\\\\\\\\n+    if last_error is not None:\\\\\\\\\\\\\\\\n+        raise last_error\\\\\\\\\\\\\\\\n+    raise RuntimeError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"No observer vision URLs configured\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def write_state(state: dict[str, Any], state_path: str | None = None) -> Nonecomposition-spec.md\\\\\\\\\\\\\\\\n        docs/cypherclaw-tracker-framework.md\\\\\\\\\\\\\\\\n        docs/cypherclaw-upgrade-checklist.md\\\\\\\\\\\\\\\\n        my-claw/curriculum/\\\\\\\\\\\\\\\\n        my-claw/scripts/cypherclaw_av_boot.sh\\\\\\\\\\\\\\\\n        my-claw/sdp/prd-music-production-course.md\\\\\\\\\\\\\\\\n        my-claw/sdp/prd-r750-ollama-integration.md\\\\\\\\\\\\\\\\n        my-claw/sdp/prd-songwriter-emsd-completion.md\\\\\\\\\\\\\\\\n        my-claw/systemd/cypherclaw-av-stack.service\\\\\\\\\\\\\\\\n        my-claw/systemd/cypherclaw-observer-ollama.service\\\\\\\\\\\\\\\\n        my-claw/tools/archive_paths.py\\\\\\\\\\\\\\\\n        my-claw/tools/capture_alias.py\\\\\\\\\\\\\\\\n        my-claw/tools/contact_mic_calibration.py\\\\\\\\\\\\\\\\n        my-claw/tools/gallery_x11.py\\\\\\\\\\\\\\\\n        my-claw/tools/room_presence_daemon.py\\\\\\\\\\\\\\\\n        my-claw/tools/runtime_paths.py\\\\\\\\\\\\\\\\n        my-claw/tools/sample_playback_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/arrangement_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/artistic_identity.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/cadence_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/capstone_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/cast_planner.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/commission_context.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/dsp_scene_lab.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/ear_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/emsd_performance.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/emsd_runtime.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/harmonic_planner.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/hook_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/instrument_patches.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/master_bus.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/mix_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/music_tracker.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/piece_commission.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/piece_queue.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/practice_curriculum.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/presence_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/procedural_arc.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/prosody_engine.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/reharmonizer.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/repertoire_memory.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/sample_event_renderer.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/sample_lab.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/sample_status.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/sound_palette_lab.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/tracker_cadence.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/tracker_compiler.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/tracker_variation.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/voice_aliases.py\\\\\\\\\\\\\\\\n        my-claw/tools/senseweave/voice_shaping.py\\\\\\\\\\\\\\\\n        promptclaw/glyphweave_cli.py\\\\\\\\\\\\\\\\n        rewrite_hook.py\\\\\\\\\\\\\\\\n        sdp/assumption-log.md\\\\\\\\\\\\\\\\n        sdp/clarification-register.md\\\\\\\\\\\\\\\\n        sdp/domain-model.md\\\\\\\\\\\\\\\\n        sdp/implementation-plan.md\\\\\\\\\\\\\\\\n        sdp/logs/\\\\\\\\\\\\\\\\n        sdp/notifications.log\\\\\\\\\\\\\\\\n        sdp/prd-snapshot.md\\\\\\\\\\\\\\\\n        sdp/requirements-register.md\\\\\\\\\\\\\\\\n        sdp/run-log.md\\\\\\\\\\\\\\\\n        sdp/self-improvement/\\\\\\\\\\\\\\\\n        sdp/state.db.legacy-20260416T045403Z\\\\\\\\\\\\\\\\n        sdp/task-graph.md\\\\\\\\\\\\\\\\n        sdp/telemetry/\\\\\\\\\\\\\\\\n        sdp/templates/candidates/\\\\\\\\\\\\\\\\n        sdp/templates/claude/\\\\\\\\\\\\\\\\n        sdp/verification/t-001@20260416t043834z-manual-verify.md\\\\\\\\\\\\\\\\n        sdp/verification/t-010@20260408t223256zb-verify.md\\\\\\\\\\\\\\\\n        sdp/verification/t-012@20260416t043834z-manual-verify.md\\\\\\\\\\\\\\\\n        tests/test_archive_paths.py\\\\\\\\\\\\\\\\n        tests/test_arrangement_engine.py\\\\\\\\\\\\\\\\n        tests/test_artistic_identity.py\\\\\\\\\\\\\\\\n        tests/test_cadence_engine.py\\\\\\\\\\\\\\\\n        tests/test_capstone_engine.py\\\\\\\\\\\\\\\\n        tests/test_capture_alias.py\\\\\\\\\\\\\\\\n        tests/test_cast_planner.py\\\\\\\\\\\\\\\\n        tests/test_commission_context.py\\\\\\\\\\\\\\\\n        tests/test_contact_mic_calibration_runtime.py\\\\\\\\\\\\\\\\n        tests/test_cypherclaw_audio_runtime.py\\\\\\\\\\\\\\\\n        tests/test_cypherclaw_av_stack_service.py\\\\\\\\\\\\\\\\n        tests/test_cypherclaw_boot_runtime.py\\\\\\\\\\\\\\\\n        tests/test_dsp_scene_lab.py\\\\\\\\\\\\\\\\n        tests/test_ear_engine.py\\\\\\\\\\\\\\\\n        tests/test_emsd_curriculum.py\\\\\\\\\\\\\\\\n        tests/test_emsd_performance.py\\\\\\\\\\\\\\\\n        tests/test_emsd_runtime.py\\\\\\\\\\\\\\\\n        tests/test_form_grammar.py\\\\\\\\\\\\\\\\n        tests/test_gallery_x11_runtime.py\\\\\\\\\\\\\\\\n        tests/test_glyphweave_cli.py\\\\\\\\\\\\\\\\n        tests/test_harmonic_planner.py\\\\\\\\\\\\\\\\n        tests/test_hook_engine.py\\\\\\\\\\\\\\\\n        tests/test_instrument_patches.py\\\\\\\\\\\\\\\\n        tests/test_master_bus.py\\\\\\\\\\\\\\\\n        tests/test_midi_keyboard_listener_runtime.py\\\\\\\\\\\\\\\\n        tests/test_mix_engine.py\\\\\\\\\\\\\\\\n        tests/test_music_tracker.py\\\\\\\\\\\\\\\\n        tests/test_music_tracker_runtime.py\\\\\\\\\\\\\\\\n        tests/test_musical_integration_runtime.py\\\\\\\\\\\\\\\\n        tests/test_observer_vision_runtime.py\\\\\\\\\\\\\\\\n        tests/test_piece_commission.py\\\\\\\\\\\\\\\\n        tests/test_piece_queue.py\\\\\\\\\\\\\\\\n        tests/test_practice_curriculum.py\\\\\\\\\\\\\\\\n        tests/test_presence_engine.py\\\\\\\\\\\\\\\\n        tests/test_procedural_arc.py\\\\\\\\\\\\\\\\n        tests/test_prosody_engine.py\\\\\\\\\\\\\\\\n        tests/test_reharmonizer.py\\\\\\\\\\\\\\\\n        tests/test_repertoire_memory.py\\\\\\\\\\\\\\\\n        tests/test_repertoire_memory_score_tree.py\\\\\\\\\\\\\\\\n        tests/test_room_presence_daemon.py\\\\\\\\\\\\\\\\n        tests/test_runtime_paths.py\\\\\\\\\\\\\\\\n        tests/test_sample_dsp_activity.py\\\\\\\\\\\\\\\\n        tests/test_sample_event_renderer.py\\\\\\\\\\\\\\\\n        tests/test_sample_lab.py\\\\\\\\\\\\\\\\n        tests/test_sample_status.py\\\\\\\\\\\\\\\\n        tests/test_score_tree.py\\\\\\\\\\\\\\\\n        tests/test_score_tree_pipeline.py\\\\\\\\\\\\\\\\n        tests/test_self_listener_tracker_runtime.py\\\\\\\\\\\\\\\\n        tests/test_sound_palette_lab.py\\\\\\\\\\\\\\\\n        tests/test_tracker_cadence.py\\\\\\\\\\\\\\\\n        tests/test_tracker_compiler.py\\\\\\\\\\\\\\\\n        tests/test_tracker_variation.py\\\\\\\\\\\\\\\\n        tests/test_voice_aliases.py\\\\\\\\\\\\\\\\n        tests/test_voice_shaping.py\\\\\\\\\\\\\\\\n        verification_reports/\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nno changes added to commit (use \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"git add\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" and/or \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"git commit -a\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\ndiff --git a/CHANGELOG.md b/CHANGELOG.md\\\\\\\\\\\\\\\\nindex c0e1324..aa40528 100644\\\\\\\\\\\\\\\\n--- a/CHANGELOG.md\\\\\\\\\\\\\\\\n+++ b/CHANGELOG.md\\\\\\\\\\\\\\\\n@@ -2,6 +2,109 @@\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n ## Unreleased\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n+- Tuned local SDP agent templates for dirty-baseline operation: leads must commit task-scoped changes, while verifiers now treat unrelated pre-existing dirty workspace state as notes instead of failing otherwise-correct tasks or asking agents to clean another operator's work.\\\\\\\\\\\\\\\\n+- Implemented ST1-ST6 of the score-tree songwriting stack end to end: added `piece_commission.py`, `piece_brief.py`, `form_grammar.py`, `score_tree.py`, `recursive_composer.py`, `composition_gate.py`, `tracker_compiler.py`, and `piece_queue.py`; extended `repertoire_memory.py` to store structural score-tree summaries; and rewired `duet_composer.py` so tracker solo mode can commission a piece, build a complete score tree, gate it, compile it into tracker scenes, and precompose the next piece into a small persistent queue instead of treating the tracker as the composer.\\\\\\\\\\\\\\\\n+- Rebalanced the first live score-tree pass for audibility: fresh post-restart commissions now avoid jumping straight to a maximal sparse suite unless the cadence is already wind-down/sleep-oriented, and `music_tracker_runtime.py` now emits stronger safe amplitudes for primary melody/bass/rhythm lanes so a healthy running piece is easier to hear and meter.\\\\\\\\\\\\\\\\n+- Fixed the long-section tracker compile bug that was turning songs into isolated sustained tones: `tracker_compiler.py` now converts large section budgets into repeat counts plus modest note-length scaling, and `music_tracker.py` quantizes those repeats into real repeated phrase cycles instead of stretching a handful of notes across the whole scene.\\\\\\\\\\\\\\\\n+- Finished the next score-tree composition pass: `tracker_compiler.py` now derives and enriches a fresh score per section, applies section-function and motif-aware phrase transforms before tracker quantization, and `music_tracker.py` now varies repeated cycles inside long sections, so longer pieces can develop through distinct section writing instead of only looping one shared phrase body.\\\\\\\\\\\\\\\\n+- Added internal phrase-family development inside longer sections: `Phrase` now carries metadata, `tracker_compiler.py` expands section bodies into recursive families like `A`, `A_prime`, and `B`, and `music_tracker.py` annotates emitted steps with `internal_phrase_family` so development sections can be tested and diagnosed as more than literal loops.\\\\\\\\\\\\\\\\n+- Coordinated those internal phrase families across tracker roles: shared root/function profiles now shape melody, bass, counter, and color variants together, and tracker steps expose `internal_family_root_degree` plus `internal_family_function` for diagnostics and future orchestration consumers.\\\\\\\\\\\\\\\\n+- Added authored section transitions: `tracker_compiler.py` now tags each non-final scene with the next scene/function/root target, and `music_tracker.py` marks and retunes final-cycle tail steps as transition preparation so long sections aim into the following section instead of simply looping until a hard boundary.\\\\\\\\\\\\\\\\n+- Added staged lane windows inside repeated tracker scenes: `music_tracker.py` now assigns per-role `entry_cycle` / `exit_cycle` metadata and delays counter/color support in long development-style sections, so sections can thicken internally instead of launching every lane at row 0.\\\\\\\\\\\\\\\\n+- Fixed transition metadata through motif recall: recalled `Recap` / `Release` lanes now strip stale source-scene transition fields and attach the current scene's own transition target to their final preparation tail.\\\\\\\\\\\\\\\\n+- Added section-level motif development and local harmonic progressions: `tracker_compiler.py` now labels each section as statement, sequence/fragment, contrast inversion, recall answer, liquidation, or residue, reshapes phrase material accordingly, and applies section-local progressions that are exposed on tracker scenes and steps for bass/progression verification.\\\\\\\\\\\\\\\\n+- Added section-level rhythmic development: `tracker_compiler.py` now maps section functions to named rhythm cells such as steady statement, syncopated fragment, half-time displacement, recall groove, and residue breath, reshaping phrase durations/accents and exposing `rhythm_development` / `rhythm_cell` through tracker metadata.\\\\\\\\\\\\\\\\n+- Fixed recalled motif rhythm metadata so later sections that borrow earlier material inherit the current scene's rhythm/progression profile instead of leaking the source scene's old `rhythm_development`.\\\\\\\\\\\\\\\\n+- Added arrangement automation curves to tracker playback: `music_tracker.py` now derives `arrangement_curve` from section rhythm, writes row-point automation for `density`, `master_amp`, and `reverb_send`, shapes note velocity across each lane's active window, and `music_tracker_runtime.py` / `duet_composer.py` now expose and apply interpolated automation to the live master bus during the section. Low density also thins optional color/counter runtime events while preserving melody and bass continuity.\\\\\\\\\\\\\\\\n+- Fixed a live capture fallback issue that made the sampler lean on a quiet self bus: `room_listener.py` now skips absent named JACK ports and tries direct `jack_rec` fallback ports such as `system:capture_1`, while `sample_dsp_activity.py` now resolves missing `theramini_in` to `contact_mic` / `room_mic` before `self_bus`.\\\\\\\\\\\\\\\\n+- Rebalanced the live song mix after the repeat-cycle fix: `music_tracker_runtime.py` now gives texture lanes a stronger floor while slightly easing bass dominance, and `emsd_performance.py` now uses a gentler amp-scaling curve so normal `away_practice` songs no longer pin bass and melody at the top of the EMSD gain range.\\\\\\\\\\\\\\\\n+- Fixed the live score-tree runtime on CypherClaw: `duet_composer.py` now derives commission context defensively from the world when `TrackerPlan` lacks `day_phase` / `weekly_phase`, `master_bus.py` now exposes an explicit `sw_master_smooth` seed helper, and `restart_composer.sh` now reseeds that master node again after the new composer PID is confirmed alive so the first piece does not run with scene-level `/n_set` traffic targeting a dead node.\\\\\\\\\\\\\\\\n+- Added a concrete score-tree composition spec for the next songwriting pass: `cypherclaw-score-tree-composition-spec.md` now defines the piece commission layer, narrative brief contract, section-function grammar, score-tree data model, recursive composer, composition gate, tracker compiler, repertoire score-tree memory, and rollout phases needed to move CypherClaw from short tracker-first sketches toward longer, more varied composed pieces.\\\\\\\\\\\\\\\\n+- Isolated observer vision from the shared local model queue: added `cypherclaw-observer-ollama.service` on `127.0.0.1:11435`, routed `observer_vision.py` to try `11435` before `11434`, and taught the multimodal call path to fail over across ordered observer Ollama URLs before dropping to local fallback mode.\\\\\\\\\\\\\\\\n+- Moved heavy runtime storage toward the large archive volume: added `archive_paths.py`, taught `sample_playback_engine.py` and `archive_daemon.py` to resolve a shared archive root (preferring `/mnt/archive/cypherclaw` on the live box), updated `cypherclaw_boot.sh` to put porch/side capture rings on that archive root, and reconfigured the live host so Litestream observatory/state file replicas live off the root disk with a much tighter observatory snapshot retention window.\\\\\\\\\\\\\\\\n+- Hardened the slow observer-vision path: `observer_vision.py` now treats Ollama `503 server busy / maximum pending requests exceeded` as queue saturation instead of a user-facing description, preserves the HTTP body detail in `vision_error`, emits a compact local fallback description with `vision_backend: \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"local_fallback\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"`, and backs off before retrying the multimodal model call again.\\\\\\\\\\\\\\\\n+- Repaired the live display/camera contract on CypherClaw: `cypherclaw_av_boot.sh` now reapplies the observed dual-head layout (`DP-2` face at `1280x1024`, `DP-0` gallery at `3840x2160`) and launches face/gallery on `:0.0` / `:0.1`, while `gallery_x11.py` now uses origin positioning on the secondary X screen instead of the old combined-desktop offset that left the 4K monitor partially black.\\\\\\\\\\\\\\\\n+- Hardened the local webcam path: `observer_vision.py` now defaults to `/dev/video0`, records `video_device`, and rejects stale old JPEGs when `ffmpeg` capture fails; `room_presence_daemon.py` can now run in `--observer-frame-only` mode and report `capture_source: \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"observer_frame\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"` so presence can share the single observer webcam instead of contending for it.\\\\\\\\\\\\\\\\n+- Mirrored the shared observer frame back into `/tmp/room_frame.jpg` when `room_presence_daemon.py` is running in `--observer-frame-only` mode, so archive and room-frame consumers stay fresh instead of freezing on the last independent room-camera capture.\\\\\\\\\\\\\\\\n+- Tightened the user-boot camera ownership path too: `cypherclaw_boot.sh` now deduplicates the local observer/presence daemons and starts `room_presence_daemon.py` in shared-observer mode, which prevents repeated boot invocations from piling up dozens of competing camera loops on the live box.\\\\\\\\\\\\\\\\n+- Locked the EMSD room sampler to tracker transport: `sample_dsp_activity.py` now emits `transport_trigger_now` / `transport_trigger_key`, `sample_playback_engine.py` uses those keys to launch once per musical bucket instead of only by cooldown, and the face/status layer can now reflect that transport-synchronized sampler execution.\\\\\\\\\\\\\\\\n+- Made the self-monitor more truthful: `self_listener.py` now derives glyph-facing brightness and motion from captured audio features instead of target-only metadata, while `cypherclaw_av_boot.sh` pins the live meter to the verified JACK path on CypherClaw and still leaves PipeWire / `pw-jack` capture as fallback code paths.\\\\\\\\\\\\\\\\n+- Fixed the remaining live self-monitor blackout path: when direct `jack_rec` capture times out, `self_listener.py` now falls back to analyzing a fresh `/tmp/room_capture.wav` clip instead of writing a dark `capture_timeout` state, so glyph and sampler decisions stay audio-derived on boxes where the JACK recorder hangs.\\\\\\\\\\\\\\\\n+- Added real EMSD master-bus control: `master_bus.py` now translates live `mix_*` fields plus tracker-scene `master_amp` / `reverb_send` automation into `sw_master_smooth` `/n_set` updates at scene start, so EMSD mix intent now shapes the summed output path instead of only per-note rendering.\\\\\\\\\\\\\\\\n+- Extended hook phrasing into actual later-section pitch behavior: `score_from_mood()` now publishes hook answer-degree metadata, and `music_tracker.py` uses that data in `Recap` / `Release` / `Resolution` / `Afterglow` so later sections can answer harmonically as well as textually.\\\\\\\\\\\\\\\\n+- Collapsed split boot ownership for the core AV stack: `cypherclaw_boot.sh` now delegates audio/composer/face/gallery/room-listener/sample startup to `cypherclaw_av_boot.sh`, which keeps one authority for those daemons instead of racing duplicate boot paths.\\\\\\\\\\\\\\\\n+- Added a replayable musical integration regression that exercises the composer-state -> sampler-plan -> sample-playback -> self-listener glyph state -> face-status chain, so this integration can be verified without a live host.\\\\\\\\\\\\\\\\n+- Hardened the live audio runtime after the Scarlett/JACK outage: `start_audio.sh` now links the repo SynthDef bundle into `~/.local/share/SuperCollider/synthdefs`, starts `scsynth` with synthdef auto-load enabled, and prefers a real JACK/Scarlett graph before falling back to `pw-jack`; `restart_composer.sh` now restarts the composer gracefully and verifies the new PID instead of rebuilding synthdefs with `/d_recv`; and `cypherclaw_boot.sh` no longer blindly sends `/n_set` to master node `99999` after boot.\\\\\\\\\\\\\\\\n+- Tightened that audio-runtime recovery again so `start_audio.sh` only stays on the real-JACK path when `system:playback_1` is actually present, and it now retries `scsynth` on `pw-jack` automatically if the real JACK graph disappears or never registers `SuperCollider:out_1`.\\\\\\\\\\\\\\\\n+- Made the Scarlett recovery path deterministic: when real JACK needs to be rebuilt, `start_audio.sh` now clears stale JACK state, relaunches `jackdbus`, and configures the ALSA backend for `hw:USB` before starting `scsynth`, so the box can recover onto the Scarlett monitor path instead of drifting into a PipeWire-only fallback.\\\\\\\\\\\\\\\\n+- Relaxed composer restart verification to the real steady-state condition: `restart_composer.sh` now waits for any healthy `duet_composer.py` process instead of only trusting the very first child PID, which avoids false failures during the current live startup race.\\\\\\\\\\\\\\\\n+- Made the composer restart truly session-detached: `restart_composer.sh` now launches `duet_composer.py` with `nohup setsid ... </dev/null` so the live composer survives operator SSH/session teardown instead of disappearing with the parent shell.\\\\\\\\\\\\\\\\n+- Added a persistent cold-boot path for the live AV runtime: `cypherclaw_av_boot.sh` now restarts `start_audio.sh`, `restart_composer.sh`, `self_listener.py`, `room_listener.py`, `sample_playback_engine.py`, and `face_display.py` under detached sessions, and `cypherclaw-av-stack.service` can bind that stack to `graphical.target` so music and the face monitor return after reboot without a manual SSH recovery.\\\\\\\\\\\\\\\\n+- Tightened the cold-boot wrapper to avoid daemon duplication: it now waits for `SuperCollider:out_1` before launching the meter, and it only backfills `room_listener.py`, `sample_playback_engine.py`, and `face_display.py` if another startup source has not already brought them up during the same boot.\\\\\\\\\\\\\\\\n+- Made the cold-boot wrapper opportunistic instead of combative: if `scsynth` and `duet_composer.py` are already present from another startup path, `cypherclaw_av_boot.sh` now skips `start_audio.sh` / `restart_composer.sh` entirely and only backfills the missing meter/listener surface.\\\\\\\\\\\\\\\\n+- Made `self_listener.py` backend-aware: it now auto-selects between `jack_rec` and `pw-jack jack_rec`, sets `JACK_NO_START_SERVER=1` on its capture probes to avoid waking an unwanted JACK server, and publishes `capture_backend` in `/tmp/self_listen.json` so operators can tell which live graph the meter is following.\\\\\\\\\\\\\\\\n+- Hardened that backend selection for the real CypherClaw boot race: direct `jack_lsp` probes can now take longer without forcing a false `pw-jack` fallback, `self_listener.py` caches the last working backend and resets that cache after failed capture loops, its `jack_rec` capture path now discards child stdout/stderr instead of risking a blocked pipe and stale meter state, and `cypherclaw_av_boot.sh` now deduplicates stale `room_listener.py`, `sample_playback_engine.py`, and `face_display.py` copies instead of letting old bad boot loops accumulate dozens of live daemons.\\\\\\\\\\\\\\\\n+- Made the cold-boot meter less ambiguous: `cypherclaw_av_boot.sh` now chooses `SELF_LISTENER_CAPTURE_BACKEND` from the boot-time graph decision, preferring a live PipeWire sink monitor before JACK fallbacks, and it performs a second delayed dedupe pass so late-start room/sampler/face daemons from other boot hooks are collapsed back to one process each.\\\\\\\\\\\\\\\\n+- Swapped the self-listener toward a host-stable monitor path: `self_listener.py` now prefers a PipeWire sink monitor target when one is available, still falls back to direct JACK or `pw-jack` port capture when needed, and keeps the old backend cache/reprobe logic only as fallback behavior instead of the primary live path.\\\\\\\\\\\\\\\\n+- Brought the gallery back under the same AV boot contract as the face: the repo now ships a top-level `gallery_x11.py` entrypoint again, and `cypherclaw_av_boot.sh` now starts and deduplicates `gallery_x11.py` alongside `face_display.py` so reboot recovery cannot leave the gallery unmanaged or multiplied into dozens of stale X processes.\\\\\\\\\\\\\\\\n+- Tightened the display recovery behavior again: `cypherclaw_av_boot.sh` now force-restarts `face_display.py` and `gallery_x11.py` on recovery instead of only deduplicating them, because a single stale headless display process was enough to leave the monitors blank while still looking “healthy” in `ps`.\\\\\\\\\\\\\\\\n+- Fixed the display-runtime environment for those restarts too: `cypherclaw_av_boot.sh` now exports `XDG_RUNTIME_DIR=/run/user/1000` before launching face and gallery, which avoids the live SDL/X error where both display clients would restart with `DISPLAY=:0` but still fail to attach to the user session.\\\\\\\\\\\\\\\\n+- Turned EMSD sample planning into real playback: added `sample_event_renderer.py`, `sample_playback_engine.py`, and `sample_status.py`; `cypherclaw_boot.sh` now starts the playback daemon; `/tmp/sample_dsp_activity.json` now feeds rendered room-derived WAV events through `pw-play`; and `/tmp/sample_playback_state.json` exposes the live sampler state for operators and face surfaces.\\\\\\\\\\\\\\\\n+- Hardened the sample-playback daemon so stable ambient scenes can refresh repeatedly after cooldown instead of firing once per unchanged signature, and render failures now write a structured error state instead of crashing the loop.\\\\\\\\\\\\\\\\n+- Taught `face_display.py` to surface the live EMSD sample layer from `/tmp/sample_dsp_activity.json`, so the head monitor can show which source and activity mode the room-sampling layer is currently holding or triggering.\\\\\\\\\\\\\\\\n+- Rebalanced EMSD source authority toward the room in lived-in late phases: capstone `Convergence` and `Crystallization` now prefer `room_mic` outside `away_practice`, DSP scene focus follows that same room bias, and `sample_dsp_activity.py` can retarget a sparse late-phase `self_bus` request onto a fresh room capture while still preserving the original requested source in state for operator visitests/test_first_boot.py:444:        identity = bootstrap_identity(identity_path=path)\\\\\\\\n+sdp/logs/Verify_T-021_20260416T043834Z_1776337553.log:3766:./sdp/logs/Verify_T-006_20260416T043834Z_1776330893.log:1848:sdp/logs/Verify_T-020_20260416T043834Z_1776326247.log:2082:sdp/logs/Verify_T-008_20260408T223256Z_1775692000.log:1689:tests/test_first_boot.py:454:        identity = bootstrap_identity(identity_path=path)\\\\\\\\n+sdp/logs/Verify_T-021_20260416T043834Z_1776337553.log:3767:./sdp/logs/Verify_T-006_20260416T043834Z_1776330893.log:1849:sdp/logs/Verify_T-020_20260416T043834Z_1776326247.log:2083:sdp/logs/Verify_T-008_20260408T223256Z_1775692000.log:1691:tests/test_first_boot.py:463:        identity = bootstrap_identity(identity_path=path)\\\\\\\\n+sdp/logs/Verify_T-021_20260416T043834Z_1776337553.log:3768:./sdp/logs/Verify_T-006_20260416T043834Z_1776330893.log:1850:sdp/logs/Verify_T-020_20260416T043834Z_1776326247.log:2084:sdp/logs/Verify_T-008_20260408T223256Z_1775692000.log:1693:tests/test_first_boot.py:470:        identity = bootstrap_identity(\\\\\\\\n+sdp/logs/Verify_T-021_20260416T043834Z_1776337553.log:3769:./sdp/logs/Verify_T-006_20260416T043834Z_1776330893.log:1851:sdp/logs/Verify_T-020_20260416T043834Z_1776326247.log:2085:sdp/logs/Verify_T-008_20260408T223256Z_1775692000.log:1716:my-claw/tools/first_boot.py:224:def bootstrap_identity(\\\\\\\\n+sdp/logs/Verify_T-021_20260416T043834Z_1776337553.log:3770:./sdp/logs/Verify_T-006_20260416T043834Z_1776330893.log:1852:sdp/logs/Verify_T-020_20260416T043834Z_1776326247.log:2086:sdp/logs/Verify_T-008_20260408T223256Z_1775692000.log:2058:my-claw/tools/daemon.py:2445:    _announcer = FirstBootAnnouncer(announce_fn=lambda payload: tg_send(\\\\\\\\n+sdp/lo