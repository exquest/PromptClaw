+        snapshot = _write_ltm(tmp_path / "snapshot.json", _uniform_counts())
+        current = _write_ltm(tmp_path / "current.json", _peaked_counts(25.0))
+        config_path = tmp_path / "idyom_kl_audit_config.json"
+        config_path.write_text(
