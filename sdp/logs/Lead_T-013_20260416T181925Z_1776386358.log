 }
 
+_AGGREGATE_INTENTION_KEYS: tuple[str, ...] = (
+    "global_energy",
+    "global_restraint",
+    "global_brightness",
+)
+
 
 @dataclass(frozen=True)
 class DiagnosticPaths:
@@ -69,6 +76,7 @@
     production_course: str = "unavailable"
     theramini_relation: str = "unavailable"
     critique_notes: str = "unavailable"
