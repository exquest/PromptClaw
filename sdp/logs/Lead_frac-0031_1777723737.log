   presence = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"no clear people\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    return f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{lighting} {dominant} room, {presence}.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def error_text(exc: Exception) -> str:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Normalize error text for state files without hiding the actual cause.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    return str(exc).strip()[:MAX_ERROR_CHARS]\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def normalize_vision_description(text: str) -> str:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Trim low-signal model chatter from scene descriptions.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cleaned = text.replace(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\r\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").strip()\\\\\\\\\\\\\\\\n+    for prefix in (\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Okay, processing…\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Okay, processing...\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Okay, processing\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Processing…\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Processing...\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n+    ):\\\\\\\\\\\\\\\\n+        if cleaned.startswith(prefix):\\\\\\\\\\\\\\\\n+            cleaned = cleaned[len(prefix):].lstrip()\\\\\\\\\\\\\\\\n+    return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\".join(part.strip() for part in cleaned.splitlines() if part.strip())\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def parse_http_error(exc: urllib.error.HTTPError) -> RuntimeError:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Preserve useful Ollama error details from an HTTP response.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    detail = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n     try:\\\\\\\\\\\\\\\\n-        if capture():\\\\\\\\\\\\\\\\n-            result = fast_analyze(FRAME)\\\\\\\\\\\\\\\\n-            now = time.time()\\\\\\\\\\\\\\\\n-            # Vision analysis on slower cadence\\\\\\\\\\\\\\\\n-            if now - last_vision > VISION_INTERVAL:\\\\\\\\\\\\\\\\n-                try:\\\\\\\\\\\\\\\\n-                    last_description = vision_analyze(FRAME)\\\\\\\\\\\\\\\\n-                    last_vision = now\\\\\\\\\\\\\\\\n+        raw = exc.read().decode()\\\\\\\\\\\\\\\\n+        parsed = json.loads(raw)\\\\\\\\\\\\\\\\n+        if isinstance(parsed, dict):\\\\\\\\\\\\\\\\n+            detail = str(parsed.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"error\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")).strip()\\\\\\\\\\\\\\\\n+        if not detail:\\\\\\\\\\\\\\\\n+            detail = raw.strip()\\\\\\\\\\\\\\\\n+    except Exception:\\\\\\\\\\\\\\\\n+        detail = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    suffix = f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" {detail}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\" if detail else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    return RuntimeError(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"HTTP Error {exc.code}: {exc.reason}{suffix}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def _load_cv2():\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Load cv2 lazily so local development without OpenCV still works.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    try:\\\\\\\\\\\\\\\\n+        return importlib.import_module(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"cv2\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+    except Exception:\\\\\\\\\\\\\\\\n+        return None\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def detect_visual_person_cue(frame_path: str, cv2_module=None) -> dict[str, Any]:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Detect explicit face/person cues with OpenCV when available.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+    cv2_module = _load_cv2() if cv2_module is None else cv2_module\\\\\\\\\\\\\\\\n+    if cv2_module is None:\\\\\\\\\\\\\\\\n+        return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    try:\\\\\\\\\\\\\\\\n+        image = cv2_module.imread(frame_path)\\\\\\\\\\\\\\\\n+        if image is None:\\\\\\\\\\\\\\\\n+            return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"visual_person_cue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"face_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0}\\\\\\\\\\\\\\\\n+        gray = cv2_module.cvtColor(image, cv2_module.COLOR_BGR2GRAY)\\\\\\\\\\\\\\\\n+        cascade = cv2_module.CascadeClassifier(\\\\\\\\\\\\\\\\n+            os.path.join(cv2_module.data.haarcascades, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"haarcascade_frontalface_default.xml\\\\\\