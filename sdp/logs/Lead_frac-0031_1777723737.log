\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"keyboard\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+_IGNORE_HINTS = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"theremini\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"perform-ve\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"scarlett\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-def midi_to_freq(note):\\\\\\\\\\\\\\\\n+def midi_to_freq(note: int) -> float:\\\\\\\\\\\\\\\\n     return 440.0 * (2 ** ((note - 69) / 12.0))\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-def midi_to_name(note):\\\\\\\\\\\\\\\\n-    names = [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"C#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"D\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"D#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"E\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"F\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"F#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"G\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"G#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"A\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"A#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"B\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n-    return f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{names[note % 12]}{note // 12 - 1}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-def write_state(state):\\\\\\\\\\\\\\\\n+def write_state(state: dict) -> None:\\\\\\\\\\\\\\\\n     tmp = STATE_FILE.with_suffix(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\".tmp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n     tmp.write_text(json.dumps(state))\\\\\\\\\\\\\\\\n     os.replace(str(tmp), str(STATE_FILE))\\\\\\\\\\\\\\\\n \\\\\\\\\\\\\\\\n-def run(devices):\\\\\\\\\\\\\\\\n-    print(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"MIDI keyboard listener on {devices}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", flush=True)\\\\\\\\\\\\\\\\n-    \\\\\\\\\\\\\\\\n-    fds = {}\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+def discover_keyboard_devices(amidi_listing: str | None = None) -> list[str]:\\\\\\\\\\\\\\\\n+    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Return `/dev/midi*` devices matching the keyboard controllers.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    verify_device_paths = amidi_listing is None\\\\\\\\\\\\\\\\n+    if amidi_listing is None:\\\\\\\\\\\\\\\\n+        try:\\\\\\\\\\\\\\\\n+            result = subprocess.run(\\\\\\\\\\\\\\\\n+                [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"amidi\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"-l\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"],\\\\\\\\\\\\\\\\n+                capture_output=True,\\\\\\\\\\\\\\\\n+                text=True,\\\\\\\\\\\\\\\\n+                timeout=2,\\\\\\\\\\\\\\\\n+                check=False,\\\\\\\\\\\\\\\\n+            )\\\\\\\\\\\\\\\\n+            amidi_listing = result.stdout\\\\\\\\\\\\\\\\n+        except Exception:\\\\\\\\\\\\\\\\n+            amidi_listing = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n+\\\\\\\\\\\\\\\\n+    devices: list[str] = []\\\\\\\\\\\\\\\\n+    for line in amidi_listing.splitlines():\\\\\\\\\\\\\\\\n+        line = line.strip()\\\\\\\\\\\\\\\\n+        if not line.startswith(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"IO  hw:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        lowered = line.lower()\\\\\\\\\\\\\\\\n+        if any(hint in lowered for hint in _IGNORE_HINTS):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\\\n+        if not any(hint in lowered for hint in _KEYBOARD_HINTS):\\\\\\\\\\\\\\\\n+            continue\\\\\\\\\\\\\\