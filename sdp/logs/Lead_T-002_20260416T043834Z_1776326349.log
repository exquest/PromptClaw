+            interval = abs(_midi_number(left.frequency_hz) - _midi_number(right.frequency_hz)) % 12.0
+            distance_to_dissonance = min(
+                abs(interval - target)
+                for target in (1.0, 2.0, 6.0, 10.0, 11.0)
