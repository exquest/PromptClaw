+    onset_density = float(metrics.get("onset_density", 0.0) or 0.0)
+    repetition = float(metrics.get("repetition_score", 0.0) or 0.0)
+    centroid = float(metrics.get("spectral_centroid_hz", 0.0) or 0.0)
