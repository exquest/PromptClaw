+
+    metrics_raw = entry.get("ear_metrics") if isinstance(entry, Mapping) else getattr(entry, "ear_metrics", None)
+    metrics = _numeric_mapping(metrics_raw)
+    if not metrics:
+        return {}
+    return _derive_feedback_scores(metrics)
