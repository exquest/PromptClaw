+    noisy = analyze_captured_audio(noise, sample_rate)
+
+    assert abs(tonal["pitch_hz"] - 440.0) < 12.0
+    assert tonal["spectral_centroid_hz"] > 300.0
+    assert noisy["spectral_flatness"] > tonal["spectral_flatness"]
