+def _shape_repetition_score(intervals: Sequence[float]) -> float:
+    if len(intervals) < 4:
+        return 0.0
+    shapes = [tuple(round(interval) for interval in intervals[index : index + 3]) for index in range(len(intervals) - 2)]
+    if not shapes:
