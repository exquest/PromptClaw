+        if note.freq > 0.0:
+            events.append(
+                _EarEvent(
+                    frequency_hz=float(note.freq),
+                    duration_s=duration,
+                    amplitude=1.0,
+                    accent=bool(note.accent),
+                    start_s=start,
+                )
+            )
