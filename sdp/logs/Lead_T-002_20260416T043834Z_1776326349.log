+def _get_value(source: object, *names: str, default: object = None) -> object:
+    if isinstance(source, Mapping):
+        for name in names:
+            if name in source:
+                return source[name]
+    for name in names:
+        if hasattr(source, name):
+            return getattr(source, name)
+    return default
