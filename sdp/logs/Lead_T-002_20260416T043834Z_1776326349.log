+def test_analyze_captured_audio_uses_synthetic_audio_features() -> None:
+    sample_rate = 8000
+    duration_s = 0.5
+    sine = [
+        0.4 * math.sin(2.0 * math.pi * 440.0 * index / sample_rate)
+        for index in range(int(sample_rate * duration_s))
+    ]
+    rng = random.Random(7)
+    noise = [rng.uniform(-0.4, 0.4) for _ in sine]
