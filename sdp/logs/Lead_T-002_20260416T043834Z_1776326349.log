+    bins = [0.0] * 18
+    for event in events:
+        midi = _midi_number(event.frequency_hz)
+        index = int(_clamp((midi - 24.0) / 4.0, 0.0, len(bins) - 1))
+        bins[index] += max(event.amplitude, 0.001)
