+        ("harsh", "harsh_score"),
+        ("muddy", "muddy_score"),
+        ("underdeveloped", "underdeveloped_score"),
+    ):
+        if float(feedback_scores.get(key, 0.0) or 0.0) >= 0.55:
+            tags.append(f"ear_correct={name}")
+    return tuple(tags)
