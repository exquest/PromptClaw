+            "muddy_score": 0.0,
+            "underdeveloped_score": 0.0,
+        }
+    keys = ("static_score", "harsh_score", "muddy_score", "underdeveloped_score")
+    return {
+        key: round(sum(score.get(key, 0.0) for score in scores) / len(scores), 3)
+        for key in keys
+    }
+
