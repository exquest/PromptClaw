+                "amplitude": 0.2,
+                "accent": True,
+            },
+            {
+                "frequency_hz": 277.18,
+                "duration_seconds": 0.25,
+                "time_seconds": 0.25,
+                "amplitude": 0.16,
+            },
+            {
+                "frequency_hz": 329.63,
+                "duration_seconds": 0.5,
+                "time_seconds": 0.5,
+                "amplitude": 0.18,
+            },
+            {
