+def _round_metrics(metrics: Mapping[str, float]) -> dict[str, float]:
+    rounded: dict[str, float] = {}
+    for key, value in metrics.items():
+        if key.endswith("_hz") or key == "pitch_hz":
+            rounded[key] = round(float(value), 2)
+        else:
