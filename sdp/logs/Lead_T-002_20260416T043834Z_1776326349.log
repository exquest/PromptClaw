+def _bool_value(source: object, *names: str, default: bool = False) -> bool:
+    value = _get_value(source, *names, default=default)
+    if isinstance(value, str):
+        return value.strip().lower() in {"1", "true", "yes", "accent"}
+    return bool(value)
