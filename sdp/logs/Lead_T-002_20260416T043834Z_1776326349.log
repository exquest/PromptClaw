+def _tracker_spectral_metrics(events: Sequence[_EarEvent]) -> dict[str, float]:
+    if not events:
+        return {
+            "spectral_centroid_hz": 0.0,
+            "spectral_flatness": 0.0,
+            "roughness": 0.0,
+        }
