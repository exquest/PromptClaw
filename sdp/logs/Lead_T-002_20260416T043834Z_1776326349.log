+    hook = float(metrics.get("hook_clarity", 0.0) or 0.0)
+    cadence = float(metrics.get("cadence_strength", 0.0) or 0.0)
+    development = float(metrics.get("development_score", 0.0) or 0.0)
+    return {
+        "static_score": _clamp(
