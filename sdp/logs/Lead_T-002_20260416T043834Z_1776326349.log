+        return {
+            "spectral_centroid_hz": 0.0,
+            "spectral_flatness": 0.0,
+            "roughness": 0.0,
+        }
+    total = sum(magnitude for _freq, magnitude in spectrum)
+    if total <= _EPSILON:
+        return {
+            "spectral_centroid_hz": 0.0,
+            "spectral_flatness": 0.0,
+            "roughness": 0.0,
+        }
