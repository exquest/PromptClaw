+    avg_duration = sum(event.duration_s for event in events) / max(1, len(events))
+    duration_bonus = 0.08 if final_duration >= avg_duration * 1.25 else 0.0
+    accent_bonus = 0.08 if events and events[-1].accent else 0.0
