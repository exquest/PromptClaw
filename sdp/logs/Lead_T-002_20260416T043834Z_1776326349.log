+def _entry_feedback_scores(entry: object) -> dict[str, float]:
+    feedback_raw = entry.get("feedback_scores") if isinstance(entry, Mapping) else getattr(entry, "feedback_scores", None)
+    feedback = _numeric_mapping(feedback_raw)
+    if feedback:
