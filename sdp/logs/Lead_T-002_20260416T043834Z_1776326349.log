"""Lightweight musical self-analysis for performed notes."""
from __future__ import annotations

import math
from typing import Sequence

from .synthesis.continuous_learner import PlayedNote


def _midi_number(freq: float) -> float:
    return 69.0 + 12.0 * math.log2(max(freq, 1e-6) / 440.0)


def analyze_played_notes(notes: Sequence[PlayedNote]) -> dict[str, float]:
    """Summarize melodic variety, spread, and closure from played notes."""

    freqs = [note.freq for note in notes if note.freq > 0.0]
    if len(freqs) < 2:
        return {
            "interval_variety": 0.0,
            "register_spread": 0.0,
            "hook_clarity": 0.0,
            "leap_ratio": 0.0,
            "cadence_strength": 0.0,
        }

    midis = [_midi_number(freq) for freq in freqs]
    intervals = [abs(midis[i] - midis[i - 1]) for i in range(1, len(midis))]
    rounded_intervals = {round(interval) for interval in intervals}
    interval_variety = min(1.0, len(rounded_intervals) / max(1.0, len(intervals)))
    register_spread = max(midis) - min(midis)
    leap_ratio = sum(1 for interval in intervals if interval >= 4.5) / max(1, len(intervals))

    accented = sum(1 for note in notes if note.accent)
    first_shape = [round(interval) for interval in intervals[:2]]
    repeated_shape = 0
    if len(intervals) >= 4:
        second_shape = [round(interval) for interval in intervals[2:4]]
        repeated_shape = 1 if first_shape == second_shape else 0
    hook_clarity = max(
        0.0,
        min(
            1.0,
            0.35 + repeated_shape * 0.3 + min(0.2, accented / max(1, len(notes)) * 0.4) + (0.15 if leap_ratio < 0.55 else 0.0),
        ),
    )

    end_interval = abs(midis[-1] - midis[0])
    cadence_strength = max(0.0, min(1.0, 1.0 - min(end_interval, 12.0) / 12.0 + (0.1 if notes[-1].accent else 0.0)))

    return {
        "interval_variety": round(interval_variety, 3),
        "register_spread": round(register_spread, 3),
        "hook_clarity": round(hook_clarity, 3),
        "leap_ratio": round(leap_ratio, 3),
        "cadence_strength": round(cadence_strength, 3),
    }

