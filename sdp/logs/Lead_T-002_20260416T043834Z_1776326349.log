+    metrics["pitch_confidence"] = round(confidence, 3)
+    metrics["onset_density"] = round(_estimate_audio_onset_density(normalized, sample_rate), 3)
+    metrics.update(feedback_scores(metrics))
+    return _round_metrics(metrics)
