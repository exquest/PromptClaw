{
  "project": {
    "name": "Starter Claw",
    "description": "A starter claw for software, research, and documentation work."
  },
  "artifacts": {
    "root": ".promptclaw"
  },
  "control_plane": {
    "mode": "heuristic",
    "agent": "claude",
    "allow_fallback": true
  },
  "routing": {
    "verification_enabled": true,
    "max_retries": 1,
    "ask_user_on_ambiguity": true,
    "default_task_type": "general"
  },
  "agents": {
    "codex": {
      "name": "codex",
      "enabled": true,
      "kind": "mock",
      "shell_command": "",
      "command": [],
      "env": {},
      "capabilities": [
        "coding",
        "implementation",
        "refactoring",
        "testing"
      ],
      "instruction_file": "prompts/agents/codex.md"
    },
    "claude": {
      "name": "claude",
      "enabled": true,
      "kind": "mock",
      "shell_command": "",
      "command": [],
      "env": {},
      "capabilities": [
        "architecture",
        "specification",
        "verification"
      ],
      "instruction_file": "prompts/agents/claude.md"
    },
    "gemini": {
      "name": "gemini",
      "enabled": true,
      "kind": "mock",
      "shell_command": "",
      "command": [],
      "env": {},
      "capabilities": [
        "docs",
        "research",
        "synthesis"
      ],
      "instruction_file": "prompts/agents/gemini.md"
    }
  }
}
