[Unit]
Description=CypherClaw Dashboard Generator
After=postgresql.service

[Service]
Type=oneshot
User=user
WorkingDirectory=/home/user/cypherclaw
Environment=PYTHONPATH=/home/user/cypherclaw/tools
ExecStart=/usr/bin/python3 /home/user/cypherclaw/tools/dashboard_generator.py

[Install]
WantedBy=multi-user.target
